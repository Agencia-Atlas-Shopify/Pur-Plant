{% doc %}
  @prompt
    necesito un espaciado en blanco no muy alto
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-spacer-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    height: {{ block.settings.height_desktop }}px;
  }

  @media screen and (max-width: 749px) {
    .ai-spacer-{{ ai_gen_id }} {
      height: {{ block.settings.height_mobile }}px;
    }
  }
{% endstyle %}

<div class="ai-spacer-{{ ai_gen_id }}" {{ block.shopify_attributes }}></div>

{% schema %}
{
  "name": "Espaciado",
  "settings": [
    {
      "type": "range",
      "id": "height_desktop",
      "label": "Altura en escritorio",
      "min": 10,
      "max": 200,
      "step": 5,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "height_mobile",
      "label": "Altura en móvil",
      "min": 10,
      "max": 150,
      "step": 5,
      "unit": "px",
      "default": 30
    }
  ],
  "presets": [
    {
      "name": "Espaciado"
    }
  ]
}
{% endschema %}
