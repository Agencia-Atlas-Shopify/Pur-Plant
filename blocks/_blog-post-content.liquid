

<div class="blog-post-content rte" data-pp-article>
  {%- if block.settings.show_toc -%}
    <nav class="pp-toc" data-pp-toc aria-label="Tabla de contenidos" hidden>
      <button type="button" class="pp-toc__header" data-pp-toc-toggle aria-expanded="true">
        <span class="pp-toc__title">{{ block.settings.toc_title | default: 'Tabla de contenidos' }}</span>
        <span class="pp-toc__chevron" aria-hidden="true">▾</span>
      </button>
      <ol class="pp-toc__list" data-pp-toc-list></ol>
    </nav>
  {%- endif -%}

  <rte-formatter>
    {{ article.content }}
  </rte-formatter>
</div>

{% stylesheet %}
  .blog-post-content {
    max-width: var(--page-content-width, 100%);
    margin: 0 auto;
    width: 100%;
  }

  /* ── Responsive embeds (YouTube, Vimeo, etc.) ── */
  .blog-post-content iframe,
  .blog-post-content video,
  .blog-post-content embed,
  .blog-post-content object {
    max-width: 100%;
    width: 100%;
    height: auto;
    display: block;
  }

  .blog-post-content .pp-embed {
    position: relative;
    width: 100%;
    max-width: 720px;
    aspect-ratio: var(--embed-ratio, 16 / 9);
    margin: 24px auto;
    overflow: hidden;
    border-radius: 12px;
    background: #000;
  }

  .blog-post-content .pp-embed--vertical {
    max-width: 360px;
    border-radius: 16px;
  }

  @media screen and (max-width: 749px) {
    .blog-post-content .pp-embed {
      max-width: 100%;
      margin: 16px 0;
      border-radius: 8px;
    }
    .blog-post-content .pp-embed--vertical {
      max-width: 320px;
      margin: 16px auto;
      border-radius: 12px;
    }
  }

  .blog-post-content .pp-embed iframe,
  .blog-post-content .pp-embed video,
  .blog-post-content .pp-embed embed,
  .blog-post-content .pp-embed object {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: 0;
  }

  .blog-post-content img,
  .blog-post-content table {
    max-width: 100%;
    height: auto;
  }

  .blog-post-content {
    overflow-wrap: break-word;
    word-wrap: break-word;
  }

  /* ── Table of contents ── */
  .pp-toc {
    margin: 20px 0 32px;
    padding: 16px 18px;
    background: #f3f6f1;
    border: 1px solid #e2e8de;
    border-radius: 12px;
    font-family: 'Inter', sans-serif;
  }

  .pp-toc__header {
    display: flex;
    width: 100%;
    align-items: center;
    justify-content: space-between;
    background: none;
    border: 0;
    padding: 0;
    cursor: pointer;
    color: #23372c;
    font-family: inherit;
    font-size: 15px;
    font-weight: 600;
    text-align: left;
  }

  .pp-toc__chevron {
    transition: transform 0.2s ease;
    font-size: 14px;
    opacity: 0.6;
  }

  .pp-toc[data-collapsed="true"] .pp-toc__chevron {
    transform: rotate(-90deg);
  }

  .pp-toc[data-collapsed="true"] .pp-toc__list {
    display: none;
  }

  .pp-toc__list {
    list-style: none;
    margin: 12px 0 0;
    padding: 0;
    counter-reset: toc;
  }

  .pp-toc__list li {
    margin: 4px 0;
    padding: 0;
    line-height: 1.5;
  }

  .pp-toc__list li.is-h3 {
    padding-left: 18px;
  }

  .pp-toc__list a {
    color: #23372c;
    text-decoration: none;
    font-size: 14px;
    opacity: 0.85;
    transition: opacity 0.15s;
  }

  .pp-toc__list a:hover {
    opacity: 1;
    text-decoration: underline;
  }

  @media screen and (max-width: 749px) {
    .pp-toc { padding: 14px 14px; }
    .pp-toc__header { font-size: 14px; }
    .pp-toc__list a { font-size: 13px; }
  }
{% endstylesheet %}

<script>
(function() {
  if (window.__ppArticleEnhanceInit) return;
  window.__ppArticleEnhanceInit = true;

  function slugify(text) {
    return (text || '')
      .toLowerCase()
      .normalize('NFD').replace(/[\u0300-\u036f]/g, '')
      .replace(/[^a-z0-9\s-]/g, '')
      .trim()
      .replace(/\s+/g, '-')
      .slice(0, 80);
  }

  function isVertical(iframe) {
    var src = (iframe.getAttribute('src') || '').toLowerCase();
    if (src.indexOf('/shorts/') !== -1) return true;
    if (src.indexOf('youtube.com/embed/') !== -1 && src.indexOf('shorts') !== -1) return true;
    var w = parseFloat(iframe.getAttribute('width'));
    var h = parseFloat(iframe.getAttribute('height'));
    if (w > 0 && h > 0 && h > w) return true;
    var sw = iframe.style.width;
    var sh = iframe.style.height;
    if (sw && sh) {
      var nw = parseFloat(sw);
      var nh = parseFloat(sh);
      if (nw > 0 && nh > 0 && nh > nw) return true;
    }
    return false;
  }

  function wrapEmbeds(container) {
    var selectors = 'iframe[src*="youtube"], iframe[src*="youtu.be"], iframe[src*="vimeo"], iframe[src*="dailymotion"], iframe[src*="tiktok"], iframe[src*="instagram"]';
    container.querySelectorAll(selectors).forEach(function(iframe) {
      if (iframe.closest('.pp-embed')) return;
      var vertical = isVertical(iframe);
      var wrap = document.createElement('div');
      wrap.className = 'pp-embed' + (vertical ? ' pp-embed--vertical' : '');
      wrap.style.setProperty('--embed-ratio', vertical ? '9 / 16' : '16 / 9');
      iframe.removeAttribute('width');
      iframe.removeAttribute('height');
      iframe.style.width = '';
      iframe.style.height = '';
      iframe.parentNode.insertBefore(wrap, iframe);
      wrap.appendChild(iframe);
    });
  }

  // Patterns / classes that mark a heading as "not a real section" — it stays in
  // the document (as a <p> to preserve styling) but is excluded from TOC.
  var TOC_SKIP_PATTERNS = [
    /^compartir/i,
    /^comparte/i,
    /^\s*relacionados?\s*$/i,
    /^comentarios?/i,
    /^(autor|author)/i,
    /^índice$/i,
    /^indice$/i,
    /^tabla de contenidos?/i,
    /^sumario$/i,
    /^ver también/i
  ];

  function shouldSkipHeading(h) {
    if (h.classList.contains('pp-toc-skip')) return true;
    if (h.classList.contains('no-toc')) return true;
    if (h.dataset && h.dataset.tocSkip !== undefined) return true;
    var text = (h.textContent || '').trim();
    for (var i = 0; i < TOC_SKIP_PATTERNS.length; i++) {
      if (TOC_SKIP_PATTERNS[i].test(text)) return true;
    }
    return false;
  }

  function demoteToParagraph(h) {
    var p = document.createElement('p');
    p.className = 'pp-heading-demoted ' + (h.className || '').trim();
    p.innerHTML = h.innerHTML;
    if (h.id) p.id = h.id;
    h.parentNode.replaceChild(p, h);
  }

  function buildTOC(container) {
    var toc = container.querySelector('[data-pp-toc]');
    if (!toc) return;
    var list = toc.querySelector('[data-pp-toc-list]');
    if (!list) return;

    // First pass: demote "skip" headings to <p> so they stay visible but don't act as anchors
    var allHeadings = Array.prototype.slice.call(
      container.querySelectorAll('rte-formatter h2, rte-formatter h3')
    );
    allHeadings.forEach(function(h) {
      if (shouldSkipHeading(h)) demoteToParagraph(h);
    });

    // Re-query real headings after demotion
    var headings = container.querySelectorAll('rte-formatter h2, rte-formatter h3');
    var used = {};
    var count = 0;

    headings.forEach(function(h) {
      var text = (h.textContent || '').trim();
      if (!text) return;
      var id = h.id || slugify(text);
      if (!id) return;
      if (used[id]) { id = id + '-' + (++used[id]); } else { used[id] = 1; }
      h.id = id;

      var li = document.createElement('li');
      li.className = h.tagName === 'H3' ? 'is-h3' : 'is-h2';
      var a = document.createElement('a');
      a.href = '#' + id;
      a.textContent = text;
      li.appendChild(a);
      list.appendChild(li);
      count++;
    });

    if (count >= 2) {
      toc.hidden = false;
    }

    var toggle = toc.querySelector('[data-pp-toc-toggle]');
    if (toggle) {
      toggle.addEventListener('click', function() {
        var collapsed = toc.getAttribute('data-collapsed') === 'true';
        toc.setAttribute('data-collapsed', collapsed ? 'false' : 'true');
        toggle.setAttribute('aria-expanded', collapsed ? 'true' : 'false');
      });
    }
  }

  function init() {
    document.querySelectorAll('[data-pp-article]').forEach(function(container) {
      wrapEmbeds(container);
      buildTOC(container);
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
})();
</script>

{% schema %}
{
  "name": "t:names.content",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_toc",
      "label": "Mostrar tabla de contenidos",
      "default": true
    },
    {
      "type": "text",
      "id": "toc_title",
      "label": "Título tabla de contenidos",
      "default": "Tabla de contenidos"
    }
  ],
  "presets": [
    {
      "name": "t:names.content"
    }
  ]
}
{% endschema %}
