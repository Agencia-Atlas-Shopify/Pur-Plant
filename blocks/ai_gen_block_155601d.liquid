{% doc %}
  @prompt
    genera una seccion en la que pueda elegir 5 productos, que se vean en una linea en pc y en movil en carrusel. Necesito que tenga titulo, descripcion, y los productos un boton de añadir que se añadan al carrito directamente. Todo centralizado y sin bordes redondeados en las imagenes de producto
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-product-row-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    padding: 40px 20px;
  }

  .ai-product-row-container-{{ ai_gen_id }} {
    max-width: 1200px;
    margin: 0 auto;
  }

  .ai-product-row-header-{{ ai_gen_id }} {
    text-align: center;
    margin-bottom: 32px;
  }

  .ai-product-row-title-{{ ai_gen_id }} {
    margin: 0 0 12px;
    font-size: 32px;
    color: {{ block.settings.title_color }};
  }

  .ai-product-row-description-{{ ai_gen_id }} {
    margin: 0;
    font-size: 16px;
    color: {{ block.settings.description_color }};
  }

  .ai-product-row-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 20px;
  }

  .ai-product-row-item-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    text-align: center;
  }

  .ai-product-row-image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    aspect-ratio: 1;
    margin-bottom: 12px;
    overflow: hidden;
  }

  .ai-product-row-image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .ai-product-row-image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-product-row-image-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
  }

  .ai-product-row-product-title-{{ ai_gen_id }} {
    font-size: 14px;
    margin: 0 0 8px;
    color: {{ block.settings.product_title_color }};
  }

  .ai-product-row-product-price-{{ ai_gen_id }} {
    font-size: 16px;
    font-weight: 600;
    margin: 0 0 12px;
    color: {{ block.settings.product_price_color }};
  }

  .ai-product-row-add-button-{{ ai_gen_id }} {
    padding: 12px 20px;
    background-color: {{ block.settings.button_bg_color }};
    color: {{ block.settings.button_text_color }};
    border: none;
    cursor: pointer;
    font-size: 14px;
    transition: background-color 0.3s ease;
    width: 100%;
  }

  .ai-product-row-add-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_bg_color }};
  }

  .ai-product-row-add-button-{{ ai_gen_id }}:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  .ai-product-row-empty-state-{{ ai_gen_id }} {
    text-align: center;
    padding: 40px 20px;
    color: #666;
    font-size: 14px;
  }

  @media screen and (max-width: 989px) {
    .ai-product-row-grid-{{ ai_gen_id }} {
      display: flex;
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      gap: 16px;
      padding-bottom: 16px;
      -webkit-overflow-scrolling: touch;
    }

    .ai-product-row-item-{{ ai_gen_id }} {
      flex: 0 0 70%;
      scroll-snap-align: start;
    }
  }

  @media screen and (max-width: 749px) {
    .ai-product-row-item-{{ ai_gen_id }} {
      flex: 0 0 85%;
    }
  }
{% endstyle %}

<product-row-{{ ai_gen_id }} class="ai-product-row-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-product-row-container-{{ ai_gen_id }}">
    {% if block.settings.title != blank or block.settings.description != blank %}
      <div class="ai-product-row-header-{{ ai_gen_id }}">
        {% if block.settings.title != blank %}
          <h2 class="ai-product-row-title-{{ ai_gen_id }}">{{ block.settings.title }}</h2>
        {% endif %}
        {% if block.settings.description != blank %}
          <div class="ai-product-row-description-{{ ai_gen_id }}">{{ block.settings.description }}</div>
        {% endif %}
      </div>
    {% endif %}

    {% liquid
      assign has_products = false
      for i in (1..5)
        assign product_key = 'product_' | append: i
        assign product = block.settings[product_key]
        if product != blank
          assign has_products = true
          break
        endif
      endfor
    %}

    {% if has_products %}
      <div class="ai-product-row-grid-{{ ai_gen_id }}">
        {% for i in (1..5) %}
          {% liquid
            assign product_key = 'product_' | append: i
            assign product = block.settings[product_key]
          %}

          {% if product != blank %}
            <div class="ai-product-row-item-{{ ai_gen_id }}" data-product-id="{{ product.id }}">
              <div class="ai-product-row-image-wrapper-{{ ai_gen_id }}">
                {% if product.featured_image %}
                  <img
                    src="{{ product.featured_image | image_url: width: 400 }}"
                    alt="{{ product.featured_image.alt | escape }}"
                    class="ai-product-row-image-{{ ai_gen_id }}"
                    loading="lazy"
                    width="400"
                    height="400"
                  >
                {% else %}
                  <div class="ai-product-row-image-placeholder-{{ ai_gen_id }}">
                    {{ 'product-1' | placeholder_svg_tag }}
                  </div>
                {% endif %}
              </div>

              <h3 class="ai-product-row-product-title-{{ ai_gen_id }}">
                {{ product.title }}
              </h3>

              <div class="ai-product-row-product-price-{{ ai_gen_id }}">
                {{ product.price | money }}
              </div>

              <button
                class="ai-product-row-add-button-{{ ai_gen_id }}"
                data-variant-id="{{ product.selected_or_first_available_variant.id }}"
                {% unless product.available %}disabled{% endunless %}
              >
                {% if product.available %}
                  {{ block.settings.button_text }}
                {% else %}
                  Agotado
                {% endif %}
              </button>
            </div>
          {% endif %}
        {% endfor %}
      </div>
    {% else %}
      <div class="ai-product-row-empty-state-{{ ai_gen_id }}">
        Selecciona hasta 5 productos para mostrar en esta sección
      </div>
    {% endif %}
  </div>
</product-row-{{ ai_gen_id }}>

<script>
  (function() {
    class ProductRow{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.buttons = this.querySelectorAll('.ai-product-row-add-button-{{ ai_gen_id }}');
        this.setupEventListeners();
      }

      setupEventListeners() {
        this.buttons.forEach((button) => {
          button.addEventListener('click', this.handleAddToCart.bind(this));
        });
      }

      async handleAddToCart(event) {
        const button = event.target;
        const variantId = button.dataset.variantId;

        if (!variantId || button.disabled) return;

        button.disabled = true;
        const originalText = button.textContent;
        button.textContent = 'Añadiendo...';

        try {
          const response = await fetch('/cart/add.js', {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json',
            },
            body: JSON.stringify({
              items: [
                {
                  id: variantId,
                  quantity: 1,
                },
              ],
            }),
          });

          if (!response.ok) {
            throw new Error('Error al añadir al carrito');
          }

          button.textContent = '¡Añadido!';

          document.dispatchEvent(new CustomEvent('cart:refresh'));

          setTimeout(() => {
            button.textContent = originalText;
            button.disabled = false;
          }, 2000);
        } catch (error) {
          console.error('Error:', error);
          button.textContent = 'Error';
          setTimeout(() => {
            button.textContent = originalText;
            button.disabled = false;
          }, 2000);
        }
      }
    }

    customElements.define('product-row-{{ ai_gen_id }}', ProductRow{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Fila de productos",
  "settings": [
    {
      "type": "header",
      "content": "Contenido"
    },
    {
      "type": "text",
