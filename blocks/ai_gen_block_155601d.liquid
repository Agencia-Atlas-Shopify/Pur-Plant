    {
      "type": "color",
      "id": "description_color",
      "label": "Color de la descripción",
      "default": "#666666"
    },
    {
      "type": "color",
      "id": "product_title_color",
      "label": "Color del título del producto",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "product_price_color",
      "label": "Color del precio",
      "default": "#000000"
    }
  ],
  "presets": [
    {
      "name": "Fila de productos"
    }
  ]
}
{% endschema %}
