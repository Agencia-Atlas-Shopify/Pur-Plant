      "default": "Descubre nuestra selección especial"
    },
    {
      "type": "header",
      "content": "Productos"
    },
    {
      "type": "product",
      "id": "product_1",
      "label": "Producto 1"
    },
    {
      "type": "product",
      "id": "product_2",
      "label": "Producto 2"
    },
    {
      "type": "product",
      "id": "product_3",
      "label": "Producto 3"
    },
    {
      "type": "product",
      "id": "product_4",
      "label": "Producto 4"
    },
    {
      "type": "product",
      "id": "product_5",
      "label": "Producto 5"
    },
    {
      "type": "header",
      "content": "Botón"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Texto del botón",
      "default": "Añadir al carrito"
    },
    {
      "type": "color",
