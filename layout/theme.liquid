<!doctype html>
<html
  {% if request.design_mode %}
    class="shopify-design-mode"
  {% endif %}
  lang="{{ request.locale.iso_code }}"
>
  <head>
    {%- if settings.favicon != blank -%}
      <link
        rel="icon"
        type="image/png"
        href="{{ settings.favicon | image_url: width: 32, height: 32 }}"
      >
    {%- endif -%}

    {% comment %} This a way to wait for main content to load when navigating to a new page so that the view transitions can work consistently {% endcomment %}
    {% if settings.transition_to_main_product or settings.page_transition_enabled %}
      <link
        rel="expect"
        href="#MainContent"
        blocking="render"
        id="view-transition-render-blocker"
      >
    {% endif %}

    {%- render 'meta-tags' -%}
    {%- render 'stylesheets' -%}
    {%- render 'fonts' -%}
    {%- render 'scripts' -%}

    {%- comment -%} Defer Klaviyo, Swym, Judge.me etc until first interaction (inline for zero-RTT, minified) {%- endcomment -%}
    <script>{% render 'pp-defer-3p-inline' %}</script>

    {%- comment -%} Inlined critical CSS so above-the-fold renders without waiting for external CSS {%- endcomment -%}
    {% render 'pp-critical-inline' %}

    {%- comment -%} Preload critical assets for LCP {%- endcomment -%}
    <link rel="preload" as="image" href="{{ 'logo_pur_plant_isotipo.png' | asset_url }}" fetchpriority="high">
    {%- if template.name == 'product' and product.featured_image -%}
      <link
        rel="preload"
        as="image"
        href="{{ product.featured_image | image_url: width: 1200 }}"
        imagesrcset="{{ product.featured_image | image_url: width: 600 }} 600w, {{ product.featured_image | image_url: width: 900 }} 900w, {{ product.featured_image | image_url: width: 1200 }} 1200w"
        imagesizes="(min-width: 750px) 60vw, 100vw"
        fetchpriority="high"
      >
    {%- endif -%}
    {%- comment -%} Home: preload first 4 featured collections' images as LCP candidate {%- endcomment -%}
    {%- if template.name == 'index' -%}
      {%- assign preload_count = 0 -%}
      {%- for collection in collections -%}
        {%- if preload_count < 4 and collection.image -%}
          <link
            rel="preload"
            as="image"
            href="{{ collection.image | image_url: width: 480 }}"
            imagesrcset="{{ collection.image | image_url: width: 240 }} 240w, {{ collection.image | image_url: width: 360 }} 360w, {{ collection.image | image_url: width: 480 }} 480w, {{ collection.image | image_url: width: 600 }} 600w"
            imagesizes="(min-width: 750px) 25vw, 50vw"
            fetchpriority="high"
          >
          {%- assign preload_count = preload_count | plus: 1 -%}
        {%- endif -%}
      {%- endfor -%}
    {%- endif -%}

    {%- comment -%} Organization schema.org (site-wide) {%- endcomment -%}
    {% render 'pp-organization-jsonld' %}
    {%- render 'theme-styles-variables' -%}
    {%- render 'color-schemes' -%}
    {%- comment -%} Non-critical CSS: load async via preload+onload trick to stop blocking FCP/LCP {%- endcomment -%}
    <link rel="preload" href="{{ 'pp-sections.css' | asset_url }}" as="style" onload="this.onload=null;this.rel='stylesheet'">
    <link rel="preload" href="{{ 'aileron-font.css' | asset_url }}" as="style" onload="this.onload=null;this.rel='stylesheet'">
    <noscript>
      {{ 'pp-sections.css' | asset_url | stylesheet_tag }}
      {{ 'aileron-font.css' | asset_url | stylesheet_tag }}
    </noscript>
    <style>
      product-card.pp-product-card-standalone h3.pp-card__title,
      product-card.pp-product-card-standalone h3.pp-card__title a,
      .pp-product-card-standalone h3.pp-card__title,
      .pp-product-card-standalone h3.pp-card__title a,
      h3.pp-card__title,
      h3.pp-card__title a {
        font-family: 'Inter', sans-serif !important;
        font-size: 15px !important;
        font-weight: 400 !important;
        line-height: 1.4 !important;
        color: #1a1a1a !important;
        text-decoration: none !important;
        letter-spacing: 0 !important;
        text-transform: none !important;
      }
      .pp-card__price-regular {
        font-family: 'Inter', sans-serif !important;
        font-size: 14.7px !important;
        font-weight: 700 !important;
        color: #1a1a1a !important;
      }
      .pp-card__price-sale {
        font-family: 'Inter', sans-serif !important;
        font-size: 15.9px !important;
        font-weight: 900 !important;
        color: #000000 !important;
      }
      .pp-card__price-compare {
        font-family: 'Inter', sans-serif !important;
        font-size: 14.7px !important;
        font-weight: 300 !important;
        color: #999999 !important;
        text-decoration: line-through !important;
      }
    </style>
    <script>
      document.addEventListener('DOMContentLoaded', function() {
        var titles = document.querySelectorAll('.pp-card__title, h3.pp-card__title');
        var prices = document.querySelectorAll('.pp-card__price-regular, .pp-card__price-sale, .pp-card__price-compare');
        console.log('[PP DEBUG] Found ' + titles.length + ' titles, ' + prices.length + ' prices');
        if (titles.length > 0) {
          var t = titles[0];
          var cs = getComputedStyle(t);
          console.log('[PP DEBUG] TITLE h3: font-size=' + cs.fontSize + ' font-family=' + cs.fontFamily + ' font-weight=' + cs.fontWeight);
          var a = t.querySelector('a');
          if (a) {
            var acs = getComputedStyle(a);
            console.log('[PP DEBUG] TITLE a: font-size=' + acs.fontSize + ' font-family=' + acs.fontFamily + ' font-weight=' + acs.fontWeight);
            // FORCE override via JS as test
            a.style.setProperty('font-size', '15px', 'important');
            a.style.setProperty('font-family', 'Inter, sans-serif', 'important');
            a.style.setProperty('font-weight', '400', 'important');
            a.style.setProperty('letter-spacing', '0', 'important');
            a.style.setProperty('text-transform', 'none', 'important');
            console.log('[PP DEBUG] TITLE a AFTER JS FORCE: font-size=' + getComputedStyle(a).fontSize);
          }
          // Also force h3 itself
          t.style.setProperty('font-size', '15px', 'important');
          t.style.setProperty('font-family', 'Inter, sans-serif', 'important');
          t.style.setProperty('font-weight', '400', 'important');
          t.style.setProperty('letter-spacing', '0', 'important');
          t.style.setProperty('text-transform', 'none', 'important');
        }
        // Force ALL titles and links
        document.querySelectorAll('.pp-card__title').forEach(function(el) {
          el.style.setProperty('font-size', '15px', 'important');
          el.style.setProperty('font-family', 'Inter, sans-serif', 'important');
          el.style.setProperty('font-weight', '400', 'important');
          el.style.setProperty('letter-spacing', '0', 'important');
          el.style.setProperty('line-height', '1.4', 'important');
          el.style.setProperty('text-transform', 'none', 'important');
          var link = el.querySelector('a');
          if (link) {
            link.style.setProperty('font-size', '15px', 'important');
            link.style.setProperty('font-family', 'Inter, sans-serif', 'important');
            link.style.setProperty('font-weight', '400', 'important');
            link.style.setProperty('letter-spacing', '0', 'important');
            link.style.setProperty('text-transform', 'none', 'important');
          }
        });
        document.querySelectorAll('.pp-card__price-regular').forEach(function(el) {
          el.style.setProperty('font-size', '14.7px', 'important');
          el.style.setProperty('font-weight', '700', 'important');
          el.style.setProperty('font-family', 'Inter, sans-serif', 'important');
        });
        document.querySelectorAll('.pp-card__price-sale').forEach(function(el) {
          el.style.setProperty('font-size', '15.9px', 'important');
          el.style.setProperty('font-weight', '900', 'important');
          el.style.setProperty('font-family', 'Inter, sans-serif', 'important');
          el.style.setProperty('color', '#000000', 'important');
        });
        document.querySelectorAll('.pp-card__price-compare').forEach(function(el) {
          el.style.setProperty('font-size', '14.7px', 'important');
          el.style.setProperty('font-weight', '300', 'important');
          el.style.setProperty('font-family', 'Inter, sans-serif', 'important');
          el.style.setProperty('color', '#999999', 'important');
        });
        console.log('[PP DEBUG] JS force applied to all cards');
      });
    </script>
    {% if request.design_mode %}
      {%- render 'theme-editor' -%}
    {% endif %}

    {{ content_for_header }}
  </head>

  <body class="page-width-{{ settings.page_width }} card-hover-effect-{{ settings.card_hover_effect }} template-{{ template.name }}">
    {% render 'skip-to-content-link', href: '#MainContent', text: 'accessibility.skip_to_text' %}
    <div id="header-group">
      {% sections 'header-group' %}
    </div>

    <script>
      // Inline header height and menu style calculations to prevent layout shift
      // Note: Updates in calculateHeaderGroupHeight(), updateTransparentHeaderOffset() and setHeaderMenuStyle() utilities.js should be kept in sync with this function
      (function setHeaderHeighCustomProperties() {
        /*
         * Header calculation functions for maintaining CSS variables
         * Mimic calculateHeaderGroupHeight() in utilities.js
         */
        const header = document.querySelector('header-component');
        const headerGroup = document.querySelector('#header-group');
        const hasHeaderSection = headerGroup?.querySelector('.header-section');

        if (!header || !headerGroup) return;

        const headerTopRow = header.querySelector('.header__row--top');
        const headerHeight = header.offsetHeight;

        // Calculate the total height of the header group
        let headerGroupHeight = 0;
        const children = headerGroup.children;
        for (let i = 0; i < children.length; i++) {
          const element = children[i];
          if (element === header || !(element instanceof HTMLElement)) continue;
          headerGroupHeight += element.offsetHeight;
        }

        // Check for transparent header special case
        if (header.hasAttribute('transparent') && header.parentElement?.nextElementSibling) {
          headerGroupHeight += headerHeight;
        }

        // Set CSS variables
        document.body.style.setProperty('--header-height', `${headerHeight}px`);
        document.body.style.setProperty('--header-group-height', `${headerGroupHeight}px`);

        if (headerTopRow) {
          window.requestAnimationFrame(function () {
            document.body.style.setProperty('--top-row-height', `${headerTopRow.offsetHeight}px`);
          });
        }

        /**
         * Updates CSS custom properties for transparent header offset calculation
         * Mimic updateTransparentHeaderOffset() in utilities.js
         */

        if (!hasHeaderSection || !header?.hasAttribute('transparent')) {
          document.body.style.setProperty('--transparent-header-offset-boolean', '0');
          return;
        }

        const hasImmediateSection = hasHeaderSection.nextElementSibling?.classList.contains('shopify-section');

        const shouldApplyOffset = !hasImmediateSection ? '1' : '0';
        document.body.style.setProperty('--transparent-header-offset-boolean', shouldApplyOffset);
      })();

      (function setHeaderMenuStyle() {
        const headerComponent = document.querySelector('#header-component');
        if (headerComponent) {
          const isTouchDevice = 'ontouchstart' in window && navigator.maxTouchPoints > 0;
          const overflowList = headerComponent?.querySelector('overflow-list');
          const hasReachedMinimum = overflowList && overflowList.hasAttribute('minimum-reached');
          headerComponent.dataset.menuStyle = isTouchDevice || hasReachedMinimum ? 'drawer' : 'menu';
        }
      })();
    </script>

    <main
      id="MainContent"
      class="content-for-layout"
      role="main"
      data-page-transition-enabled="{{ settings.page_transition_enabled }}"
      data-product-transition="{{ settings.transition_to_main_product }}"
      data-template="{{ template }}"
    >
      {{ content_for_layout }}
    </main>

    <footer>
      {% sections 'footer-group' %}
    </footer>

    {% render 'search-modal' %}

    {% if settings.quick_add or settings.mobile_quick_add %}
      {% render 'quick-add-modal' %}
    {% endif %}
  </body>
</html>
