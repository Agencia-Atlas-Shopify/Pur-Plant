{%- comment -%}
  Pur Plant custom robots.txt.
  Shopify's default rules are preserved via `{{ group.rules }}` + we append
  extra Disallow rules for tracking-heavy paths and faceted search URLs.
{%- endcomment -%}
{% for group in robots.default_groups %}
  {{- group.user_agent }}

  {% for rule in group.rules %}
    {{- rule }}
  {% endfor %}

  {%- comment -%} Extra disallow rules for Pur Plant {%- endcomment -%}
  Disallow: /pp-atlas-robots-test-marker
  Disallow: /cart
  Disallow: /cart/*
  Disallow: /checkouts/*
  Disallow: /orders/*
  Disallow: /account
  Disallow: /account/*
  Disallow: /apps/*
  Disallow: /*?*variant=
  Disallow: /*?*sort_by=
  Disallow: /*?*filter.*=
  Disallow: /*?*utm_
  Disallow: /*?*fbclid=
  Disallow: /*?*gclid=
  Disallow: /*?*dm_i=
  Disallow: /search?q=
  Disallow: /*/search?q=

  {%- if group.sitemap != blank %}
    {{ group.sitemap }}
  {%- endif %}
{% endfor %}
