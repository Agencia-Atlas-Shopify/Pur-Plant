{%- comment -%}
  PP Cart Recommendations

  Shows a horizontal "completa tu pedido" scroller inside the cart drawer.

  Data source:
    - If settings.pp_cart_reco_collection is set → list products from that collection.
    - Otherwise → default to Shopify's /recommendations/products.json intent=related
      fed by the first cart item (loaded client-side via JS).
{%- endcomment -%}

{%- liquid
  assign title = settings.pp_cart_reco_title | default: 'Completa tu pedido'
  assign limit = settings.pp_cart_reco_limit | default: 8
  assign source_collection = settings.pp_cart_reco_collection
  assign first_item_product_id = cart.items.first.product.id
-%}

<div
  class="pp-cart-reco"
  data-cart-reco
  data-limit="{{ limit }}"
  data-product-id="{{ first_item_product_id }}"
  {%- if source_collection != blank %} data-collection-handle="{{ source_collection.handle }}"{%- endif -%}
>
  <h4 class="pp-cart-reco__title">{{ title | upcase }}</h4>
  <div class="pp-cart-reco__track" data-cart-reco-list>
    {%- if source_collection != blank -%}
      {%- comment -%} SSR the collection products when a collection is configured {%- endcomment -%}
      {%- for product in source_collection.products limit: limit -%}
        {%- assign reco_variant = product.selected_or_first_available_variant -%}
        <div class="pp-cart-reco__card">
          <a href="{{ product.url }}" class="pp-cart-reco__media">
            {%- if product.featured_image -%}
              {{ product.featured_image | image_url: width: 300 | image_tag: loading: 'lazy', class: 'pp-cart-reco__img', alt: product.title }}
            {%- endif -%}
            <span class="pp-cart-reco__price">{{ product.price | money }}</span>
          </a>
          {%- if reco_variant.available and product.has_only_default_variant -%}
            <button
              type="button"
              class="pp-cart-reco__add"
              data-cart-reco-add
              data-variant-id="{{ reco_variant.id }}"
              aria-label="{{ 'actions.add_to_cart' | t }}"
            >+</button>
          {%- else -%}
            <a href="{{ product.url }}" class="pp-cart-reco__add" aria-label="Ver">→</a>
          {%- endif -%}
        </div>
      {%- endfor -%}
    {%- endif -%}
  </div>
</div>

<script src="{{ 'pp-cart-reco.js' | asset_url }}" defer></script>

{% stylesheet %}
  .pp-cart-reco {
    padding: 16px 20px;
    background: #f6f4ed;
    border-radius: 12px;
  }

  .pp-cart-reco__title {
    font-family: 'Inter', sans-serif;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #23372c;
    margin: 0 0 10px;
  }

  .pp-cart-reco__track {
    display: flex;
    gap: 8px;
    overflow-x: auto;
    padding-bottom: 4px;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    touch-action: pan-x;
  }

  .pp-cart-reco__track::-webkit-scrollbar {
    height: 4px;
  }

  .pp-cart-reco__track::-webkit-scrollbar-thumb {
    background: rgba(35, 55, 44, 0.2);
    border-radius: 2px;
  }

  .pp-cart-reco__card {
    scroll-snap-align: start;
    flex: 0 0 calc(23.333% - 6px);
    position: relative;
  }

  .pp-cart-reco__media {
    display: block;
    aspect-ratio: 4 / 5;
    overflow: hidden;
    border-radius: 8px;
    background: #efeae0;
    position: relative;
  }

  .pp-cart-reco__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .pp-cart-reco__price {
    position: absolute;
    bottom: 0;
    right: 0;
    background: #23372c;
    color: #e4ffd3;
    font-family: 'Inter', sans-serif;
    font-size: 11px;
    font-weight: 500;
    padding: 3px 7px;
    line-height: 1.2;
  }

  .pp-cart-reco__add {
    position: absolute;
    top: 4px;
    right: 4px;
    background: rgba(255, 255, 255, 0.9);
    color: #23372c;
    border: none;
    width: 26px;
    height: 26px;
    border-radius: 50%;
    cursor: pointer;
    font-size: 20px;
    font-weight: 400;
    line-height: 1;
    padding: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    text-decoration: none;
    transition: background 0.15s;
  }

  .pp-cart-reco__add:hover {
    background: #fff;
  }
{% endstylesheet %}
