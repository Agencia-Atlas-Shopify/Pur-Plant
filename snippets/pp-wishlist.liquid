{%- comment -%}
  RC Wishlist
  Native wishlist functionality using localStorage
  Compatible with Wishlist Plus and other apps

  Usage:
  {% render 'pp-wishlist', product: product %}
  {% render 'pp-wishlist', type: 'icon' %} (for header)
  {% render 'pp-wishlist', type: 'page' %} (for wishlist page)
{%- endcomment -%}

{%- style -%}
  /* Wishlist button on product */
  .pp-wishlist-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 0.75rem 1rem;
    font-size: var(--pp-text-xs, 0.6875rem);
    font-weight: 500;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    background: transparent;
    border: 1px solid rgb(var(--pp-product-text, 0 0 0) / 0.2);
    color: rgb(var(--pp-product-text, 0 0 0));
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .pp-wishlist-btn:hover {
    border-color: currentColor;
  }

  .pp-wishlist-btn svg {
    width: 18px;
    height: 18px;
    transition: fill 0.2s ease, transform 0.2s ease;
  }

  .pp-wishlist-btn.is-wishlisted {
    color: #d2c7b7;
    border-color: #d2c7b7;
  }

  .pp-wishlist-btn.is-wishlisted svg {
    fill: #d2c7b7;
  }

  .pp-wishlist-btn.is-wishlisted:hover svg {
    transform: scale(1.1);
  }

  /* Icon only (for product cards) */
  .pp-wishlist-btn--icon {
    position: absolute;
    top: 0.5rem;
    right: 0.5rem;
    width: auto;
    height: auto;
    padding: 0;
    background: transparent;
    border: none;
    border-radius: 0;
    z-index: 5;
    opacity: 0;
    transform: none;
    transition: opacity 0.2s ease;
    color: #fff;
    filter: drop-shadow(0 1px 2px rgb(0 0 0 / 0.4));
    cursor: pointer;
  }

  .pp-product-card-standalone:hover .pp-wishlist-btn--icon,
  .pp-product-card:hover .pp-wishlist-btn--icon,
  .pp-wishlist-btn--icon.is-wishlisted {
    opacity: 1;
  }

  .pp-wishlist-btn--icon svg {
    width: 22px;
    height: 20px;
  }

  .pp-wishlist-btn--icon.is-wishlisted {
    color: #d2c7b7;
    filter: none;
  }

  .pp-wishlist-btn--icon.is-wishlisted svg {
    fill: #d2c7b7;
    stroke: #d2c7b7;
  }

  /* Header icon */
  .pp-wishlist-icon {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    background: transparent;
    border: none;
    color: inherit;
    cursor: pointer;
  }

  .pp-wishlist-icon svg {
    width: 20px;
    height: 20px;
  }

  .pp-wishlist-icon__count {
    position: absolute;
    top: 4px;
    right: 2px;
    min-width: 18px;
    height: 18px;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0 5px;
    font-size: 10px;
    font-weight: 600;
    background: rgb(var(--pp-header-text, 0 0 0));
    color: rgb(var(--pp-header-bg, 255 255 255));
    border-radius: 50%;
    opacity: 1;
    transform: scale(1);
    transition: opacity 0.2s ease, transform 0.2s ease;
  }

  .pp-wishlist-icon__count:empty,
  .pp-wishlist-icon__count[data-count="0"] {
    opacity: 0;
    transform: scale(0);
    pointer-events: none;
  }

  /* Animation when count changes */
  .pp-wishlist-icon__count.is-animating {
    animation: wishlist-bounce 0.3s ease;
  }

  @keyframes wishlist-bounce {
    0% { transform: scale(1); }
    50% { transform: scale(1.3); }
    100% { transform: scale(1); }
  }

  /* Wishlist page */
  .pp-wishlist-page {
    padding: 80px 0;
    min-height: 60vh;
  }

  .pp-wishlist-page .pp-container {
    max-width: 76rem;
    margin: 0 auto;
    padding: 0 20px;
  }

  @media screen and (min-width: 1000px) {
    .pp-wishlist-page .pp-container {
      padding: 0 30px;
    }
  }

  .pp-wishlist-page__header {
    text-align: center;
    margin-bottom: 3.5rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid rgb(var(--pp-product-text, 0 0 0) / 0.1);
  }

  .pp-wishlist-page__title {
    font-family: var(--pp-heading-font-family);
    font-size: var(--pp-text-h3, 1.5rem);
    font-weight: var(--pp-heading-font-weight, 400);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin: 0 0 1rem;
  }

  @media screen and (min-width: 750px) {
    .pp-wishlist-page__title {
      font-size: var(--pp-text-h2, 1.75rem);
    }
  }

  .pp-wishlist-page__count {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: var(--pp-text-sm, 0.75rem);
    font-weight: 400;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: rgb(var(--pp-product-text, 0 0 0) / 0.6);
  }

  .pp-wishlist-page__count span {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 24px;
    height: 24px;
    padding: 0 8px;
    background: rgb(var(--pp-product-text, 0 0 0));
    color: rgb(var(--pp-product-bg, 255 255 255));
    border-radius: 12px;
    font-weight: 600;
    font-size: 11px;
  }

  .pp-wishlist-page__count span[data-count="0"],
  .pp-wishlist-page__count span:empty {
    background: rgb(var(--pp-product-text, 0 0 0) / 0.2);
  }

  .pp-wishlist-page__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
  }

  @media screen and (min-width: 750px) {
    .pp-wishlist-page__grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media screen and (min-width: 990px) {
    .pp-wishlist-page__grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  .pp-wishlist-page__empty {
    text-align: center;
    padding: 4rem 2rem;
  }

  .pp-wishlist-page__empty-title {
    font-size: var(--pp-text-lg, 1rem);
    margin: 0 0 0.5rem;
  }

  .pp-wishlist-page__empty-text {
    font-size: var(--pp-text-sm, 0.75rem);
    opacity: 0.6;
    margin: 0 0 1.5rem;
  }

  .pp-wishlist-page__empty-link {
    display: inline-block;
    padding: 0.875rem 2rem;
    font-size: var(--pp-text-xs, 0.6875rem);
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    text-decoration: none;
    background: rgb(var(--pp-product-text, 0 0 0));
    color: rgb(var(--pp-product-bg, 255 255 255));
  }
  /* ── Swym wishlist modal/drawer — close button override ── */
  #swym-wishlist-fly-cnt-wrapper .swym-close,
  #swym-wishlist-fly-cnt-wrapper .swym-wishlist-close,
  #swym-wishlist-fly-cnt-wrapper [class*="close"],
  .swym-wishlist-overlay .swym-close,
  .swym-popup .swym-close,
  .swym-wishlist-modal .swym-close,
  button.swym-close,
  .swym-wishlist-fly-cnt-close {
    all: unset;
    position: absolute;
    top: 16px;
    right: 16px;
    width: 32px;
    height: 32px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    background: #23372c;
    color: #e4ffd3;
    cursor: pointer;
    z-index: 10;
    transition: opacity 0.15s;
    box-sizing: border-box;
  }

  #swym-wishlist-fly-cnt-wrapper .swym-close::before,
  #swym-wishlist-fly-cnt-wrapper .swym-wishlist-close::before,
  .swym-wishlist-overlay .swym-close::before,
  button.swym-close::before,
  .swym-wishlist-fly-cnt-close::before {
    content: '';
    width: 14px;
    height: 14px;
    background: currentColor;
    -webkit-mask: url('data:image/svg+xml;utf8,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 14 14"><path fill="none" stroke="black" stroke-width="1.2" d="M1 1L13 13M1 13L13 1"/></svg>') center/contain no-repeat;
    mask: url('data:image/svg+xml;utf8,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 14 14"><path fill="none" stroke="black" stroke-width="1.2" d="M1 1L13 13M1 13L13 1"/></svg>') center/contain no-repeat;
  }

  #swym-wishlist-fly-cnt-wrapper .swym-close:hover,
  button.swym-close:hover,
  .swym-wishlist-fly-cnt-close:hover {
    opacity: 0.85;
  }
{%- endstyle -%}

{%- if type == 'icon' -%}
  {%- comment -%} Header wishlist icon {%- endcomment -%}
  <a href="/pages/wishlist" class="pp-wishlist-icon" aria-label="{{ 'header.wishlist' | t | default: 'Wishlist' }}">
    <svg viewBox="0 0 26 24" fill="none" stroke="currentColor" stroke-width="1">
      <path d="M20.583 22.75 13 17.333 5.417 22.75V5.417A2.167 2.167 0 0 1 7.583 3.25h10.834a2.167 2.167 0 0 1 2.166 2.167V22.75Z"/>
    </svg>
    <span class="pp-wishlist-icon__count" data-wishlist-count></span>
  </a>

{%- elsif type == 'page' -%}
  {%- comment -%} Wishlist page content {%- endcomment -%}
  <section class="pp-wishlist-page">
    <div class="pp-container">
      <header class="pp-wishlist-page__header">
        <h1 class="pp-wishlist-page__title">{{ 'wishlist.title' | t | default: 'My Wishlist' }}</h1>
        <p class="pp-wishlist-page__count">
          <span data-wishlist-page-count data-count="0">0</span>
          {{ 'wishlist.items' | t | default: 'items saved' }}
        </p>
      </header>

      <div class="pp-wishlist-page__grid" data-wishlist-grid>
        {%- comment -%} Products loaded via JavaScript {%- endcomment -%}
      </div>

      <div class="pp-wishlist-page__empty" data-wishlist-empty style="display: none;">
        <h2 class="pp-wishlist-page__empty-title">{{ 'wishlist.empty_title' | t | default: 'Your wishlist is empty' }}</h2>
        <p class="pp-wishlist-page__empty-text">{{ 'wishlist.empty_text' | t | default: 'Browse our products and add your favorites!' }}</p>
        <a href="/collections/all" class="pp-wishlist-page__empty-link">{{ 'wishlist.continue_shopping' | t | default: 'Continue Shopping' }}</a>
      </div>
    </div>
  </section>

{%- else -%}
  {%- comment -%} Product wishlist button {%- endcomment -%}
  <button
    type="button"
    class="pp-wishlist-btn{% if icon_only %} pp-wishlist-btn--icon{% endif %}"
    data-wishlist-add
    data-product-id="{{ product.id }}"
    data-product-handle="{{ product.handle }}"
    aria-label="{{ 'products.product.add_wishlist' | t | default: 'Add to wishlist' }}"
  >
    <svg viewBox="0 0 26 24" fill="none" stroke="currentColor" stroke-width="1">
      <path d="M20.583 22.75 13 17.333 5.417 22.75V5.417A2.167 2.167 0 0 1 7.583 3.25h10.834a2.167 2.167 0 0 1 2.166 2.167V22.75Z"/>
    </svg>
    {%- unless icon_only -%}
      <span data-wishlist-text>{{ 'products.product.add_wishlist' | t | default: 'Add to Wishlist' }}</span>
    {%- endunless -%}
  </button>
{%- endif -%}

<script>
  (function() {
    // Prevent multiple initializations
    if (window.ppWishlistInitialized) return;
    window.ppWishlistInitialized = true;

    const STORAGE_KEY = 'pp_wishlist';

    // Get wishlist from localStorage
    function getWishlist() {
      try {
        return JSON.parse(localStorage.getItem(STORAGE_KEY) || '[]');
      } catch {
        return [];
      }
    }

    // Save wishlist to localStorage
    function saveWishlist(wishlist) {
      localStorage.setItem(STORAGE_KEY, JSON.stringify(wishlist));
      updateCounts(true);
      document.dispatchEvent(new CustomEvent('pp:wishlist:updated', { detail: { wishlist } }));
    }

    // Add/remove from wishlist
    function toggleWishlist(productId, productHandle) {
      let wishlist = getWishlist();
      const index = wishlist.findIndex(item => item.id === productId);

      if (index > -1) {
        wishlist.splice(index, 1);
      } else {
        wishlist.push({ id: productId, handle: productHandle, addedAt: Date.now() });
      }

      saveWishlist(wishlist);
      return index === -1; // Returns true if added, false if removed
    }

    // Check if product is in wishlist
    function isInWishlist(productId) {
      return getWishlist().some(item => item.id === productId);
    }

    // Update all count displays
    function updateCounts(animate = false) {
      const count = getWishlist().length;
      document.querySelectorAll('[data-wishlist-count]').forEach(el => {
        el.textContent = count > 0 ? count : '';
        el.dataset.count = count;
        if (animate && count > 0) {
          el.classList.add('is-animating');
          setTimeout(() => el.classList.remove('is-animating'), 300);
        }
      });
      document.querySelectorAll('[data-wishlist-page-count]').forEach(el => {
        el.textContent = count;
        el.dataset.count = count;
      });
    }

    // Update button states
    function updateButtons() {
      document.querySelectorAll('[data-wishlist-add]').forEach(btn => {
        const productId = btn.dataset.productId;
        const isWishlisted = isInWishlist(productId);
        btn.classList.toggle('is-wishlisted', isWishlisted);

        const text = btn.querySelector('[data-wishlist-text]');
        if (text) {
          text.textContent = isWishlisted ? 'Remove from Wishlist' : 'Add to Wishlist';
        }
      });
    }

    // Use event delegation for wishlist buttons
    document.addEventListener('click', (e) => {
      const btn = e.target.closest('[data-wishlist-add]');
      if (!btn) return;

      e.preventDefault();
      e.stopPropagation();

      const productId = btn.dataset.productId;
      const productHandle = btn.dataset.productHandle;
      const added = toggleWishlist(productId, productHandle);

      btn.classList.toggle('is-wishlisted', added);

      const text = btn.querySelector('[data-wishlist-text]');
      if (text) {
        text.textContent = added ? 'Remove from Wishlist' : 'Add to Wishlist';
      }

      // Animation
      const svg = btn.querySelector('svg');
      if (svg) {
        svg.style.transform = 'scale(1.2)';
        setTimeout(() => {
          svg.style.transform = '';
        }, 200);
      }
    });

    // Initialize wishlist page
    async function initWishlistPage() {
      const grid = document.querySelector('[data-wishlist-grid]');
      const empty = document.querySelector('[data-wishlist-empty]');

      if (!grid) return;

      const wishlist = getWishlist();

      if (wishlist.length === 0) {
        grid.style.display = 'none';
        empty.style.display = 'block';
        return;
      }

      grid.style.display = '';
      empty.style.display = 'none';

      // Fetch and render products
      for (const item of wishlist) {
        try {
          const response = await fetch(`/products/${item.handle}.json`);
          if (!response.ok) continue;

          const data = await response.json();
          const product = data.product;
          const variant = product.variants[0];
          const image = product.images[0]?.src || '';

          let priceHtml = '';
          if (variant.compare_at_price && variant.compare_at_price > variant.price) {
            priceHtml = `
              <span style="color: rgb(180 0 0);">${formatMoney(variant.price)}</span>
              <s style="opacity: 0.5;">${formatMoney(variant.compare_at_price)}</s>
            `;
          } else {
            priceHtml = formatMoney(variant.price);
          }

          const productCard = document.createElement('div');
          productCard.className = 'pp-product-card';
          productCard.innerHTML = `
            <div style="position: relative;">
              <a href="/products/${product.handle}" style="display: block;">
                <div style="aspect-ratio: 3/4; overflow: hidden; background: #f5f5f5;">
                  ${image ? `<img src="${image}" alt="${product.title}" style="width: 100%; height: 100%; object-fit: cover;">` : ''}
                </div>
              </a>
              <button
                type="button"
                class="pp-wishlist-btn pp-wishlist-btn--icon is-wishlisted"
                data-wishlist-add
                data-product-id="${product.id}"
                data-product-handle="${product.handle}"
                style="opacity: 1; transform: scale(1);"
              >
                <svg viewBox="0 0 26 24" fill="currentColor" stroke="currentColor" stroke-width="1">
                  <path d="M20.583 22.75 13 17.333 5.417 22.75V5.417A2.167 2.167 0 0 1 7.583 3.25h10.834a2.167 2.167 0 0 1 2.166 2.167V22.75Z"/>
                </svg>
              </button>
            </div>
            <div style="padding-top: 0.75rem;">
              <a href="/products/${product.handle}" style="text-decoration: none; color: inherit;">
                <h3 style="font-size: 0.75rem; margin: 0 0 0.25rem;">${product.title}</h3>
                <p style="font-size: 0.75rem; margin: 0;">${priceHtml}</p>
              </a>
            </div>
          `;

          grid.appendChild(productCard);

          // Add event listener to remove button
          const removeBtn = productCard.querySelector('[data-wishlist-add]');
          removeBtn.addEventListener('click', () => {
            toggleWishlist(product.id.toString(), product.handle);
            productCard.remove();

            if (getWishlist().length === 0) {
              grid.style.display = 'none';
              empty.style.display = 'block';
            }
          });

        } catch (error) {
          console.error('Error loading wishlist product:', error);
        }
      }
    }

    function formatMoney(cents) {
      if (typeof Shopify !== 'undefined' && Shopify.formatMoney) {
        return Shopify.formatMoney(cents);
      }
      return (cents / 100).toLocaleString('en-US', {
        style: 'currency',
        currency: 'EUR'
      });
    }

    // Expose updateButtons globally so it can be called after DOM changes
    window.ppWishlistUpdateButtons = updateButtons;
    window.ppWishlistUpdateCounts = updateCounts;

    // Initialize when DOM is ready
    function init() {
      updateCounts();
      updateButtons();
      initWishlistPage();
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', init);
    } else {
      init();
    }

    // Also update buttons when wishlist changes
    document.addEventListener('pp:wishlist:updated', updateButtons);

    // Re-init counts/buttons on Shopify view transitions & browser back/forward
    window.addEventListener('pageshow', () => {
      updateCounts();
      updateButtons();
    });
    document.addEventListener('shopify:section:load', () => {
      updateCounts();
      updateButtons();
    });
  })();
</script>

<script>
  // Update wishlist button states after page load (for dynamically rendered content)
  if (window.ppWishlistUpdateButtons) {
    window.ppWishlistUpdateButtons();
  }
</script>
