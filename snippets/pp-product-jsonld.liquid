{%- comment -%}
  PP Product JSON-LD — Enriched Product + BreadcrumbList schema.org.

  Reads:
    - product.metafields.reviews.rating / rating_count  (Judge.me-compatible)
    - product.metafields.custom.coleccion_principal     (breadcrumb anchor)

  Falls back to product | structured_data when data is missing.
{%- endcomment -%}

{%- liquid
  assign rating_mf = product.metafields.reviews.rating
  assign rating_count_mf = product.metafields.reviews.rating_count
  assign rating_count = rating_count_mf | plus: 0
  assign has_rating = false
  if rating_mf != blank and rating_count > 0
    assign has_rating = true
    assign rating_val = rating_mf.value.rating
  endif

  comment
    Use vendor only if it looks like a real brand (has letters, length >= 3).
    Junk values like "1111" or "-" fall back to "Pur Plant".
  endcomment
  assign brand = 'Pur Plant'
  if product.vendor != blank
    assign vendor_clean = product.vendor | strip
    assign vendor_len = vendor_clean | size
    assign vendor_downcased = vendor_clean | downcase
    assign alpha_chars = 'abcdefghijklmnopqrstuvwxyz' | split: ''
    assign vendor_has_letter = false
    for c in alpha_chars
      if vendor_downcased contains c
        assign vendor_has_letter = true
        break
      endif
    endfor
    if vendor_len >= 3 and vendor_has_letter
      assign brand = vendor_clean
    endif
  endif
  assign current_variant = product.selected_or_first_available_variant
  assign product_url = shop.url | append: product.url
-%}

<script type="application/ld+json">
{
  "@context": "https://schema.org/",
  "@type": "Product",
  "name": {{ product.title | json }},
  "description": {{ product.description | strip_html | truncate: 5000 | json }},
  "image": [
    {%- for image in product.images limit: 5 -%}
      {{ image | image_url: width: 1200 | prepend: 'https:' | json }}{%- unless forloop.last %},{% endunless -%}
    {%- endfor -%}
  ],
  "sku": {{ current_variant.sku | default: current_variant.id | json }},
  {%- if current_variant.barcode != blank -%}
  "gtin13": {{ current_variant.barcode | json }},
  {%- endif -%}
  "mpn": {{ current_variant.id | json }},
  "brand": {
    "@type": "Brand",
    "name": {{ brand | json }}
  },
  "url": {{ product_url | json }},
  {%- if has_rating -%}
  "aggregateRating": {
    "@type": "AggregateRating",
    "ratingValue": {{ rating_val | json }},
    "ratingCount": {{ rating_count | json }},
    "bestRating": "5",
    "worstRating": "1"
  },
  {%- endif -%}
  "offers": {
    "@type": "{% if product.variants.size > 1 %}AggregateOffer{% else %}Offer{% endif %}",
    {%- if product.variants.size > 1 -%}
    "priceCurrency": {{ cart.currency.iso_code | json }},
    "lowPrice": {{ product.price_min | money_without_currency | replace: ',', '.' | json }},
    "highPrice": {{ product.price_max | money_without_currency | replace: ',', '.' | json }},
    "offerCount": {{ product.variants.size }},
    {%- else -%}
    "priceCurrency": {{ cart.currency.iso_code | json }},
    "price": {{ current_variant.price | money_without_currency | replace: ',', '.' | json }},
    {%- endif -%}
    "availability": {%- if current_variant.available -%}"https://schema.org/InStock"{%- else -%}"https://schema.org/OutOfStock"{%- endif -%},
    "url": {{ product_url | json }},
    "itemCondition": "https://schema.org/NewCondition"
  }
}
</script>

{%- comment -%} BreadcrumbList JSON-LD {%- endcomment -%}
{%- liquid
  assign bc_coll = product.metafields.custom.coleccion_principal.value
  if bc_coll == blank and product.collections.size > 0
    assign bc_coll = product.collections.first
  endif
-%}

{%- if bc_coll != blank -%}
  {%- liquid
    assign bc_items = 'Pur Plant|||' | append: shop.url | append: '^^^'
    assign walk = bc_coll
    assign chain = ''
    for i in (1..5)
      assign parent = walk.metafields.custom.coleccion_padre.value
      if parent != blank
        if chain == ''
          assign chain = parent.title | append: '|||' | append: shop.url | append: parent.url
        else
          assign chain = parent.title | append: '|||' | append: shop.url | append: parent.url | append: '^^^' | append: chain
        endif
        assign walk = parent
      else
        break
      endif
    endfor
    if chain != ''
      assign bc_items = bc_items | append: chain | append: '^^^'
    endif
    assign bc_items = bc_items | append: bc_coll.title | append: '|||' | append: shop.url | append: bc_coll.url | append: '^^^' | append: product.title | append: '|||' | append: product_url
    assign bc_list = bc_items | split: '^^^'
  -%}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      {%- for item in bc_list -%}
        {%- assign parts = item | split: '|||' -%}
        {
          "@type": "ListItem",
          "position": {{ forloop.index }},
          "name": {{ parts[0] | json }},
          "item": {{ parts[1] | json }}
        }{% unless forloop.last %},{% endunless %}
      {%- endfor -%}
    ]
  }
  </script>
{%- endif -%}
