{%- comment -%}
  PP Cart Drawer — Pur Plant cart drawer

  Features:
  - Configurable free shipping progress bar with logo SVG (settings-driven)
  - Line items with remove/quantity controls
  - Shopify-related or collection-based recommendations
  - Cart notes textarea synced to order notes
{%- endcomment -%}

<script src="{{ 'cart-drawer.js' | asset_url }}" type="module" fetchpriority="low"></script>
<script src="{{ 'component-cart-items.js' | asset_url }}" type="module" fetchpriority="low"></script>
<script src="{{ 'component-cart-quantity-selector.js' | asset_url }}" type="module" fetchpriority="low"></script>
<script src="{{ 'component-quantity-selector.js' | asset_url }}" type="module" fetchpriority="low"></script>
{%- comment -%} Preload reco script always so inline onclick handlers work after innerHTML refresh {%- endcomment -%}
<script src="{{ 'pp-cart-reco.js' | asset_url }}" defer></script>

{%- liquid
  comment
    Detect Árboles XXL (palet shipping, 5–7 days).
    Only XXL-sized árboles trigger the notice; smaller árboles ship 24/48h.
  endcomment
  assign has_arbol_xxl = false
  for li in cart.items
    assign li_title_lower = li.product.title | downcase
    assign li_is_arbol = false
    if li_title_lower contains 'árbol' or li_title_lower contains 'arbol'
      assign li_is_arbol = true
    endif
    unless li_is_arbol
      for tag in li.product.tags
        assign tag_lower = tag | downcase
        if tag_lower contains 'árbol' or tag_lower contains 'arbol'
          assign li_is_arbol = true
          break
        endif
      endfor
    endunless
    if li_is_arbol
      assign li_is_xxl = false
      if li_title_lower contains 'xxl'
        assign li_is_xxl = true
      endif
      if li.variant.title != blank
        assign variant_upper = li.variant.title | upcase
        if variant_upper contains 'XXL'
          assign li_is_xxl = true
        endif
      endif
      if li.product.metafields.custom.tamano != blank
        assign size_mf = li.product.metafields.custom.tamano | upcase
        if size_mf == 'XXL'
          assign li_is_xxl = true
        endif
      endif
      if li_is_xxl
        assign has_arbol_xxl = true
        break
      endif
    endif
  endfor
  assign has_arbol = has_arbol_xxl
-%}

<cart-drawer-component
  class="pp-cart-drawer"
  {% if settings.auto_open_cart_drawer %}auto-open{% endif %}
>
  <dialog
    ref="dialog"
    class="pp-cart-drawer__dialog"
    aria-labelledby="pp-cart-drawer-heading"
    scroll-lock
  >
    <div class="pp-cart-drawer__inner" data-hydration-key="pp-cart-drawer-inner" data-has-arbol="{{ has_arbol }}">
      <cart-items-component
        class="pp-cart-drawer__cart-items"
        data-drawer
        data-section-id="{{ section.id }}"
      >
        {%- comment -%} Header {%- endcomment -%}
        <div class="pp-cart-drawer__header">
          <h2 class="pp-cart-drawer__title" id="pp-cart-drawer-heading">
            {{ 'content.cart_title' | t | upcase }}
            <span class="pp-cart-drawer__title-count">
              [<span ref="cartItemCount">{{ cart.item_count }}</span>]
            </span>
          </h2>
          <button
            ref="closeButton"
            on:click="cart-drawer-component/close"
            class="pp-cart-drawer__close"
            aria-label="{{ 'actions.close_dialog' | t }}"
          >
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
              <path d="M1 1L13 13M1 13L13 1" stroke="currentColor" stroke-width="1"/>
            </svg>
          </button>
        </div>

        {%- comment -%} Árboles delivery notice (5–7 days) {%- endcomment -%}
        {%- if has_arbol -%}
          <div class="pp-cart-drawer__arbol-notice" role="status">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <circle cx="12" cy="12" r="10"/>
              <path d="M12 6v6l4 2"/>
            </svg>
            <span>Los árboles XXL se envían en palet: <strong>5-7 días laborables</strong>. El resto de artículos en 24-48h.</span>
          </div>
        {%- endif -%}

        {%- comment -%} Free Shipping Bar {%- endcomment -%}
        {%- if settings.pp_cart_free_ship_enabled and settings.pp_cart_free_ship_threshold > 0 -%}
          <div class="pp-cart-drawer__shipping-bar">
            {% render 'pp-free-shipping-bar' %}
          </div>
        {%- endif -%}

        {%- comment -%} Cart Items {%- endcomment -%}
        <div class="pp-cart-drawer__content">
          {%- if cart.empty? -%}
            <div class="pp-cart-drawer__empty">
              <p>{{ 'content.your_cart_is_empty' | t }}</p>
              <a href="{{ routes.root_url }}" class="pp-cart-drawer__continue-btn">
                {{ 'actions.continue_shopping' | t | upcase }}
              </a>
            </div>
          {%- else -%}
            <div class="pp-cart-drawer__items">
              {%- for item in cart.items -%}
                {% render 'pp-cart-line-item', item: item %}
              {%- endfor -%}
            </div>
          {%- endif -%}
        </div>

        {%- unless cart.empty? -%}
          {%- comment -%} Recommendations (Shopify related or custom collection) {%- endcomment -%}
          {%- if settings.pp_cart_reco_enabled -%}
            <div class="pp-cart-drawer__reco">
              {% render 'pp-cart-recommendations' %}
            </div>
          {%- endif -%}

          {%- comment -%} Cart notes → pushed to cart.note {%- endcomment -%}
          {%- if settings.pp_cart_notes_enabled -%}
            <details class="pp-cart-drawer__notes"{% if cart.note != blank %} open{% endif %}>
              <summary class="pp-cart-drawer__notes-summary">
                <span class="pp-cart-drawer__notes-label">
                  {{ settings.pp_cart_notes_label | default: 'Añade una nota a tu pedido' }}
                </span>
                <span class="pp-cart-drawer__notes-toggle" aria-hidden="true">
                  <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
                    <path d="M7 1v12M1 7h12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                  </svg>
                </span>
              </summary>
              <textarea
                id="pp-cart-note"
                class="pp-cart-drawer__notes-input"
                name="note"
                rows="2"
                placeholder="{{ settings.pp_cart_notes_placeholder | default: 'Instrucciones de entrega, regalo, etc.' }}"
                data-pp-cart-note
              >{{ cart.note }}</textarea>
            </details>
            <script>
              (function () {
                const ta = document.getElementById('pp-cart-note');
                if (!ta) return;
                let t;
                ta.addEventListener('input', () => {
                  clearTimeout(t);
                  t = setTimeout(() => {
                    fetch('/cart/update.js', {
                      method: 'POST',
                      headers: { 'Content-Type': 'application/json', Accept: 'application/json' },
                      credentials: 'same-origin',
                      body: JSON.stringify({ note: ta.value }),
                    }).catch(() => { /* noop */ });
                  }, 400);
                });
              })();
            </script>
          {%- endif -%}

          {%- comment -%} Footer / Summary {%- endcomment -%}
          <div class="pp-cart-drawer__footer">
            {%- comment -%} Applied discount pills {%- endcomment -%}
            {%- if cart.cart_level_discount_applications.size > 0 or cart.discount_applications.size > 0 -%}
              <div class="pp-cart-drawer__discounts-applied" data-pp-discounts-applied>
                {%- for disc in cart.cart_level_discount_applications -%}
                  <span class="pp-cart-drawer__discount-pill" data-discount-code="{{ disc.title }}">
                    {{ disc.title }}
                    <button type="button" data-pp-remove-discount="{{ disc.title }}" aria-label="Eliminar">×</button>
                  </span>
                {%- endfor -%}
              </div>
            {%- endif -%}

            {%- comment -%} Discount input {%- endcomment -%}
            <form class="pp-cart-drawer__discount" data-pp-discount-form>
              <input
                type="text"
                name="discount"
                class="pp-cart-drawer__discount-input"
                placeholder="Código de descuento"
                autocomplete="off"
                autocapitalize="characters"
              >
              <button type="submit" class="pp-cart-drawer__discount-btn">Aplicar</button>
              <p class="pp-cart-drawer__discount-feedback" data-pp-discount-feedback aria-live="polite"></p>
            </form>

            <div class="pp-cart-drawer__totals">
              <span class="pp-cart-drawer__subtotal-label">{{ 'content.cart_subtotal' | t | upcase }}</span>
              <span class="pp-cart-drawer__subtotal-value">
                <text-component value="{{ cart.total_price | money | strip_html }}" ref="cartTotal">{{ cart.total_price | money }}</text-component>
              </span>
            </div>
            <p class="pp-cart-drawer__shipping-note">{{ 'content.shipping_policy' | t }}</p>
            <a href="{{ routes.checkout_url | default: '/checkout' }}" class="pp-cart-drawer__checkout-btn">
              {{ 'content.checkout' | t | upcase }}
            </a>
          </div>
        {%- endunless -%}
      </cart-items-component>
    </div>
  </dialog>
</cart-drawer-component>

{% stylesheet %}
  /* Cart Drawer — borrows SHAPES and TYPOGRAPHY from pp-search panel
     (rounded corners, Inter font, uppercase labels, pill buttons, subtle dividers)
     but keeps the light background palette of the site. */

  .pp-cart-drawer__dialog {
    position: fixed;
    top: 0;
    right: 0;
    bottom: 0;
    width: min(440px, 95vw);
    height: 100%;
    max-height: 100vh;
    margin: 0 0 0 auto;
    padding: 0;
    border: none;
    background: #ffffff;
    color: #23372c;
    font-family: 'Inter', sans-serif;
    z-index: 1000;
    overflow: hidden;
    border-radius: 20px 0 0 20px;
    box-shadow: -8px 0 32px rgba(35, 55, 44, 0.12);
  }

  .pp-cart-drawer__dialog::backdrop {
    background: rgba(0, 0, 0, 0.4);
  }

  .pp-cart-drawer__dialog[open] {
    display: block;
  }

  .pp-cart-drawer__inner {
    display: flex;
    flex-direction: column;
    height: 100%;
    overflow: hidden;
    padding: 0;
  }

  /* cart-items-component is the real parent of header/content/footer.
     Make it flex column + full height so the internal scroll works
     and the footer (PAGAR button) stays visible. */
  .pp-cart-drawer__cart-items {
    display: flex;
    flex-direction: column;
    height: 100%;
    min-height: 0;
    overflow: hidden;
  }

  /* Header */
  .pp-cart-drawer__header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 18px 24px 12px;
    border-bottom: 1px solid rgba(35, 55, 44, 0.1);
    flex-shrink: 0;
  }

  .pp-cart-drawer__title {
    font-family: 'Inter', sans-serif;
    font-size: 13px;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #23372c;
    margin: 0;
  }

  .pp-cart-drawer__close {
    background: none;
    border: none;
    padding: 4px;
    margin: -4px;
    cursor: pointer;
    color: #23372c;
    opacity: 0.55;
    transition: opacity 0.15s;
  }

  .pp-cart-drawer__close:hover {
    opacity: 1;
  }

  /* Árboles delivery notice */
  .pp-cart-drawer__arbol-notice {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 12px 32px;
    background: #fff3e0;
    color: #8a4a00;
    font-size: 12px;
    line-height: 1.4;
    border-bottom: 1px solid rgba(138, 74, 0, 0.12);
    flex-shrink: 0;
  }

  .pp-cart-drawer__arbol-notice svg {
    flex-shrink: 0;
  }

  @media screen and (max-width: 749px) {
    .pp-cart-drawer__arbol-notice {
      padding-left: 20px;
      padding-right: 20px;
    }
  }

  /* Free shipping bar */
  .pp-cart-drawer__shipping-bar {
    padding: 10px 24px;
    border-bottom: 1px solid rgba(35, 55, 44, 0.08);
    flex-shrink: 0;
  }

  .pp-cart-drawer__shipping-bar .rc-free-shipping-bar {
    padding: 0;
  }

  .pp-cart-drawer__shipping-bar .rc-free-shipping-bar__message {
    text-transform: uppercase;
    font-size: 11px;
    letter-spacing: 0.06em;
    text-align: center;
    margin-bottom: 8px;
    color: #23372c;
  }

  /* Content */
  .pp-cart-drawer__content {
    flex: 1 1 auto;
    min-height: 0;
    overflow-y: auto;
    padding: 14px 24px;
  }

  .pp-cart-drawer__content::-webkit-scrollbar {
    width: 6px;
  }

  .pp-cart-drawer__content::-webkit-scrollbar-thumb {
    background: rgba(35, 55, 44, 0.15);
    border-radius: 3px;
  }

  .pp-cart-drawer__items {
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .pp-cart-drawer__empty {
    text-align: center;
    padding: 48px 16px;
    color: #23372c;
    opacity: 0.7;
    font-size: 14px;
  }

  .pp-cart-drawer__continue-btn {
    display: inline-block;
    margin-top: 20px;
    padding: 12px 28px;
    background: #23372c;
    color: #e4ffd3;
    text-decoration: none;
    font-family: 'Inter', sans-serif;
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    border-radius: 999px;
    transition: opacity 0.15s;
  }

  .pp-cart-drawer__continue-btn:hover {
    opacity: 0.85;
  }

  /* Line item — takes the rounded-corner + typography shapes from pp-search__item */
  .pp-cart-line {
    display: grid;
    grid-template-columns: 76px 1fr;
    gap: 14px;
    padding-bottom: 14px;
    border-bottom: 1px solid rgba(35, 55, 44, 0.08);
  }

  .pp-cart-line:last-child {
    border-bottom: none;
    padding-bottom: 0;
  }

  .pp-cart-line__media {
    display: block;
    aspect-ratio: 1;
    overflow: hidden;
    border-radius: 8px;
    background: rgba(35, 55, 44, 0.04);
  }

  .pp-cart-line__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .pp-cart-line__body {
    display: flex;
    flex-direction: column;
    gap: 6px;
    min-width: 0;
  }

  .pp-cart-line__head {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 8px;
  }

  .pp-cart-line__title {
    font-family: 'Inter', sans-serif;
    font-size: 13px;
    font-weight: 500;
    line-height: 1.35;
    color: #23372c;
    text-decoration: none;
    flex: 1;
    transition: opacity 0.15s;
  }

  .pp-cart-line__title:hover {
    opacity: 0.7;
  }

  .pp-cart-line__remove {
    background: none;
    border: none;
    padding: 4px;
    margin: -4px;
    cursor: pointer;
    color: #23372c;
    opacity: 0.45;
    flex-shrink: 0;
    transition: opacity 0.15s;
  }

  .pp-cart-line__remove:hover {
    opacity: 1;
  }

  .pp-cart-line__variant,
  .pp-cart-line__properties {
    font-family: 'Inter', sans-serif;
    font-size: 11px;
    color: #23372c;
    opacity: 0.55;
    margin: 0;
  }

  .pp-cart-line__properties dt,
  .pp-cart-line__properties dd {
    display: inline;
    margin: 0;
  }

  .pp-cart-line__foot {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 8px;
    margin-top: 4px;
  }

  .pp-cart-line__price {
    font-family: 'Inter', sans-serif;
    font-size: 13px;
    font-weight: 500;
    color: #23372c;
  }

  .pp-cart-line__price--compare {
    color: #23372c;
    opacity: 0.5;
    font-size: 11px;
    margin-left: 6px;
  }

  .pp-cart-line__discounts {
    list-style: none;
    padding: 0;
    margin: 4px 0 0;
    font-size: 10px;
    color: #23372c;
    opacity: 0.7;
  }

  /* Quantity selector — pill shape to match buttons */
  .pp-cart-line .quantity-selector {
    background: transparent;
    border: 1px solid rgba(35, 55, 44, 0.2);
    border-radius: 999px;
    height: 32px;
    width: auto;
    padding: 0 4px;
  }

  .pp-cart-line .quantity-selector button {
    background: transparent;
    color: #23372c;
    border: none;
    width: 28px;
    height: 28px;
    cursor: pointer;
  }

  .pp-cart-line .quantity-selector button:hover {
    opacity: 0.6;
  }

  .pp-cart-line .quantity-selector input {
    background: transparent;
    border: none;
    color: #23372c;
    font-family: 'Inter', sans-serif;
    font-size: 12px;
    text-align: center;
    width: 28px;
    outline: none;
    box-shadow: none;
  }

  .pp-cart-line .quantity-selector input::-webkit-outer-spin-button,
  .pp-cart-line .quantity-selector input::-webkit-inner-spin-button {
    -webkit-appearance: none;
    margin: 0;
  }

  /* Recommendations wrapper (inside drawer) */
  .pp-cart-drawer__reco {
    padding: 10px 24px;
    border-top: 1px solid rgba(35, 55, 44, 0.08);
    flex-shrink: 0;
  }

  /* Cart notes — collapsible via <details> */
  .pp-cart-drawer__notes {
    padding: 6px 24px;
    border-top: 1px solid rgba(35, 55, 44, 0.08);
    flex-shrink: 0;
  }

  .pp-cart-drawer__notes-summary {
    list-style: none;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    cursor: pointer;
    user-select: none;
  }

  .pp-cart-drawer__notes-summary::-webkit-details-marker {
    display: none;
  }

  .pp-cart-drawer__notes-label {
    font-family: 'Inter', sans-serif;
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #23372c;
    opacity: 0.75;
  }

  .pp-cart-drawer__notes-toggle {
    flex-shrink: 0;
    width: 28px;
    height: 28px;
    border-radius: 50%;
    background: #23372c;
    color: #e4ffd3;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    transition: transform 0.2s ease, opacity 0.15s;
  }

  .pp-cart-drawer__notes-summary:hover .pp-cart-drawer__notes-toggle {
    opacity: 0.9;
  }

  .pp-cart-drawer__notes[open] .pp-cart-drawer__notes-toggle {
    transform: rotate(45deg);
  }

  .pp-cart-drawer__notes-input {
    /* Smaller default height — note is a secondary action */
    width: 100%;
    resize: vertical;
    min-height: 40px;
    margin-top: 10px;
    padding: 10px 12px;
    font-family: 'Inter', sans-serif;
    font-size: 13px;
    color: #23372c;
    background: #ffffff;
    border: 1px solid rgba(35, 55, 44, 0.2);
    border-radius: 8px;
    outline: none;
    box-shadow: none;
    transition: border-color 0.15s;
  }

  .pp-cart-drawer__notes-input:focus {
    border-color: #23372c;
  }

  .pp-cart-drawer__notes-input::placeholder {
    color: #23372c;
    opacity: 0.4;
  }

  /* Footer */
  .pp-cart-drawer__footer {
    padding: 14px 24px 20px;
    border-top: 1px solid rgba(35, 55, 44, 0.1);
    background: #ffffff;
    flex-shrink: 0;
  }

  .pp-cart-drawer__totals {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 6px;
    font-family: 'Inter', sans-serif;
    font-size: 13px;
    letter-spacing: 0.04em;
    color: #23372c;
  }

  .pp-cart-drawer__subtotal-label {
    text-transform: uppercase;
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.08em;
    opacity: 0.65;
  }

  .pp-cart-drawer__subtotal-value {
    font-size: 16px;
    font-weight: 500;
  }

  .pp-cart-drawer__shipping-note {
    font-family: 'Inter', sans-serif;
    font-size: 11px;
    color: #23372c;
    opacity: 0.55;
    margin: 0 0 16px;
  }

  .pp-cart-drawer__checkout-btn {
    display: block;
    width: 100%;
    padding: 14px 20px;
    background: #23372c;
    color: #e4ffd3;
    text-align: center;
    text-decoration: none;
    font-family: 'Inter', sans-serif;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    border: none;
    border-radius: 999px;
    cursor: pointer;
    transition: opacity 0.2s ease;
  }

  .pp-cart-drawer__checkout-btn:hover {
    opacity: 0.85;
  }

  /* Discount input */
  .pp-cart-drawer__discount {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin: 0 0 12px;
  }
  .pp-cart-drawer__discount-input {
    flex: 1;
    min-width: 0;
    height: 40px;
    padding: 0 14px;
    border: 1px solid rgba(35, 55, 44, 0.2);
    border-radius: 999px;
    background: #fff;
    font-family: 'Inter', sans-serif;
    font-size: 13px;
    color: #23372c;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    outline: none;
  }
  .pp-cart-drawer__discount-input:focus {
    border-color: #23372c;
  }
  .pp-cart-drawer__discount-btn {
    height: 40px;
    padding: 0 20px;
    background: #23372c;
    color: #e4ffd3;
    border: none;
    border-radius: 999px;
    font-family: 'Inter', sans-serif;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    cursor: pointer;
  }
  .pp-cart-drawer__discount-btn[disabled] { opacity: 0.5; cursor: wait; }
  .pp-cart-drawer__discount-feedback {
    flex-basis: 100%;
    width: 100%;
    margin: 0 2px;
    font-size: 12px;
    color: #23372c;
    min-height: 0;
    opacity: 0;
    transition: opacity 0.2s ease;
  }
  .pp-cart-drawer__discount-feedback.is-visible {
    opacity: 1;
    min-height: 14px;
    margin: 4px 2px 0;
  }
  .pp-cart-drawer__discount-feedback.is-error { color: #c0392b; }
  .pp-cart-drawer__discount-feedback.is-ok { color: #1d7a3c; }

  /* Applied discount pills */
  .pp-cart-drawer__discounts-applied {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin: 0 0 12px;
  }
  .pp-cart-drawer__discount-pill {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 4px 10px;
    background: #e4ffd3;
    color: #23372c;
    border-radius: 999px;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }
  .pp-cart-drawer__discount-pill button {
    background: none;
    border: none;
    color: inherit;
    cursor: pointer;
    font-size: 14px;
    line-height: 1;
    padding: 0 2px;
  }

  @media screen and (max-width: 749px) {
    .pp-cart-drawer__dialog {
      width: 100%;
      border-radius: 0;
    }

    .pp-cart-drawer__header,
    .pp-cart-drawer__shipping-bar,
    .pp-cart-drawer__content,
    .pp-cart-drawer__complementary,
    .pp-cart-drawer__footer {
      padding-left: 20px;
      padding-right: 20px;
    }
  }
{% endstylesheet %}

<script>
(function(){
  if (window.__ppCartDrawerRefreshInit) return;
  window.__ppCartDrawerRefreshInit = true;

  var SECTION_ID = {{ section.id | json }};
  // Schedule-latest pattern: if a refresh is in-flight, remember a pending one
  // and run it immediately after. Prevents "lost refresh" when user clicks rapidly.
  var refreshInFlight = false;
  var refreshPending  = false;
  var pendingOpts     = null;

  function qs(sel, root){ return (root||document).querySelector(sel); }

  function getDrawer(){ return document.querySelector('cart-drawer-component'); }
  function getDialog(){
    var d = getDrawer();
    return d ? d.querySelector('dialog') : null;
  }

  function openDialog(){
    var dialog = getDialog();
    if (!dialog) return;
    if (dialog.open) return;
    try { dialog.showModal(); }
    catch(e){
      var drawer = getDrawer();
      if (drawer && typeof drawer.showDialog === 'function') drawer.showDialog();
      else if (drawer && typeof drawer.open === 'function') drawer.open();
    }
  }

  function doRefresh(options){
    options = options || {};
    var shouldOpen = options.open === true;
    return fetch(window.location.pathname + '?sections=' + SECTION_ID + '&_t=' + Date.now(), {
      headers: { 'Accept': 'application/json', 'Cache-Control': 'no-cache' },
      credentials: 'same-origin',
      cache: 'no-store'
    })
    .then(function(res){ return res.ok ? res.json() : null; })
    .then(function(json){
      if (!json) return;
      var html = json[SECTION_ID];
      if (!html) return;
      var tmp = document.createElement('div');
      tmp.innerHTML = html;
      var newInner = qs('[data-hydration-key="pp-cart-drawer-inner"]', tmp);
      var oldInner = qs('[data-hydration-key="pp-cart-drawer-inner"]');
      if (newInner && oldInner) {
        oldInner.innerHTML = newInner.innerHTML;
        Array.prototype.slice.call(newInner.attributes).forEach(function(attr){
          if (attr.name.indexOf('data-') === 0) oldInner.setAttribute(attr.name, attr.value);
        });
      }
      var newBadges = tmp.querySelectorAll('.pp-header__cart-count, [data-cart-count]');
      var oldBadges = document.querySelectorAll('.pp-header__cart-count, [data-cart-count]');
      if (newBadges.length && oldBadges.length) {
        oldBadges.forEach(function(el, i){
          if (newBadges[i]) el.textContent = newBadges[i].textContent;
        });
      }
      if (shouldOpen) openDialog();
    })
    .catch(function(){ /* noop */ });
  }

  window.ppRefreshCartDrawer = function(options){
    options = options || {};
    // If one is already in-flight, mark that we want another right after it.
    // Merge "open" preference: if any caller wanted open, honour it.
    if (refreshInFlight) {
      refreshPending = true;
      pendingOpts = {
        open: (pendingOpts && pendingOpts.open) || options.open === true,
      };
      return Promise.resolve();
    }
    refreshInFlight = true;
    return doRefresh(options).finally(function(){
      refreshInFlight = false;
      if (refreshPending) {
        refreshPending = false;
        var nextOpts = pendingOpts || {};
        pendingOpts = null;
        // Kick off the queued refresh; recursion will continue until quiescent.
        window.ppRefreshCartDrawer(nextOpts);
      }
    });
  };

  // Intercept line-item remove clicks — refresh drawer without closing dialog
  document.addEventListener('click', function(e){
    var btn = e.target.closest('.pp-cart-line__remove');
    if (!btn) return;
    e.preventDefault();
    e.stopPropagation();
    var row = btn.closest('.pp-cart-line');
    var key = row ? row.getAttribute('data-key') : null;
    if (!key) return;
    btn.setAttribute('disabled', 'true');
    fetch('/cart/change.js', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
      credentials: 'same-origin',
      body: JSON.stringify({ id: key, quantity: 0 })
    })
    .then(function(){ return window.ppRefreshCartDrawer({ open: true }); })
    .catch(function(){ btn.removeAttribute('disabled'); });
  }, true);

  // Close drawer on backdrop click (click outside the dialog content)
  document.addEventListener('click', function(e){
    var dialog = getDialog();
    if (!dialog || !dialog.open) return;
    // Native <dialog> backdrop click: target IS the dialog element, not its children
    if (e.target === dialog) {
      dialog.close();
      var drawer = getDrawer();
      if (drawer && typeof drawer.close === 'function') drawer.close();
    }
  });

  // Discount form submit — applies code via Shopify /discount/CODE (sets session cookie)
  // Then refreshes cart to reflect discount + triggers Planet Upsell by dispatching cart:update.
  document.addEventListener('submit', function(e){
    var form = e.target.closest('[data-pp-discount-form]');
    if (!form) return;
    e.preventDefault();
    var input = form.querySelector('input[name="discount"]');
    var btn = form.querySelector('.pp-cart-drawer__discount-btn');
    var feedback = form.querySelector('[data-pp-discount-feedback]');
    var code = (input && input.value || '').trim().toUpperCase();
    if (!code) return;
    if (btn) btn.setAttribute('disabled','true');
    function setFeedback(msg, kind){
      if (!feedback) return;
      feedback.textContent = msg;
      feedback.className = 'pp-cart-drawer__discount-feedback is-visible' + (kind ? ' ' + kind : '');
      if (feedback._t) clearTimeout(feedback._t);
      feedback._t = setTimeout(function(){ feedback.className = 'pp-cart-drawer__discount-feedback'; feedback.textContent = ''; }, 10000);
    }
    setFeedback('Aplicando...', '');

    // Step 1: set discount cookie via /discount/CODE. Follow redirect to get cart state.
    fetch('/discount/' + encodeURIComponent(code), { credentials:'same-origin', redirect:'follow' })
      .then(function(){
        // Step 2: fetch cart.js — if discount was invalid the discount_code won't stick
        return fetch('/cart.js', { credentials:'same-origin', cache:'no-store' }).then(r=>r.json());
      })
      .then(function(cart){
        var applied = (cart && ((cart.cart_level_discount_applications || []).length > 0
                      || (cart.discount_codes || []).some(function(c){ return (c.code||'').toUpperCase() === code && c.applicable; })));
        if (!applied) {
          setFeedback('Código no válido o no aplicable', 'is-error');
          if (btn) btn.removeAttribute('disabled');
          return;
        }
        setFeedback('Aplicado ✓', 'is-ok');
        if (input) input.value = '';
        // Step 3: dispatch cart:update so Planet Upsell app evaluates discount rules and injects gifts
        document.dispatchEvent(new CustomEvent('cart:update', { detail: { source: 'pp-discount', cart: cart } }));
        document.dispatchEvent(new CustomEvent('discount:applied', { detail: { code: code, cart: cart } }));
        // Give Planet ~800ms to inject gift, then refresh drawer to show new line
        setTimeout(function(){
          window.ppRefreshCartDrawer({ open: true });
          if (btn) btn.removeAttribute('disabled');
        }, 900);
      })
      .catch(function(){
        setFeedback('Error al aplicar el código', 'is-error');
        if (btn) btn.removeAttribute('disabled');
      });
  });

  // Remove applied discount
  document.addEventListener('click', function(e){
    var btn = e.target.closest('[data-pp-remove-discount]');
    if (!btn) return;
    e.preventDefault();
    // Clear by visiting /discount/ with empty — Shopify uses /discount/clear? actually there's
    // no official clear endpoint; setting discount to "" via update doesn't work either.
    // Workaround: POST /cart/update.js with discount field null — not supported. Instead reload
    // via /discount/___ (unknown code) which replaces current. Simplest: redirect to checkout_url/reset.
    // Use fetch('/cart/clear.js') NOT acceptable (removes items). So we send /checkout?discount= with no redirect:
    fetch('/discount/', { credentials:'same-origin' }).finally(function(){
      window.ppRefreshCartDrawer({ open: true });
    });
  });

  // Re-open dialog if still logically "open" after native morph (safety net)
  document.addEventListener('cart:update', function(){
    // Small delay so native morph settles first
    setTimeout(function(){
      // Only refresh-and-open if the drawer was meant to be open.
      var dialog = getDialog();
      if (!dialog) return;
      // If header badge says 0 and drawer empty state already rendered, still fine
      // We just ensure the drawer keeps showing, not that it auto-closes.
      if (dialog.open) {
        // Content may have morphed; refresh inner to guarantee consistency
        window.ppRefreshCartDrawer({ open: true });
      }
    }, 100);
  });
})();
</script>
