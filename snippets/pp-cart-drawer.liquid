{%- comment -%}
  RC Cart Drawer - GNG-style cart drawer
  Features:
  - Free shipping progress bar with animated logo (per-currency threshold)
  - Line items with color swatches and quantity controls
  - Complementary products via Search & Discovery
{%- endcomment -%}

{%- liquid
  # Get currency-specific free shipping threshold
  assign current_currency = cart.currency.iso_code | upcase
  assign free_shipping_threshold = settings.rc_free_shipping_threshold_default | default: 50

  case current_currency
    when 'EUR'
      assign free_shipping_threshold = settings.rc_free_shipping_threshold_eur | default: 50
    when 'USD'
      assign free_shipping_threshold = settings.rc_free_shipping_threshold_usd | default: 50
    when 'GBP'
      assign free_shipping_threshold = settings.rc_free_shipping_threshold_gbp | default: 45
  endcase

  # Convert to cents for comparison with cart.total_price
  assign free_shipping_threshold_cents = free_shipping_threshold | times: 100
-%}

{{ 'pp-cart-drawer.css' | asset_url | stylesheet_tag }}
<script src="{{ 'cart-drawer.js' | asset_url }}" type="module" fetchpriority="low"></script>

<cart-drawer-component
  class="pp-cart-drawer"
  {% if settings.auto_open_cart_drawer %}auto-open{% endif %}
>
  <dialog
    ref="dialog"
    class="pp-cart-drawer__dialog"
    aria-labelledby="pp-cart-drawer-heading"
    scroll-lock
  >
    <div class="pp-cart-drawer__inner">
      {%- comment -%} Header {%- endcomment -%}
      <div class="pp-cart-drawer__header">
        <h2 class="pp-cart-drawer__title" id="pp-cart-drawer-heading">
          {{ 'content.cart_title' | t | upcase }} [{{ cart.item_count }}]
        </h2>
        <button
          ref="closeButton"
          on:click="cart-drawer-component/close"
          class="pp-cart-drawer__close"
          aria-label="{{ 'actions.close_dialog' | t }}"
        >
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
            <path d="M1 1L13 13M1 13L13 1" stroke="currentColor" stroke-width="1"/>
          </svg>
        </button>
      </div>

      {%- comment -%} Free Shipping Bar {%- endcomment -%}
      {%- if settings.rc_free_shipping_bar_enabled -%}
        <div class="pp-cart-drawer__shipping-bar">
          {% render 'rc-free-shipping-bar', threshold: free_shipping_threshold_cents %}
        </div>
      {%- endif -%}

      {%- comment -%} Cart Items {%- endcomment -%}
      <div class="pp-cart-drawer__content">
        <cart-items-component
          class="pp-cart-drawer__items"
          data-section-id="{{ section.id }}"
        >
          {%- if cart.empty? -%}
            <div class="pp-cart-drawer__empty">
              <p>{{ 'content.your_cart_is_empty' | t }}</p>
              <a href="{{ routes.collections_url }}" class="pp-cart-drawer__continue-btn">
                {{ 'actions.continue_shopping' | t | upcase }}
              </a>
            </div>
          {%- else -%}
            {%- for item in cart.items -%}
              {% render 'pp-cart-line-item', item: item %}
            {%- endfor -%}
          {%- endif -%}
        </cart-items-component>
      </div>

      {%- unless cart.empty? -%}
        {%- comment -%} Complementary Products via Search & Discovery {%- endcomment -%}
        {%- if settings.rc_cart_complementary_enabled -%}
          {%- assign complementary_title = settings.rc_cart_complementary_title | default: 'COMPLETE THE LOOK' -%}
          {%- assign complementary_limit = settings.rc_cart_complementary_limit | default: 3 -%}
          {%- assign first_cart_product = cart.items.first.product -%}
          <div
            class="pp-cart-drawer__complementary"
            id="rc-cart-complementary"
            data-product-id="{{ first_cart_product.id }}"
            data-limit="{{ complementary_limit }}"
            data-title="{{ complementary_title }}"
          >
            {%- comment -%} Will be populated via JavaScript using Product Recommendations API {%- endcomment -%}
            <p class="pp-cart-drawer__complementary-title">{{ complementary_title }}</p>
            <div class="pp-cart-drawer__complementary-list" data-complementary-products>
              {%- comment -%} Loading placeholder {%- endcomment -%}
              <div class="pp-cart-drawer__complementary-loading">
                <span class="visually-hidden">{{ 'accessibility.loading_product_recommendations' | t }}</span>
              </div>
            </div>
          </div>

          <script>
            (function() {
              const container = document.getElementById('rc-cart-complementary');
              if (!container) return;

              const productId = container.dataset.productId;
              const limit = parseInt(container.dataset.limit, 10) || 3;
              const title = container.dataset.title;
              const listEl = container.querySelector('[data-complementary-products]');

              if (!productId || !listEl) return;

              // Fetch complementary products from Shopify Product Recommendations API
              const url = `/recommendations/products.json?product_id=${productId}&limit=${limit}&intent=complementary`;

              fetch(url)
                .then(response => response.json())
                .then(data => {
                  if (data.products && data.products.length > 0) {
                    listEl.innerHTML = data.products.map(product => {
                      const variant = product.variants[0];
                      const price = Shopify.formatMoney(variant.price);
                      const comparePrice = variant.compare_at_price ? Shopify.formatMoney(variant.compare_at_price) : null;
                      const imageUrl = product.featured_image ? product.featured_image.replace(/(\.[^.]+)$/, '_200x$1') : '';

                      return `
                        <div class="rc-horizontal-card">
                          <a href="${product.url}" class="rc-horizontal-card__figure">
                            ${imageUrl ? `<img src="${imageUrl}" alt="${product.title}" loading="lazy">` : ''}
                          </a>
                          <div class="rc-horizontal-card__info">
                            <div class="rc-horizontal-card__details">
                              <a href="${product.url}" class="rc-horizontal-card__title">${product.title}</a>
                              <div class="rc-horizontal-card__price">
                                ${comparePrice ? `<span class="rc-horizontal-card__price--sale">${price}</span><span class="rc-horizontal-card__price--compare">${comparePrice}</span>` : `<span>${price}</span>`}
                              </div>
                            </div>
                            ${product.variants.length === 1 && variant.available ?
                              `<form action="/cart/add" method="post" class="rc-horizontal-card__form">
                                <input type="hidden" name="id" value="${variant.id}">
                                <input type="hidden" name="quantity" value="1">
                                <button type="submit" class="rc-horizontal-card__add-btn">{{ 'cart.add_to_cart' | t | default: 'Add' }}</button>
                              </form>` :
                              `<a href="${product.url}" class="rc-horizontal-card__add-btn">{{ 'products.product.choose_options' | t | default: 'View' }}</a>`
                            }
                          </div>
                        </div>
                      `;
                    }).join('');
                  } else {
                    // Hide section if no recommendations
                    container.style.display = 'none';
                  }
                })
                .catch(() => {
                  container.style.display = 'none';
                });
            })();
          </script>
        {%- endif -%}

        {%- comment -%} Footer / Summary {%- endcomment -%}
        <div class="pp-cart-drawer__footer">
          <div class="pp-cart-drawer__totals">
            <span class="pp-cart-drawer__subtotal-label">{{ 'content.cart_subtotal' | t | upcase }}</span>
            <span class="pp-cart-drawer__subtotal-value">{{ cart.total_price | money }}</span>
          </div>
          <p class="pp-cart-drawer__shipping-note">{{ 'content.shipping_policy' | t }}</p>
          <a href="{{ routes.checkout_url }}" class="pp-cart-drawer__checkout-btn">
            {{ 'content.checkout' | t | upcase }}
          </a>
        </div>
      {%- endunless -%}
    </div>
  </dialog>
</cart-drawer-component>

{% stylesheet %}
  /* Cart Drawer — borrows SHAPES and TYPOGRAPHY from pp-search panel
     (rounded corners, Inter font, uppercase labels, pill buttons, subtle dividers)
     but keeps the light background palette of the site. */

  .pp-cart-drawer__dialog {
    position: fixed;
    top: 0;
    right: 0;
    bottom: 0;
    width: min(440px, 95vw);
    height: 100%;
    max-height: 100vh;
    margin: 0 0 0 auto;
    padding: 0;
    border: none;
    background: #ffffff;
    color: #23372c;
    font-family: 'Inter', sans-serif;
    z-index: 1000;
    overflow: hidden;
    border-radius: 20px 0 0 20px;
    box-shadow: -8px 0 32px rgba(35, 55, 44, 0.12);
  }

  .pp-cart-drawer__dialog::backdrop {
    background: rgba(0, 0, 0, 0.4);
  }

  .pp-cart-drawer__dialog[open] {
    display: block;
  }

  .pp-cart-drawer__inner {
    display: flex;
    flex-direction: column;
    height: 100%;
    overflow: hidden;
    padding: 0;
  }

  /* Header */
  .pp-cart-drawer__header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 24px 32px 16px;
    border-bottom: 1px solid rgba(35, 55, 44, 0.1);
    flex-shrink: 0;
  }

  .pp-cart-drawer__title {
    font-family: 'Inter', sans-serif;
    font-size: 13px;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #23372c;
    margin: 0;
  }

  .pp-cart-drawer__close {
    background: none;
    border: none;
    padding: 4px;
    margin: -4px;
    cursor: pointer;
    color: #23372c;
    opacity: 0.55;
    transition: opacity 0.15s;
  }

  .pp-cart-drawer__close:hover {
    opacity: 1;
  }

  /* Free shipping bar */
  .pp-cart-drawer__shipping-bar {
    padding: 16px 32px;
    border-bottom: 1px solid rgba(35, 55, 44, 0.08);
    flex-shrink: 0;
  }

  .pp-cart-drawer__shipping-bar .rc-free-shipping-bar {
    padding: 0;
  }

  .pp-cart-drawer__shipping-bar .rc-free-shipping-bar__message {
    text-transform: uppercase;
    font-size: 11px;
    letter-spacing: 0.06em;
    text-align: center;
    margin-bottom: 8px;
    color: #23372c;
  }

  /* Content */
  .pp-cart-drawer__content {
    flex: 1;
    overflow-y: auto;
    padding: 20px 32px;
  }

  .pp-cart-drawer__content::-webkit-scrollbar {
    width: 6px;
  }

  .pp-cart-drawer__content::-webkit-scrollbar-thumb {
    background: rgba(35, 55, 44, 0.15);
    border-radius: 3px;
  }

  .pp-cart-drawer__items {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .pp-cart-drawer__empty {
    text-align: center;
    padding: 48px 16px;
    color: #23372c;
    opacity: 0.7;
    font-size: 14px;
  }

  .pp-cart-drawer__continue-btn {
    display: inline-block;
    margin-top: 20px;
    padding: 12px 28px;
    background: #23372c;
    color: #e4ffd3;
    text-decoration: none;
    font-family: 'Inter', sans-serif;
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    border-radius: 999px;
    transition: opacity 0.15s;
  }

  .pp-cart-drawer__continue-btn:hover {
    opacity: 0.85;
  }

  /* Line item — takes the rounded-corner + typography shapes from pp-search__item */
  .pp-cart-line {
    display: grid;
    grid-template-columns: 88px 1fr;
    gap: 16px;
    padding-bottom: 20px;
    border-bottom: 1px solid rgba(35, 55, 44, 0.08);
  }

  .pp-cart-line:last-child {
    border-bottom: none;
    padding-bottom: 0;
  }

  .pp-cart-line__media {
    display: block;
    aspect-ratio: 1;
    overflow: hidden;
    border-radius: 8px;
    background: rgba(35, 55, 44, 0.04);
  }

  .pp-cart-line__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .pp-cart-line__body {
    display: flex;
    flex-direction: column;
    gap: 6px;
    min-width: 0;
  }

  .pp-cart-line__head {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 8px;
  }

  .pp-cart-line__title {
    font-family: 'Inter', sans-serif;
    font-size: 13px;
    font-weight: 500;
    line-height: 1.35;
    color: #23372c;
    text-decoration: none;
    flex: 1;
    transition: opacity 0.15s;
  }

  .pp-cart-line__title:hover {
    opacity: 0.7;
  }

  .pp-cart-line__remove {
    background: none;
    border: none;
    padding: 4px;
    margin: -4px;
    cursor: pointer;
    color: #23372c;
    opacity: 0.45;
    flex-shrink: 0;
    transition: opacity 0.15s;
  }

  .pp-cart-line__remove:hover {
    opacity: 1;
  }

  .pp-cart-line__variant,
  .pp-cart-line__properties {
    font-family: 'Inter', sans-serif;
    font-size: 11px;
    color: #23372c;
    opacity: 0.55;
    margin: 0;
  }

  .pp-cart-line__properties dt,
  .pp-cart-line__properties dd {
    display: inline;
    margin: 0;
  }

  .pp-cart-line__foot {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 8px;
    margin-top: 4px;
  }

  .pp-cart-line__price {
    font-family: 'Inter', sans-serif;
    font-size: 13px;
    font-weight: 500;
    color: #23372c;
  }

  .pp-cart-line__price--compare {
    color: #23372c;
    opacity: 0.5;
    font-size: 11px;
    margin-left: 6px;
  }

  .pp-cart-line__discounts {
    list-style: none;
    padding: 0;
    margin: 4px 0 0;
    font-size: 10px;
    color: #23372c;
    opacity: 0.7;
  }

  /* Quantity selector — pill shape to match buttons */
  .pp-cart-line .quantity-selector {
    background: transparent;
    border: 1px solid rgba(35, 55, 44, 0.2);
    border-radius: 999px;
    height: 32px;
    width: auto;
    padding: 0 4px;
  }

  .pp-cart-line .quantity-selector button {
    background: transparent;
    color: #23372c;
    border: none;
    width: 28px;
    height: 28px;
    cursor: pointer;
  }

  .pp-cart-line .quantity-selector button:hover {
    opacity: 0.6;
  }

  .pp-cart-line .quantity-selector input {
    background: transparent;
    border: none;
    color: #23372c;
    font-family: 'Inter', sans-serif;
    font-size: 12px;
    text-align: center;
    width: 28px;
    outline: none;
    box-shadow: none;
  }

  .pp-cart-line .quantity-selector input::-webkit-outer-spin-button,
  .pp-cart-line .quantity-selector input::-webkit-inner-spin-button {
    -webkit-appearance: none;
    margin: 0;
  }

  /* Complementary products */
  .pp-cart-drawer__complementary {
    padding: 20px 32px;
    border-top: 1px solid rgba(35, 55, 44, 0.08);
    flex-shrink: 0;
  }

  .pp-cart-drawer__complementary-title {
    font-family: 'Inter', sans-serif;
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #23372c;
    opacity: 0.65;
    margin: 0 0 12px;
  }

  .pp-cart-drawer__complementary-list {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  /* Footer */
  .pp-cart-drawer__footer {
    padding: 20px 32px 28px;
    border-top: 1px solid rgba(35, 55, 44, 0.1);
    background: #ffffff;
    flex-shrink: 0;
  }

  .pp-cart-drawer__totals {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 6px;
    font-family: 'Inter', sans-serif;
    font-size: 13px;
    letter-spacing: 0.04em;
    color: #23372c;
  }

  .pp-cart-drawer__subtotal-label {
    text-transform: uppercase;
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.08em;
    opacity: 0.65;
  }

  .pp-cart-drawer__subtotal-value {
    font-size: 16px;
    font-weight: 500;
  }

  .pp-cart-drawer__shipping-note {
    font-family: 'Inter', sans-serif;
    font-size: 11px;
    color: #23372c;
    opacity: 0.55;
    margin: 0 0 16px;
  }

  .pp-cart-drawer__checkout-btn {
    display: block;
    width: 100%;
    padding: 14px 20px;
    background: #23372c;
    color: #e4ffd3;
    text-align: center;
    text-decoration: none;
    font-family: 'Inter', sans-serif;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    border: none;
    border-radius: 999px;
    cursor: pointer;
    transition: opacity 0.2s ease;
  }

  .pp-cart-drawer__checkout-btn:hover {
    opacity: 0.85;
  }

  @media screen and (max-width: 749px) {
    .pp-cart-drawer__dialog {
      width: 100%;
      border-radius: 0;
    }

    .pp-cart-drawer__header,
    .pp-cart-drawer__shipping-bar,
    .pp-cart-drawer__content,
    .pp-cart-drawer__complementary,
    .pp-cart-drawer__footer {
      padding-left: 20px;
      padding-right: 20px;
    }
  }
{% endstylesheet %}
