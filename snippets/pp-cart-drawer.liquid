{%- comment -%}
  PP Cart Drawer — Pur Plant cart drawer

  Features:
  - Configurable free shipping progress bar with logo SVG (settings-driven)
  - Line items with remove/quantity controls
  - Shopify-related or collection-based recommendations
  - Cart notes textarea synced to order notes
{%- endcomment -%}

<script src="{{ 'cart-drawer.js' | asset_url }}" type="module" fetchpriority="low"></script>
<script src="{{ 'component-cart-items.js' | asset_url }}" type="module" fetchpriority="low"></script>
<script src="{{ 'component-cart-quantity-selector.js' | asset_url }}" type="module" fetchpriority="low"></script>
<script src="{{ 'component-quantity-selector.js' | asset_url }}" type="module" fetchpriority="low"></script>

<cart-drawer-component
  class="pp-cart-drawer"
  {% if settings.auto_open_cart_drawer %}auto-open{% endif %}
>
  <dialog
    ref="dialog"
    class="pp-cart-drawer__dialog"
    aria-labelledby="pp-cart-drawer-heading"
    scroll-lock
  >
    <div class="pp-cart-drawer__inner" data-hydration-key="pp-cart-drawer-inner">
      <cart-items-component
        class="pp-cart-drawer__cart-items"
        data-drawer
        data-section-id="{{ section.id }}"
      >
        {%- comment -%} Header {%- endcomment -%}
        <div class="pp-cart-drawer__header">
          <h2 class="pp-cart-drawer__title" id="pp-cart-drawer-heading">
            {{ 'content.cart_title' | t | upcase }}
            <span class="pp-cart-drawer__title-count">
              [<span ref="cartItemCount">{{ cart.item_count }}</span>]
            </span>
          </h2>
          <button
            ref="closeButton"
            on:click="cart-drawer-component/close"
            class="pp-cart-drawer__close"
            aria-label="{{ 'actions.close_dialog' | t }}"
          >
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
              <path d="M1 1L13 13M1 13L13 1" stroke="currentColor" stroke-width="1"/>
            </svg>
          </button>
        </div>

        {%- comment -%} Free Shipping Bar {%- endcomment -%}
        {%- if settings.pp_cart_free_ship_enabled and settings.pp_cart_free_ship_threshold > 0 -%}
          <div class="pp-cart-drawer__shipping-bar">
            {% render 'pp-free-shipping-bar' %}
          </div>
        {%- endif -%}

        {%- comment -%} Cart Items {%- endcomment -%}
        <div class="pp-cart-drawer__content">
          {%- if cart.empty? -%}
            <div class="pp-cart-drawer__empty">
              <p>{{ 'content.your_cart_is_empty' | t }}</p>
              <a href="{{ routes.collections_url }}" class="pp-cart-drawer__continue-btn">
                {{ 'actions.continue_shopping' | t | upcase }}
              </a>
            </div>
          {%- else -%}
            <div class="pp-cart-drawer__items">
              {%- for item in cart.items -%}
                {% render 'pp-cart-line-item', item: item %}
              {%- endfor -%}
            </div>
          {%- endif -%}
        </div>

        {%- unless cart.empty? -%}
          {%- comment -%} Recommendations (Shopify related or custom collection) {%- endcomment -%}
          {%- if settings.pp_cart_reco_enabled -%}
            <div class="pp-cart-drawer__reco">
              {% render 'pp-cart-recommendations' %}
            </div>
          {%- endif -%}

          {%- comment -%} Cart notes → pushed to cart.note {%- endcomment -%}
          {%- if settings.pp_cart_notes_enabled -%}
            <details class="pp-cart-drawer__notes"{% if cart.note != blank %} open{% endif %}>
              <summary class="pp-cart-drawer__notes-summary">
                <span class="pp-cart-drawer__notes-label">
                  {{ settings.pp_cart_notes_label | default: 'Añade una nota a tu pedido' }}
                </span>
                <span class="pp-cart-drawer__notes-toggle" aria-hidden="true">
                  <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
                    <path d="M7 1v12M1 7h12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                  </svg>
                </span>
              </summary>
              <textarea
                id="pp-cart-note"
                class="pp-cart-drawer__notes-input"
                name="note"
                rows="2"
                placeholder="{{ settings.pp_cart_notes_placeholder | default: 'Instrucciones de entrega, regalo, etc.' }}"
                data-pp-cart-note
              >{{ cart.note }}</textarea>
            </details>
            <script>
              (function () {
                const ta = document.getElementById('pp-cart-note');
                if (!ta) return;
                let t;
                ta.addEventListener('input', () => {
                  clearTimeout(t);
                  t = setTimeout(() => {
                    fetch('/cart/update.js', {
                      method: 'POST',
                      headers: { 'Content-Type': 'application/json', Accept: 'application/json' },
                      credentials: 'same-origin',
                      body: JSON.stringify({ note: ta.value }),
                    }).catch(() => { /* noop */ });
                  }, 400);
                });
              })();
            </script>
          {%- endif -%}

          {%- comment -%} Footer / Summary {%- endcomment -%}
          <div class="pp-cart-drawer__footer">
            <div class="pp-cart-drawer__totals">
              <span class="pp-cart-drawer__subtotal-label">{{ 'content.cart_subtotal' | t | upcase }}</span>
              <span class="pp-cart-drawer__subtotal-value">
                <text-component value="{{ cart.total_price | money | strip_html }}" ref="cartTotal">{{ cart.total_price | money }}</text-component>
              </span>
            </div>
            <p class="pp-cart-drawer__shipping-note">{{ 'content.shipping_policy' | t }}</p>
            <a href="{{ routes.checkout_url | default: '/checkout' }}" class="pp-cart-drawer__checkout-btn">
              {{ 'content.checkout' | t | upcase }}
            </a>
          </div>
        {%- endunless -%}
      </cart-items-component>
    </div>
  </dialog>
</cart-drawer-component>

{% stylesheet %}
  /* Cart Drawer — borrows SHAPES and TYPOGRAPHY from pp-search panel
     (rounded corners, Inter font, uppercase labels, pill buttons, subtle dividers)
     but keeps the light background palette of the site. */

  .pp-cart-drawer__dialog {
    position: fixed;
    top: 0;
    right: 0;
    bottom: 0;
    width: min(440px, 95vw);
    height: 100%;
    max-height: 100vh;
    margin: 0 0 0 auto;
    padding: 0;
    border: none;
    background: #ffffff;
    color: #23372c;
    font-family: 'Inter', sans-serif;
    z-index: 1000;
    overflow: hidden;
    border-radius: 20px 0 0 20px;
    box-shadow: -8px 0 32px rgba(35, 55, 44, 0.12);
  }

  .pp-cart-drawer__dialog::backdrop {
    background: rgba(0, 0, 0, 0.4);
  }

  .pp-cart-drawer__dialog[open] {
    display: block;
  }

  .pp-cart-drawer__inner {
    display: flex;
    flex-direction: column;
    height: 100%;
    overflow: hidden;
    padding: 0;
  }

  /* Header */
  .pp-cart-drawer__header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 24px 32px 16px;
    border-bottom: 1px solid rgba(35, 55, 44, 0.1);
    flex-shrink: 0;
  }

  .pp-cart-drawer__title {
    font-family: 'Inter', sans-serif;
    font-size: 13px;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #23372c;
    margin: 0;
  }

  .pp-cart-drawer__close {
    background: none;
    border: none;
    padding: 4px;
    margin: -4px;
    cursor: pointer;
    color: #23372c;
    opacity: 0.55;
    transition: opacity 0.15s;
  }

  .pp-cart-drawer__close:hover {
    opacity: 1;
  }

  /* Free shipping bar */
  .pp-cart-drawer__shipping-bar {
    padding: 16px 32px;
    border-bottom: 1px solid rgba(35, 55, 44, 0.08);
    flex-shrink: 0;
  }

  .pp-cart-drawer__shipping-bar .rc-free-shipping-bar {
    padding: 0;
  }

  .pp-cart-drawer__shipping-bar .rc-free-shipping-bar__message {
    text-transform: uppercase;
    font-size: 11px;
    letter-spacing: 0.06em;
    text-align: center;
    margin-bottom: 8px;
    color: #23372c;
  }

  /* Content */
  .pp-cart-drawer__content {
    flex: 1;
    overflow-y: auto;
    padding: 20px 32px;
  }

  .pp-cart-drawer__content::-webkit-scrollbar {
    width: 6px;
  }

  .pp-cart-drawer__content::-webkit-scrollbar-thumb {
    background: rgba(35, 55, 44, 0.15);
    border-radius: 3px;
  }

  .pp-cart-drawer__items {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .pp-cart-drawer__empty {
    text-align: center;
    padding: 48px 16px;
    color: #23372c;
    opacity: 0.7;
    font-size: 14px;
  }

  .pp-cart-drawer__continue-btn {
    display: inline-block;
    margin-top: 20px;
    padding: 12px 28px;
    background: #23372c;
    color: #e4ffd3;
    text-decoration: none;
    font-family: 'Inter', sans-serif;
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    border-radius: 999px;
    transition: opacity 0.15s;
  }

  .pp-cart-drawer__continue-btn:hover {
    opacity: 0.85;
  }

  /* Line item — takes the rounded-corner + typography shapes from pp-search__item */
  .pp-cart-line {
    display: grid;
    grid-template-columns: 88px 1fr;
    gap: 16px;
    padding-bottom: 20px;
    border-bottom: 1px solid rgba(35, 55, 44, 0.08);
  }

  .pp-cart-line:last-child {
    border-bottom: none;
    padding-bottom: 0;
  }

  .pp-cart-line__media {
    display: block;
    aspect-ratio: 1;
    overflow: hidden;
    border-radius: 8px;
    background: rgba(35, 55, 44, 0.04);
  }

  .pp-cart-line__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .pp-cart-line__body {
    display: flex;
    flex-direction: column;
    gap: 6px;
    min-width: 0;
  }

  .pp-cart-line__head {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 8px;
  }

  .pp-cart-line__title {
    font-family: 'Inter', sans-serif;
    font-size: 13px;
    font-weight: 500;
    line-height: 1.35;
    color: #23372c;
    text-decoration: none;
    flex: 1;
    transition: opacity 0.15s;
  }

  .pp-cart-line__title:hover {
    opacity: 0.7;
  }

  .pp-cart-line__remove {
    background: none;
    border: none;
    padding: 4px;
    margin: -4px;
    cursor: pointer;
    color: #23372c;
    opacity: 0.45;
    flex-shrink: 0;
    transition: opacity 0.15s;
  }

  .pp-cart-line__remove:hover {
    opacity: 1;
  }

  .pp-cart-line__variant,
  .pp-cart-line__properties {
    font-family: 'Inter', sans-serif;
    font-size: 11px;
    color: #23372c;
    opacity: 0.55;
    margin: 0;
  }

  .pp-cart-line__properties dt,
  .pp-cart-line__properties dd {
    display: inline;
    margin: 0;
  }

  .pp-cart-line__foot {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 8px;
    margin-top: 4px;
  }

  .pp-cart-line__price {
    font-family: 'Inter', sans-serif;
    font-size: 13px;
    font-weight: 500;
    color: #23372c;
  }

  .pp-cart-line__price--compare {
    color: #23372c;
    opacity: 0.5;
    font-size: 11px;
    margin-left: 6px;
  }

  .pp-cart-line__discounts {
    list-style: none;
    padding: 0;
    margin: 4px 0 0;
    font-size: 10px;
    color: #23372c;
    opacity: 0.7;
  }

  /* Quantity selector — pill shape to match buttons */
  .pp-cart-line .quantity-selector {
    background: transparent;
    border: 1px solid rgba(35, 55, 44, 0.2);
    border-radius: 999px;
    height: 32px;
    width: auto;
    padding: 0 4px;
  }

  .pp-cart-line .quantity-selector button {
    background: transparent;
    color: #23372c;
    border: none;
    width: 28px;
    height: 28px;
    cursor: pointer;
  }

  .pp-cart-line .quantity-selector button:hover {
    opacity: 0.6;
  }

  .pp-cart-line .quantity-selector input {
    background: transparent;
    border: none;
    color: #23372c;
    font-family: 'Inter', sans-serif;
    font-size: 12px;
    text-align: center;
    width: 28px;
    outline: none;
    box-shadow: none;
  }

  .pp-cart-line .quantity-selector input::-webkit-outer-spin-button,
  .pp-cart-line .quantity-selector input::-webkit-inner-spin-button {
    -webkit-appearance: none;
    margin: 0;
  }

  /* Recommendations wrapper (inside drawer) */
  .pp-cart-drawer__reco {
    padding: 16px 32px;
    border-top: 1px solid rgba(35, 55, 44, 0.08);
    flex-shrink: 0;
  }

  /* Cart notes — collapsible via <details> */
  .pp-cart-drawer__notes {
    padding: 14px 32px;
    border-top: 1px solid rgba(35, 55, 44, 0.08);
    flex-shrink: 0;
  }

  .pp-cart-drawer__notes-summary {
    list-style: none;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    cursor: pointer;
    user-select: none;
  }

  .pp-cart-drawer__notes-summary::-webkit-details-marker {
    display: none;
  }

  .pp-cart-drawer__notes-label {
    font-family: 'Inter', sans-serif;
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #23372c;
    opacity: 0.75;
  }

  .pp-cart-drawer__notes-toggle {
    flex-shrink: 0;
    width: 28px;
    height: 28px;
    border-radius: 50%;
    background: #23372c;
    color: #e4ffd3;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    transition: transform 0.2s ease, opacity 0.15s;
  }

  .pp-cart-drawer__notes-summary:hover .pp-cart-drawer__notes-toggle {
    opacity: 0.9;
  }

  .pp-cart-drawer__notes[open] .pp-cart-drawer__notes-toggle {
    transform: rotate(45deg);
  }

  .pp-cart-drawer__notes-input {
    width: 100%;
    resize: vertical;
    min-height: 56px;
    margin-top: 10px;
    padding: 10px 12px;
    font-family: 'Inter', sans-serif;
    font-size: 13px;
    color: #23372c;
    background: #ffffff;
    border: 1px solid rgba(35, 55, 44, 0.2);
    border-radius: 8px;
    outline: none;
    box-shadow: none;
    transition: border-color 0.15s;
  }

  .pp-cart-drawer__notes-input:focus {
    border-color: #23372c;
  }

  .pp-cart-drawer__notes-input::placeholder {
    color: #23372c;
    opacity: 0.4;
  }

  /* Footer */
  .pp-cart-drawer__footer {
    padding: 20px 32px 28px;
    border-top: 1px solid rgba(35, 55, 44, 0.1);
    background: #ffffff;
    flex-shrink: 0;
  }

  .pp-cart-drawer__totals {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 6px;
    font-family: 'Inter', sans-serif;
    font-size: 13px;
    letter-spacing: 0.04em;
    color: #23372c;
  }

  .pp-cart-drawer__subtotal-label {
    text-transform: uppercase;
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.08em;
    opacity: 0.65;
  }

  .pp-cart-drawer__subtotal-value {
    font-size: 16px;
    font-weight: 500;
  }

  .pp-cart-drawer__shipping-note {
    font-family: 'Inter', sans-serif;
    font-size: 11px;
    color: #23372c;
    opacity: 0.55;
    margin: 0 0 16px;
  }

  .pp-cart-drawer__checkout-btn {
    display: block;
    width: 100%;
    padding: 14px 20px;
    background: #23372c;
    color: #e4ffd3;
    text-align: center;
    text-decoration: none;
    font-family: 'Inter', sans-serif;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    border: none;
    border-radius: 999px;
    cursor: pointer;
    transition: opacity 0.2s ease;
  }

  .pp-cart-drawer__checkout-btn:hover {
    opacity: 0.85;
  }

  @media screen and (max-width: 749px) {
    .pp-cart-drawer__dialog {
      width: 100%;
      border-radius: 0;
    }

    .pp-cart-drawer__header,
    .pp-cart-drawer__shipping-bar,
    .pp-cart-drawer__content,
    .pp-cart-drawer__complementary,
    .pp-cart-drawer__footer {
      padding-left: 20px;
      padding-right: 20px;
    }
  }
{% endstylesheet %}
