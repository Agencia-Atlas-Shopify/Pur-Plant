{%- comment -%}
  RC Product Card Standalone
  A self-contained product card that doesn't rely on theme blocks
  Used in RC Collection section where theme blocks can't be used

  @param {object} product - The product object
  @param {string} image_ratio - Image aspect ratio: 'adapt', 'portrait', 'portrait-tall', 'square', 'landscape'
{%- endcomment -%}

{%- liquid
  assign variant = product.selected_or_first_available_variant
  assign featured_image = variant.featured_image | default: product.featured_image
  assign second_image = product.images[1]
  assign has_quick_add = false
  if settings.quick_add and product.available
    assign has_quick_add = true
  endif

  # Set aspect ratio based on parameter
  assign ratio_class = 'pp-card__media--portrait'
  case image_ratio
    when 'adapt'
      assign ratio_class = 'pp-card__media--adapt'
    when 'portrait'
      assign ratio_class = 'pp-card__media--portrait'
    when 'portrait-tall'
      assign ratio_class = 'pp-card__media--portrait-tall'
    when 'square'
      assign ratio_class = 'pp-card__media--square'
    when 'landscape'
      assign ratio_class = 'pp-card__media--landscape'
  endcase
-%}

<product-card
  class="product-card pp-product-card-standalone"
  data-product-id="{{ product.id }}"
>
  <a
    href="{{ product.url }}"
    class="product-card__link pp-card__link"
    ref="productCardLink"
  >
    <span class="visually-hidden">{{ product.title }}</span>
  </a>

  <div class="pp-card__content">
    {%- comment -%} Image Slider {%- endcomment -%}
    <div class="pp-card__media {{ ratio_class }}" data-pp-card-slider>
      {%- if featured_image != blank -%}
        <div class="pp-card__slider-track" data-pp-slider-track>
          {%- for image in product.images limit: 6 -%}
            <div class="pp-card__slide{% if forloop.first %} is-active{% endif %}" data-slide-index="{{ forloop.index0 }}">
              <img
                src="{{ image | image_url: width: 500 }}"
                srcset="{{ image | image_url: width: 250 }} 250w, {{ image | image_url: width: 375 }} 375w, {{ image | image_url: width: 500 }} 500w, {{ image | image_url: width: 700 }} 700w"
                sizes="(min-width: 1200px) 23vw, (min-width: 750px) 32vw, 50vw"
                alt="{{ image.alt | default: product.title | escape }}"
                class="pp-card__image"
                loading="lazy"
                width="{{ image.width }}"
                height="{{ image.height }}"
              >
            </div>
          {%- endfor -%}
        </div>

        {%- if product.images.size > 1 -%}
          {%- comment -%} Navigation Arrows {%- endcomment -%}
          <button type="button" class="pp-card__slider-nav pp-card__slider-nav--prev" data-pp-slider-prev aria-label="{{ 'general.previous' | t | default: 'Previous' }}">
            <svg viewBox="0 0 20 35" fill="currentColor" width="10" height="16">
              <path d="M0.748048 17.3633L19.1328 -6.01032e-08L19.8203 0.726562L2.20508 17.3633L19.8203 34L19.1328 34.7266L0.748048 17.3633Z"/>
            </svg>
          </button>
          <button type="button" class="pp-card__slider-nav pp-card__slider-nav--next" data-pp-slider-next aria-label="{{ 'general.next' | t | default: 'Next' }}">
            <svg viewBox="0 0 20 35" fill="currentColor" width="10" height="16">
              <path d="M19.8203 17.3633L1.43555 34.7266L0.748047 34L18.3633 17.3633L0.748047 0.726562L1.43555 0L19.8203 17.3633Z"/>
            </svg>
          </button>
        {%- endif -%}
      {%- else -%}
        <div class="pp-card__placeholder">
          {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
        </div>
      {%- endif -%}

      {%- comment -%}
        Badge — single label, priority order:
          Pet Friendly > Novedad > Fácil Cuidado > Purificadora > Oferta > Últimas Unidades > Vuelve Pronto
      {%- endcomment -%}
      {%- liquid
        assign type_needle = '|' | append: product.type | append: '|'
        assign plantas_types = '|Plantas|Plantas Interior|Plantas Exterior|Plantas Minis|Plantas Hidropónicas|Cactus|Alocasias|Calatheas|Begonias|Anthurium|Ficus|Hoya|Peperomias|Helecho|Monstera|Philodendron|Palmera|Adansonii|Croton|Marantas|Deliciosa|Fittonia|Caladium|Dracaena|Kalanchoe|Euphorbia|Cyclamen|Hypoestes|Ceropegia|Espatifilo|Areca|Dieffenbachia|Adenium|Cóleo|Aglaonema|Orquídeas|Chamaedorea|Bromelia|Crassula Ovata|Suculentas y Crasas|Bambú|Leuconeura|carnosa|Aloe Vera|Oxalis|Hoya Kerrii Variegada|Carnívora|Pet Friendly|Árboles|Árboles Frutales|Arce Japonés|Bonsái|Acebo|Jazmin|Hibiscus|Calluna|Crisantemo|Hortensia|Euonymus|Kokedamas|Kits Kokedamas|Lavanda|Guindilla|Aromáticas|Coníferas|'
        assign is_planta = false
        if plantas_types contains type_needle
          assign is_planta = true
        endif

        assign badge = ''

        if is_planta and product.metafields.custom.pet_friendly == true
          assign badge = 'pet'
        endif

        if badge == ''
          if product.tags contains 'New In' or product.tags contains 'new in' or product.tags contains 'Novedades' or product.tags contains 'Novedad'
            assign badge = 'nuevo'
          endif
        endif

        if badge == '' and is_planta
          assign dif = product.metafields.custom.dificultad | downcase
          if dif contains 'fácil' or dif contains 'facil'
            assign badge = 'facil'
          endif
        endif

        if badge == '' and is_planta and product.metafields.custom.purificadora == true
          assign badge = 'pur'
        endif

        if badge == '' and product.compare_at_price > product.price
          assign badge = 'oferta'
        endif

        if badge == '' and product.available and product.variants.first.inventory_quantity <= 5 and product.variants.first.inventory_quantity > 0
          assign badge = 'last'
        endif

        if badge == '' and product.available == false
          assign badge = 'pronto'
        endif
      -%}

      {%- if badge != '' -%}
        <div class="pp-badge-list">
          {%- case badge -%}
            {%- when 'pet' -%}<span class="pp-badge pp-badge--pet">PET FRIENDLY</span>
            {%- when 'nuevo' -%}<span class="pp-badge pp-badge--new">NOVEDAD</span>
            {%- when 'facil' -%}<span class="pp-badge pp-badge--facil">FÁCIL CUIDADO</span>
            {%- when 'pur' -%}<span class="pp-badge pp-badge--pur">PURIFICADORA</span>
            {%- when 'oferta' -%}<span class="pp-badge pp-badge--sale">OFERTA</span>
            {%- when 'last' -%}<span class="pp-badge pp-badge--last-units">ÚLTIMAS UNIDADES</span>
            {%- when 'pronto' -%}<span class="pp-badge pp-badge--sold-out">VUELVE PRONTO</span>
          {%- endcase -%}
        </div>
      {%- endif -%}

      {%- comment -%} Quick Add - Inline variant buttons {%- endcomment -%}
      {%- if product.available -%}
        {%- comment -%} Mobile-only "+" floating button on image {%- endcomment -%}
        {%- if product.has_only_default_variant -%}
          <button
            type="button"
            class="pp-card__mobile-add"
            data-variant-id="{{ product.first_available_variant.id }}"
            data-pp-add-to-cart
            aria-label="Añadir"
          >+</button>
        {%- endif -%}

        <div class="pp-card__quick-add" data-pp-quick-add>
          {%- if product.has_only_default_variant -%}
            {%- comment -%} Single variant - direct add to cart (desktop) {%- endcomment -%}
            <button
              type="button"
              class="pp-card__quick-add-single"
              data-variant-id="{{ product.first_available_variant.id }}"
              data-pp-add-to-cart
            >
              Añadir
            </button>
          {%- else -%}
            {%- comment -%} Multiple variants - show size/option buttons {%- endcomment -%}
            {%- assign size_option = nil -%}
            {%- for option in product.options_with_values -%}
              {%- assign option_name_downcase = option.name | downcase -%}
              {%- if option_name_downcase == 'size' or option_name_downcase == 'talla' or option_name_downcase == 'taille' -%}
                {%- assign size_option = option -%}
                {%- break -%}
              {%- endif -%}
            {%- endfor -%}

            {%- if size_option -%}
              <div class="pp-card__quick-add-variants">
                {%- for value in size_option.values -%}
                  {%- assign variant_for_size = nil -%}
                  {%- assign variant_available = false -%}
                  {%- for variant in product.variants -%}
                    {%- if variant.options contains value -%}
                      {%- assign variant_for_size = variant -%}
                      {%- if variant.available -%}
                        {%- assign variant_available = true -%}
                        {%- break -%}
                      {%- endif -%}
                    {%- endif -%}
                  {%- endfor -%}

                  <button
                    type="button"
                    class="pp-card__variant-btn{% unless variant_available %} pp-card__variant-btn--unavailable{% endunless %}"
                    data-variant-id="{{ variant_for_size.id }}"
                    data-pp-add-to-cart
                    {% unless variant_available %}disabled{% endunless %}
                    title="{{ value }}{% unless variant_available %} - {{ 'products.product.sold_out' | t | default: 'Sold out' }}{% endunless %}"
                  >
                    {{ value }}
                  </button>
                {%- endfor -%}
              </div>
            {%- else -%}
              {%- comment -%} No size option found, show first option {%- endcomment -%}
              {%- assign first_option = product.options_with_values | first -%}
              <div class="pp-card__quick-add-variants">
                {%- for value in first_option.values -%}
                  {%- assign variant_for_option = nil -%}
                  {%- assign variant_available = false -%}
                  {%- for variant in product.variants -%}
                    {%- if variant.options contains value -%}
                      {%- assign variant_for_option = variant -%}
                      {%- if variant.available -%}
                        {%- assign variant_available = true -%}
                        {%- break -%}
                      {%- endif -%}
                    {%- endif -%}
                  {%- endfor -%}

                  <button
                    type="button"
                    class="pp-card__variant-btn{% unless variant_available %} pp-card__variant-btn--unavailable{% endunless %}"
                    data-variant-id="{{ variant_for_option.id }}"
                    data-pp-add-to-cart
                    {% unless variant_available %}disabled{% endunless %}
                  >
                    {{ value }}
                  </button>
                {%- endfor -%}
              </div>
            {%- endif -%}
          {%- endif -%}
        </div>
      {%- endif -%}
    </div>

    {%- comment -%} Info {%- endcomment -%}
    <div class="pp-card__info">
      <div class="pp-card__title-row">
        <h3 class="pp-card__title">
          <a href="{{ product.url }}">{{ product.title }}</a>
        </h3>
        {%- comment -%} Swym wishlist button is injected here automatically {%- endcomment -%}
      </div>

      {%- liquid
        assign rating_mf = product.metafields.reviews.rating
        assign rating_count_mf = product.metafields.reviews.rating_count
      -%}
      {%- if rating_mf != blank and rating_count_mf != blank and rating_count_mf.value != 0 -%}
        {%- assign rating_val = rating_mf.value.rating | round: 1 -%}
        <div class="pp-card__stars" aria-label="{{ rating_val }} de 5 estrellas">
          {%- for i in (1..5) -%}
            {%- if i <= rating_val -%}
              <svg class="pp-card__star pp-card__star--full" width="11" height="11" viewBox="0 0 24 24" fill="#23372c" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
            {%- else -%}
              <svg class="pp-card__star" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="#23372c" stroke-width="1.5" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
            {%- endif -%}
          {%- endfor -%}
          <span class="pp-card__stars-count">({{ rating_count_mf }})</span>
        </div>
      {%- endif -%}

      <div class="pp-card__price">
        {%- if variant.compare_at_price > variant.price -%}
          <span class="pp-card__price-sale">{{ variant.price | money }}</span>
          <s class="pp-card__price-compare">{{ variant.compare_at_price | money }}</s>
        {%- else -%}
          <span class="pp-card__price-regular">{{ variant.price | money }}</span>
        {%- endif -%}
      </div>

      {%- comment -%} Color Swatches - RC Product Card Style {%- endcomment -%}
      {%- assign swatch_option = 'Color' -%}
      {%- assign color_option = product.options_by_name[swatch_option] -%}
      {%- if color_option == blank -%}
        {%- assign swatch_option = 'Colour' -%}
        {%- assign color_option = product.options_by_name[swatch_option] -%}
      {%- endif -%}
      {%- if color_option -%}
        <fieldset class="pp-product-card__swatches">
          <legend class="sr-only">{{ color_option.name }}</legend>
          {%- for value in color_option.values -%}
            {%- assign color_value = value | downcase | replace: ' ', '' -%}
            {%- assign is_selected = false -%}
            {%- if product.selected_or_first_available_variant.options contains value -%}
              {%- assign is_selected = true -%}
            {%- endif -%}
            {%- assign is_white = false -%}
            {%- if color_value == 'white' or color_value == 'blanco' or color_value == '#ffffff' or color_value == '#fff' -%}
              {%- assign is_white = true -%}
            {%- endif -%}

            <a
              href="{{ product.url }}?variant={{ product.variants[forloop.index0].id }}"
              class="pp-color-swatch{% if is_selected %} is-selected{% endif %}{% if is_white %} is-white{% endif %}"
              style="--swatch-background: linear-gradient(to right, {{ value }}, {{ value }})"
              draggable="false"
            >
              <span class="sr-only">{{ value }}</span>
            </a>
          {%- endfor -%}
        </fieldset>
      {%- endif -%}
    </div>
  </div>
</product-card>

<style>
  .pp-product-card-standalone {
    position: relative;
    display: block;
    width: 100%;
  }

  .pp-card__link {
    position: absolute;
    inset: 0;
    z-index: 1;
  }

  .pp-card__content {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .pp-card__media {
    position: relative;
    overflow: hidden;
    background: rgb(245 245 245);
  }

  /* Aspect ratio variants */
  .pp-card__media--adapt {
    border-radius: 8px;
    aspect-ratio: 3 / 4;
  }

  .pp-card__media--portrait {
    aspect-ratio: 3 / 4;
  }

  .pp-card__media--portrait-tall {
    aspect-ratio: 4 / 5;
  }

  .pp-card__media--square {
    aspect-ratio: 1 / 1;
  }

  .pp-card__media--landscape {
    aspect-ratio: 4 / 3;
  }

  .pp-card__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* Image Slider - Horizontal scroll */
  .pp-card__slider-track {
    display: flex;
    width: 100%;
    height: 100%;
    overflow-x: auto;
    overflow-y: hidden;
    scroll-snap-type: x mandatory;
    scrollbar-width: none;
    -ms-overflow-style: none;
    cursor: grab;
  }

  .pp-card__slider-track::-webkit-scrollbar {
    display: none;
  }

  .pp-card__slider-track.is-dragging {
    cursor: grabbing;
    scroll-snap-type: none;
    user-select: none;
  }

  .pp-card__slider-track img {
    pointer-events: none;
    user-select: none;
    -webkit-user-drag: none;
  }

  .pp-card__slide {
    flex: 0 0 100%;
    width: 100%;
    height: 100%;
    scroll-snap-align: start;
  }

  /* Slider Navigation Arrows - No background */
  .pp-card__slider-nav {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 3;
    width: 32px;
    height: 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #ffffff00;
    border: none;
    padding: 0;
    cursor: pointer;
    opacity: 0;
    color: rgb(var(--pp-product-text, 0 0 0));
    transition: opacity 0.2s ease, transform 0.2s ease;
  }

  .pp-card__slider-nav svg {
    width: 10px;
    height: auto;
  }

  .pp-card__slider-nav--prev {
    left: 6px;
  }

  .pp-card__slider-nav--next {
    right: 6px;
  }

  .pp-card__slider-nav:hover {
    transform: translateY(-50%) scale(1.1);
  }

  .pp-product-card-standalone:hover .pp-card__slider-nav {
    opacity: 1;
  }

  /* Hide arrows on touch devices - swipe/drag instead */
  @media screen and (pointer: coarse) {
    .pp-card__slider-nav {
      display: none;
    }
  }

  .pp-card__placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .pp-card__placeholder svg {
    width: 50%;
    height: auto;
    opacity: 0.3;
  }

  /* Badges — Pur Plant style */
  .pp-badge-list {
    position: absolute;
    z-index: 2;
    inset-block-start: 8px;
    inset-inline-start: 8px;
    inset-inline-end: 8px;
    display: flex;
    flex-direction: row;
    flex-wrap: wrap;
    gap: 4px;
  }

  .pp-badge {
    display: inline-flex;
    align-items: center;
    width: max-content;
    padding: 3px 8px;
    font-family: 'Inter', sans-serif;
    font-weight: 500;
    font-size: 12px;
    letter-spacing: 0.02em;
    text-transform: uppercase;
    background: #DAFFD3;
    border: 1px solid #37433F;
    border-radius: 20px;
    color: #37433F;
  }

  .pp-badge--custom,
  .pp-badge--last-units,
  .pp-badge--sale,
  .pp-badge--sold-out {
    background: #DAFFD3;
    border-color: #37433F;
    color: #37433F;
  }

  .pp-card__quick-add {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 2;
    opacity: 0;
    transform: translateY(100%);
    transition: opacity 0.3s ease, transform 0.3s ease;
    /* Apple Glass Effect - More transparent */
    background: rgb(255 255 255 / 0.35);
    backdrop-filter: blur(25px) saturate(200%);
    -webkit-backdrop-filter: blur(25px) saturate(200%);
    padding: 0.75rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
  }

  .pp-product-card-standalone:hover .pp-card__quick-add {
    opacity: 1;
    transform: translateY(0);
  }

  /* Floating "+" on image — MOBILE ONLY */
  .pp-card__mobile-add {
    display: none;
  }

  @media screen and (max-width: 749px) {
    .pp-card__mobile-add {
      display: flex;
      position: absolute;
      bottom: 8px;
      right: 8px;
      z-index: 3;
      width: 34px;
      height: 34px;
      border-radius: 50%;
      background: #23372c;
      color: #e4ffd3;
      border: none;
      font-size: 22px;
      line-height: 1;
      font-weight: 400;
      padding: 0;
      align-items: center;
      justify-content: center;
      cursor: pointer;
      box-shadow: 0 2px 8px rgba(0,0,0,.2);
    }
    .pp-card__mobile-add.is-added { background: #2d7a3d; }
    /* Hide desktop bottom bar on mobile */
    .pp-card__quick-add { display: none; }
  }

  .pp-card__quick-add-single {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    padding: 10px 16px;
    background-color: #e4ffd3;
    color: #23372c;
    border: 1px solid #23372c;
    border-radius: 100px;
    font-family: 'Inter', sans-serif;
    font-size: 13px;
    font-weight: 400;
    letter-spacing: 0;
    text-transform: none;
    line-height: 1;
    cursor: pointer;
    transition: background-color 0.25s ease, color 0.25s ease, border-color 0.25s ease;
  }

  .pp-card__quick-add-single:hover {
    background-color: #23372c;
    color: #e4ffd3;
    border-color: #23372c;
  }

  .pp-card__quick-add-variants {
    display: flex;
    flex-wrap: nowrap;
    justify-content: center;
    gap: 0.25rem;
    width: 100%;
  }

  .pp-card__variant-btn {
    min-width: 0;
    flex: 1 1 0;
    height: 32px;
    padding: 0 0.25rem;
    background: rgb(255 255 255 / 0.5);
    border: 1px solid rgb(255 255 255 / 0.4);
    border-radius: 6px;
    font-size: var(--text-xs, 0.6875rem);
    font-weight: 500;
    text-transform: uppercase;
    cursor: pointer;
    transition: all 0.2s ease;
    box-shadow: 0 2px 8px rgb(0 0 0 / 0.1);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
  }

  .pp-card__variant-btn:hover:not(:disabled) {
    background: rgb(0 0 0);
    color: rgb(255 255 255);
    border-color: rgb(0 0 0);
    transform: scale(1.05);
  }

  .pp-card__variant-btn--unavailable {
    opacity: 0.4;
    cursor: not-allowed;
    text-decoration: line-through;
    background: rgb(200 200 200 / 0.5);
  }

  .pp-card__info {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    padding: 0.25rem 0;
  }

  .pp-card__stars {
    display: inline-flex;
    align-items: center;
    gap: 1px;
    font-family: 'Inter', sans-serif;
    font-size: 11px;
    color: #23372c;
    line-height: 1;
  }

  .pp-card__stars-count {
    margin-left: 4px;
    opacity: 0.7;
  }

  .pp-card__star {
    flex-shrink: 0;
  }

  .pp-product-card-standalone .pp-card__title {
    margin: 0 !important;
    font-family: 'Inter', sans-serif !important;
    font-weight: 400 !important;
    font-size: 13.1px !important;
    line-height: 1.4 !important;
    color: #1a1a1a !important;
  }

  .pp-product-card-standalone .pp-card__title a {
    color: inherit !important;
    text-decoration: none !important;
    font-family: 'Inter', sans-serif !important;
    font-size: 13.1px !important;
    font-weight: 400 !important;
    line-height: 1.4 !important;
  }

  .pp-product-card-standalone .pp-card__price {
    display: flex !important;
    align-items: center !important;
    gap: 0.5rem !important;
  }

  /* Precio normal (sin oferta) */
  .pp-product-card-standalone .pp-card__price-regular {
    font-family: 'Inter', sans-serif !important;
    font-size: 12.8px !important;
    font-weight: 300 !important;
    color: #1a1a1a !important;
  }

  /* Precio con oferta (negro bold) */
  .pp-product-card-standalone .pp-card__price-sale {
    font-family: 'Inter', sans-serif !important;
    font-size: 13.9px !important;
    font-weight: 900 !important;
    color: #000000 !important;
  }

  /* Precio tachado */
  .pp-product-card-standalone .pp-card__price-compare {
    font-family: 'Inter', sans-serif !important;
    font-size: 12.8px !important;
    font-weight: 300 !important;
    color: #999999 !important;
    text-decoration: line-through !important;
  }

  /* Color Swatches - RC Product Card Style */
  .pp-product-card__swatches {
    display: flex;
    flex-wrap: wrap;
    gap: 0.25rem;
    margin: 0;
    padding: 0;
    border: 0;
  }

  .pp-product-card__swatches legend {
    position: absolute;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border-width: 0;
    width: 1px;
    height: 1px;
    margin: -1px;
    padding: 0;
    overflow: hidden;
  }

  .pp-color-swatch {
    width: 12px;
    height: 12px;
    display: grid;
    place-items: center;
    position: relative;
    background: var(--swatch-background) no-repeat center / cover;
    border: 1px solid transparent;
    border-radius: 0;
    padding: 0;
    text-decoration: none;
    z-index: 2;
    transition: border-color 0.2s ease;
  }

  .pp-color-swatch.is-selected {
    border-color: rgb(0 0 0);
  }

  .pp-color-swatch.is-white:not(.is-selected) {
    border-color: rgb(210 210 210);
  }

  .pp-color-swatch .sr-only {
    position: absolute;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border-width: 0;
    width: 1px;
    height: 1px;
    margin: -1px;
    padding: 0;
    overflow: hidden;
  }

  /* Quick add loading state */
  .pp-card__variant-btn.is-loading,
  .pp-card__quick-add-single.is-loading {
    pointer-events: none;
    opacity: 0.6;
  }

  .pp-card__variant-btn.is-added,
  .pp-card__quick-add-single.is-added {
    background: rgb(0 128 0);
    color: rgb(255 255 255);
    border-color: rgb(0 128 0);
  }
</style>

<script>
  (function() {
    if (window.ppQuickAddInitialized) return;
    window.ppQuickAddInitialized = true;

    async function refreshCartDrawer() {
      if (typeof window.ppRefreshCartDrawer === 'function') {
        await window.ppRefreshCartDrawer({ open: true });
      }
    }

    async function addToCart(variantId, button) {
      if (!variantId) return;

      button.classList.add('is-loading');
      const originalText = button.textContent;

      // OPEN DRAWER IMMEDIATELY — don't wait for network. Content fills in as fetches resolve.
      if (typeof window.ppRefreshCartDrawer === 'function') {
        window.ppRefreshCartDrawer({ open: true });
      }

      try {
        const response = await fetch('/cart/add.js', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
          },
          body: JSON.stringify({
            id: variantId,
            quantity: 1
          })
        });

        if (!response.ok) {
          throw new Error('Failed to add to cart');
        }

        const addedItem = await response.json();

        // Success feedback
        button.classList.remove('is-loading');
        button.classList.add('is-added');
        button.textContent = '✓';

        // Fetch updated cart (fire-and-forget badge update)
        fetch('/cart.js').then(r => r.json()).then(cart => {
          document.querySelectorAll('[data-cart-count]').forEach(el => el.textContent = cart.item_count);
          document.dispatchEvent(new CustomEvent('cart:updated', { detail: { cart } }));
          document.dispatchEvent(new CustomEvent('cart:add', { detail: { cart, items: [addedItem] } }));
        }).catch(() => {});

        // Refresh and open cart drawer (ppRefreshCartDrawer handles opening via {open:true})
        // Refresh drawer content (fire-and-forget — drawer was opened earlier)
        if (typeof window.ppRefreshCartDrawer === 'function') {
          window.ppRefreshCartDrawer({ open: true });
        }

        // Reset button after delay
        setTimeout(() => {
          button.classList.remove('is-added');
          button.textContent = originalText;
        }, 1500);

      } catch (error) {
        console.error('Error adding to cart:', error);
        button.classList.remove('is-loading');
        button.textContent = originalText;
      }
    }

    // Event delegation for add to cart buttons
    document.addEventListener('click', (e) => {
      const button = e.target.closest('[data-pp-add-to-cart]');
      if (!button) return;

      e.preventDefault();
      e.stopPropagation();

      const variantId = button.dataset.variantId;
      if (variantId && !button.disabled) {
        addToCart(variantId, button);
      }
    });
  })();

  // Image Slider functionality - Scroll based
  (function() {
    if (window.ppCardSliderInitialized) return;
    window.ppCardSliderInitialized = true;

    function scrollToSlide(track, index, loop) {
      const slides = track.querySelectorAll('.pp-card__slide');
      const totalSlides = slides.length;

      // Loop logic
      if (loop) {
        if (index < 0) index = totalSlides - 1;
        if (index >= totalSlides) index = 0;
      } else {
        if (index < 0) index = 0;
        if (index >= totalSlides) index = totalSlides - 1;
      }

      const slideWidth = track.offsetWidth;
      track.scrollTo({
        left: slideWidth * index,
        behavior: 'smooth'
      });
    }

    function getCurrentSlideIndex(track) {
      const slideWidth = track.offsetWidth;
      return Math.round(track.scrollLeft / slideWidth);
    }

    // Event delegation for slider navigation arrows
    document.addEventListener('click', (e) => {
      // Previous button
      const prevBtn = e.target.closest('[data-pp-slider-prev]');
      if (prevBtn) {
        e.preventDefault();
        e.stopPropagation();
        const slider = prevBtn.closest('[data-pp-card-slider]');
        const track = slider?.querySelector('[data-pp-slider-track]');
        if (track) {
          const current = getCurrentSlideIndex(track);
          scrollToSlide(track, current - 1, true);
        }
        return;
      }

      // Next button
      const nextBtn = e.target.closest('[data-pp-slider-next]');
      if (nextBtn) {
        e.preventDefault();
        e.stopPropagation();
        const slider = nextBtn.closest('[data-pp-card-slider]');
        const track = slider?.querySelector('[data-pp-slider-track]');
        if (track) {
          const current = getCurrentSlideIndex(track);
          scrollToSlide(track, current + 1, true);
        }
        return;
      }
    });

    // Drag to scroll functionality for desktop
    let isDragging = false;
    let startX = 0;
    let scrollLeft = 0;
    let currentTrack = null;
    let hasMoved = false;

    document.addEventListener('mousedown', (e) => {
      const track = e.target.closest('[data-pp-slider-track]');
      if (!track) return;

      // Ignore if clicking on navigation buttons
      if (e.target.closest('[data-pp-slider-prev]') || e.target.closest('[data-pp-slider-next]')) return;

      // Check if there's more than one slide
      if (track.querySelectorAll('.pp-card__slide').length <= 1) return;

      isDragging = true;
      hasMoved = false;
      currentTrack = track;
      startX = e.clientX;
      scrollLeft = track.scrollLeft;
      track.classList.add('is-dragging');
      e.preventDefault();
    });

    document.addEventListener('mousemove', (e) => {
      if (!isDragging || !currentTrack) return;

      e.preventDefault();
      const x = e.clientX;
      const walk = (startX - x) * 1.5;

      if (Math.abs(walk) > 3) {
        hasMoved = true;
      }

      currentTrack.scrollLeft = scrollLeft + walk;
    });

    document.addEventListener('mouseup', (e) => {
      if (!isDragging) return;

      if (currentTrack) {
        currentTrack.classList.remove('is-dragging');

        // Snap to nearest slide
        if (hasMoved) {
          const slideWidth = currentTrack.offsetWidth;
          const targetIndex = Math.round(currentTrack.scrollLeft / slideWidth);
          scrollToSlide(currentTrack, targetIndex, false);
        }
      }
      isDragging = false;
      currentTrack = null;
      hasMoved = false;
    });

    document.addEventListener('mouseleave', (e) => {
      if (!isDragging) return;

      if (currentTrack) {
        currentTrack.classList.remove('is-dragging');
        // Snap to nearest slide on mouse leave too
        if (hasMoved) {
          const slideWidth = currentTrack.offsetWidth;
          const targetIndex = Math.round(currentTrack.scrollLeft / slideWidth);
          scrollToSlide(currentTrack, targetIndex, false);
        }
      }
      isDragging = false;
      currentTrack = null;
      hasMoved = false;
    });
  })();
</script>
