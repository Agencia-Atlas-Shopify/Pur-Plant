{%- comment -%}
  PP Free Shipping Bar — custom element that shows progress toward
  the free shipping threshold. All text, colors and the logo SVG
  are configurable from the theme customiser.

  Usage:
    {% render 'pp-free-shipping-bar' %}
{%- endcomment -%}

{%- liquid
  assign threshold_cents = settings.pp_cart_free_ship_threshold | times: 100
  assign bar_bg = settings.pp_cart_free_ship_bar_bg | default: '#f3f0e6'
  assign bar_fill = settings.pp_cart_free_ship_bar_fill | default: '#23372c'
  assign bar_text = settings.pp_cart_free_ship_bar_text | default: '#23372c'
  assign logo_width = settings.pp_cart_free_ship_logo_width | default: 48
  assign unreached = settings.pp_cart_free_ship_unreached | default: '¡Gasta {{ remaining_amount }} más y consigue envío gratis!'
  assign reached = settings.pp_cart_free_ship_reached | default: 'Tu pedido cumple los requisitos de envío gratuito.'
-%}

<pp-free-shipping-bar
  class="pp-fsbar"
  data-threshold="{{ threshold_cents }}"
  data-total-price="{{ cart.total_price }}"
  data-unreached="{{ unreached | escape }}"
  data-reached="{{ reached | escape }}"
  style="--pp-fsbar-bg: {{ bar_bg }}; --pp-fsbar-fill: {{ bar_fill }}; --pp-fsbar-text: {{ bar_text }}; --pp-fsbar-logo-width: {{ logo_width }}px;"
>
  <span class="pp-fsbar__message" data-fsbar-message></span>
  <div class="pp-fsbar__track">
    <div class="pp-fsbar__fill" data-fsbar-fill></div>
    <div class="pp-fsbar__icon" data-fsbar-icon>
      {%- if settings.pp_cart_free_ship_logo_svg != blank -%}
        {{ settings.pp_cart_free_ship_logo_svg | strip }}
      {%- else -%}
        <svg aria-hidden="true" focusable="false" width="48" viewBox="0 0 846 337" fill="none">
