      {%- endif -%}
    </div>
  </div>
</pp-free-shipping-bar>

<script src="{{ 'pp-free-shipping-bar.js' | asset_url }}" type="module"></script>

{% stylesheet %}
  .pp-fsbar {
    display: block;
    padding: 14px 20px;
    background: var(--pp-fsbar-bg, #f3f0e6);
    color: var(--pp-fsbar-text, #23372c);
    border-radius: 12px;
    font-family: 'Inter', sans-serif;
  }

  .pp-fsbar__message {
    display: block;
    font-size: 10px;
    font-weight: 500;
    text-align: center;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    margin-bottom: 10px;
    color: var(--pp-fsbar-text, #23372c);
  }

  .pp-fsbar__track {
    position: relative;
    height: 4px;
    background: rgba(35, 55, 44, 0.12);
    border-radius: 999px;
    overflow: visible;
  }

  .pp-fsbar__fill {
    position: absolute;
    top: 0;
    left: 0;
    height: 100%;
    width: 0;
    background: var(--pp-fsbar-fill, #23372c);
    border-radius: 999px;
    transition: width 0.4s ease;
  }

  .pp-fsbar__icon {
    position: absolute;
    top: 50%;
    left: 0;
    transform: translate(-50%, -50%);
    color: var(--pp-fsbar-fill, #23372c);
    transition: left 0.4s ease;
    display: flex;
    align-items: center;
    justify-content: center;
    line-height: 0;
    width: var(--pp-fsbar-logo-width, 48px);
    height: var(--pp-fsbar-logo-width, 48px);
  }

  .pp-fsbar__icon svg {
    display: block;
    width: 100% !important;
    height: auto !important;
    max-width: 100%;
    max-height: 100%;
  }

  .pp-fsbar--reached .pp-fsbar__icon {
    transform: translate(-100%, -50%);
  }
{% endstylesheet %}
