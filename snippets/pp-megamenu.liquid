<script>
(function() {
  var mega = document.getElementById('pp-megamenu');
  if (!mega) return;

  var panels = mega.querySelectorAll('[data-mega-panel]');
  var sidebarBtns = mega.querySelectorAll('[data-mega-sub]');
  var subPanels = mega.querySelectorAll('[data-mega-subcontent]');
  var closeTimer = null;

  function positionMega() {
    var header = document.querySelector('.pp-header');
    if (!header) return;
    /* Always anchor to .pp-header__inner bottom so CSS margin-top eats its
       border-radius. The announcement bar (below inner) is covered by the
       megamenu overlay — same behaviour with or without scroll. */
    var inner = header.querySelector('.pp-header__inner') || header;
    var rect = inner.getBoundingClientRect();
    var top = (rect.top >= 0 && rect.bottom > 0 && rect.bottom < 500)
      ? rect.bottom
      : (parseFloat(getComputedStyle(document.documentElement).getPropertyValue('--pp-header-height')) || 80);
    mega.style.setProperty('--pp-mega-top', top + 'px');
  }
  positionMega();
  window.addEventListener('scroll', positionMega);
  window.addEventListener('resize', positionMega);
  window.addEventListener('load', positionMega);
  if (document.fonts && document.fonts.ready) {
    document.fonts.ready.then(positionMega);
  }

  function open(panelId) {
    positionMega();
    requestAnimationFrame(positionMega);
    mega.setAttribute('aria-hidden', 'false');
    document.body.classList.add('pp-mega-open');
    panels.forEach(function(p) {
      p.classList.toggle('is-active', p.getAttribute('data-mega-panel') === panelId);
    });
    /* Activate default sub-image for plantas panel */
    if (panelId === 'plantas') {
      var activeBtn = mega.querySelector('.pp-mega__tab.is-active[data-mega-sub]');
      var defaultSub = activeBtn ? activeBtn.getAttribute('data-mega-sub') : 'interior';
      /* Only activate if no sub is already active */
      var hasActive = mega.querySelector('.pp-mega__image-slot.is-active');
      if (!hasActive) activateSub(defaultSub);
    }
  }

  function close() {
    mega.setAttribute('aria-hidden', 'true');
    document.body.classList.remove('pp-mega-open');
    /* Clear all sub-panel active states */
    sidebarBtns.forEach(function(b) { b.classList.remove('is-active'); });
    subPanels.forEach(function(p) { p.classList.remove('is-active'); });
    /* Clear dynamic image slots */
    mega.querySelectorAll('.pp-mega__image-slot').forEach(function(s) { s.classList.remove('is-active'); });
  }

  function activateSub(subId) {
    sidebarBtns.forEach(function(b) {
      b.classList.toggle('is-active', b.getAttribute('data-mega-sub') === subId);
    });
    subPanels.forEach(function(p) {
      p.classList.toggle('is-active', p.getAttribute('data-mega-subcontent') === subId);
    });
    /* Sync dynamic image */
    mega.querySelectorAll('.pp-mega__image--dynamic .pp-mega__image-slot').forEach(function(slot) {
      slot.classList.toggle('is-active', slot.getAttribute('data-mega-img') === subId);
    });
  }

  sidebarBtns.forEach(function(btn) {
    btn.addEventListener('mouseenter', function() {
      activateSub(btn.getAttribute('data-mega-sub'));
    });
    btn.addEventListener('click', function() {
      activateSub(btn.getAttribute('data-mega-sub'));
    });
  });

  var headerLinks = document.querySelectorAll('.pp-header__desktop-link, .pp-header__nav-link');
  headerLinks.forEach(function(link) {
    link.addEventListener('mouseenter', function() {
      clearTimeout(closeTimer);
      var text = (link.textContent || '').trim().toLowerCase();
      if (text === 'plantas' || text.indexOf('planta') !== -1) {
        open('plantas');
      } else if (text === 'regalos') {
        open('regalos');
      } else if (text.indexOf('sobre') !== -1 || text.indexOf('pur plant') !== -1) {
        open('sobre');
      } else {
        closeTimer = setTimeout(close, 300);
      }
    });
  });

  mega.addEventListener('mouseenter', function() { clearTimeout(closeTimer); });
  mega.addEventListener('mouseleave', function() { closeTimer = setTimeout(close, 200); });

  var header = document.querySelector('.pp-header');
  if (header) {
    header.addEventListener('mouseleave', function(e) {
      var related = e.relatedTarget;
      if (related && (mega.contains(related) || mega === related)) return;
      closeTimer = setTimeout(close, 200);
    });
  }

  document.addEventListener('keydown', function(e) { if (e.key === 'Escape') close(); });

  document.addEventListener('click', function(e) {
    var hamburger = e.target.closest('.pp-header__menu-toggle');
    if (!hamburger) return;
    e.stopPropagation();
    e.preventDefault();
    if (mega.getAttribute('aria-hidden') === 'false') { close(); }
    else { open('plantas'); }
  }, true);

  var mobileMenu = document.querySelector('pp-mobile-menu');
  if (mobileMenu) {
    new MutationObserver(function() {
      if (mobileMenu.hasAttribute('open') && mega.getAttribute('aria-hidden') === 'false') {
        mobileMenu.removeAttribute('open');
        mobileMenu.setAttribute('hidden', '');
      }
    }).observe(mobileMenu, { attributes: true, attributeFilter: ['open'] });
  }

  var mobileCloseBtn = mega.querySelector('[data-mega-close]');
  if (mobileCloseBtn) { mobileCloseBtn.addEventListener('click', close); }

  mega.querySelectorAll('[data-mega-mobile-tab]').forEach(function(tab) {
    tab.addEventListener('click', function() {
      mega.querySelectorAll('[data-mega-mobile-tab]').forEach(function(t) { t.classList.remove('is-active'); });
      tab.classList.add('is-active');
      open(tab.getAttribute('data-mega-mobile-tab'));
    });
  });

  function lockBodyScroll() {
    if (window.innerWidth < 750) {
      document.body.classList.add('pp-mega-scroll-lock');
    }
  }
  function unlockBodyScroll() {
    document.body.classList.remove('pp-mega-scroll-lock');
    document.body.style.overflow = '';
  }

  var origOpen = open;
  open = function(panelId) { origOpen(panelId); lockBodyScroll(); };
  var origClose = close;
  close = function() { origClose(); unlockBodyScroll(); };

  window.addEventListener('resize', function() {
    if (window.innerWidth >= 750) unlockBodyScroll();
  });

  window.addEventListener('pageshow', unlockBodyScroll);

  mega.addEventListener('click', function(e) {
    var a = e.target.closest('a[href]');
    if (a) unlockBodyScroll();
  });

  mega.querySelectorAll('.pp-mega__mobile-item').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var existing = btn.nextElementSibling;
      if (existing && existing.classList.contains('pp-mega__mobile-sub-links')) {
        existing.remove();
        btn.classList.remove('is-expanded');
        var plus = btn.querySelector('.pp-mega__mobile-plus');
        if (plus) plus.textContent = '+';
        return;
      }
      var panel = btn.closest('[data-mega-panel]');
      if (panel) {
        panel.querySelectorAll('.pp-mega__mobile-sub-links').forEach(function(el) { el.remove(); });
        panel.querySelectorAll('.pp-mega__mobile-item.is-expanded').forEach(function(el) {
          el.classList.remove('is-expanded');
          var p = el.querySelector('.pp-mega__mobile-plus');
          if (p) p.textContent = '+';
        });
      }
      var linksDiv = document.createElement('div');
      linksDiv.className = 'pp-mega__mobile-sub-links';
      var subId = btn.getAttribute('data-mega-sub');
      var colIdx = btn.getAttribute('data-mega-col');
      if (subId) {
        var subPanel = mega.querySelector('[data-mega-subcontent="' + subId + '"]');
        if (!subPanel) return;
        var cols = subPanel.querySelectorAll('.pp-mega__col');
        cols.forEach(function(col) {
          col.querySelectorAll('a').forEach(function(a) {
            var link = document.createElement('a');
            link.href = a.href;
            link.className = 'pp-mega__mobile-sub-link';
            link.textContent = a.textContent.trim();
            linksDiv.appendChild(link);
          });
        });
      } else if (colIdx !== null) {
        var content = panel.querySelector('.pp-mega__content, .pp-mega__content--full');
        if (!content) return;
        var cols = content.querySelectorAll('.pp-mega__col');
        var col = cols[parseInt(colIdx)];
        if (!col) return;
        col.querySelectorAll('a').forEach(function(a) {
          var link = document.createElement('a');
          link.href = a.href;
          link.className = 'pp-mega__mobile-sub-link';
          link.textContent = a.textContent.trim();
          linksDiv.appendChild(link);
        });
      }
      if (linksDiv.children.length > 0) {
        btn.after(linksDiv);
        btn.classList.add('is-expanded');
        var plus = btn.querySelector('.pp-mega__mobile-plus');
        if (plus) plus.textContent = '−';
      }
    });
  });

  window.ppMegamenu = { open: open, close: close };
})();
</script>
