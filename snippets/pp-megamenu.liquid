{%- comment -%}
  PP Megamenu - Full-screen overlay navigation
  Triggered by the hamburger button in pp-header.liquid
  Include via: {% render 'pp-megamenu' %}
{%- endcomment -%}

{{ 'pp-megamenu.css' | asset_url | stylesheet_tag }}

<div id="pp-megamenu" class="pp-megamenu" aria-hidden="true" role="dialog" aria-modal="true" aria-label="Menú de navegación">

  {%- comment -%} Top bar with close button {%- endcomment -%}
  <div class="pp-megamenu__topbar">
    <button type="button" class="pp-megamenu__close" data-megamenu-close aria-label="Cerrar menú">
      <svg width="18" height="18" viewBox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <path d="M1 1L13 13M13 1L1 13" stroke="currentColor" stroke-width="1.5"/>
      </svg>
      <span>Cerrar</span>
    </button>
  </div>

  {%- comment -%} Main scrollable body {%- endcomment -%}
  <div class="pp-megamenu__body">

    {%- comment -%} ========== Top-level tabs ========== {%- endcomment -%}
    <ul class="pp-megamenu__toplevel" role="tablist">
      <li><button type="button" class="pp-megamenu__toplevel-btn" role="tab" aria-selected="true" data-mega-toplevel="plantas">Plantas</button></li>
      <li><button type="button" class="pp-megamenu__toplevel-btn" role="tab" aria-selected="false" data-mega-toplevel="regalos">Regalos</button></li>
      <li><button type="button" class="pp-megamenu__toplevel-btn" role="tab" aria-selected="false" data-mega-toplevel="sobre">Sobre Pur Plant</button></li>
    </ul>

    {%- comment -%} =====================================================================
       PANEL: PLANTAS
       ===================================================================== {%- endcomment -%}
    <div class="pp-megamenu__panel" data-mega-panel="plantas" aria-hidden="false">

      {%- comment -%} Sub-tabs {%- endcomment -%}
      <ul class="pp-megamenu__subtabs" role="tablist">
        <li><button type="button" class="pp-megamenu__subtab-btn" role="tab" aria-selected="true" data-mega-subtab="interior">Interior</button></li>
        <li><button type="button" class="pp-megamenu__subtab-btn" role="tab" aria-selected="false" data-mega-subtab="exterior">Exterior</button></li>
        <li><button type="button" class="pp-megamenu__subtab-btn" role="tab" aria-selected="false" data-mega-subtab="macetas">Macetas</button></li>
        <li><button type="button" class="pp-megamenu__subtab-btn" role="tab" aria-selected="false" data-mega-subtab="terrarios">Terrarios</button></li>
        <li><button type="button" class="pp-megamenu__subtab-btn" role="tab" aria-selected="false" data-mega-subtab="cuidados">Cuidados</button></li>
