<script>
(function() {
  var mega = document.getElementById('pp-megamenu');
  if (!mega) return;

  var panels = mega.querySelectorAll('[data-mega-panel]');
  var sidebarBtns = mega.querySelectorAll('[data-mega-sub]');
  var subPanels = mega.querySelectorAll('[data-mega-subcontent]');
  var closeTimer = null;

  /* Position mega below pp-header__inner (above announcement) */
  function positionMega() {
    var inner = document.querySelector('.pp-header__inner');
    if (inner && window.innerWidth >= 750) {
      var rect = inner.getBoundingClientRect();
      mega.style.setProperty('--pp-mega-top', (rect.bottom) + 'px');
    }
  }
  positionMega();
  window.addEventListener('scroll', positionMega);
  window.addEventListener('resize', positionMega);

  function open(panelId) {
    mega.setAttribute('aria-hidden', 'false');
    document.body.classList.add('pp-mega-open');
    panels.forEach(function(p) {
      p.classList.toggle('is-active', p.getAttribute('data-mega-panel') === panelId);
    });
  }

  function close() {
    mega.setAttribute('aria-hidden', 'true');
    document.body.classList.remove('pp-mega-open');
  }

  function activateSub(subId) {
    sidebarBtns.forEach(function(b) {
      b.classList.toggle('is-active', b.getAttribute('data-mega-sub') === subId);
    });
    subPanels.forEach(function(p) {
      p.classList.toggle('is-active', p.getAttribute('data-mega-subcontent') === subId);
    });
  }

  /* Sidebar hover/click */
  sidebarBtns.forEach(function(btn) {
    btn.addEventListener('mouseenter', function() {
      activateSub(btn.getAttribute('data-mega-sub'));
    });
    btn.addEventListener('click', function() {
      activateSub(btn.getAttribute('data-mega-sub'));
    });
  });

  /* Header nav hover to open */
  var headerLinks = document.querySelectorAll('.pp-header__desktop-link, .pp-header__nav-link');
  headerLinks.forEach(function(link) {
    link.addEventListener('mouseenter', function() {
      clearTimeout(closeTimer);
      var text = (link.textContent || '').trim().toLowerCase();
      if (text === 'plantas' || text.indexOf('planta') !== -1) {
        open('plantas');
      } else if (text === 'regalos') {
        open('regalos');
      } else if (text.indexOf('sobre') !== -1 || text.indexOf('pur plant') !== -1) {
        open('sobre');
      } else if (text === 'cuidados') {
        open('plantas');
        activateSub('cuidados');
      } else {
        // Non-menu link, close
        closeTimer = setTimeout(close, 300);
      }
    });
  });

  /* Keep open while hovering megamenu */
  mega.addEventListener('mouseenter', function() {
    clearTimeout(closeTimer);
  });

  /* Close when leaving megamenu */
  mega.addEventListener('mouseleave', function() {
    closeTimer = setTimeout(close, 200);
  });

  /* Close when leaving header area */
  var header = document.querySelector('.pp-header');
  if (header) {
    header.addEventListener('mouseleave', function(e) {
      /* Don't close if moving into the megamenu */
      var related = e.relatedTarget;
      if (related && (mega.contains(related) || mega === related)) return;
      closeTimer = setTimeout(close, 200);
    });
  }

  /* ESC to close */
  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape') close();
  });

  /* Hamburger opens plantas by default */
  document.addEventListener('click', function(e) {
    var hamburger = e.target.closest('.pp-header__menu-toggle');
    if (!hamburger) return;
    e.stopPropagation();
    e.preventDefault();
    if (mega.getAttribute('aria-hidden') === 'false') {
      close();
    } else {
      open('plantas');
    }
  }, true);

  /* Close mobile menu if it opens */
  var mobileMenu = document.querySelector('pp-mobile-menu');
  if (mobileMenu) {
    new MutationObserver(function() {
      if (mobileMenu.hasAttribute('open') && mega.getAttribute('aria-hidden') === 'false') {
        mobileMenu.removeAttribute('open');
        mobileMenu.setAttribute('hidden', '');
      }
    }).observe(mobileMenu, { attributes: true, attributeFilter: ['open'] });
  }

  /* Mobile close button */
  var mobileCloseBtn = mega.querySelector('[data-mega-close]');
  if (mobileCloseBtn) {
    mobileCloseBtn.addEventListener('click', close);
  }

  /* Mobile tabs */
  mega.querySelectorAll('[data-mega-mobile-tab]').forEach(function(tab) {
    tab.addEventListener('click', function() {
      mega.querySelectorAll('[data-mega-mobile-tab]').forEach(function(t) { t.classList.remove('is-active'); });
      tab.classList.add('is-active');
      open(tab.getAttribute('data-mega-mobile-tab'));
    });
  });

  /* Lock body scroll on mobile when open */
  function updateBodyScroll() {
    if (window.innerWidth < 750 && mega.getAttribute('aria-hidden') === 'false') {
      document.body.style.overflow = 'hidden';
    } else {
      document.body.style.overflow = '';
    }
  }

  var origOpen = open;
  open = function(panelId) {
    origOpen(panelId);
    updateBodyScroll();
  };
  var origClose = close;
  close = function() {
    origClose();
    document.body.style.overflow = '';
  };

  window.ppMegamenu = { open: open, close: close };
})();
</script>
