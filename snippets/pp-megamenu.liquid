<script>
(function() {
  'use strict';

  var megamenu = document.getElementById('pp-megamenu');
  if (!megamenu) return;

  /* ----- References ----- */
  var closeBtn = megamenu.querySelector('[data-megamenu-close]');
  var toplevelBtns = megamenu.querySelectorAll('[data-mega-toplevel]');
  var subtabBtns = megamenu.querySelectorAll('[data-mega-subtab]');
  var panels = megamenu.querySelectorAll('[data-mega-panel]');
  var subpanels = megamenu.querySelectorAll('[data-mega-subpanel]');

  /* ----- Open / Close ----- */
  function open() {
    megamenu.setAttribute('aria-hidden', 'false');
    document.body.classList.add('pp-megamenu-open');
    /* Focus the close button after transition */
    setTimeout(function() { closeBtn.focus(); }, 100);
  }

  function close() {
    megamenu.setAttribute('aria-hidden', 'true');
    document.body.classList.remove('pp-megamenu-open');
    /* Return focus to the hamburger if available */
    var hamburger = document.querySelector('.pp-header__menu-toggle');
    if (hamburger) hamburger.focus();
  }

  /* ----- Top-level tab switching ----- */
  function activateToplevel(key) {
    toplevelBtns.forEach(function(btn) {
      btn.setAttribute('aria-selected', btn.getAttribute('data-mega-toplevel') === key ? 'true' : 'false');
    });
    panels.forEach(function(panel) {
      panel.setAttribute('aria-hidden', panel.getAttribute('data-mega-panel') === key ? 'false' : 'true');
    });
  }

  /* ----- Sub-tab switching (within Plantas) ----- */
  function activateSubtab(key) {
    subtabBtns.forEach(function(btn) {
      btn.setAttribute('aria-selected', btn.getAttribute('data-mega-subtab') === key ? 'true' : 'false');
    });
    subpanels.forEach(function(sp) {
      sp.setAttribute('aria-hidden', sp.getAttribute('data-mega-subpanel') === key ? 'false' : 'true');
    });
  }

  /* ----- Event listeners ----- */

  /* Close button */
  closeBtn.addEventListener('click', close);

  /* Top-level tabs — click + hover */
  toplevelBtns.forEach(function(btn) {
    btn.addEventListener('click', function() {
      activateToplevel(btn.getAttribute('data-mega-toplevel'));
    });
    btn.addEventListener('mouseenter', function() {
      activateToplevel(btn.getAttribute('data-mega-toplevel'));
    });
  });

  /* Sub-tabs — click + hover */
  subtabBtns.forEach(function(btn) {
    btn.addEventListener('click', function() {
      activateSubtab(btn.getAttribute('data-mega-subtab'));
    });
    btn.addEventListener('mouseenter', function() {
      activateSubtab(btn.getAttribute('data-mega-subtab'));
    });
  });

  /* ESC key */
  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape' && megamenu.getAttribute('aria-hidden') === 'false') {
      close();
    }
  });

  /* ----- Hook into PP Header hamburger button ----- */
  /* The hamburger is .pp-header__menu-toggle. We listen on document for
     clicks so it works even if the header re-renders. */
  document.addEventListener('click', function(e) {
    var hamburger = e.target.closest('.pp-header__menu-toggle');
    if (!hamburger) return;

    /* Prevent mobile menu from also opening */
    e.stopPropagation();
    e.preventDefault();

    /* Close mobile menu if open */
    var mobileMenu = document.querySelector('pp-mobile-menu');
    if (mobileMenu && mobileMenu.hasAttribute('open')) {
      mobileMenu.removeAttribute('open');
      mobileMenu.setAttribute('hidden', '');
    }

    var isOpen = megamenu.getAttribute('aria-hidden') === 'false';
    if (isOpen) {
      close();
    } else {
      open();
    }
  }, true); /* capture phase to run before mobile menu */

  /* ----- Close when clicking outside the body content (on the overlay itself) ----- */
  megamenu.addEventListener('click', function(e) {
    if (e.target === megamenu) {
      close();
    }
  });

  /* ----- Open megamenu on hover over header nav links ----- */
  var navLinkMap = {
    '/collections/plantas': 'plantas',
    '/collections/plantas-interior': 'plantas',
    '/collections/regalos': 'regalos',
    '/pages/sobre-nosotros': 'sobre'
  };

  document.addEventListener('mouseenter', function(e) {
    var link = e.target.closest('.pp-header__desktop-link, .pp-header__nav-link');
    if (!link) return;
    var href = link.getAttribute('href');
    var panel = null;
    for (var path in navLinkMap) {
      if (href && href.indexOf(path) !== -1) {
        panel = navLinkMap[path];
        break;
      }
    }
    // Also match by text content
    if (!panel) {
      var text = (link.textContent || '').trim().toLowerCase();
      if (text === 'plantas') panel = 'plantas';
      else if (text === 'regalos') panel = 'regalos';
      else if (text.indexOf('sobre') !== -1 || text.indexOf('pur plant') !== -1) panel = 'sobre';
    }
    if (panel) {
      open();
      activateToplevel(panel);
    }
  }, true);

  /* ----- Expose globally so header JS can call ppMegamenu.open() / .close() if needed ----- */
  window.ppMegamenu = {
    open: open,
    close: close,
    isOpen: function() { return megamenu.getAttribute('aria-hidden') === 'false'; }
  };

})();
</script>
