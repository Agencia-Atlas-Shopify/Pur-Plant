{% doc %}
  @prompt
    texto h2 en blanco
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-h2-text-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
  }

  .ai-h2-text__heading-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    margin: 0;
    text-align: {{ block.settings.text_alignment }};
    font-size: {{ block.settings.font_size }}px;
  }

  @media screen and (max-width: 749px) {
    .ai-h2-text__heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.font_size_mobile }}px;
    }
  }
{% endstyle %}

<div class="ai-h2-text-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  {% if block.settings.heading != blank %}
    <h2 class="ai-h2-text__heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
  {% endif %}
</div>

{% schema %}
{
  "name": "Texto H2",
  "settings": [
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Texto"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Color del texto",
      "default": "#FFFFFF"
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Alineación",
      "options": [
        {
          "value": "left",
          "label": "Izquierda"
        },
        {
          "value": "center",
          "label": "Centro"
        },
        {
          "value": "right",
          "label": "Derecha"
        }
      ],
      "default": "center"
    },
    {
      "type": "range",
      "id": "font_size",
      "label": "Tamaño de fuente (escritorio)",
      "min": 16,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 48
    },
    {
      "type": "range",
      "id": "font_size_mobile",
      "label": "Tamaño de fuente (móvil)",
      "min": 16,
      "max": 72,
      "step": 4,
      "unit": "px",
      "default": 32
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Ancho en escritorio",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    }
  ],
  "presets": [
    {
      "name": "Texto H2"
    }
  ]
}
{% endschema %}
