{% doc %}
  @prompt
    quiero una lista de páginas exactamente igual que una lista de carrusel de colecciones. Justificado a la izquierda, que escoga la imagen destacada de la página, y que pueda añadir más de 80 paginas
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-pages-carousel-{{ ai_gen_id }} {
    width: 100%;
    display: block;
  }

  .ai-pages-carousel-container-{{ ai_gen_id }} {
    position: relative;
    overflow: hidden;
    width: 100%;
  }

  .ai-pages-carousel-wrapper-{{ ai_gen_id }} {
    display: flex;
    gap: {{ block.settings.gap }}px;
    overflow-x: auto;
    scroll-behavior: smooth;
    scrollbar-width: none;
    -ms-overflow-style: none;
    padding-bottom: 10px;
  }

  .ai-pages-carousel-wrapper-{{ ai_gen_id }}::-webkit-scrollbar {
    display: none;
  }

  .ai-pages-carousel-item-{{ ai_gen_id }} {
    flex: 0 0 {{ block.settings.card_width }}px;
    min-width: {{ block.settings.card_width }}px;
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: inherit;
    transition: transform 0.2s ease;
  }

  .ai-pages-carousel-item-{{ ai_gen_id }}:hover {
    transform: translateY(-4px);
  }

  .ai-pages-carousel-image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    aspect-ratio: {{ block.settings.image_aspect_ratio }};
    overflow: hidden;
    border-radius: {{ block.settings.image_border_radius }}px;
    background-color: #f4f4f4;
  }

  .ai-pages-carousel-image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-pages-carousel-image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: #f4f4f4;
  }

  .ai-pages-carousel-image-placeholder-{{ ai_gen_id }} svg {
    width: 50%;
    height: 50%;
    opacity: 0.3;
  }

  .ai-pages-carousel-title-{{ ai_gen_id }} {
    margin-top: {{ block.settings.title_spacing }}px;
    font-size: {{ block.settings.title_size }}px;
    font-weight: {{ block.settings.title_weight }};
    color: {{ block.settings.title_color }};
    line-height: 1.3;
  }

  .ai-pages-carousel-navigation-{{ ai_gen_id }} {
    display: flex;
    gap: 8px;
    margin-top: 16px;
  }

  .ai-pages-carousel-nav-button-{{ ai_gen_id }} {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    border: 1px solid {{ block.settings.nav_border_color }};
    background-color: {{ block.settings.nav_bg_color }};
    color: {{ block.settings.nav_icon_color }};
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .ai-pages-carousel-nav-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.nav_hover_bg_color }};
    border-color: {{ block.settings.nav_hover_border_color }};
  }

  .ai-pages-carousel-nav-button-{{ ai_gen_id }}:disabled {
    opacity: 0.3;
    cursor: not-allowed;
  }

  .ai-pages-carousel-nav-button-{{ ai_gen_id }} svg {
    width: 20px;
    height: 20px;
  }

  @media screen and (max-width: 749px) {
    .ai-pages-carousel-item-{{ ai_gen_id }} {
      flex: 0 0 {{ block.settings.card_width_mobile }}px;
      min-width: {{ block.settings.card_width_mobile }}px;
    }
  }
{% endstyle %}

<pages-carousel-{{ ai_gen_id }} class="ai-pages-carousel-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-pages-carousel-container-{{ ai_gen_id }}">
    <div class="ai-pages-carousel-wrapper-{{ ai_gen_id }}" data-carousel-wrapper>
      {% for i in (1..100) %}
        {% assign page_key = 'page_' | append: i %}
        {% assign page = block.settings[page_key] %}
        
        {% if page != blank %}
          <a href="{{ page.url }}" class="ai-pages-carousel-item-{{ ai_gen_id }}">
            <div class="ai-pages-carousel-image-wrapper-{{ ai_gen_id }}">
              {% if page.image %}
                <img
                  src="{{ page.image | image_url: width: 600 }}"
                  alt="{{ page.image.alt | default: page.title | escape }}"
                  loading="lazy"
                  width="600"
                  height="{{ 600 | divided_by: block.settings.image_aspect_ratio }}"
                  class="ai-pages-carousel-image-{{ ai_gen_id }}"
                >
              {% else %}
                <div class="ai-pages-carousel-image-placeholder-{{ ai_gen_id }}">
                  {{ 'image' | placeholder_svg_tag }}
                </div>
              {% endif %}
            </div>
            {% if block.settings.show_title %}
              <h3 class="ai-pages-carousel-title-{{ ai_gen_id }}">{{ page.title }}</h3>
            {% endif %}
          </a>
        {% endif %}
      {% endfor %}
    </div>

    {% if block.settings.show_navigation %}
      <div class="ai-pages-carousel-navigation-{{ ai_gen_id }}">
        <button
          class="ai-pages-carousel-nav-button-{{ ai_gen_id }}"
          data-nav-prev
          aria-label="Anterior"
        >
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="15 18 9 12 15 6"></polyline>
          </svg>
        </button>
        <button
          class="ai-pages-carousel-nav-button-{{ ai_gen_id }}"
          data-nav-next
          aria-label="Siguiente"
        >
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="9 18 15 12 9 6"></polyline>
          </svg>
        </button>
      </div>
    {% endif %}
  </div>
</pages-carousel-{{ ai_gen_id }}>

<script>
  (function() {
    class PagesCarousel{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.wrapper = this.querySelector('[data-carousel-wrapper]');
        this.prevButton = this.querySelector('[data-nav-prev]');
        this.nextButton = this.querySelector('[data-nav-next]');
        
        if (this.prevButton && this.nextButton) {
          this.setupNavigation();
        }
      }

      setupNavigation() {
        this.prevButton.addEventListener('click', () => this.scroll('prev'));
        this.nextButton.addEventListener('click', () => this.scroll('next'));
        
        this.wrapper.addEventListener('scroll', () => this.updateButtonStates());
        this.updateButtonStates();
      }

      scroll(direction) {
        const scrollAmount = this.wrapper.offsetWidth * 0.8;
        const currentScroll = this.wrapper.scrollLeft;
        
        if (direction === 'prev') {
          this.wrapper.scrollLeft = currentScroll - scrollAmount;
        } else {
          this.wrapper.scrollLeft = currentScroll + scrollAmount;
        }
      }

      updateButtonStates() {
        const isAtStart = this.wrapper.scrollLeft <= 0;
        const isAtEnd = this.wrapper.scrollLeft + this.wrapper.offsetWidth >= this.wrapper.scrollWidth - 1;
        
        this.prevButton.disabled = isAtStart;
        this.nextButton.disabled = isAtEnd;
      }
    }

    customElements.define('pages-carousel-{{ ai_gen_id }}', PagesCarousel{{ ai_gen_id }});
  })();
</script>

