{{ 'pp-sections.css' | asset_url | stylesheet_tag }}

<section class="pp-coll-title" style="
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  ">
  <div class="pp-coll-title__inner">
    <h1 class="pp-coll-title__heading">{{ collection.title }}</h1>
  </div>
</section>

{% schema %}
{
  "name": "PP Collection Title",
  "tag": "section",
  "class": "pp-coll-title-section",
  "settings": [
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 32
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 16
    }
  ],
  "templates": ["collection"],
  "presets": [
    {
      "name": "PP Collection Title",
      "category": "Pur Plant"
    }
  ]
}
{% endschema %}
