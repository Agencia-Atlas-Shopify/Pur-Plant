{{ 'pp-page-guide.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign page_type = page.metafields.custom.page_type | default: ''
  assign blocks_raw = page.metafields.custom.page_blocks
  assign is_care_guide = false
  if page_type == 'guia-cuidado'
    assign is_care_guide = true
  endif

  assign breadcrumb_label = 'Guia'
  case page_type
    when 'guia-cuidado'
      assign breadcrumb_label = 'Guia Cuidados'
    when 'guia-tipos'
      assign breadcrumb_label = 'Tipos de Plantas'
    when 'guia-problemas'
      assign breadcrumb_label = 'Problemas Plantas'
    when 'plantas-domicilio'
      assign breadcrumb_label = 'Plantas a Domicilio'
    when 'flores-domicilio'
      assign breadcrumb_label = 'Flores a Domicilio'
  endcase
-%}

<section class="pp-guide" style="background-color: {{ section.settings.bg_color }}; padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px;">
  <div style="max-width: var(--page-content-width, 120rem); margin: 0 auto; padding: 0 var(--page-margin, 40px);">

    {%- if section.settings.show_breadcrumb -%}
      <nav class="pp-guide__breadcrumb">
        <a href="/">Pur Plant</a> <span>/</span>
        <span>{{ breadcrumb_label }}</span> <span>/</span>
        <span>{{ page.title }}</span>
      </nav>
    {%- endif -%}

    <h1 class="pp-guide__title">{{ page.title }}</h1>

    {%- if is_care_guide and section.settings.show_care_icons -%}
      {%- assign icon_luz = page.metafields.custom.guia_icono_luz -%}
      {%- assign icon_riego = page.metafields.custom.guia_icono_riego -%}
      {%- assign icon_clima = page.metafields.custom.guia_icono_clima -%}
      {%- assign icon_pet = page.metafields.custom.guia_icono_pet -%}
      {%- assign icon_plagas = page.metafields.custom.guia_icono_plagas -%}
      {%- if icon_luz != blank or icon_riego != blank or icon_clima != blank or icon_plagas != blank -%}
        <div class="pp-guide__icons">
          {%- if icon_luz != blank -%}<div class="pp-guide__icon"><span class="pp-guide__icon-label">Luz</span><span class="pp-guide__icon-value">{{ icon_luz }}</span></div>{%- endif -%}
          {%- if icon_riego != blank -%}<div class="pp-guide__icon"><span class="pp-guide__icon-label">Riego</span><span class="pp-guide__icon-value">{{ icon_riego }}</span></div>{%- endif -%}
          {%- if icon_clima != blank -%}<div class="pp-guide__icon"><span class="pp-guide__icon-label">Clima</span><span class="pp-guide__icon-value">{{ icon_clima }}</span></div>{%- endif -%}
          {%- if icon_pet -%}<div class="pp-guide__icon"><span class="pp-guide__icon-label">Pet Friendly</span><span class="pp-guide__icon-value">Si</span></div>{%- endif -%}
          {%- if icon_plagas != blank -%}<div class="pp-guide__icon"><span class="pp-guide__icon-label">Plagas</span><span class="pp-guide__icon-value">{{ icon_plagas }}</span></div>{%- endif -%}
        </div>
      {%- endif -%}
    {%- endif -%}

    {%- if blocks_raw != blank -%}
      <div class="pp-guide__body pp-guide__body--columns">
        {%- for block in blocks_raw -%}
          {%- case block.type -%}
            {%- when 'heading' -%}
              {%- if block.level == 1 -%}
              {%- elsif block.level == 2 -%}
                <h2 class="pp-guide__h2">{{ block.text }}</h2>
              {%- elsif block.level == 3 -%}
                <h3 class="pp-guide__h3">{{ block.text }}</h3>
              {%- else -%}
                <h4 class="pp-guide__h4">{{ block.text }}</h4>
              {%- endif -%}
            {%- when 'paragraph' -%}
              <p class="pp-guide__p">{{ block.text }}</p>
            {%- when 'image' -%}
              <div class="pp-guide__image">
                <img src="{{ block.url }}" alt="{{ block.alt | default: page.title }}" loading="lazy" style="max-width:100%;height:auto;border-radius:8px;">
              </div>
            {%- when 'button' -%}
              <a href="{{ block.url | default: '#' }}" class="pp-guide__button">{{ block.text }}</a>
            {%- when 'list' -%}
              <ul class="pp-guide__list">
                {%- for item in block.items -%}
                  <li>{{ item }}</li>
                {%- endfor -%}
              </ul>
          {%- endcase -%}
        {%- endfor -%}
      </div>
    {%- else -%}
      {%- if page.content != blank -%}
        <div class="pp-guide__body">{{ page.content }}</div>
      {%- endif -%}
    {%- endif -%}

  </div>
</section>

{% schema %}
{
  "name": "PP Page Guide",
  "settings": [
    { "type": "checkbox", "id": "show_breadcrumb", "label": "Show breadcrumb", "default": true },
    { "type": "checkbox", "id": "show_care_icons", "label": "Show care icons", "default": true },
    { "type": "color", "id": "bg_color", "label": "Background color", "default": "#ffffff" },
    { "type": "range", "id": "padding_top", "label": "Padding top", "min": 0, "max": 100, "step": 4, "unit": "px", "default": 40 },
    { "type": "range", "id": "padding_bottom", "label": "Padding bottom", "min": 0, "max": 100, "step": 4, "unit": "px", "default": 60 }
  ]
}
{% endschema %}
