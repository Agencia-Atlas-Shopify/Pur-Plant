{%- comment -%}
  PP Page Guide — Renders guide pages (guia-cuidado, guia-tipos, guia-problemas, plantas-domicilio)
  Reads content from page.metafields.custom.page_content JSON array.
  Widget types: heading, text (raw HTML), image.
  Also uses: page_type, page_icon_* (care icons for guia-cuidado), page_collection_1..3.
{%- endcomment -%}

{{ 'pp-page-guide.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign page_type = page.metafields.custom.page_type | default: ''
  assign is_care_guide = false
  if page_type == 'guia-cuidado'
    assign is_care_guide = true
  elsif page.template_suffix contains 'guia-cuidado' or page.template_suffix contains 'cuidado-plantas'
    # Auto-detect: si la página usa una plantilla de cuidados, activamos los iconos
    # sin tener que rellenar el metafield page_type a mano.
    assign is_care_guide = true
  endif

  # Detección "tipos de plantas" — productos se renderizan en card horizontal
  # (foto + título + descripción + botón) en vez del grid 4-col estándar.
  assign is_tipos = false
  if page_type == 'guia-tipos'
    assign is_tipos = true
  elsif page.handle contains 'tipos-' or page.handle contains '-tipos-' or page.handle == 'guia-tipos-plantas'
    # Cubre handles: tipos-buganvilla, tipos-de-X, guia-tipos-de-X, X-tipos-Y, etc.
    assign is_tipos = true
  elsif page.template_suffix contains 'tipos'
    assign is_tipos = true
  endif
  assign products_per_row = section.settings.products_per_row | default: 4

  comment
    Determine breadcrumb middle label based on page_type
  endcomment
  assign breadcrumb_label = 'Guia'
  assign breadcrumb_url = ''
  case page_type
    when 'guia-cuidado'
      assign breadcrumb_label = 'Guía Cuidados'
      assign breadcrumb_url = '/pages/guia-cuidado-plantas'
    when 'guia-tipos'
      assign breadcrumb_label = 'Guía de Tipos'
      assign breadcrumb_url = '/pages/guia-tipos-plantas'
    when 'guia-problemas'
      assign breadcrumb_label = 'Guía de Problemas'
      assign breadcrumb_url = '/pages/guia-problemas-plantas'
    when 'plantas-domicilio'
      assign breadcrumb_label = 'Plantas a Domicilio'
      assign breadcrumb_url = '/pages/plantas-a-domicilio'
  endcase
-%}

<style>
  /* --- Hero (full-width, overlaps header) --- */
  .pp-guide-hero {
    position: relative;
    left: 50%;
    right: 50%;
    width: 100vw;
    margin-left: -50vw;
    margin-right: -50vw;
    min-height: 450px;
    display: flex;
    align-items: flex-end;
    justify-content: flex-start;
    overflow: hidden;
    border-radius: 0;
    margin-bottom: 48px;
    margin-top: calc(-1 * (var(--pp-guide-pad-top, 40px) + var(--pp-header-height, 120px)));
    padding-top: var(--pp-header-height, 120px);
  }

  .pp-guide-hero__bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .pp-guide-hero__bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .pp-guide-hero__gradient {
    position: absolute;
    inset: 0;
    background: rgba(35, 55, 44, 0.3);
    z-index: 1;
  }

  .pp-guide-hero__content {
    position: relative;
    z-index: 2;
    text-align: left;
    padding: 40px 32px;
    max-width: 800px;
  }

  .pp-guide-hero__title {
    font-family: 'Aileron', sans-serif;
    font-size: clamp(36px, 6vw, 64px);
    font-weight: 700;
    color: #e4ffd3;
    line-height: 0.8;
    margin: 0;
    letter-spacing: -0.07em;
    text-transform: uppercase;
  }

  /* --- PP Page Guide: content widget styles --- */
  .pp-guide .pp-content__heading {
    font-family: 'Aileron', sans-serif;
    font-size: clamp(24px, 3.5vw, 34px);
    font-weight: 800;
    color: #23372c;
    line-height: 1.2;
    margin: 40px 0 15px;
    text-transform: lowercase;
  }
  .pp-guide .pp-content__heading::first-letter {
    text-transform: uppercase;
  }

  .pp-guide .pp-content__heading:first-child {
    margin-top: 0;
  }

  @media screen and (max-width: 749px) {
    .pp-guide-hero {
      min-height: 280px;
      margin-bottom: 24px;
    }
    .pp-guide-hero__content {
      padding: 24px 20px;
    }
  }

  .pp-guide .pp-content__text {
    font-family: var(--pp-font-body);
    font-size: 15px;
    font-weight: 400;
    color: var(--pp-text);
    line-height: 1.75;
    margin: 0 0 24px;
  }

  .pp-guide .pp-content__text p { margin: 0 0 16px; }
  .pp-guide .pp-content__text p.pp-empty { margin: 0; line-height: 0; font-size: 0; }
  .pp-guide .pp-content__text p:last-child { margin-bottom: 0; }
  .pp-guide .pp-content__text ul,
  .pp-guide .pp-content__text ol { margin: 0 0 16px; padding-left: 24px; }
  .pp-guide .pp-content__text li { margin-bottom: 6px; }
  .pp-guide .pp-content__text a { color: var(--pp-dark-green); text-decoration: underline; }
  .pp-guide .pp-content__text a:hover { opacity: 0.8; }
  .pp-guide .pp-content__text strong { font-weight: 600; }

  .pp-guide .pp-content__image {
    margin: 0 0 24px;
  }

  .pp-guide .pp-content__image img {
    max-width: 100%;
    height: auto;
    border-radius: var(--pp-radius, 8px);
    display: block;
  }

  /* --- Product grid --- */
  .pp-guide__product-grid-wrapper {
    margin: 56px 0;
    padding: 40px 0;
    border-top: 1px solid rgba(35, 55, 44, 0.1);
    border-bottom: 1px solid rgba(35, 55, 44, 0.1);
  }

  .pp-guide__product-grid-title {
    font-family: var(--pp-font-heading);
    font-size: clamp(20px, 2.5vw, 28px);
    font-weight: 400;
    color: var(--pp-dark-green);
    margin: 0 0 24px;
    text-align: center;
  }

  .pp-guide__product-grid {
    display: grid;
    grid-template-columns: repeat(var(--pp-products-per-row, 4), 1fr);
    gap: 20px;
  }

  @media screen and (max-width: 989px) {
    .pp-guide__product-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media screen and (max-width: 749px) {
    .pp-guide__product-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 12px;
    }

    .pp-guide__product-grid-wrapper {
      margin: 36px 0;
      padding: 28px 0;
    }
  }

  .pp-content__video {
    position: relative;
    aspect-ratio: 16 / 9;
    margin: 0 0 24px;
    border-radius: 8px;
    overflow: hidden;
    background: #000;
    max-width: 800px;
  }
  .pp-content__video iframe,
  .pp-content__video video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: 0;
  }

  .pp-content__cta { margin: 8px 0 24px; }
  .pp-cta-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 12px 22px;
    border: 1px solid #23372c;
    border-radius: 999px;
    font-family: 'Inter', sans-serif;
    font-size: 13px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: #23372c;
    text-decoration: none;
    transition: background .2s, color .2s;
  }
  .pp-cta-btn:hover { background: #23372c; color: #fff; }

  /* ── RTE fallback (guías nuevas editadas con el editor estándar de Shopify) ──
     Heredan EXACTAMENTE los mismos estilos que las guías migradas con JSON
     (Aileron headings lowercase con first-letter uppercase, Inter body). */
  .pp-guide .pp-guide__body--rte rte-formatter { display: block; }
  .pp-guide .pp-guide__body--rte h1,
  .pp-guide .pp-guide__body--rte h2,
  .pp-guide .pp-guide__body--rte h3,
  .pp-guide .pp-guide__body--rte h4 {
    font-family: 'Aileron', sans-serif;
    font-weight: 800;
    color: #23372c;
    line-height: 1.2;
    margin: 40px 0 15px;
    text-transform: lowercase;
  }
  .pp-guide .pp-guide__body--rte h1::first-letter,
  .pp-guide .pp-guide__body--rte h2::first-letter,
  .pp-guide .pp-guide__body--rte h3::first-letter,
  .pp-guide .pp-guide__body--rte h4::first-letter { text-transform: uppercase; }
  .pp-guide .pp-guide__body--rte h1 { font-size: clamp(28px, 4vw, 38px); }
  .pp-guide .pp-guide__body--rte h2 { font-size: clamp(24px, 3.5vw, 34px); }
  .pp-guide .pp-guide__body--rte h3 { font-size: clamp(20px, 2.8vw, 26px); }
  .pp-guide .pp-guide__body--rte h4 { font-size: 18px; }
  .pp-guide .pp-guide__body--rte h1:first-child,
  .pp-guide .pp-guide__body--rte h2:first-child { margin-top: 0; }
  .pp-guide .pp-guide__body--rte p {
    font-family: var(--pp-font-body);
    font-size: 15px;
    font-weight: 400;
    color: var(--pp-text);
    line-height: 1.75;
    margin: 0 0 16px;
  }
  .pp-guide .pp-guide__body--rte ul,
  .pp-guide .pp-guide__body--rte ol { margin: 0 0 16px; padding-left: 24px; font-family: var(--pp-font-body); }
  .pp-guide .pp-guide__body--rte li { margin-bottom: 6px; line-height: 1.75; }
  .pp-guide .pp-guide__body--rte a { color: var(--pp-dark-green); text-decoration: underline; }
  .pp-guide .pp-guide__body--rte a:hover { opacity: 0.8; }
  .pp-guide .pp-guide__body--rte strong { font-weight: 600; }
  .pp-guide .pp-guide__body--rte img {
    display: block;
    max-width: 100%;
    height: auto;
    border-radius: 12px;
    margin: 24px auto;
  }
  /* Vídeos / iframes responsive (YouTube, Vimeo, etc.) — wrap automático */
  .pp-guide .pp-guide__body--rte .pp-embed {
    position: relative;
    width: 100%;
    max-width: 720px;
    aspect-ratio: var(--embed-ratio, 16 / 9);
    margin: 24px auto;
    overflow: hidden;
    border-radius: 12px;
    background: #000;
  }
  .pp-guide .pp-guide__body--rte .pp-embed--vertical {
    max-width: 360px;
    border-radius: 16px;
  }
  .pp-guide .pp-guide__body--rte .pp-embed iframe,
  .pp-guide .pp-guide__body--rte .pp-embed video,
  .pp-guide .pp-guide__body--rte .pp-embed embed,
  .pp-guide .pp-guide__body--rte .pp-embed object {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: 0;
  }
  .pp-guide .pp-guide__body--rte iframe,
  .pp-guide .pp-guide__body--rte video {
    max-width: 100%;
  }

  /* ── Shortcodes [productos] / [colecciones] dentro de RTE (mismo estilo que blog) ── */
  .pp-guide .pp-blog-embed { margin: 24px 0; width: 100%; background: transparent; clear: both; }
  .pp-guide rte-formatter p:has(> .pp-blog-embed) { margin: 0; padding: 0; background: transparent; }
  .pp-guide .pp-blog-embed__heading-link { color: inherit; text-decoration: none; display: inline-flex; align-items: center; gap: 8px; }
  .pp-guide .pp-blog-embed__heading {
    font-family: 'Aileron', sans-serif; font-size: 18px; font-weight: 600;
    letter-spacing: 0.02em; text-transform: uppercase; color: #23372c;
    margin: 0 0 16px; display: block;
  }
  .pp-guide .pp-blog-embed__heading::first-letter { text-transform: uppercase; }
  .pp-guide .pp-blog-embed__heading .pp-blog-embed__heading-arrow {
    display: inline-block; margin-left: 8px; vertical-align: middle;
  }
  .pp-guide .pp-blog-embed__heading-arrow { transition: transform 0.15s ease; }
  .pp-guide .pp-blog-embed__heading-link:hover .pp-blog-embed__heading-arrow { transform: translateX(4px); }
  .pp-guide .pp-blog-embed__grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px; }
  .pp-guide .pp-blog-embed--single .pp-blog-embed__grid { grid-template-columns: minmax(0, 280px); justify-content: center; }
  .pp-guide .pp-blog-embed__grid--2 { grid-template-columns: repeat(2, 1fr); }
  .pp-guide .pp-blog-embed__grid--3 { grid-template-columns: repeat(3, 1fr); }
  .pp-guide .pp-blog-embed product-card.pp-product-card-standalone .pp-card__media { background: transparent; }
  .pp-guide .pp-blog-embed product-card.pp-product-card-standalone .pp-badge-list { inset-block-start: 28px; }
  @media screen and (max-width: 999px) {
    .pp-guide .pp-blog-embed__grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media screen and (max-width: 600px) {
    .pp-guide .pp-blog-embed__grid { grid-template-columns: repeat(2, 1fr); gap: 10px; }
    .pp-guide .pp-blog-embed--single .pp-blog-embed__grid { grid-template-columns: minmax(0, 220px); }
    .pp-guide .pp-blog-embed__heading { font-size: 15px; }
  }

  /* ── EXPLORA: colecciones / páginas relacionadas al final de la guía ── */
  .pp-guide__explora {
    margin: 56px auto 0;
    padding: 40px 0;
    border-top: 1px solid rgba(35, 55, 44, 0.1);
    text-align: center;
  }
  .pp-guide__explora-title {
    font-family: 'Aileron', sans-serif;
    font-size: clamp(22px, 3vw, 30px);
    font-weight: 800;
    letter-spacing: 0.04em;
    color: #23372c;
    margin: 0 0 28px;
    text-transform: uppercase;
  }
  .pp-guide__explora-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 24px;
    max-width: 920px;
    margin: 0 auto;
  }
  .pp-guide__explora-card {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: inherit;
    gap: 12px;
  }
  .pp-guide__explora-img {
    width: 100%;
    aspect-ratio: 1 / 1;
    object-fit: cover;
    border-radius: 12px;
    background: #f0eee8;
    transition: transform 0.2s ease;
  }
  .pp-guide__explora-img--placeholder { display: block; }
  .pp-guide__explora-card:hover .pp-guide__explora-img { transform: translateY(-3px); }
  .pp-guide__explora-card-title {
    font-family: var(--pp-font-body);
    font-size: 16px;
    font-weight: 600;
    color: #23372c;
    text-align: center;
  }
  @media screen and (max-width: 600px) {
    .pp-guide__explora { padding: 28px 0; margin-top: 36px; }
    .pp-guide__explora-grid { grid-template-columns: repeat(2, 1fr); gap: 14px; }
    .pp-guide__explora-card-title { font-size: 14px; }
  }

  .pp-content__products-inline {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
    gap: 16px;
    margin: 24px 0;
  }
  .pp-inline-product {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: inherit;
    border-radius: 8px;
    overflow: hidden;
    background: #fff;
    transition: transform .2s;
  }
  .pp-inline-product:hover { transform: translateY(-2px); }
  .pp-inline-product__img {
    width: 100%;
    aspect-ratio: 1 / 1;
    object-fit: cover;
    display: block;
    background: #f5f5f5;
  }
  .pp-inline-product__title {
    padding: 10px 12px;
    font-size: 14px;
    line-height: 1.4;
    font-weight: 500;
  }

  /* ── Card row (tipos de plantas: foto izq + título/desc/botón der) ── */
  .pp-card-row {
    display: grid;
    grid-template-columns: clamp(160px, 22%, 220px) 1fr;
    gap: 28px;
    align-items: center;
    padding: 28px 0;
    border-bottom: 1px solid rgba(35, 55, 44, 0.12);
  }
  .pp-card-row:first-child { border-top: 1px solid rgba(35, 55, 44, 0.12); }
  .pp-card-row__media {
    display: block;
    text-decoration: none;
    overflow: hidden;
    border-radius: 8px;
    background: rgba(0,0,0,.03);
  }
  .pp-card-row__img {
    display: block;
    width: 100%;
    height: auto;
    aspect-ratio: 1 / 1;
    object-fit: cover;
    transition: transform .25s ease;
  }
  .pp-card-row__img--placeholder {
    aspect-ratio: 1 / 1;
    background: rgba(0,0,0,.06);
  }
  .pp-card-row__media:hover .pp-card-row__img { transform: scale(1.03); }
  .pp-card-row__body { min-width: 0; }
  .pp-card-row__title-link { text-decoration: none; color: inherit; }
  /* Override RTE underline (línea 286 lo fuerza en <a> dentro de pp-guide__body--rte) */
  .pp-guide .pp-guide__body--rte .pp-card-row a,
  .pp-guide .pp-guide__body--rte .pp-blog-embed a,
  .pp-guide .pp-card-row a,
  .pp-guide .pp-blog-embed a { text-decoration: none; }
  .pp-card-row__title {
    font-family: 'Tenor Sans', serif;
    font-size: clamp(20px, 2.4vw, 28px);
    font-weight: 400;
    color: #23372c;
    margin: 0 0 10px;
    line-height: 1.2;
  }
  .pp-card-row__title-link:hover .pp-card-row__title { color: #4B7A5A; }
  .pp-card-row__desc {
    font-family: 'Inter', sans-serif;
    font-size: 15px;
    line-height: 1.6;
    color: #23372c;
    opacity: 0.85;
    margin: 0 0 16px;
  }
  .pp-card-row__btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: transparent;
    color: #23372c;
    border: 1px solid #23372c;
    padding: 10px 18px;
    font-family: 'Aileron', sans-serif;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: .08em;
    text-transform: uppercase;
    text-decoration: none;
    border-radius: 100px;
    transition: background .2s ease, color .2s ease;
  }
  .pp-card-row__btn:hover { background: #23372c; color: #fff; }
  .pp-card-row__btn-arrow { line-height: 1; }
  @media (max-width: 749px) {
    .pp-card-row {
      grid-template-columns: 120px 1fr;
      gap: 16px;
      padding: 20px 0;
    }
    .pp-card-row__title { font-size: 20px; margin-bottom: 6px; }
    .pp-card-row__desc { font-size: 14px; margin-bottom: 10px; }
    .pp-card-row__btn { padding: 8px 14px; font-size: 11px; }
  }

  /* Cuando is_tipos: los wrappers grid pasan a columna única para acomodar row cards */
  .pp-guide--tipos .pp-guide__product-grid,
  .pp-guide--tipos .pp-blog-embed__grid,
  .pp-guide--tipos .pp-blog-embed__grid--2,
  .pp-guide--tipos .pp-blog-embed__grid--3 {
    grid-template-columns: 1fr !important;
    gap: 0 !important;
  }
  .pp-guide--tipos .pp-card-row:first-child { border-top: 0; }
</style>

<section
  class="pp-guide{% if is_tipos %} pp-guide--tipos{% endif %}"
  style="
    background-color: {{ section.settings.bg_color }};
    --pp-guide-pad-top: {{ section.settings.padding_top }}px;
    --pp-guide-pad-bottom: {{ section.settings.padding_bottom }}px;
    --pp-products-per-row: {{ products_per_row }};
  "
>

  {%- comment -%} -- 1. Hero Section (full-width, under header) -- {%- endcomment -%}
  {%- assign hero_image = page.metafields.custom.imagen_portada.value -%}
  {%- assign hero_image_url = page.metafields.custom.imagen_portada_url.value -%}
  <div class="pp-guide-hero">
    {%- if hero_image -%}
      <div class="pp-guide-hero__bg">
        {{ hero_image | image_url: width: 1600 | image_tag: loading: 'eager', sizes: '100vw' }}
      </div>
    {%- elsif hero_image_url != blank -%}
      <div class="pp-guide-hero__bg">
        <img src="{{ hero_image_url }}" alt="{{ page.title | escape }}" loading="eager">
      </div>
    {%- endif -%}
    <div class="pp-guide-hero__gradient"></div>
    <div class="pp-guide-hero__content">
      <h1 class="pp-guide-hero__title">{{ page.title }}</h1>
    </div>
  </div>

  {%- comment -%} -- Breadcrumb (after hero). 2º nivel enlazado a la guía pilar. -- {%- endcomment -%}
  {%- if section.settings.show_breadcrumb -%}
    <nav class="pp-guide__breadcrumb" aria-label="Breadcrumb">
      <a href="/">Inicio</a>
      <span class="pp-guide__breadcrumb-sep">/</span>
      {%- if breadcrumb_url != '' and page.url != breadcrumb_url -%}
        <a href="{{ breadcrumb_url }}">{{ breadcrumb_label }}</a>
      {%- else -%}
        <span>{{ breadcrumb_label }}</span>
      {%- endif -%}
      <span class="pp-guide__breadcrumb-sep">/</span>
      <span>{{ page.title }}</span>
    </nav>
  {%- endif -%}

  {%- comment -%} -- Care icons (guia-cuidado only) -- {%- endcomment -%}
  {%- if is_care_guide and section.settings.show_care_icons -%}
    {%- liquid
      assign icon_luz = page.metafields.custom.page_icon_luz | default: ''
      assign icon_riego = page.metafields.custom.page_icon_riego | default: ''
      assign icon_clima = page.metafields.custom.page_icon_clima | default: ''
      assign icon_pet = page.metafields.custom.page_icon_pet | default: ''
      assign icon_toxica = page.metafields.custom.page_icon_toxica | default: ''
      assign icon_plagas = page.metafields.custom.page_icon_plagas | default: ''
      assign has_any_icon = false
      if icon_luz != blank or icon_riego != blank or icon_clima != blank or icon_pet != blank or icon_toxica != blank or icon_plagas != blank
        assign has_any_icon = true
      endif
    -%}
    {%- if has_any_icon -%}
      <div class="pp-guide__care-icons">
        {%- if icon_luz != blank -%}
          <div class="pp-guide__care-item">
            <img src="{{ 'icono-luz-indirecta-planta.png' | asset_url }}" alt="Luz" width="36" height="36" loading="lazy">
            <span class="pp-guide__care-label">Luz</span>
            <span class="pp-guide__care-value">{{ icon_luz }}</span>
          </div>
        {%- endif -%}
        {%- if icon_riego != blank -%}
          <div class="pp-guide__care-item">
            <img src="{{ 'icono-riego-planta.png' | asset_url }}" alt="Riego" width="36" height="36" loading="lazy">
            <span class="pp-guide__care-label">Riego</span>
            <span class="pp-guide__care-value">{{ icon_riego }}</span>
          </div>
        {%- endif -%}
        {%- if icon_clima != blank -%}
          <div class="pp-guide__care-item">
            <img src="{{ 'iconclima.png' | asset_url }}" alt="Clima" width="36" height="36" loading="lazy">
            <span class="pp-guide__care-label">Clima</span>
            <span class="pp-guide__care-value">{{ icon_clima }}</span>
          </div>
        {%- endif -%}
        {%- if icon_pet != blank -%}
          <div class="pp-guide__care-item">
            <img src="{{ 'icono-petfriendly-planta.png' | asset_url }}" alt="Pet Friendly" width="36" height="36" loading="lazy">
            <span class="pp-guide__care-label">Pet Friendly</span>
            <span class="pp-guide__care-value">{%- if icon_pet == true or icon_pet == 'true' -%}Sí{%- elsif icon_pet == false or icon_pet == 'false' -%}No{%- else -%}{{ icon_pet }}{%- endif -%}</span>
          </div>
        {%- endif -%}
        {%- if icon_toxica != blank -%}
          <div class="pp-guide__care-item">
            <img src="{{ 'icono-planta-toxica.png' | asset_url }}" alt="Tóxica" width="36" height="36" loading="lazy">
            <span class="pp-guide__care-label">Tóxica</span>
            <span class="pp-guide__care-value">{{ icon_toxica }}</span>
          </div>
        {%- endif -%}
        {%- if icon_plagas != blank -%}
          <div class="pp-guide__care-item">
            <img src="{{ 'plagas-enfermedades-icon.png' | asset_url }}" alt="Plagas" width="36" height="36" loading="lazy">
            <span class="pp-guide__care-label">Plagas</span>
            <span class="pp-guide__care-value">{{ icon_plagas }}</span>
          </div>
        {%- endif -%}
      </div>
    {%- endif -%}
  {%- endif -%}

  {%- comment -%}
    -- Content body --
    Guías antiguas migradas: contenido en metafield custom.page_content (JSON).
    Guías nuevas: si el JSON está vacío, fallback al campo Content estándar de la
    página (RTE de Shopify) — Maca/equipo edita como cualquier otra página, con
    texto, imágenes, vídeos de YouTube/Vimeo, etc. El theme aplica los estilos de
    guía (tipografía, embeds responsive) en ambos casos.
  {%- endcomment -%}
  {%- assign page_content_val = page.metafields.custom.page_content.value -%}
  {%- if page_content_val != blank -%}
    {%- comment -%} JSON-based (migrated guides) — JS renders {%- endcomment -%}
    <script type="application/json" data-page-content>{{ page_content_val | json }}</script>
    <div data-content-container class="pp-guide__body"></div>
  {%- elsif page.content != blank -%}
    {%- comment -%} RTE fallback (new guides) — server-rendered.
       Procesa shortcodes [productos] / [colecciones] como en el blog:
         [productos]        todos los del metafield productos_destacados
         [productos N]      el N-ésimo (1-indexed)
         [productos N,M]    fila 2-cards
         [productos N,M,O]  fila 3-cards
         [colecciones]      cada colección de colecciones_relacionadas con cabecera + 4 productos
         [colecciones N]    sólo la N-ésima
    {%- endcomment -%}
    {%- assign rte_content = page.content -%}
    {%- assign rte_prods = page.metafields.custom.productos_destacados.value -%}
    {%- assign rte_colls = page.metafields.custom.colecciones_relacionadas.value -%}

    {%- if rte_prods != blank and rte_prods.size > 0 -%}
      {%- capture rte_all_prods -%}
        <div class="pp-blog-embed pp-blog-embed--products"><div class="pp-blog-embed__grid">
          {%- for p in rte_prods -%}{%- if is_tipos -%}{%- render 'pp-product-card-row', product: p -%}{%- else -%}{%- render 'pp-product-card-standalone', product: p, image_ratio: 'portrait' -%}{%- endif -%}{%- endfor -%}
        </div></div>
      {%- endcapture -%}
      {%- assign rte_content = rte_content | replace: '<p>[productos]</p>', rte_all_prods | replace: '[productos]', rte_all_prods -%}
      {%- for p in rte_prods -%}
        {%- assign idx = forloop.index -%}
        {%- capture tok_p -%}[productos {{ idx }}]{%- endcapture -%}
        {%- capture tok_p_wrap -%}<p>[productos {{ idx }}]</p>{%- endcapture -%}
        {%- capture single_p -%}
          <div class="pp-blog-embed pp-blog-embed--products pp-blog-embed--single"><div class="pp-blog-embed__grid">
            {%- if is_tipos -%}{%- render 'pp-product-card-row', product: p -%}{%- else -%}{%- render 'pp-product-card-standalone', product: p, image_ratio: 'portrait' -%}{%- endif -%}
          </div></div>
        {%- endcapture -%}
        {%- assign rte_content = rte_content | replace: tok_p_wrap, single_p | replace: tok_p, single_p -%}
      {%- endfor -%}
      {%- assign psize = rte_prods.size -%}
      {%- if psize > 1 -%}
        {%- for i in (1..psize) -%}
          {%- for j in (1..psize) -%}
            {%- if j != i -%}
              {%- assign p1 = nil -%}{%- assign p2 = nil -%}
              {%- for prod in rte_prods -%}
                {%- if forloop.index == i -%}{%- assign p1 = prod -%}{%- endif -%}
                {%- if forloop.index == j -%}{%- assign p2 = prod -%}{%- endif -%}
              {%- endfor -%}
              {%- if p1 and p2 -%}
                {%- capture tok_pair -%}[productos {{ i }},{{ j }}]{%- endcapture -%}
                {%- capture tok_pair_wrap -%}<p>[productos {{ i }},{{ j }}]</p>{%- endcapture -%}
                {%- capture pair_html -%}
                  <div class="pp-blog-embed pp-blog-embed--products"><div class="pp-blog-embed__grid pp-blog-embed__grid--2">
                    {%- if is_tipos -%}{%- render 'pp-product-card-row', product: p1 -%}{%- else -%}{%- render 'pp-product-card-standalone', product: p1, image_ratio: 'portrait' -%}{%- endif -%}
                    {%- if is_tipos -%}{%- render 'pp-product-card-row', product: p2 -%}{%- else -%}{%- render 'pp-product-card-standalone', product: p2, image_ratio: 'portrait' -%}{%- endif -%}
                  </div></div>
                {%- endcapture -%}
                {%- assign rte_content = rte_content | replace: tok_pair_wrap, pair_html | replace: tok_pair, pair_html -%}
              {%- endif -%}
              {%- if psize > 2 -%}
                {%- for k in (1..psize) -%}
                  {%- if k != i and k != j -%}
                    {%- assign p3 = nil -%}
                    {%- for prod in rte_prods -%}{%- if forloop.index == k -%}{%- assign p3 = prod -%}{%- endif -%}{%- endfor -%}
                    {%- if p1 and p2 and p3 -%}
                      {%- capture tok_tri -%}[productos {{ i }},{{ j }},{{ k }}]{%- endcapture -%}
                      {%- capture tok_tri_wrap -%}<p>[productos {{ i }},{{ j }},{{ k }}]</p>{%- endcapture -%}
                      {%- capture tri_html -%}
                        <div class="pp-blog-embed pp-blog-embed--products"><div class="pp-blog-embed__grid pp-blog-embed__grid--3">
                          {%- if is_tipos -%}{%- render 'pp-product-card-row', product: p1 -%}{%- else -%}{%- render 'pp-product-card-standalone', product: p1, image_ratio: 'portrait' -%}{%- endif -%}
                          {%- if is_tipos -%}{%- render 'pp-product-card-row', product: p2 -%}{%- else -%}{%- render 'pp-product-card-standalone', product: p2, image_ratio: 'portrait' -%}{%- endif -%}
                          {%- if is_tipos -%}{%- render 'pp-product-card-row', product: p3 -%}{%- else -%}{%- render 'pp-product-card-standalone', product: p3, image_ratio: 'portrait' -%}{%- endif -%}
                        </div></div>
                      {%- endcapture -%}
                      {%- assign rte_content = rte_content | replace: tok_tri_wrap, tri_html | replace: tok_tri, tri_html -%}
                    {%- endif -%}
                  {%- endif -%}
                {%- endfor -%}
              {%- endif -%}
            {%- endif -%}
          {%- endfor -%}
        {%- endfor -%}
      {%- endif -%}
    {%- endif -%}

    {%- if rte_colls != blank and rte_colls.size > 0 -%}
      {%- capture rte_all_colls -%}
        {%- for c in rte_colls -%}
          <div class="pp-blog-embed pp-blog-embed--collection">
            <a href="{{ c.url }}" class="pp-blog-embed__heading-link"><h3 class="pp-blog-embed__heading">{{ c.title }}<span class="pp-blog-embed__heading-arrow" aria-hidden="true">→</span></h3></a>
            <div class="pp-blog-embed__grid">
              {%- for p in c.products limit: 4 -%}{%- if is_tipos -%}{%- render 'pp-product-card-row', product: p -%}{%- else -%}{%- render 'pp-product-card-standalone', product: p, image_ratio: 'portrait' -%}{%- endif -%}{%- endfor -%}
            </div>
          </div>
        {%- endfor -%}
      {%- endcapture -%}
      {%- assign rte_content = rte_content | replace: '<p>[colecciones]</p>', rte_all_colls | replace: '[colecciones]', rte_all_colls -%}
      {%- for c in rte_colls -%}
        {%- assign idx = forloop.index -%}
        {%- capture tok_c -%}[colecciones {{ idx }}]{%- endcapture -%}
        {%- capture tok_c_wrap -%}<p>[colecciones {{ idx }}]</p>{%- endcapture -%}
        {%- capture single_c -%}
          <div class="pp-blog-embed pp-blog-embed--collection">
            <a href="{{ c.url }}" class="pp-blog-embed__heading-link"><h3 class="pp-blog-embed__heading">{{ c.title }}<span class="pp-blog-embed__heading-arrow" aria-hidden="true">→</span></h3></a>
            <div class="pp-blog-embed__grid">
              {%- for p in c.products limit: 4 -%}{%- if is_tipos -%}{%- render 'pp-product-card-row', product: p -%}{%- else -%}{%- render 'pp-product-card-standalone', product: p, image_ratio: 'portrait' -%}{%- endif -%}{%- endfor -%}
            </div>
          </div>
        {%- endcapture -%}
        {%- assign rte_content = rte_content | replace: tok_c_wrap, single_c | replace: tok_c, single_c -%}
      {%- endfor -%}
    {%- endif -%}

    <div class="pp-guide__body pp-guide__body--rte rte" data-pp-guide-rte>
      <rte-formatter>
        {{ rte_content }}
      </rte-formatter>
    </div>
  {%- else -%}
    <div class="pp-guide__empty">
      <p>Esta guia aun no tiene contenido configurado.</p>
    </div>
  {%- endif -%}

  {%- comment -%} -- Product grids -- {%- endcomment -%}
  {%- assign coll_1 = page.metafields.custom.page_collection_1.value -%}
  {%- if coll_1 -%}
    <div class="pp-guide__product-grid-wrapper">
      {%- if coll_1.title != blank -%}
        <h3 class="pp-guide__product-grid-title">{{ coll_1.title }}</h3>
      {%- endif -%}
      <div class="pp-guide__product-grid">
        {%- for product in coll_1.products limit: 8 -%}
          {%- if is_tipos -%}{%- render 'pp-product-card-row', product: product -%}{%- else -%}{%- render 'pp-product-card-standalone', product: product, image_ratio: 'portrait' -%}{%- endif -%}
        {%- endfor -%}
      </div>
    </div>
  {%- endif -%}

  {%- assign coll_2 = page.metafields.custom.page_collection_2.value -%}
  {%- if coll_2 -%}
    <div class="pp-guide__product-grid-wrapper">
      {%- if coll_2.title != blank -%}
        <h3 class="pp-guide__product-grid-title">{{ coll_2.title }}</h3>
      {%- endif -%}
      <div class="pp-guide__product-grid">
        {%- for product in coll_2.products limit: 8 -%}
          {%- if is_tipos -%}{%- render 'pp-product-card-row', product: product -%}{%- else -%}{%- render 'pp-product-card-standalone', product: product, image_ratio: 'portrait' -%}{%- endif -%}
        {%- endfor -%}
      </div>
    </div>
  {%- endif -%}

  {%- assign coll_3 = page.metafields.custom.page_collection_3.value -%}
  {%- if coll_3 -%}
    <div class="pp-guide__product-grid-wrapper">
      {%- if coll_3.title != blank -%}
        <h3 class="pp-guide__product-grid-title">{{ coll_3.title }}</h3>
      {%- endif -%}
      <div class="pp-guide__product-grid">
        {%- for product in coll_3.products limit: 8 -%}
          {%- if is_tipos -%}{%- render 'pp-product-card-row', product: product -%}{%- else -%}{%- render 'pp-product-card-standalone', product: product, image_ratio: 'portrait' -%}{%- endif -%}
        {%- endfor -%}
      </div>
    </div>
  {%- endif -%}

  {%- comment -%}
    -- EXPLORA: bloque final con colecciones + páginas relacionadas (Evelin pidió enlazado interno).
    Sólo aparece si hay items en cualquiera de los dos metafields.
  {%- endcomment -%}
  {%- assign rel_colls = page.metafields.custom.colecciones_relacionadas.value -%}
  {%- assign rel_pages = page.metafields.custom.paginas_relacionadas.value -%}
  {%- assign has_rel_colls = false -%}
  {%- if rel_colls != blank and rel_colls.size > 0 -%}{%- assign has_rel_colls = true -%}{%- endif -%}
  {%- assign has_rel_pages = false -%}
  {%- if rel_pages != blank and rel_pages.size > 0 -%}{%- assign has_rel_pages = true -%}{%- endif -%}
  {%- if has_rel_colls or has_rel_pages -%}
    <div class="pp-guide__explora">
      <h2 class="pp-guide__explora-title">EXPLORA</h2>
      <div class="pp-guide__explora-grid">
        {%- if has_rel_colls -%}
          {%- for c in rel_colls -%}
            <a href="{{ c.url }}" class="pp-guide__explora-card">
              {%- if c.featured_image != blank -%}
                {{ c.featured_image | image_url: width: 600 | image_tag: class: 'pp-guide__explora-img', alt: c.title, loading: 'lazy', widths: '300, 450, 600' }}
              {%- elsif c.products.first.featured_image != blank -%}
                {{ c.products.first.featured_image | image_url: width: 600 | image_tag: class: 'pp-guide__explora-img', alt: c.title, loading: 'lazy', widths: '300, 450, 600' }}
              {%- else -%}
                <div class="pp-guide__explora-img pp-guide__explora-img--placeholder"></div>
              {%- endif -%}
              <span class="pp-guide__explora-card-title">{{ c.title }}</span>
            </a>
          {%- endfor -%}
        {%- endif -%}
        {%- if has_rel_pages -%}
          {%- for pg in rel_pages -%}
            {%- assign pg_img = pg.metafields.custom.imagen_portada.value -%}
            {%- assign pg_img_url = pg.metafields.custom.imagen_portada_url | default: '' -%}
            <a href="{{ pg.url }}" class="pp-guide__explora-card">
              {%- if pg_img -%}
                {{ pg_img | image_url: width: 600 | image_tag: class: 'pp-guide__explora-img', alt: pg.title, loading: 'lazy', widths: '300, 450, 600' }}
              {%- elsif pg_img_url != blank -%}
                <img src="{{ pg_img_url }}" alt="{{ pg.title | escape }}" class="pp-guide__explora-img" loading="lazy">
              {%- else -%}
                <div class="pp-guide__explora-img pp-guide__explora-img--placeholder"></div>
              {%- endif -%}
              <span class="pp-guide__explora-card-title">{{ pg.title }}</span>
            </a>
          {%- endfor -%}
        {%- endif -%}
      </div>
    </div>
  {%- endif -%}

  {%- comment -%} -- Fallback -- {%- endcomment -%}
  <div class="pp-guide__empty" data-pp-empty style="display:none;">
    <p>Esta guia aun no tiene contenido configurado.</p>
  </div>

</section>

<script>
(function() {
  var dataEl = document.querySelector('[data-page-content]');
  var container = document.querySelector('[data-content-container]');
  var emptyMsg = document.querySelector('[data-pp-empty]');
  if (!dataEl || !container) return;

  var widgets;
  try { widgets = JSON.parse(dataEl.textContent); } catch(e) { widgets = []; }
  dataEl.remove();

  if (!Array.isArray(widgets) || !widgets.length) {
    if (emptyMsg) emptyMsg.style.display = '';
    return;
  }

  var html = '';
  widgets.forEach(function(w) {
    if (!w || !w.type) return;

    if (w.type === 'heading') {
      html += '<h2 class="pp-content__heading">' + w.value + '</h2>';
    } else if (w.type === 'text') {
      html += '<div class="pp-content__text">' + w.value + '</div>';
    } else if (w.type === 'image') {
      html += '<div class="pp-content__image"><img src="' + w.src + '" alt="' + (w.alt || '') + '" loading="lazy"></div>';
    }
  });

  container.innerHTML = html;

  /* Collapse empty &nbsp; paragraphs */
  container.querySelectorAll('.pp-content__text p').forEach(function(p) {
    if (p.innerHTML.replace(/&nbsp;/g, '').replace(/\u00a0/g, '').trim() === '') {
      p.classList.add('pp-empty');
    }
  });
})();

/* Wrap iframes (YouTube/Vimeo/etc.) en RTE fallback con aspect-ratio responsive */
(function() {
  var container = document.querySelector('[data-pp-guide-rte]');
  if (!container) return;
  var selectors = 'iframe[src*="youtube"], iframe[src*="youtu.be"], iframe[src*="vimeo"], iframe[src*="dailymotion"], iframe[src*="tiktok"], iframe[src*="instagram"]';
  container.querySelectorAll(selectors).forEach(function(iframe) {
    if (iframe.closest('.pp-embed')) return;
    var w = parseFloat(iframe.getAttribute('width'));
    var h = parseFloat(iframe.getAttribute('height'));
    var vertical = (w > 0 && h > 0 && h > w) || (iframe.getAttribute('src') || '').indexOf('/shorts/') !== -1;
    var wrap = document.createElement('div');
    wrap.className = 'pp-embed' + (vertical ? ' pp-embed--vertical' : '');
    wrap.style.setProperty('--embed-ratio', vertical ? '9 / 16' : '16 / 9');
    iframe.removeAttribute('width');
    iframe.removeAttribute('height');
    iframe.style.width = '';
    iframe.style.height = '';
    iframe.parentNode.insertBefore(wrap, iframe);
    wrap.appendChild(iframe);
  });
})();
</script>

{% schema %}
{
  "name": "PP Page Guide",
  "tag": "section",
  "class": "pp-guide-section",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_breadcrumb",
      "label": "Show breadcrumb",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_care_icons",
      "label": "Show care icons (guia-cuidado only)",
      "default": true
    },
    {
      "type": "range",
      "id": "products_per_row",
      "min": 2,
      "max": 6,
      "step": 1,
      "label": "Products per row (desktop)",
      "default": 4
    },
    {
      "type": "header",
      "content": "Banner CTA"
    },
    {
      "type": "text",
      "id": "banner_text",
      "label": "Banner text"
    },
    {
      "type": "text",
      "id": "banner_cta_text",
      "label": "CTA button text"
    },
    {
      "type": "url",
      "id": "banner_cta_url",
      "label": "CTA button URL"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "#F5F0E8"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 60
    }
  ],
  "templates": ["page"],
  "presets": [
    {
      "name": "PP Page Guide",
      "category": "Pur Plant"
    }
  ]
}
{% endschema %}