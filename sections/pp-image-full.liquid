<section class="pp-image-full" style="
  background: {{ section.settings.bg_color }};
  padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px;
">
  {%- if section.settings.image != blank -%}
    <div class="pp-image-full__wrap" style="
      width: {{ section.settings.max_width_pct }}%;
      height: {{ section.settings.height }}px;
      {%- case section.settings.align -%}
        {%- when 'left' -%}margin: 0 auto 0 0;
        {%- when 'center' -%}margin: 0 auto;
        {%- when 'right' -%}margin: 0 0 0 auto;
      {%- endcase -%}
    ">
      {{
        section.settings.image
        | image_url: width: 1920
        | image_tag:
          loading: 'lazy',
          widths: '600, 900, 1200, 1600, 1920',
          sizes: '100vw',
          class: 'pp-image-full__img',
          style: 'object-position: ' | append: section.settings.focal_point
      }}
    </div>
  {%- else -%}
    <div class="pp-image-full__placeholder" style="
      width: {{ section.settings.max_width_pct }}%;
      height: {{ section.settings.height }}px;
      {%- case section.settings.align -%}
        {%- when 'left' -%}margin: 0 auto 0 0;
        {%- when 'center' -%}margin: 0 auto;
        {%- when 'right' -%}margin: 0 0 0 auto;
      {%- endcase -%}
    ">
      {{ 'lifestyle-1' | placeholder_svg_tag: 'pp-image-full__placeholder-svg' }}
    </div>
  {%- endif -%}
</section>

<style>
.pp-image-full__wrap,
.pp-image-full__placeholder {
  overflow: hidden;
  display: block;
}

.pp-image-full__img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}

.pp-image-full__placeholder {
  background: #e8ede8;
}

.pp-image-full__placeholder-svg {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

@media screen and (max-width: 749px) {
  .pp-image-full__wrap,
  .pp-image-full__placeholder {
    width: 100% !important;
    margin: 0 !important;
    height: {{ section.settings.height_mobile }}px !important;
  }
}
</style>

{% schema %}
{
  "name": "PP Image Full",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "select",
      "id": "focal_point",
      "label": "Focal point",
      "options": [
        { "value": "center center", "label": "Center" },
        { "value": "top center", "label": "Top" },
        { "value": "bottom center", "label": "Bottom" },
        { "value": "center left", "label": "Left" },
        { "value": "center right", "label": "Right" }
      ],
      "default": "center center"
    },
    {
      "type": "range",
      "id": "max_width_pct",
      "label": "Width (%)",
      "min": 20,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "select",
      "id": "align",
      "label": "Alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "center"
    },
    {
      "type": "range",
      "id": "height",
      "label": "Height desktop (px)",
      "min": 100,
      "max": 900,
      "step": 20,
      "unit": "px",
      "default": 500
    },
    {
      "type": "range",
      "id": "height_mobile",
      "label": "Height mobile (px)",
      "min": 100,
      "max": 700,
      "step": 20,
      "unit": "px",
      "default": 300
    },
    {
      "type": "header",
      "content": "Colors & Spacing"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "PP Image Full",
      "category": "Pur Plant",
      "settings": {
        "max_width_pct": 100,
        "align": "center",
        "height": 500,
        "height_mobile": 300,
        "padding_top": 0,
        "padding_bottom": 0
      }
    }
  ]
}
{% endschema %}
