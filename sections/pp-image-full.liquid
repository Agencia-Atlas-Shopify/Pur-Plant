<section class="pp-image-full" style="
  background: {{ section.settings.bg_color }};
  padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px;
">
  {%- assign margin_style = '' -%}
  {%- case section.settings.align -%}
    {%- when 'left' -%}{%- assign margin_style = 'margin: 0 auto 0 0;' -%}
    {%- when 'center' -%}{%- assign margin_style = 'margin: 0 auto;' -%}
    {%- when 'right' -%}{%- assign margin_style = 'margin: 0 0 0 auto;' -%}
  {%- endcase -%}

  {%- if section.settings.image != blank -%}
    <div class="pp-image-full__wrap{% if section.settings.auto_height %} pp-image-full__wrap--auto{% endif %}" style="
      width: {{ section.settings.max_width_pct }}%;
      {%- unless section.settings.auto_height -%}height: {{ section.settings.height }}px;{%- endunless -%}
      {{ margin_style }}
    ">
      {{
        section.settings.image
        | image_url: width: 1920
        | image_tag:
          loading: 'lazy',
          widths: '600, 900, 1200, 1600, 1920',
          sizes: '100vw',
          class: 'pp-image-full__img'
      }}
    </div>
  {%- else -%}
    <div class="pp-image-full__placeholder" style="
      width: {{ section.settings.max_width_pct }}%;
      height: {{ section.settings.height }}px;
      {{ margin_style }}
    ">
      {{ 'lifestyle-1' | placeholder_svg_tag: 'pp-image-full__placeholder-svg' }}
    </div>
  {%- endif -%}
</section>

<style>
.pp-image-full__wrap,
.pp-image-full__placeholder {
  overflow: hidden;
  display: block;
}

.pp-image-full__img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}

.pp-image-full__wrap--auto .pp-image-full__img {
  height: auto;
  object-fit: unset;
}

.pp-image-full__placeholder {
  background: #e8ede8;
}

.pp-image-full__placeholder-svg {
  width: 100%;
  height: 100%;
}

@media screen and (max-width: 749px) {
  .pp-image-full__wrap:not(.pp-image-full__wrap--auto),
  .pp-image-full__placeholder {
    height: {{ section.settings.height_mobile }}px !important;
  }
  .pp-image-full__wrap,
  .pp-image-full__placeholder {
    width: 100% !important;
    margin: 0 !important;
  }
}
</style>

{% schema %}
{
  "name": "PP Image Full",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "range",
      "id": "max_width_pct",
      "label": "Max width (%)",
      "min": 20,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 80
    },
    {
      "type": "select",
      "id": "align",
      "label": "Alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "center"
    },
    {
      "type": "checkbox",
      "id": "auto_height",
      "label": "Auto height (natural ratio)",
      "default": true
    },
    {
      "type": "range",
      "id": "height",
      "label": "Fixed height desktop (px)",
      "info": "Only used when Auto height is off",
      "min": 100,
      "max": 900,
      "step": 20,
      "unit": "px",
      "default": 500
    },
    {
      "type": "range",
      "id": "height_mobile",
      "label": "Fixed height mobile (px)",
      "info": "Only used when Auto height is off",
      "min": 100,
      "max": 700,
      "step": 20,
      "unit": "px",
      "default": 300
    },
    {
      "type": "header",
      "content": "Colors & Spacing"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "PP Image Full",
      "category": "Pur Plant",
      "settings": {
        "max_width_pct": 80,
        "align": "center",
        "auto_height": true,
        "height": 500,
        "height_mobile": 300,
        "padding_top": 0,
        "padding_bottom": 0
      }
    }
  ]
}
{% endschema %}
