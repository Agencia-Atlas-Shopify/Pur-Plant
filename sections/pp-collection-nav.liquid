{%- comment -%}
  PP Collection Nav — Title + collection links bar
{%- endcomment -%}

{%- style -%}
  .pp-collection-nav {
    padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px;
    border-bottom: none;
  }

  .pp-collection-nav__inner {
    padding: 0 var(--page-margin, 40px);
    display: flex;
    align-items: baseline;
    gap: 32px;
    overflow-x: auto;
    scrollbar-width: none;
    -ms-overflow-style: none;
    white-space: nowrap;
  }

  .pp-collection-nav__inner::-webkit-scrollbar {
    display: none;
  }

  .pp-collection-nav__title {
    font-family: 'Aileron', var(--font-body--family), sans-serif;
    font-size: 31.6px;
    font-weight: 900;
    color: #23372C;
    letter-spacing: -0.036em;
    margin: 0;
    flex-shrink: 0;
  }

  .pp-collection-nav__view-all {
    font-family: 'Inter', var(--font-body--family), sans-serif;
    font-size: 17.9px;
    font-weight: 400;
    color: #23372C;
    text-decoration: none;
    flex-shrink: 0;
    transition: opacity 0.2s;
  }

  .pp-collection-nav__view-all:hover {
    opacity: 0.6;
  }

  .pp-collection-nav__links {
    display: flex;
    align-items: baseline;
    gap: 32px;
  }

  .pp-collection-nav__link {
    font-family: 'Inter', var(--font-body--family), sans-serif;
    font-size: 17.9px;
    font-weight: 400;
    color: rgba(35, 55, 44, 0.6);
    text-decoration: none;
    flex-shrink: 0;
    transition: opacity 0.2s;
  }

  .pp-collection-nav__link:hover,
  .pp-collection-nav__link.is-active {
    color: #23372C;
    font-weight: 500;
  }

  .pp-collection-nav__link.is-active {
    text-decoration: underline;
    text-underline-offset: 6px;
  }

  @media screen and (max-width: 749px) {
    .pp-collection-nav__inner {
      padding: 0 20px;
      gap: 24px;
    }

    .pp-collection-nav__links {
      gap: 24px;
    }
  }
{%- endstyle -%}

<div class="pp-collection-nav">
  <div class="pp-collection-nav__inner">
    {% if section.settings.title != blank %}
      <h2 class="pp-collection-nav__title">{{ section.settings.title }}</h2>
    {% endif %}

    {% if section.settings.view_all_url != blank %}
      <a href="{{ section.settings.view_all_url }}" class="pp-collection-nav__view-all">
        {{ section.settings.view_all_text | default: 'Ver todo' }}
      </a>
    {% endif %}

    <nav class="pp-collection-nav__links" data-pp-tabs-nav>
      {% for block in section.blocks %}
        {%- liquid
          assign tab_url = block.settings.url
          assign tab_handle = ''
          if tab_url contains '/collections/'
            assign tab_handle = tab_url | split: '/collections/' | last | split: '?' | first | split: '/' | first
          endif
        -%}
        <a
          href="{{ tab_url | default: '#' }}"
          class="pp-collection-nav__link"
          {% if tab_handle != '' %}data-handle="{{ tab_handle }}"{% endif %}
          {{ block.shopify_attributes }}
        >
          {{ block.settings.label }}
        </a>
      {% endfor %}
    </nav>
  </div>
</div>

<script>
(function(){
  if (window.__ppTabsInit) return;
  window.__ppTabsInit = true;

  document.addEventListener('click', function(e){
    var link = e.target.closest('.pp-collection-nav__link[data-handle]');
    if (!link) return;
    // Only hijack if a grid target exists on the same page
    var grid = document.querySelector('[data-pp-tabs-target]');
    if (!grid) return; // Let the link navigate normally if no target
    e.preventDefault();
    var handle = link.dataset.handle;
    if (!handle) return;

    // Active state
    var nav = link.closest('[data-pp-tabs-nav]');
    if (nav) {
      nav.querySelectorAll('.pp-collection-nav__link').forEach(function(a){
        a.classList.remove('is-active');
      });
    }
    link.classList.add('is-active');

    // Loading state
    grid.classList.add('is-loading');
    grid.style.opacity = '0.4';

    fetch('/collections/' + encodeURIComponent(handle) + '?view=cards-only', {
      headers: { 'Accept': 'text/html' },
      credentials: 'same-origin'
    })
    .then(function(r){ return r.ok ? r.text() : ''; })
    .then(function(html){
      if (!html) return;
      var tmp = document.createElement('div');
      tmp.innerHTML = html;
      var cards = tmp.querySelector('[data-collection-cards]');
      if (!cards) return;
      // Replace ONLY the product-cards inside the grid, keep banners/CTAs
      var targetInner = grid.querySelector('[data-pp-tabs-items]') || grid;
      targetInner.innerHTML = cards.innerHTML;
    })
    .catch(function(){ /* noop */ })
    .finally(function(){
      grid.classList.remove('is-loading');
      grid.style.opacity = '';
    });
  });
})();
</script>

{% schema %}
{
  "name": "PP Collection Nav",
  "class": "pp-collection-nav-section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "MUST"
    },
    {
      "type": "text",
      "id": "view_all_text",
      "label": "View all text",
      "default": "Ver todo"
    },
    {
      "type": "url",
      "id": "view_all_url",
      "label": "View all link"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 60,
      "step": 4,
      "unit": "px",
      "default": 24
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 60,
      "step": 4,
      "unit": "px",
      "default": 16
    }
  ],
  "blocks": [
    {
      "type": "collection_link",
      "name": "Collection link",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Interior"
        },
        {
          "type": "url",
          "id": "url",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "PP Collection Nav",
      "category": "Pur Plant",
      "settings": {
        "title": "MUST",
        "view_all_text": "Ver todo"
      },
      "blocks": [
        { "type": "collection_link", "settings": { "label": "Interior" } },
        { "type": "collection_link", "settings": { "label": "Exterior" } },
        { "type": "collection_link", "settings": { "label": "Cuidados" } },
        { "type": "collection_link", "settings": { "label": "Macetas" } },
        { "type": "collection_link", "settings": { "label": "Accesorios" } },
        { "type": "collection_link", "settings": { "label": "Autorriegos" } },
        { "type": "collection_link", "settings": { "label": "Abonos" } }
      ]
    }
  ]
}
{% endschema %}
