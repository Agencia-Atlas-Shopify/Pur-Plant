{{ 'pp-sections.css' | asset_url | stylesheet_tag }}

<section class="pp-trust-badges">
  {%- if section.settings.heading != blank -%}
    <h2 class="pp-trust-badges__heading">{{ section.settings.heading }}</h2>
  {%- endif -%}

  <div class="pp-trust-badges__grid">
    {%- for block in section.blocks -%}
      <div class="pp-trust-badges__item" {{ block.shopify_attributes }}>
        {%- if block.settings.icon != blank -%}
          <img
            src="{{ block.settings.icon | image_url: width: 200 }}"
            alt="{{ block.settings.title }}"
            width="100"
            height="100"
            loading="lazy"
            class="pp-trust-badges__icon"
          >
        {%- endif -%}
        {%- if block.settings.title != blank -%}
          <h3 class="pp-trust-badges__title">{{ block.settings.title }}</h3>
        {%- endif -%}
        {%- if block.settings.description != blank -%}
          <p class="pp-trust-badges__desc">{{ block.settings.description }}</p>
        {%- endif -%}
      </div>
    {%- endfor -%}
  </div>
</section>

{% schema %}
{
  "name": "PP Trust Badges",
  "tag": "section",
  "class": "pp-trust-badges-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "POR QUÉ COMPRAR EN PUR PLANT"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 40
    }
  ],
  "blocks": [
    {
      "type": "badge",
      "name": "Badge",
      "settings": [
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Icon"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Envíos rápidos y seguros"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "PP Trust Badges",
      "category": "Pur Plant",
      "blocks": [
        { "type": "badge", "settings": { "title": "ENVÍOS RÁPIDOS Y SEGUROS" } },
        { "type": "badge", "settings": { "title": "SIEMPRE CONTIGO" } },
        { "type": "badge", "settings": { "title": "CALIDAD PREMIUM" } }
      ]
    }
  ]
}
{% endschema %}
