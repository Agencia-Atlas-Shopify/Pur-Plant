<style>
  .pp-footer {
    background: #23372c;
    color: #e4ffd3;
    padding: 80px var(--page-margin, 40px) 40px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0;
    min-height: 400px;
    justify-content: space-between;
  }

  .pp-footer__logo {
    align-self: flex-start;
    margin-bottom: auto;
  }

  .pp-footer__logo img {
    width: 60px;
    height: 60px;
    border-radius: 50%;
    display: block;
  }

  .pp-footer__bottom {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 28px;
    width: 100%;
  }

  .pp-footer__social {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 32px;
    flex-wrap: wrap;
  }

  .pp-footer__social a {
    font-family: 'Tenor Sans', Georgia, serif;
    font-size: 14px;
    font-weight: 400;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #e4ffd3;
    text-decoration: none;
    transition: opacity 0.2s;
  }

  .pp-footer__social a:hover {
    opacity: 0.6;
  }

  .pp-footer__legal {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 28px;
    flex-wrap: wrap;
  }

  .pp-footer__legal a {
    font-family: 'Inter', sans-serif;
    font-size: 15px;
    font-weight: 400;
    color: #e4ffd3;
    text-decoration: none;
    opacity: 0.8;
    transition: opacity 0.2s;
  }

  .pp-footer__legal a:hover {
    opacity: 1;
  }

  .pp-footer__contact {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
  }

  .pp-footer__contact-logo {
    width: 24px;
    height: 24px;
    border-radius: 50%;
    display: block;
  }

  .pp-footer__whatsapp {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-family: 'Inter', sans-serif;
    font-size: 13px;
    font-weight: 500;
    color: #e4ffd3;
    text-decoration: none;
    transition: opacity 0.2s;
  }

  .pp-footer__whatsapp:hover {
    opacity: 0.7;
  }

  .pp-footer__payments {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    flex-wrap: wrap;
  }

  .pp-footer__payment-icon {
    height: 24px;
    width: auto;
    opacity: 0.7;
    transition: opacity 0.2s;
  }

  .pp-footer__payment-icon:hover {
    opacity: 1;
  }

  .pp-footer__copyright {
    font-family: 'Inter', sans-serif;
    font-size: 12px;
    font-weight: 400;
    color: #e4ffd3;
    opacity: 0.6;
    letter-spacing: 0.05em;
  }

  @media screen and (max-width: 749px) {
    .pp-footer {
      padding: 60px 20px 30px;
      min-height: 320px;
    }

    .pp-footer__social {
      gap: 20px;
    }

    .pp-footer__social a {
      font-size: 12px;
    }

    .pp-footer__legal {
      gap: 16px;
    }

    .pp-footer__legal a {
      font-size: 12px;
    }
  }
</style>

<footer class="pp-footer">
  <div class="pp-footer__logo">
    {%- if section.settings.logo != blank -%}
      <img src="{{ section.settings.logo | image_url: width: 120 }}" alt="Pur Plant" width="60" height="60">
    {%- else -%}
      <img src="{{ 'logo_pur_plant_isotipo.png' | asset_url }}" alt="Pur Plant" width="60" height="60">
    {%- endif -%}
  </div>

  <div class="pp-footer__bottom">
    <nav class="pp-footer__social">
      {%- if section.settings.instagram_url != blank -%}
        <a href="{{ section.settings.instagram_url }}" target="_blank" rel="noopener">Instagram</a>
      {%- endif -%}
      {%- if section.settings.tiktok_url != blank -%}
        <a href="{{ section.settings.tiktok_url }}" target="_blank" rel="noopener">Tik Tok</a>
      {%- endif -%}
      {%- if section.settings.pinterest_url != blank -%}
        <a href="{{ section.settings.pinterest_url }}" target="_blank" rel="noopener">Pinterest</a>
      {%- endif -%}
      {%- if section.settings.facebook_url != blank -%}
        <a href="{{ section.settings.facebook_url }}" target="_blank" rel="noopener">Facebook</a>
      {%- endif -%}
      {%- if section.settings.youtube_url != blank -%}
        <a href="{{ section.settings.youtube_url }}" target="_blank" rel="noopener">YouTube</a>
      {%- endif -%}
    </nav>

    {%- if section.settings.legal_menu != blank -%}
      <nav class="pp-footer__legal">
        {%- for link in section.settings.legal_menu.links -%}
          <a href="{{ link.url }}">{{ link.title }}</a>
        {%- endfor -%}
      </nav>
    {%- endif -%}

    <div class="pp-footer__payments">
      {%- for type in shop.enabled_payment_types -%}
        {{ type | payment_type_svg_tag: class: 'pp-footer__payment-icon' }}
      {%- endfor -%}
      <svg class="pp-footer__payment-icon" viewBox="0 0 38 24" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="Bizum">
        <rect width="38" height="24" rx="3" fill="#fff"/>
        <text x="19" y="15.5" text-anchor="middle" font-family="Inter,sans-serif" font-size="8" font-weight="700" fill="#05C3DD" letter-spacing="0.3">BIZUM</text>
      </svg>
    </div>

    <div class="pp-footer__contact">
      {%- if section.settings.logo != blank -%}
        <img src="{{ section.settings.logo | image_url: width: 48 }}" alt="Pur Plant" width="24" height="24" class="pp-footer__contact-logo" loading="lazy">
      {%- else -%}
        <img src="{{ 'logo_pur_plant_isotipo.png' | asset_url }}" alt="Pur Plant" width="24" height="24" class="pp-footer__contact-logo" loading="lazy">
      {%- endif -%}
      <a href="https://wa.me/34667279907" target="_blank" rel="noopener" class="pp-footer__whatsapp" aria-label="WhatsApp">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893A11.821 11.821 0 0 0 20.885 3.488"/>
        </svg>
        667 279 907
      </a>
    </div>

    <span class="pp-footer__copyright">Pur Plant &copy; {{ 'now' | date: '%Y' }}</span>
  </div>
</footer>

{% schema %}
{
  "name": "PP Footer",
  "tag": "section",
  "class": "pp-footer-section",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo (isotipo)"
    },
    {
      "type": "link_list",
      "id": "legal_menu",
      "label": "Legal menu"
    },
    {
      "type": "header",
      "content": "Social links"
    },
    {
      "type": "url",
      "id": "instagram_url",
      "label": "Instagram"
    },
    {
      "type": "url",
      "id": "tiktok_url",
      "label": "TikTok"
    },
    {
      "type": "url",
      "id": "pinterest_url",
      "label": "Pinterest"
    },
    {
      "type": "url",
      "id": "facebook_url",
      "label": "Facebook"
    },
    {
      "type": "url",
      "id": "youtube_url",
      "label": "YouTube"
    }
  ],
  "presets": [
    {
      "name": "PP Footer",
      "category": "Pur Plant"
    }
  ]
}
{% endschema %}
