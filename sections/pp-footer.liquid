<style>
  .pp-footer {
    background: #23372c;
    color: #e4ffd3;
    padding: 60px var(--page-margin, 40px) 32px;
    display: flex;
    flex-direction: column;
    gap: 48px;
  }

  .pp-footer__top {
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: start;
    gap: 64px;
  }

  .pp-footer__brand {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 18px;
  }

  .pp-footer__logo img {
    width: 90px;
    height: 90px;
    border-radius: 50%;
    display: block;
  }

  .pp-footer__reviews {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 10px 14px;
    border: 1px solid rgba(228,255,211,0.25);
    border-radius: 10px;
    text-decoration: none;
    color: inherit;
  }

  .pp-footer__reviews-stars {
    color: #ffb400;
    font-size: 14px;
    letter-spacing: 1px;
  }

  .pp-footer__reviews-text {
    font-family: 'Inter', sans-serif;
    font-size: 12px;
    line-height: 1.3;
    color: #e4ffd3;
  }

  .pp-footer__reviews-text strong {
    font-size: 14px;
    font-weight: 600;
    display: block;
  }

  .pp-footer__promo {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .pp-footer__promo-img img {
    width: 100%;
    max-width: 280px;
    height: auto;
    border-radius: 10px;
    display: block;
  }

  .pp-footer__promo-text {
    font-family: 'Inter', sans-serif;
    font-size: 14px;
    line-height: 1.4;
    color: #e4ffd3;
    margin: 0;
  }

  .pp-footer__cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 10px 20px;
    background: #e4ffd3;
    color: #23372c;
    border-radius: 999px;
    font-family: 'Inter', sans-serif;
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    text-decoration: none;
    transition: opacity 0.15s;
  }

  .pp-footer__cta:hover { opacity: 0.85; }

  .pp-footer__cta--outline {
    background: transparent;
    color: #e4ffd3;
    border: 1px solid #e4ffd3;
  }

  .pp-footer__contact-block {
    font-family: 'Inter', sans-serif;
    font-size: 14px;
    line-height: 1.6;
    color: #e4ffd3;
    margin: 0;
  }

  .pp-footer__contact-block a {
    color: inherit;
    text-decoration: none;
  }

  .pp-footer__contact-block a:hover { text-decoration: underline; }

  /* Cols stacked vertically as accordions on all breakpoints */
  .pp-footer__cols {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 0;
    border-top: 1px solid rgba(228,255,211,0.15);
  }

  .pp-footer__col {
    border-bottom: 1px solid rgba(228,255,211,0.15);
  }

  .pp-footer__col-heading {
    font-family: 'Tenor Sans', Georgia, serif;
    font-size: 13px;
    font-weight: 400;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #e4ffd3;
    margin: 0;
    line-height: 1.3;
  }

  .pp-footer__col-toggle {
    display: flex;
    width: 100%;
    background: none;
    border: none;
    padding: 16px 0;
    cursor: pointer;
    text-align: left;
    color: inherit;
    align-items: center;
    justify-content: space-between;
  }

  .pp-footer__col-toggle-icon {
    display: block;
    font-size: 20px;
    line-height: 1;
    color: #e4ffd3;
    opacity: 0.6;
    transition: transform 0.2s;
    flex-shrink: 0;
  }

  .pp-footer__col.is-open .pp-footer__col-toggle-icon {
    transform: rotate(45deg);
    opacity: 1;
  }

  .pp-footer__col-content {
    display: none;
    padding: 0 0 16px;
  }

  .pp-footer__col.is-open .pp-footer__col-content {
    display: block;
  }

  .pp-footer__col ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .pp-footer__col a,
  .pp-footer__col p {
    font-family: 'Inter', sans-serif;
    font-size: 14px;
    font-weight: 400;
    color: #e4ffd3;
    text-decoration: none;
    opacity: 0.85;
    margin: 0;
    line-height: 1.5;
    transition: opacity 0.2s;
  }

  .pp-footer__col a:hover { opacity: 1; }

  /* Sub-links (2nd level menu) */
  .pp-footer__sub-links {
    list-style: none;
    margin: 6px 0 0;
    padding: 0 0 0 10px;
    display: flex;
    flex-direction: column;
    gap: 6px;
    border-left: 1px solid rgba(228,255,211,0.2);
  }

  .pp-footer__sub-links a {
    font-size: 13px;
    opacity: 0.65;
  }

  .pp-footer__contact-text {
    white-space: pre-line;
  }

  /* ── Bottom bar ── */
  .pp-footer__bottom {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 24px;
    width: 100%;
    border-top: 1px solid rgba(228, 255, 211, 0.15);
    padding-top: 28px;
  }

  .pp-footer__social {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 28px;
    flex-wrap: wrap;
  }

  .pp-footer__social a {
    font-family: 'Tenor Sans', Georgia, serif;
    font-size: 13px;
    font-weight: 400;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #e4ffd3;
    text-decoration: none;
    transition: opacity 0.2s;
  }

  .pp-footer__social a:hover { opacity: 0.6; }

  .pp-footer__legal {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 24px;
    flex-wrap: wrap;
  }

  .pp-footer__legal a {
    font-family: 'Inter', sans-serif;
    font-size: 13px;
    color: #e4ffd3;
    text-decoration: none;
    opacity: 0.75;
    transition: opacity 0.2s;
  }

  .pp-footer__legal a:hover { opacity: 1; }

  .pp-footer__contact-bar {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
  }

  .pp-footer__contact-logo {
    width: 22px;
    height: 22px;
    border-radius: 50%;
    display: block;
  }

  .pp-footer__whatsapp {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-family: 'Inter', sans-serif;
    font-size: 13px;
    font-weight: 500;
    color: #e4ffd3;
    text-decoration: none;
    transition: opacity 0.2s;
  }

  .pp-footer__whatsapp:hover { opacity: 0.7; }

  .pp-footer__payments {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    flex-wrap: wrap;
  }

  .pp-footer__payment-icon {
    height: 22px;
    width: auto;
    opacity: 0.7;
    transition: opacity 0.2s;
  }

  .pp-footer__payment-icon:hover { opacity: 1; }

  .pp-footer__copyright {
    font-family: 'Inter', sans-serif;
    font-size: 12px;
    color: #e4ffd3;
    opacity: 0.6;
    letter-spacing: 0.05em;
  }

  /* ── Responsive ── */
  @media screen and (max-width: 999px) {
    .pp-footer__top {
      grid-template-columns: 1fr;
      gap: 40px;
    }
    .pp-footer__brand { align-items: center; text-align: center; }
    .pp-footer__promo-img img { margin: 0 auto; }
  }

  @media screen and (max-width: 749px) {
    .pp-footer { padding: 48px 20px 24px; gap: 36px; }
    .pp-footer__col-toggle { padding: 14px 0; }
    .pp-footer__logo img { width: 70px; height: 70px; }
    .pp-footer__social { gap: 18px; }
    .pp-footer__social a { font-size: 12px; }
    .pp-footer__legal { gap: 14px; }
    .pp-footer__legal a { font-size: 12px; }
  }
</style>

<footer class="pp-footer">
  <div class="pp-footer__top">
    <div class="pp-footer__brand">
      <div class="pp-footer__logo">
        {%- if section.settings.logo != blank -%}
          <img src="{{ section.settings.logo | image_url: width: 180 }}" alt="Pur Plant" width="90" height="90">
        {%- else -%}
          <img src="{{ 'logo_pur_plant_isotipo.png' | asset_url }}" alt="Pur Plant" width="90" height="90">
        {%- endif -%}
      </div>

      {%- comment -%} Reviews badge — auto from Judge.me, fallback to manual {%- endcomment -%}
      {%- liquid
        assign jdg_rating = shop.metafields.judgeme.all_reviews_rating
        assign jdg_count = shop.metafields.judgeme.all_reviews_count
        assign reviews_rating_val = section.settings.reviews_rating
        assign reviews_count_val = section.settings.reviews_count
        if jdg_rating != blank and jdg_rating != '0.00' and jdg_rating != '0'
          assign reviews_rating_val = jdg_rating | times: 1.0 | round: 1
        endif
        if jdg_count != blank and jdg_count != '0'
          assign reviews_count_val = jdg_count | append: ' reseñas'
        endif
        assign has_reviews = false
        if reviews_rating_val != blank and reviews_count_val != blank
          assign has_reviews = true
        endif
      -%}
      {%- if has_reviews -%}
        <a class="pp-footer__reviews" href="{{ section.settings.reviews_url | default: '#' }}"{% if section.settings.reviews_url != blank %} target="_blank" rel="noopener"{% endif %}>
          <span class="pp-footer__reviews-stars" aria-hidden="true">★★★★★</span>
          <span class="pp-footer__reviews-text">
            <strong>{{ reviews_rating_val }}</strong>
            {{ reviews_count_val }}
          </span>
        </a>
      {%- endif -%}

      {%- if section.settings.promo_image != blank or section.settings.promo_text != blank -%}
        <div class="pp-footer__promo">
          {%- if section.settings.promo_image != blank -%}
            <div class="pp-footer__promo-img">
              {%- if section.settings.promo_link != blank -%}
                <a href="{{ section.settings.promo_link }}">
                  <img src="{{ section.settings.promo_image | image_url: width: 560 }}" alt="{{ section.settings.promo_text | strip_html | escape }}" loading="lazy">
                </a>
              {%- else -%}
                <img src="{{ section.settings.promo_image | image_url: width: 560 }}" alt="{{ section.settings.promo_text | strip_html | escape }}" loading="lazy">
              {%- endif -%}
            </div>
          {%- endif -%}
          {%- if section.settings.promo_text != blank -%}
            <p class="pp-footer__promo-text">{{ section.settings.promo_text }}</p>
          {%- endif -%}
        </div>
      {%- endif -%}

      {%- if section.settings.cta1_label != blank and section.settings.cta1_link != blank -%}
        <a class="pp-footer__cta" href="{{ section.settings.cta1_link }}">{{ section.settings.cta1_label }}</a>
      {%- endif -%}

      {%- if section.settings.cta2_label != blank and section.settings.cta2_link != blank -%}
        <a class="pp-footer__cta pp-footer__cta--outline" href="{{ section.settings.cta2_link }}">{{ section.settings.cta2_label }}</a>
      {%- endif -%}

      {%- if section.settings.contact_text != blank -%}
        <p class="pp-footer__contact-block">{{ section.settings.contact_text }}</p>
      {%- endif -%}
    </div>

    <div class="pp-footer__cols">
      {%- for block in section.blocks -%}
        <div class="pp-footer__col" {{ block.shopify_attributes }}>
          {%- if block.settings.heading != blank -%}
            <button class="pp-footer__col-toggle" type="button" aria-expanded="false">
              <h3 class="pp-footer__col-heading">{{ block.settings.heading }}</h3>
              <span class="pp-footer__col-toggle-icon" aria-hidden="true">+</span>
            </button>
          {%- endif -%}

          <div class="pp-footer__col-content">
            {%- case block.type -%}
              {%- when 'links_column' -%}
                {%- if block.settings.menu != blank -%}
                  <ul>
                    {%- for link in block.settings.menu.links -%}
                      <li>
                        <a href="{{ link.url }}">{{ link.title }}</a>
                        {%- if link.links.size > 0 -%}
                          <ul class="pp-footer__sub-links">
                            {%- for child in link.links -%}
                              <li><a href="{{ child.url }}">{{ child.title }}</a></li>
                            {%- endfor -%}
                          </ul>
                        {%- endif -%}
                      </li>
                    {%- endfor -%}
                  </ul>
                {%- endif -%}
              {%- when 'contact_column' -%}
                {%- if block.settings.content != blank -%}
                  <p class="pp-footer__contact-text">{{ block.settings.content }}</p>
                {%- endif -%}
            {%- endcase -%}
          </div>
        </div>
      {%- endfor -%}
    </div>
  </div>

  <div class="pp-footer__bottom">
    <nav class="pp-footer__social">
      {%- if section.settings.instagram_url != blank -%}<a href="{{ section.settings.instagram_url }}" target="_blank" rel="noopener">Instagram</a>{%- endif -%}
      {%- if section.settings.tiktok_url != blank -%}<a href="{{ section.settings.tiktok_url }}" target="_blank" rel="noopener">Tik Tok</a>{%- endif -%}
      {%- if section.settings.pinterest_url != blank -%}<a href="{{ section.settings.pinterest_url }}" target="_blank" rel="noopener">Pinterest</a>{%- endif -%}
      {%- if section.settings.facebook_url != blank -%}<a href="{{ section.settings.facebook_url }}" target="_blank" rel="noopener">Facebook</a>{%- endif -%}
      {%- if section.settings.youtube_url != blank -%}<a href="{{ section.settings.youtube_url }}" target="_blank" rel="noopener">YouTube</a>{%- endif -%}
    </nav>

    {%- if section.settings.legal_menu != blank -%}
      <nav class="pp-footer__legal">
        {%- for link in section.settings.legal_menu.links -%}
          <a href="{{ link.url }}">{{ link.title }}</a>
        {%- endfor -%}
      </nav>
    {%- endif -%}

    <div class="pp-footer__payments">
      {%- for type in shop.enabled_payment_types -%}
        {{ type | payment_type_svg_tag: class: 'pp-footer__payment-icon' }}
      {%- endfor -%}
      <svg class="pp-footer__payment-icon" viewBox="0 0 38 24" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="Bizum">
        <rect width="38" height="24" rx="3" fill="#fff"/>
        <text x="19" y="15.5" text-anchor="middle" font-family="Inter,sans-serif" font-size="8" font-weight="700" fill="#05C3DD" letter-spacing="0.3">BIZUM</text>
      </svg>
    </div>

    <div class="pp-footer__contact-bar">
      {%- if section.settings.logo != blank -%}
        <img src="{{ section.settings.logo | image_url: width: 48 }}" alt="Pur Plant" width="22" height="22" class="pp-footer__contact-logo" loading="lazy">
      {%- else -%}
        <img src="{{ 'logo_pur_plant_isotipo.png' | asset_url }}" alt="Pur Plant" width="22" height="22" class="pp-footer__contact-logo" loading="lazy">
      {%- endif -%}
      <a href="https://wa.me/34667279907" target="_blank" rel="noopener" class="pp-footer__whatsapp" aria-label="WhatsApp">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893A11.821 11.821 0 0 0 20.885 3.488"/>
        </svg>
        667 279 907
      </a>
    </div>

    <span class="pp-footer__copyright">Pur Plant &copy; {{ 'now' | date: '%Y' }}</span>
  </div>
</footer>

<script>
(function() {
  function initAccordions() {
    var cols = document.querySelectorAll('.pp-footer .pp-footer__col');
    cols.forEach(function(col, i) {
      // First column open by default
      if (i === 0) {
        col.classList.add('is-open');
        var firstBtn = col.querySelector('.pp-footer__col-toggle');
        if (firstBtn) firstBtn.setAttribute('aria-expanded', 'true');
      }
    });
    document.querySelectorAll('.pp-footer__col-toggle').forEach(function(btn) {
      btn.addEventListener('click', function() {
        var col = btn.closest('.pp-footer__col');
        var open = col.classList.toggle('is-open');
        btn.setAttribute('aria-expanded', open ? 'true' : 'false');
      });
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initAccordions);
  } else {
    initAccordions();
  }
})();
</script>

{% schema %}
{
  "name": "PP Footer",
  "tag": "section",
  "class": "pp-footer-section",
  "max_blocks": 8,
  "settings": [
    { "type": "image_picker", "id": "logo", "label": "Logo (isotipo)" },
    { "type": "link_list", "id": "legal_menu", "label": "Legal menu" },

    { "type": "header", "content": "Reseñas (auto Judge.me)", "info": "Los valores se leen automáticamente de Judge.me. Los campos manuales solo se usan como fallback si Judge.me no está disponible." },
    { "type": "url", "id": "reviews_url", "label": "URL reseñas (opcional, link del badge)" },
    { "type": "text", "id": "reviews_rating", "label": "Fallback — nota" },
    { "type": "text", "id": "reviews_count", "label": "Fallback — texto nº reseñas" },

    { "type": "header", "content": "Promo (tarjeta regalo, ofertas…)" },
    { "type": "image_picker", "id": "promo_image", "label": "Imagen promo" },
    { "type": "url", "id": "promo_link", "label": "Enlace imagen" },
    { "type": "textarea", "id": "promo_text", "label": "Texto promo", "default": "¿Te gustaría hacer un Regalo Verde a esa Persona Especial?" },
    { "type": "text", "id": "cta1_label", "label": "Botón 1 — texto", "default": "TARJETA REGALO" },
    { "type": "url", "id": "cta1_link", "label": "Botón 1 — enlace" },
    { "type": "text", "id": "cta2_label", "label": "Botón 2 — texto", "default": "OFERTAS FLASH" },
    { "type": "url", "id": "cta2_link", "label": "Botón 2 — enlace" },

    { "type": "header", "content": "Contacto" },
    { "type": "richtext", "id": "contact_text", "label": "Texto contacto", "default": "<p>667 279 907<br>info@purplant.es</p>" },

    { "type": "header", "content": "Social links" },
    { "type": "url", "id": "instagram_url", "label": "Instagram" },
    { "type": "url", "id": "tiktok_url", "label": "TikTok" },
    { "type": "url", "id": "pinterest_url", "label": "Pinterest" },
    { "type": "url", "id": "facebook_url", "label": "Facebook" },
    { "type": "url", "id": "youtube_url", "label": "YouTube" }
  ],
  "blocks": [
    {
      "type": "links_column",
      "name": "Columna de enlaces",
      "settings": [
        { "type": "text", "id": "heading", "label": "Heading", "default": "Columna" },
        { "type": "link_list", "id": "menu", "label": "Menú" }
      ]
    },
    {
      "type": "contact_column",
      "name": "Contacto / texto",
      "limit": 2,
      "settings": [
        { "type": "text", "id": "heading", "label": "Heading", "default": "CONTÁCTANOS" },
        { "type": "textarea", "id": "content", "label": "Contenido", "default": "info@purplant.es\n667 279 907\nL-V 8:00 - 17:00" }
      ]
    }
  ],
  "presets": [
    {
      "name": "PP Footer",
      "category": "Pur Plant",
      "blocks": [
        { "type": "links_column", "settings": { "heading": "¿DÓNDE ESTÁ MI PEDIDO?" } },
        { "type": "links_column", "settings": { "heading": "PLANTAS QUE ENGANCHAN" } },
        { "type": "contact_column", "settings": { "heading": "CONTÁCTANOS", "content": "info@purplant.es\n667 279 907\nL-V 8:00 - 17:00" } },
        { "type": "links_column", "settings": { "heading": "SOBRE NOSOTRXS" } },
        { "type": "links_column", "settings": { "heading": "PLANTAS A DOMICILIO" } },
        { "type": "links_column", "settings": { "heading": "ÁRBOLES A DOMICILIO" } },
        { "type": "links_column", "settings": { "heading": "FLORES" } }
      ]
    }
  ]
}
{% endschema %}
