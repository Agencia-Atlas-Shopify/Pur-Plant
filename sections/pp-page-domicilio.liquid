{%- comment -%}
  PP Page Domicilio — Renders city delivery landing pages (plantas-domicilio, flores-domicilio)
  Reads content from page.metafields.custom.page_content JSON array.
  Widget types: heading, text (raw HTML), image.
  Also uses: page_type, page_collection_1..3.
  Features hero header, trust badges, CTA buttons.
{%- endcomment -%}

{{ 'pp-page-guide.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign page_type = page.metafields.custom.page_type | default: ''
  assign products_per_row = section.settings.products_per_row | default: 4
  assign is_flores = false
  assign is_arboles = false
  assign is_macetas = false
  assign is_campaign = false
  if page_type == 'flores-domicilio'
    assign is_flores = true
  elsif page_type == 'arboles-domicilio'
    assign is_arboles = true
  elsif page_type == 'macetas-domicilio'
    assign is_macetas = true
  elsif page_type == 'campaign'
    assign is_campaign = true
  endif
  # Auto-detect por handle si el metafield no está set (macetas-a-domicilio*)
  if page_type == blank and page.handle contains 'macetas-a-domicilio'
    assign is_macetas = true
  endif

  # Parent landing for breadcrumb 2nd level + "Ver plantas" CTA fallback (avoid self-ref)
  assign parent_label = 'Plantas a Domicilio'
  assign parent_url = '/pages/plantas-a-domicilio'
  if is_flores
    assign parent_label = 'Flores a Domicilio'
    assign parent_url = '/pages/flores-a-domicilio'
  elsif is_arboles
    assign parent_label = 'Árboles a Domicilio'
    assign parent_url = '/pages/arboles'
  elsif is_macetas
    assign parent_label = 'Macetas a Domicilio'
    assign parent_url = '/pages/macetas-a-domicilio'
  elsif is_campaign
    assign parent_label = 'Ofertas'
    assign parent_url = '/collections/all'
  endif
  assign is_parent_page = false
  if page.url == parent_url
    assign is_parent_page = true
  endif

  # CTA target: admin override → else parent landing. Hide CTA on the parent itself.
  assign cta_url = section.settings.banner_cta_url
  if cta_url == blank
    assign cta_url = parent_url
  endif
-%}

<style>
  /* --- PP Page Domicilio: collection-style header (H1 usa .pp-coll-title__heading global) --- */
  .pp-domicilio .pp-coll-title__heading {
    margin: 0 0 8px;
  }
  /* breadcrumb estilo colección (pp-coll-breadcrumb no es global) */
  .pp-domicilio .pp-coll-breadcrumb {
    font-family: 'Inter', sans-serif;
    font-size: 12px;
    color: #6b7d72;
    margin: 0 0 28px;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 4px;
  }
  .pp-domicilio .pp-coll-breadcrumb a { color: #6b7d72; text-decoration: none; }
  .pp-domicilio .pp-coll-breadcrumb a:hover { text-decoration: underline; color: #23372c; }
  .pp-domicilio .pp-coll-breadcrumb span[aria-hidden] { opacity: 0.5; }
  .pp-domicilio .pp-coll-breadcrumb .pp-coll-breadcrumb__current { color: #23372c; font-weight: 500; }
  @media (max-width: 600px) { .pp-domicilio .pp-coll-breadcrumb { font-size: 11px; } }


  /* --- Content widget styles --- */
  .pp-domicilio .pp-content__heading {
    font-family: 'Aileron', sans-serif;
    font-size: clamp(22px, 3vw, 30px);
    font-weight: 800;
    color: #23372c;
    line-height: 1.2;
    margin: 36px 0 15px;
    text-transform: lowercase;
  }
  .pp-domicilio .pp-content__heading::first-letter {
    text-transform: uppercase;
  }

  .pp-domicilio .pp-content__heading:first-child {
    margin-top: 0;
  }

  .pp-domicilio .pp-content__text {
    font-family: var(--pp-font-body);
    font-size: 15px;
    font-weight: 400;
    color: var(--pp-dark-green);
    line-height: 1.75;
    margin: 0 0 24px;
    opacity: 0.85;
  }

  .pp-domicilio .pp-content__text p { margin: 0 0 16px; }
  .pp-domicilio .pp-content__text p.pp-empty { margin: 0; line-height: 0; font-size: 0; }
  .pp-domicilio .pp-content__text p:last-child { margin-bottom: 0; }
  .pp-domicilio .pp-content__text ul,
  .pp-domicilio .pp-content__text ol { margin: 0 0 16px; padding-left: 24px; }
  .pp-domicilio .pp-content__text li { margin-bottom: 6px; }
  .pp-domicilio .pp-content__text a { color: var(--pp-dark-green); text-decoration: underline; }
  .pp-domicilio .pp-content__text strong { font-weight: 600; }

  /* Paired row: text 60% + image 40%, alternating left/right */
  .pp-domicilio .pp-content__row {
    display: grid;
    grid-template-columns: 3fr 2fr;
    gap: 40px;
    align-items: center;
    margin: 40px 0;
  }
  .pp-domicilio .pp-content__row--reverse { grid-template-columns: 2fr 3fr; }
  .pp-domicilio .pp-content__row--reverse .pp-content__row-text { order: 2; }
  .pp-domicilio .pp-content__row--reverse .pp-content__row-image { order: 1; }
  .pp-domicilio .pp-content__row-text > :first-child { margin-top: 0; }
  .pp-domicilio .pp-content__row-text > :last-child { margin-bottom: 0; }

  .pp-domicilio .pp-content__image {
    margin: 0;
  }
  .pp-domicilio .pp-content__image img {
    width: 100%;
    height: auto;
    max-height: 420px;
    object-fit: cover;
    border-radius: var(--pp-radius, 8px);
    display: block;
  }

  @media screen and (max-width: 749px) {
    .pp-domicilio .pp-content__row,
    .pp-domicilio .pp-content__row--reverse {
      grid-template-columns: 1fr;
      gap: 20px;
      margin: 28px 0;
    }
    .pp-domicilio .pp-content__row--reverse .pp-content__row-text { order: 2; }
    .pp-domicilio .pp-content__row--reverse .pp-content__row-image { order: 1; }
    .pp-domicilio .pp-content__image img { max-height: 320px; }
  }

  /* --- Product grid --- */
  .pp-domicilio__product-grid-wrapper {
    margin: 24px 0;
    padding: 16px 0;
    border-bottom: 1px solid rgba(35, 55, 44, 0.1);
  }

  .pp-domicilio__product-grid-title {
    font-family: var(--pp-font-heading);
    font-size: clamp(20px, 2.5vw, 28px);
    font-weight: 400;
    color: var(--pp-dark-green);
    margin: 0 0 24px;
    text-align: center;
  }

  .pp-domicilio__product-grid {
    display: grid;
    grid-template-columns: repeat(var(--pp-products-per-row, 4), 1fr);
    gap: 20px;
  }

  /* --- Bottom CTA banner --- */
  .pp-domicilio__banner {
    background: var(--pp-dark-green);
    border-radius: var(--pp-radius);
    padding: 48px 40px;
    text-align: center;
    margin-top: 56px;
  }

  .pp-domicilio__banner-text {
    font-family: var(--pp-font-heading);
    font-size: clamp(22px, 3vw, 32px);
    font-weight: 400;
    color: #DAFFD3;
    line-height: 1.3;
    margin: 0 0 24px;
  }

  .pp-domicilio__banner-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: var(--pp-light-green);
    color: var(--pp-dark-green);
    font-family: var(--pp-font-section);
    font-size: 14px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    padding: 14px 32px;
    border-radius: 100px;
    text-decoration: none;
    transition: transform var(--pp-transition), opacity var(--pp-transition);
  }

  .pp-domicilio__banner-btn:hover {
    transform: translateY(-2px);
    opacity: 0.9;
  }

  @media screen and (max-width: 989px) {
    .pp-domicilio__product-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media screen and (max-width: 749px) {
    .pp-domicilio__product-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 12px;
    }

    .pp-domicilio__product-grid-wrapper {
      margin: 18px 0;
      padding: 12px 0;
    }

    .pp-domicilio__banner {
      padding: 32px 20px;
      margin-top: 36px;
    }
  }

  /* ── 4. Acordeón enlazado (localidades / categorías a domicilio) ── */
  .pp-domicilio__links {
    margin-top: 48px;
    max-width: 100%;
    width: 100%;
  }
  .pp-domicilio__acc {
    margin-bottom: 10px;
  }
  .pp-domicilio__acc-summary {
    list-style: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    border: 1px solid #000;
    padding: 10px;
    font-family: var(--pp-font-heading);
    font-size: clamp(20px, 2.5vw, 28px);
    font-weight: 400;
    letter-spacing: .01em;
    text-transform: uppercase;
    color: #23372c;
  }
  .pp-domicilio__acc-summary::-webkit-details-marker { display: none; }
  .pp-domicilio__acc-summary::after {
    content: "+";
    font-family: var(--pp-font-body);
    font-size: 26px;
    font-weight: 300;
    line-height: 1;
    flex-shrink: 0;
    transition: transform .2s ease;
  }
  .pp-domicilio__acc[open] > .pp-domicilio__acc-summary::after {
    content: "–";
  }
  .pp-domicilio__acc-list {
    list-style: none;
    margin: 0;
    border: 1px solid #000;
    border-top: 0;
    padding: 10px;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .pp-domicilio__acc-list a {
    color: #3a5a40;
    text-decoration: underline;
    text-underline-offset: 2px;
    font-size: 15px;
  }
  .pp-domicilio__acc-list a:hover { color: #1d2b1f; }

  /* ── 5. Carrusel de colecciones / páginas relacionadas ── */
  .pp-domicilio__carousel {
    margin-top: 48px;
  }
  .pp-domicilio__carousel-track {
    display: flex;
    gap: 16px;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    padding-bottom: 8px;
    scrollbar-width: thin;
  }
  .pp-domicilio__carousel-card {
    flex: 0 0 auto;
    width: 140px;
    scroll-snap-align: start;
    text-decoration: none;
    text-align: center;
  }
  .pp-domicilio__carousel-img {
    display: block;
    width: 140px;
    height: 140px;
    object-fit: cover;
    border-radius: 12px;
    background: rgba(0,0,0,.04);
    transition: transform .2s ease;
  }
  .pp-domicilio__carousel-card:hover .pp-domicilio__carousel-img { transform: translateY(-3px); }
  .pp-domicilio__carousel-label {
    display: block;
    margin-top: 8px;
    font-size: 13px;
    color: #1d2b1f;
  }

  /* ── 6. Contenido SEO en desplegable (usa estilo global .pp-coll-desc) ── */
  .pp-domicilio__seo { margin-top: 48px; padding: 0; }
  .pp-domicilio__seo .pp-coll-desc__inner { padding: 0; }
  .pp-domicilio__seo .pp-coll-desc__header { padding-right: 0; }

  @media (max-width: 749px) {
    .pp-domicilio__carousel-card,
    .pp-domicilio__carousel-img { width: 120px; }
    .pp-domicilio__carousel-img { height: 120px; }
  }
</style>

<section
  class="pp-guide pp-domicilio"
  style="
    background-color: {{ section.settings.bg_color }};
    --pp-guide-pad-top: {{ section.settings.padding_top }}px;
    --pp-guide-pad-bottom: {{ section.settings.padding_bottom }}px;
    --pp-products-per-row: {{ products_per_row }};
  "
>

  {%- comment -%} ─────────────────────────────────────────────────────────
       Schema.org JSON-LD emitido server-side para SEO / AI-crawlers.
       BreadcrumbList: Inicio > pillar (Plantas/Flores/Árboles/Macetas a Domicilio) > page.title
       FAQPage: extraído del contenido de page_content si contiene <details><summary class="ppx-faq__q">
       (patrón usado en las páginas de ciudad: Madrid, Barcelona, etc.)
  ───────────────────────────────────────────────────────── {%- endcomment -%}
  {%- assign _shop_url = shop.url | append: routes.root_url | replace: shop.url | prepend: shop.url -%}
  {%- capture crumb_home_url -%}{{ shop.url }}/{%- endcapture -%}
  {%- capture crumb_parent_url -%}{{ shop.url }}{{ parent_url }}{%- endcapture -%}
  {%- capture crumb_current_url -%}{{ shop.url }}{{ page.url }}{%- endcapture -%}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      {"@type":"ListItem","position":1,"name":"Inicio","item":{{ crumb_home_url | json }}}
      {%- unless is_parent_page -%}
        ,{"@type":"ListItem","position":2,"name":{{ parent_label | json }},"item":{{ crumb_parent_url | json }}}
        ,{"@type":"ListItem","position":3,"name":{{ page.title | json }},"item":{{ crumb_current_url | json }}}
      {%- else -%}
        ,{"@type":"ListItem","position":2,"name":{{ parent_label | json }},"item":{{ crumb_current_url | json }}}
      {%- endunless -%}
    ]
  }
  </script>

  {%- comment -%} FAQPage: parsear <details><summary class="ppx-faq__q">Q</summary>A</details> del metafield page_content {%- endcomment -%}
  {%- assign _faq_source = '' -%}
  {%- assign _pc = page.metafields.custom.page_content.value -%}
  {%- if _pc != blank -%}
    {%- for _w in _pc -%}
      {%- if _w.type == 'text' and _w.value contains 'ppx-faq__q' -%}
        {%- assign _faq_source = _w.value -%}
        {%- break -%}
      {%- endif -%}
    {%- endfor -%}
  {%- endif -%}
  {%- if _faq_source != '' -%}
    {%- assign _faq_count = 0 -%}
    {%- assign _faq_blocks_pre = _faq_source | split: '</details>' -%}
    {%- for block in _faq_blocks_pre -%}
      {%- if block contains 'ppx-faq__q' -%}
        {%- assign _after_open = block | split: '<summary' | last -%}
        {%- assign _after_sum = _after_open | split: '>' | last -%}
        {%- assign _q_pre = _after_sum | split: '</summary>' | first | strip_html | strip | strip_newlines -%}
        {%- assign _a_pre = _after_sum | split: '</summary>' | last | replace: '</p>', ' ' | replace: '</li>', ' ' | replace: '<br>', ' ' | replace: '<br/>', ' ' | replace: '<br />', ' ' | strip_html | strip | strip_newlines -%}
        {%- if _q_pre != '' and _a_pre != '' -%}
          {%- assign _faq_count = _faq_count | plus: 1 -%}
        {%- endif -%}
      {%- endif -%}
    {%- endfor -%}
    {%- if _faq_count > 0 -%}
      <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "FAQPage",
        "mainEntity": [
          {%- assign _fpos = 0 -%}
          {%- for block in _faq_blocks_pre -%}
            {%- if block contains 'ppx-faq__q' -%}
              {%- assign _after_open2 = block | split: '<summary' | last -%}
              {%- assign _after_sum2 = _after_open2 | split: '>' | last -%}
              {%- assign _q = _after_sum2 | split: '</summary>' | first | strip_html | strip | strip_newlines -%}
              {%- assign _a = _after_sum2 | split: '</summary>' | last | replace: '</p>', ' ' | replace: '</li>', ' ' | replace: '<br>', ' ' | replace: '<br/>', ' ' | replace: '<br />', ' ' | strip_html | strip | strip_newlines -%}
              {%- if _q != '' and _a != '' -%}
                {%- assign _fpos = _fpos | plus: 1 -%}
                {%- if _fpos > 1 -%},{%- endif -%}
                {"@type":"Question","name":{{ _q | json }},"acceptedAnswer":{"@type":"Answer","text":{{ _a | json }}}}
              {%- endif -%}
            {%- endif -%}
          {%- endfor -%}
        ]
      }
      </script>
    {%- endif -%}
  {%- endif -%}

  {%- comment -%} -- Collection-style header: H1 arriba, breadcrumb debajo -- {%- endcomment -%}
  <h1 class="pp-coll-title__heading">{{ page.title }}</h1>

  {%- comment -%} -- Breadcrumb: 2nd level is a clickable link to the pillar (Plantas/Flores/Árboles a Domicilio) so users + crawlers can ascend. -- {%- endcomment -%}
  {%- if section.settings.show_breadcrumb -%}
    <nav class="pp-coll-breadcrumb" aria-label="Breadcrumb">
      <a href="{{ routes.root_url }}">Inicio</a>
      <span aria-hidden="true">/</span>
      {%- if is_parent_page -%}
        <span class="pp-coll-breadcrumb__current">{{ parent_label }}</span>
      {%- else -%}
        <a href="{{ parent_url }}">{{ parent_label }}</a>
        <span aria-hidden="true">/</span>
        <span class="pp-coll-breadcrumb__current">{{ page.title }}</span>
      {%- endif -%}
    </nav>
  {%- endif -%}

  {%- comment -%} -- Product grids (bloque BEST SELLER / colecciones) -- {%- endcomment -%}
  {%- assign coll_1 = page.metafields.custom.page_collection_1.value -%}
  {%- if coll_1 -%}
    <div class="pp-domicilio__product-grid-wrapper">
      <div class="pp-domicilio__product-grid">
        {%- for product in coll_1.products limit: 8 -%}
          {%- render 'pp-product-card-standalone', product: product, image_ratio: 'portrait' -%}
        {%- endfor -%}
      </div>
    </div>
  {%- endif -%}

  {%- assign coll_2 = page.metafields.custom.page_collection_2.value -%}
  {%- if coll_2 -%}
    <div class="pp-domicilio__product-grid-wrapper">
      <div class="pp-domicilio__product-grid">
        {%- for product in coll_2.products limit: 8 -%}
          {%- render 'pp-product-card-standalone', product: product, image_ratio: 'portrait' -%}
        {%- endfor -%}
      </div>
    </div>
  {%- endif -%}

  {%- assign coll_3 = page.metafields.custom.page_collection_3.value -%}
  {%- if coll_3 -%}
    <div class="pp-domicilio__product-grid-wrapper">
      <div class="pp-domicilio__product-grid">
        {%- for product in coll_3.products limit: 8 -%}
          {%- render 'pp-product-card-standalone', product: product, image_ratio: 'portrait' -%}
        {%- endfor -%}
      </div>
    </div>
  {%- endif -%}

  {%- comment -%}
    -- 4. Acordeón enlazado: grupos de enlaces internos (localidades / categorías a domicilio).
    Cada grupo = título + un menú (linklist). SEO interno editable sin tocar código.
  {%- endcomment -%}
  {%- assign acc_groups = '1,2,3,4,5' | split: ',' -%}
  {%- assign has_acc = false -%}
  {%- for n in acc_groups -%}
    {%- assign menu_key = 'group_' | append: n | append: '_menu' -%}
    {%- assign g_menu = section.settings[menu_key] -%}
    {%- if g_menu != blank and g_menu.links.size > 0 -%}{%- assign has_acc = true -%}{%- endif -%}
  {%- endfor -%}
  {%- if has_acc -%}
    <div class="pp-domicilio__links">
      {%- assign acc_first = true -%}
      {%- for n in acc_groups -%}
        {%- assign title_key = 'group_' | append: n | append: '_title' -%}
        {%- assign menu_key = 'group_' | append: n | append: '_menu' -%}
        {%- assign g_title = section.settings[title_key] -%}
        {%- assign g_menu = section.settings[menu_key] -%}
        {%- if g_menu != blank and g_menu.links.size > 0 -%}
          <details class="pp-domicilio__acc"{% if acc_first %} open{% endif %}>
            <summary class="pp-domicilio__acc-summary">{{ g_title | default: g_menu.title }}</summary>
            <ul class="pp-domicilio__acc-list">
              {%- for link in g_menu.links -%}
                <li><a href="{{ link.url }}">{{ link.title }}</a></li>
              {%- endfor -%}
            </ul>
          </details>
          {%- assign acc_first = false -%}
        {%- endif -%}
      {%- endfor -%}
    </div>
  {%- else -%}
    {%- comment -%} Fallback: contenido default cuando no hay menús asignados {%- endcomment -%}
    <div class="pp-domicilio__links">
      <details class="pp-domicilio__acc" open>
        <summary class="pp-domicilio__acc-summary">{{ section.settings.group_1_title | default: parent_label }}</summary>
        <ul class="pp-domicilio__acc-list">
          <li><a href="/pages/plantas-a-domicilio-para-regalar">Plantas a domicilio para regalo</a></li>
          <li><a href="/pages/plantas-a-domicilio-baratas">Plantas a domicilio baratas</a></li>
          <li><a href="/pages/plantas-a-domicilio-cestas">Centro de plantas a domicilio</a></li>
        </ul>
      </details>
    </div>
  {%- endif -%}

  {%- comment -%}
    -- 5. Carrusel de colecciones/páginas relacionadas (enlazado interno horizontal).
    Fuente: collection_list de la sección.
  {%- endcomment -%}
  {%- assign carousel_colls = section.settings.carousel_collections -%}
  {%- if carousel_colls != blank and carousel_colls.size > 0 -%}
    <div class="pp-domicilio__carousel">
      {%- if section.settings.carousel_title != blank -%}
        <h2 class="pp-domicilio__product-grid-title">{{ section.settings.carousel_title }}</h2>
      {%- endif -%}
      <div class="pp-domicilio__carousel-track">
        {%- for coll in carousel_colls -%}
          <a href="{{ coll.url }}" class="pp-domicilio__carousel-card">
            {%- if coll.featured_image != blank -%}
              {{ coll.featured_image | image_url: width: 280 | image_tag: class: 'pp-domicilio__carousel-img', alt: coll.title, loading: 'lazy', widths: '140, 280' }}
            {%- elsif coll.products.first.featured_image != blank -%}
              {{ coll.products.first.featured_image | image_url: width: 280 | image_tag: class: 'pp-domicilio__carousel-img', alt: coll.title, loading: 'lazy', widths: '140, 280' }}
            {%- else -%}
              <span class="pp-domicilio__carousel-img"></span>
            {%- endif -%}
            <span class="pp-domicilio__carousel-label">{{ coll.title }}</span>
          </a>
        {%- endfor -%}
      </div>
    </div>
  {%- endif -%}

  {%- comment -%}
    -- 6. Contenido SEO en desplegable (Leer más). Contenido migrado de WP en page_content.
  {%- endcomment -%}
  {%- comment -%}
    Contenido SEO en desplegable (Leer más). Renderizado SSR desde el metafield
    JSON page_content (heading/text/image/cta). Se emite en orden natural para
    que los crawlers (GPTBot, Googlebot sin JS) vean el texto en el HTML crudo.
  {%- endcomment -%}
  {%- assign seo_widgets = page.metafields.custom.page_content.value -%}
  {%- if seo_widgets != blank -%}
    {%- assign seo_has_content = false -%}
    {%- for w in seo_widgets -%}
      {%- if w.type == 'heading' or w.type == 'text' or w.type == 'image' or w.type == 'cta' -%}
        {%- assign seo_has_content = true -%}
        {%- break -%}
      {%- endif -%}
    {%- endfor -%}
    {%- if seo_has_content -%}
      <section class="pp-coll-desc pp-domicilio__seo">
        <div class="pp-coll-desc__inner">
          <div class="pp-coll-desc__header">
            <h2 class="pp-coll-desc__title">{{ section.settings.seo_title | default: parent_label }}</h2>
            <button type="button" class="pp-coll-desc__toggle" data-pp-coll-desc-toggle aria-expanded="false">
              <span class="pp-coll-desc__toggle-text">{{ section.settings.seo_more_label | default: 'Leer más' }}</span>
              <svg class="pp-coll-desc__arrow" width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3 5.5L7 9.5L11 5.5"/></svg>
            </button>
          </div>
          <div class="pp-coll-desc__body" data-pp-coll-desc-body>
            <div class="pp-coll-desc__columns">
              {%- for w in seo_widgets -%}
                {%- case w.type -%}
                  {%- when 'heading' -%}
                    {%- if w.value != blank -%}<h2 class="pp-content__heading">{{ w.value }}</h2>{%- endif -%}
                  {%- when 'text' -%}
                    {%- if w.value != blank -%}<div class="pp-content__text">{{ w.value }}</div>{%- endif -%}
                  {%- when 'image' -%}
                    {%- if w.src != blank -%}
                      <div class="pp-content__image">
                        {%- if w.link != blank -%}<a href="{{ w.link }}">{%- endif -%}
                        <img src="{{ w.src }}" alt="{{ w.alt | default: '' }}" loading="lazy">
                        {%- if w.link != blank -%}</a>{%- endif -%}
                      </div>
                    {%- endif -%}
                  {%- when 'cta' -%}
                    {%- if w.url != blank and w.text != blank -%}
                      <div class="pp-content__cta"><a class="pp-cta-btn" href="{{ w.url }}">{{ w.text }} <span aria-hidden="true">&rarr;</span></a></div>
                    {%- endif -%}
                {%- endcase -%}
              {%- endfor -%}
            </div>
          </div>
        </div>
      </section>
    {%- endif -%}
  {%- endif -%}

  {%- comment -%} -- Banner CTA -- {%- endcomment -%}
  {%- if section.settings.banner_text != blank -%}
    <div class="pp-domicilio__banner">
      <p class="pp-domicilio__banner-text">{{ section.settings.banner_text }}</p>
      {%- if section.settings.banner_cta_text != blank and section.settings.banner_cta_url != blank -%}
        <a href="{{ section.settings.banner_cta_url }}" class="pp-domicilio__banner-btn">
          {{ section.settings.banner_cta_text }}
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M3.333 8h9.334M8.667 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      {%- endif -%}
    </div>
  {%- endif -%}

  {%- comment -%} -- Fallback solo en editor del theme, NO en HTML público (Google lo indexa) -- {%- endcomment -%}
  {%- if request.design_mode -%}
    <div class="pp-guide__empty" data-pp-empty>
      <p>Esta página aún no tiene contenido configurado.</p>
    </div>
  {%- endif -%}

</section>

<script>
(function() {
  /* Contenido ahora es SSR. Este IIFE sólo maneja el toggle del acordeón
     .pp-coll-desc pp-domicilio__seo: colapsa/expande contenido YA presente en
     el DOM, sin inyectar nada. Mismo patrón scrollHeight que
     pp-collection-description.liquid, así el CSS actual sigue igual. */
  var seoToggle = document.querySelector('.pp-domicilio__seo [data-pp-coll-desc-toggle]');
  if (!seoToggle) return;
  var seoSection = seoToggle.closest('.pp-coll-desc');
  if (!seoSection) return;
  var seoBody = seoSection.querySelector('[data-pp-coll-desc-body]');
  if (!seoBody) return;
  var seoText = seoToggle.querySelector('.pp-coll-desc__toggle-text');
  var moreLabel = {{ section.settings.seo_more_label | default: 'Leer m\u00e1s' | json }};
  var lessLabel = {{ section.settings.seo_less_label | default: 'Leer menos' | json }};

  seoToggle.addEventListener('click', function() {
    var expanded = seoToggle.getAttribute('aria-expanded') === 'true';
    if (expanded) {
      seoBody.style.maxHeight = '0';
      seoToggle.setAttribute('aria-expanded', 'false');
      if (seoText) seoText.textContent = moreLabel;
    } else {
      seoBody.style.maxHeight = seoBody.scrollHeight + 'px';
      seoToggle.setAttribute('aria-expanded', 'true');
      if (seoText) seoText.textContent = lessLabel;
    }
  });

  /* Recalcular alto si la ventana cambia (im\u00e1genes que reflowean) */
  window.addEventListener('resize', function() {
    if (seoToggle.getAttribute('aria-expanded') === 'true') {
      seoBody.style.maxHeight = seoBody.scrollHeight + 'px';
    }
  });

  /* Colapsar p\u00e1rrafos vac\u00edos (s\u00f3lo &nbsp;) que WP a veces deja */
  seoBody.querySelectorAll('.pp-content__text p').forEach(function(p) {
    if (p.innerHTML.replace(/&nbsp;/g, '').replace(/\u00a0/g, '').trim() === '') {
      p.classList.add('pp-empty');
    }
  });
})();
</script>

