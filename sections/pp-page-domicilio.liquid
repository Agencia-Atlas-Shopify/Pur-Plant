{%- comment -%}
  PP Page Domicilio — Renders city delivery landing pages (plantas-domicilio, flores-domicilio)
  Reads content from page.metafields.custom.page_content JSON array.
  Widget types: heading, text (raw HTML), image.
  Also uses: page_type, page_collection_1..3.
  Features hero header, trust badges, CTA buttons.
{%- endcomment -%}

{{ 'pp-page-guide.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign page_type = page.metafields.custom.page_type | default: ''
  assign products_per_row = section.settings.products_per_row | default: 4
  assign is_flores = false
  if page_type == 'flores-domicilio'
    assign is_flores = true
  endif
-%}

<style>
  /* --- PP Page Domicilio: type-specific styles --- */
  .pp-domicilio__hero {
    background: var(--pp-dark-green);
    border-radius: var(--pp-radius);
    padding: 48px 40px;
    margin: 0 0 40px;
    text-align: center;
    position: relative;
    overflow: hidden;
  }

  .pp-domicilio__hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at 60% 20%, rgba(218, 255, 211, 0.12) 0%, transparent 70%);
    pointer-events: none;
  }

  .pp-domicilio__hero-subtitle {
    font-family: var(--pp-font-section);
    font-size: 13px;
    font-weight: 600;
    color: rgba(218, 255, 211, 0.7);
    text-transform: uppercase;
    letter-spacing: 0.15em;
    margin: 0 0 12px;
    position: relative;
    z-index: 1;
  }

  .pp-domicilio__hero-title {
    font-family: var(--pp-font-heading);
    font-size: clamp(28px, 5vw, 44px);
    font-weight: 400;
    color: #fff;
    line-height: 1.15;
    margin: 0 0 16px;
    position: relative;
    z-index: 1;
  }

  .pp-domicilio__hero-city {
    color: var(--pp-light-green);
  }

  .pp-domicilio__hero-cta {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: var(--pp-light-green);
    color: var(--pp-dark-green);
    font-family: var(--pp-font-section);
    font-size: 14px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    padding: 14px 32px;
    border-radius: 100px;
    text-decoration: none;
    transition: transform var(--pp-transition), box-shadow var(--pp-transition);
    position: relative;
    z-index: 1;
  }

  .pp-domicilio__hero-cta:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 20px rgba(218, 255, 211, 0.3);
  }

  .pp-domicilio__hero-cta svg {
    width: 16px;
    height: 16px;
  }

  /* --- Trust badges --- */
  .pp-domicilio__trust {
    display: flex;
    justify-content: center;
    gap: 32px;
    flex-wrap: wrap;
    margin: 0 0 48px;
    padding: 24px 0;
    border-bottom: 1px solid rgba(35, 55, 44, 0.1);
  }

  .pp-domicilio__trust-badge {
    display: flex;
    align-items: center;
    gap: 10px;
    font-family: var(--pp-font-body);
    font-size: 14px;
    font-weight: 500;
    color: var(--pp-dark-green);
  }

  .pp-domicilio__trust-icon {
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(35, 55, 44, 0.06);
    border-radius: 50%;
    flex-shrink: 0;
    color: var(--pp-dark-green);
  }

  .pp-domicilio__trust-icon svg {
    width: 20px;
    height: 20px;
  }

  /* --- Content widget styles --- */
  .pp-domicilio .pp-content__heading {
    font-family: 'Aileron', sans-serif;
    font-size: clamp(22px, 3vw, 30px);
    font-weight: 800;
    color: #23372c;
    line-height: 1.2;
    margin: 36px 0 15px;
    text-transform: lowercase;
  }
  .pp-domicilio .pp-content__heading::first-letter {
    text-transform: uppercase;
  }

  .pp-domicilio .pp-content__heading:first-child {
    margin-top: 0;
  }

  .pp-domicilio .pp-content__text {
    font-family: var(--pp-font-body);
    font-size: 15px;
    font-weight: 400;
    color: var(--pp-dark-green);
    line-height: 1.75;
    margin: 0 0 24px;
    opacity: 0.85;
  }

  .pp-domicilio .pp-content__text p { margin: 0 0 16px; }
  .pp-domicilio .pp-content__text p.pp-empty { margin: 0; line-height: 0; font-size: 0; }
  .pp-domicilio .pp-content__text p:last-child { margin-bottom: 0; }
  .pp-domicilio .pp-content__text ul,
  .pp-domicilio .pp-content__text ol { margin: 0 0 16px; padding-left: 24px; }
  .pp-domicilio .pp-content__text li { margin-bottom: 6px; }
  .pp-domicilio .pp-content__text a { color: var(--pp-dark-green); text-decoration: underline; }
  .pp-domicilio .pp-content__text strong { font-weight: 600; }

  .pp-domicilio .pp-content__image {
    margin: 0 0 24px;
  }

  .pp-domicilio .pp-content__image img {
    max-width: 100%;
    height: auto;
    border-radius: var(--pp-radius, 8px);
    display: block;
  }

  /* --- Product grid --- */
  .pp-domicilio__product-grid-wrapper {
    margin: 56px 0;
    padding: 40px 0;
    border-top: 1px solid rgba(35, 55, 44, 0.1);
    border-bottom: 1px solid rgba(35, 55, 44, 0.1);
  }

  .pp-domicilio__product-grid-title {
    font-family: var(--pp-font-heading);
    font-size: clamp(20px, 2.5vw, 28px);
    font-weight: 400;
    color: var(--pp-dark-green);
    margin: 0 0 24px;
    text-align: center;
  }

  .pp-domicilio__product-grid {
    display: grid;
    grid-template-columns: repeat(var(--pp-products-per-row, 4), 1fr);
    gap: 20px;
  }

  /* --- Bottom CTA banner --- */
  .pp-domicilio__banner {
    background: var(--pp-dark-green);
    border-radius: var(--pp-radius);
    padding: 48px 40px;
    text-align: center;
    margin-top: 56px;
  }

  .pp-domicilio__banner-text {
    font-family: var(--pp-font-heading);
    font-size: clamp(22px, 3vw, 32px);
    font-weight: 400;
    color: #DAFFD3;
    line-height: 1.3;
    margin: 0 0 24px;
  }

  .pp-domicilio__banner-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: var(--pp-light-green);
    color: var(--pp-dark-green);
    font-family: var(--pp-font-section);
    font-size: 14px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    padding: 14px 32px;
    border-radius: 100px;
    text-decoration: none;
    transition: transform var(--pp-transition), opacity var(--pp-transition);
  }

  .pp-domicilio__banner-btn:hover {
    transform: translateY(-2px);
    opacity: 0.9;
  }

  @media screen and (max-width: 989px) {
    .pp-domicilio__product-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media screen and (max-width: 749px) {
    .pp-domicilio__hero {
      padding: 32px 20px;
    }

    .pp-domicilio__trust {
      gap: 16px;
    }

    .pp-domicilio__trust-badge {
      font-size: 13px;
      gap: 8px;
      flex: 0 0 calc(50% - 8px);
    }

    .pp-domicilio__trust-icon {
      width: 32px;
      height: 32px;
    }

    .pp-domicilio__trust-icon svg {
      width: 16px;
      height: 16px;
    }

    .pp-domicilio__product-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 12px;
    }

    .pp-domicilio__product-grid-wrapper {
      margin: 36px 0;
      padding: 28px 0;
    }

    .pp-domicilio__banner {
      padding: 32px 20px;
      margin-top: 36px;
    }
  }
</style>

<section
  class="pp-guide pp-domicilio"
  style="
    background-color: {{ section.settings.bg_color }};
    --pp-guide-pad-top: {{ section.settings.padding_top }}px;
    --pp-guide-pad-bottom: {{ section.settings.padding_bottom }}px;
    --pp-products-per-row: {{ products_per_row }};
  "
>

  {%- comment -%} -- Breadcrumb -- {%- endcomment -%}
  {%- if section.settings.show_breadcrumb -%}
    <nav class="pp-guide__breadcrumb" aria-label="Breadcrumb">
      <a href="/">Pur Plant</a>
      <span class="pp-guide__breadcrumb-sep">/</span>
      {%- if is_flores -%}
        <span>Flores a Domicilio</span>
      {%- else -%}
        <span>Plantas a Domicilio</span>
      {%- endif -%}
      <span class="pp-guide__breadcrumb-sep">/</span>
      <span>{{ page.title }}</span>
    </nav>
  {%- endif -%}

  {%- comment -%} -- Hero header -- {%- endcomment -%}
  {%- if section.settings.show_hero -%}
    <div class="pp-domicilio__hero">
      <p class="pp-domicilio__hero-subtitle">
        {%- if is_flores -%}
          Envio de flores a domicilio
        {%- else -%}
          Envio de plantas a domicilio
        {%- endif -%}
      </p>
      <h1 class="pp-domicilio__hero-title">{{ page.title }}</h1>
      <a href="{{ section.settings.banner_cta_url }}" class="pp-domicilio__hero-cta">
        {{ section.settings.banner_cta_text | default: 'Ver plantas' }}
        <svg viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M3.333 8h9.334M8.667 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    </div>
  {%- else -%}
    <h1 class="pp-guide__title">{{ page.title }}</h1>
  {%- endif -%}

  {%- comment -%} -- Trust badges -- {%- endcomment -%}
  {%- if section.settings.show_trust_badges -%}
    <div class="pp-domicilio__trust">
      <div class="pp-domicilio__trust-badge">
        <span class="pp-domicilio__trust-icon">
          <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </span>
        <span>{{ section.settings.badge_delivery }}</span>
      </div>
      <div class="pp-domicilio__trust-badge">
        <span class="pp-domicilio__trust-icon">
          <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M5 8h14M5 8a2 2 0 110-4h14a2 2 0 110 4M5 8v10a2 2 0 002 2h10a2 2 0 002-2V8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </span>
        <span>{{ section.settings.badge_shipping }}</span>
      </div>
      <div class="pp-domicilio__trust-badge">
        <span class="pp-domicilio__trust-icon">
          <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </span>
        <span>{{ section.settings.badge_guarantee }}</span>
      </div>
    </div>
  {%- endif -%}

  {%- comment -%} -- JSON data source for page_content -- {%- endcomment -%}
  <script type="application/json" data-page-content>
    {{ page.metafields.custom.page_content | default: '[]' }}
  </script>

  {%- comment -%} -- Content container (JS-rendered) -- {%- endcomment -%}
  <div data-content-container></div>

  {%- comment -%} -- Product grids -- {%- endcomment -%}
  {%- assign coll_1 = page.metafields.custom.page_collection_1.value -%}
  {%- if coll_1 -%}
    <div class="pp-domicilio__product-grid-wrapper">
      {%- if coll_1.title != blank -%}
        <h3 class="pp-domicilio__product-grid-title">{{ coll_1.title }}</h3>
      {%- endif -%}
      <div class="pp-domicilio__product-grid">
        {%- for product in coll_1.products limit: 8 -%}
          {%- render 'pp-product-card-standalone', product: product, image_ratio: 'portrait' -%}
        {%- endfor -%}
      </div>
    </div>
  {%- endif -%}

  {%- assign coll_2 = page.metafields.custom.page_collection_2.value -%}
  {%- if coll_2 -%}
    <div class="pp-domicilio__product-grid-wrapper">
      {%- if coll_2.title != blank -%}
        <h3 class="pp-domicilio__product-grid-title">{{ coll_2.title }}</h3>
      {%- endif -%}
      <div class="pp-domicilio__product-grid">
        {%- for product in coll_2.products limit: 8 -%}
          {%- render 'pp-product-card-standalone', product: product, image_ratio: 'portrait' -%}
        {%- endfor -%}
      </div>
    </div>
  {%- endif -%}

  {%- assign coll_3 = page.metafields.custom.page_collection_3.value -%}
  {%- if coll_3 -%}
    <div class="pp-domicilio__product-grid-wrapper">
      {%- if coll_3.title != blank -%}
        <h3 class="pp-domicilio__product-grid-title">{{ coll_3.title }}</h3>
      {%- endif -%}
      <div class="pp-domicilio__product-grid">
        {%- for product in coll_3.products limit: 8 -%}
          {%- render 'pp-product-card-standalone', product: product, image_ratio: 'portrait' -%}
        {%- endfor -%}
      </div>
    </div>
  {%- endif -%}

  {%- comment -%} -- Banner CTA -- {%- endcomment -%}
  {%- if section.settings.banner_text != blank -%}
    <div class="pp-domicilio__banner">
      <p class="pp-domicilio__banner-text">{{ section.settings.banner_text }}</p>
      {%- if section.settings.banner_cta_text != blank and section.settings.banner_cta_url != blank -%}
        <a href="{{ section.settings.banner_cta_url }}" class="pp-domicilio__banner-btn">
          {{ section.settings.banner_cta_text }}
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M3.333 8h9.334M8.667 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      {%- endif -%}
    </div>
  {%- endif -%}

  {%- comment -%} -- Fallback -- {%- endcomment -%}
  <div class="pp-guide__empty" data-pp-empty style="display:none;">
    <p>Esta pagina aun no tiene contenido configurado.</p>
  </div>

</section>

<script>
(function() {
  var dataEl = document.querySelector('[data-page-content]');
  var container = document.querySelector('[data-content-container]');
  var emptyMsg = document.querySelector('[data-pp-empty]');
  if (!dataEl || !container) return;

  var widgets;
  try { widgets = JSON.parse(dataEl.textContent); } catch(e) { widgets = []; }
  dataEl.remove();

  if (!Array.isArray(widgets) || !widgets.length) {
    if (emptyMsg) emptyMsg.style.display = '';
    return;
  }

  var html = '';
  widgets.forEach(function(w) {
    if (!w || !w.type) return;

    if (w.type === 'heading') {
      html += '<h2 class="pp-content__heading">' + w.value + '</h2>';
    } else if (w.type === 'text') {
      html += '<div class="pp-content__text">' + w.value + '</div>';
    } else if (w.type === 'image') {
      html += '<div class="pp-content__image"><img src="' + w.src + '" alt="' + (w.alt || '') + '" loading="lazy"></div>';
    }
  });

  container.innerHTML = html;

  /* Collapse empty &nbsp; paragraphs */
  container.querySelectorAll('.pp-content__text p').forEach(function(p) {
    if (p.innerHTML.replace(/&nbsp;/g, '').replace(/\u00a0/g, '').trim() === '') {
      p.classList.add('pp-empty');
    }
  });
})();
</script>

{% schema %}
{
  "name": "PP Page Domicilio",
  "tag": "section",
  "class": "pp-guide-section pp-domicilio-section",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_breadcrumb",
      "label": "Show breadcrumb",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_hero",
      "label": "Show hero header",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_trust_badges",
      "label": "Show trust badges",
      "default": true
    },
    {
      "type": "range",
      "id": "products_per_row",
      "min": 2,
      "max": 6,
      "step": 1,
      "label": "Products per row (desktop)",
      "default": 4
    },
    {
      "type": "header",
      "content": "Banner CTA"
    },
    {
      "type": "text",
      "id": "banner_text",
      "label": "Banner text",
      "default": "Encuentra la planta perfecta"
    },
    {
      "type": "text",
      "id": "banner_cta_text",
      "label": "CTA button text",
      "default": "Ver plantas"
    },
    {
      "type": "url",
      "id": "banner_cta_url",
      "label": "CTA button link"
    },
    {
      "type": "header",
      "content": "Trust Badges"
    },
    {
      "type": "text",
      "id": "badge_delivery",
      "label": "Trust badge: Delivery",
      "default": "Entrega en 24/48h"
    },
    {
      "type": "text",
      "id": "badge_shipping",
      "label": "Trust badge: Shipping",
      "default": "Envio gratis +49\u20ac"
    },
    {
      "type": "text",
      "id": "badge_guarantee",
      "label": "Trust badge: Guarantee",
      "default": "Garantia de frescura"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "#F5F0E8"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 60
    }
  ],
  "templates": ["page"],
  "presets": [
    {
      "name": "PP Page Domicilio",
      "category": "Pur Plant"
    }
  ]
}
{% endschema %}
