{%- comment -%}
  PP Product Main — Custom 2-column PDP section
  Left: Image gallery with vertical thumbnails
  Right: Sticky product info with editable blocks
{%- endcomment -%}

{{ 'pp-product-main.css' | asset_url | stylesheet_tag }}
<script src="{{ 'pp-shipping-countdown.js' | asset_url }}" defer></script>

{%- liquid
  assign product = product
  assign current_variant = product.selected_or_first_available_variant
  assign featured_image = current_variant.featured_image | default: product.featured_image
-%}

{% render 'pp-product-jsonld' %}

<section
  id="pp-pdp-{{ section.id }}"
  class="pp-pdp"
  data-section-id="{{ section.id }}"
  data-product-id="{{ product.id }}"
>
  <div class="pp-pdp__grid">
    {%- comment -%} ═══ LEFT: Care icons + Accordions only ═══ {%- endcomment -%}
    <div class="pp-pdp__info-left" data-pp-info-left>
      {%- comment -%} Care icons from metafields (with demo fallback) {%- endcomment -%}
      {%- assign care_icons_open = false -%}
      {%- for block in section.blocks -%}
        {%- if block.type == 'care_icon' and care_icons_open == false -%}
          {%- assign care_icons_open = true -%}
          <div class="pp-pdp__care-icons">
        {%- endif -%}
        {%- if block.type != 'care_icon' and care_icons_open -%}
          {%- assign care_icons_open = false -%}
          </div>
        {%- endif -%}
        {%- case block.type -%}
          {%- when 'care_icon' -%}
            {%- liquid
              assign mf_source = block.settings.metafield_source
              assign mf_value = blank
              assign should_show = false
              assign is_pet_true = false

              case mf_source
                when 'pet_friendly'
                  if product.metafields.custom.pet_friendly != blank
                    assign should_show = true
                    if product.metafields.custom.pet_friendly == true
                      assign mf_value = 'Sí'
                      assign is_pet_true = true
                    else
                      assign mf_value = 'No'
                    endif
                  endif
                when 'purificadora'
                  if product.metafields.custom.purificadora != blank
                    assign should_show = true
                    if product.metafields.custom.purificadora == true
                      assign mf_value = 'Sí'
                    else
                      assign mf_value = 'No'
                    endif
                  endif
                when 'luz'
                  if product.metafields.custom.luz.value != blank
                    assign should_show = true
                    assign mf_value = product.metafields.custom.luz.value | join: ', '
                  endif
                when 'riego'
                  if product.metafields.custom.riego.value != blank
                    assign should_show = true
                    assign mf_value = product.metafields.custom.riego.value | join: ', '
                  endif
                when 'dificultad'
                  if product.metafields.custom.dificultad != blank
                    assign should_show = true
                    assign mf_value = product.metafields.custom.dificultad
                  endif
                when 'ubicacion'
                  if product.metafields.custom.ubicacion != blank
                    assign should_show = true
                    assign mf_value = product.metafields.custom.ubicacion
                  endif
                when 'temperatura'
                  if product.metafields.custom.temperatura != blank
                    assign should_show = true
                    assign mf_value = product.metafields.custom.temperatura
                  endif
                when 'humedad'
                  if product.metafields.custom.humedad != blank
                    assign should_show = true
                    assign mf_value = product.metafields.custom.humedad
                  endif
                when 'crecimiento'
                  if product.metafields.custom.crecimiento != blank
                    assign should_show = true
                    assign mf_value = product.metafields.custom.crecimiento
                  endif
              endcase
            -%}
            {%- if should_show -%}
              <div class="pp-pdp__care-icon" {{ block.shopify_attributes }}>
                {%- if mf_source == 'pet_friendly' -%}
                  {%- if is_pet_true and block.settings.icon != blank -%}
                    <img src="{{ block.settings.icon | image_url: width: 80 }}" alt="{{ block.settings.label }}" width="32" height="32" loading="lazy">
                  {%- elsif is_pet_true == false and block.settings.icon_false != blank -%}
                    <img src="{{ block.settings.icon_false | image_url: width: 80 }}" alt="{{ block.settings.label }}" width="32" height="32" loading="lazy">
                  {%- elsif block.settings.icon != blank -%}
                    <img src="{{ block.settings.icon | image_url: width: 80 }}" alt="{{ block.settings.label }}" width="32" height="32" loading="lazy">
                  {%- endif -%}
                {%- elsif block.settings.icon != blank -%}
                  <img src="{{ block.settings.icon | image_url: width: 80 }}" alt="{{ block.settings.label }}" width="32" height="32" loading="lazy">
                {%- endif -%}
                {%- if block.settings.label != blank -%}
                  <span class="pp-pdp__care-label">{{ block.settings.label }}</span>
                {%- endif -%}
                <span class="pp-pdp__care-value">{{ mf_value }}</span>
              </div>
            {%- endif -%}
          {%- when 'accordion' -%}
            {%- liquid
              assign mf_key = block.settings.metafield_key
              assign cs = block.settings.content_source

              # Detect if product is planta or maceta — walk coleccion_padre up to root
              assign root_handle = ''
              assign anchor_for_root = product.metafields.custom.coleccion_principal.value
              if anchor_for_root != blank
                assign walk_root = anchor_for_root
                for i in (1..6)
                  assign parent_root = walk_root.metafields.custom.coleccion_padre.value
                  if parent_root != blank
                    assign walk_root = parent_root
                  else
                    break
                  endif
                endfor
                assign root_handle = walk_root.handle
              endif
              assign is_planta = false
              assign is_maceta = false
              if root_handle == 'plantas-de-interior' or root_handle == 'plantas-de-exterior'
                assign is_planta = true
              endif
              if root_handle == 'macetas'
                assign is_maceta = true
              endif

              # Compute has_content for current source
              assign has_content = false
              if cs == 'description' and product.description != blank
                assign has_content = true
              elsif cs == 'descripcion_corta' and product.metafields.custom.descripcion_corta != blank
                assign has_content = true
              elsif cs == 'metafield' and product.metafields.custom[mf_key] != blank
                assign has_content = true
              elsif cs == 'custom' and block.settings.custom_content != blank
                assign has_content = true
              elsif cs == 'medidas'
                # Para plantas/macetas siempre mostramos (con fallback si no hay metafields).
                # Para otros, solo si hay datos reales.
                if is_planta or is_maceta
                  assign has_content = true
                elsif product.metafields.custom.altura_cm != blank or product.metafields.custom.diametro_maceta_cm != blank
                  assign has_content = true
                endif
              elsif cs == 'acerca_planta_auto'
                if product.metafields.custom.punto_1 != blank or product.metafields.custom.punto_2 != blank or product.metafields.custom.punto_3 != blank or product.metafields.custom.punto_4 != blank or product.metafields.custom.punto_5 != blank or product.metafields.custom.familia != blank or product.metafields.custom.tipo_planta != blank or product.metafields.custom.pasaporte_fitosanitario != blank or product.metafields.custom.nombre_cientifico != blank
                  assign has_content = true
                endif
              endif

              # Video also counts as content
              if block.settings.video_url != blank
                assign has_content = true
              endif

              # Medidas restricted: only plantas + macetas
              assign show_block = has_content
              if cs == 'medidas' and is_planta == false and is_maceta == false
                assign show_block = false
              endif
            -%}
            {%- if show_block -%}
              <details class="pp-pdp__accordion"{% if block.settings.open_by_default %} open{% endif %} {{ block.shopify_attributes }}>
                <summary class="pp-pdp__accordion-header">
                  <span>{{ block.settings.heading }}</span>
                  <span class="pp-pdp__accordion-icon">+</span>
                </summary>
                <div class="pp-pdp__accordion-content">
                  {%- case cs -%}
                    {%- when 'description' -%}
                      {{ product.description }}
                    {%- when 'descripcion_corta' -%}
                      {{ product.metafields.custom.descripcion_corta | strip_html }}
                    {%- when 'metafield' -%}
                      {{ product.metafields.custom[mf_key] | metafield_tag }}
                    {%- when 'custom' -%}
                      {{ block.settings.custom_content }}
                    {%- when 'acerca_planta_auto' -%}
                      <div class="pp-pdp__acerca">
                        {%- assign has_puntos = false -%}
                        {%- if product.metafields.custom.punto_1 != blank or product.metafields.custom.punto_2 != blank or product.metafields.custom.punto_3 != blank or product.metafields.custom.punto_4 != blank or product.metafields.custom.punto_5 != blank -%}
                          {%- assign has_puntos = true -%}
                        {%- endif -%}
                        {%- if has_puntos -%}
                          <ul class="pp-pdp__acerca-puntos">
                            {%- for i in (1..5) -%}
                              {%- assign pkey = 'punto_' | append: i -%}
                              {%- assign pval = product.metafields.custom[pkey] -%}
                              {%- if pval != blank -%}<li>{{ pval }}</li>{%- endif -%}
                            {%- endfor -%}
                          </ul>
                        {%- endif -%}
                        <dl class="pp-pdp__acerca-dl">
                          {%- if product.metafields.custom.nombre_cientifico != blank -%}
                            <div><dt>Nombre científico</dt><dd><em>{{ product.metafields.custom.nombre_cientifico }}</em></dd></div>
                          {%- endif -%}
                          {%- if product.metafields.custom.familia != blank -%}
                            <div><dt>Familia</dt><dd>
                              {%- assign fam_list = product.metafields.custom.familia.value -%}
                              {%- for f in fam_list -%}{{ f }}{%- unless forloop.last %}, {% endunless -%}{%- endfor -%}
                            </dd></div>
                          {%- endif -%}
                          {%- if product.metafields.custom.tipo_planta != blank -%}
                            <div><dt>Características</dt><dd class="pp-pdp__acerca-tags">
                              {%- assign tipo_list = product.metafields.custom.tipo_planta.value -%}
                              {%- for t in tipo_list -%}<span class="pp-pdp__acerca-tag">{{ t }}</span>{%- endfor -%}
                            </dd></div>
                          {%- endif -%}
                          {%- if product.metafields.custom.pasaporte_fitosanitario != blank -%}
                            <div><dt>Pasaporte fitosanitario</dt><dd>{{ product.metafields.custom.pasaporte_fitosanitario }}</dd></div>
                          {%- endif -%}
                        </dl>
                      </div>
                    {%- when 'medidas' -%}
                      <ul class="pp-pdp__medidas-list">
                        {%- if product.metafields.custom.altura_cm != blank -%}
                          {%- assign altura_val = product.metafields.custom.altura_cm | plus: 0 -%}
                          {%- assign altura_int = altura_val | floor -%}
                          <li>Altura aproximada: {% if altura_val == altura_int %}{{ altura_int }}{% else %}{{ altura_val }}{% endif %} cm</li>
                        {%- endif -%}
                        {%- if product.metafields.custom.diametro_maceta_cm != blank -%}
                          {%- assign diam_val = product.metafields.custom.diametro_maceta_cm | plus: 0 -%}
                          {%- assign diam_int = diam_val | floor -%}
                          <li>Diámetro: {% if diam_val == diam_int %}{{ diam_int }}{% else %}{{ diam_val }}{% endif %} cm</li>
                        {%- endif -%}
                        {%- if product.metafields.custom.altura_cm == blank and product.metafields.custom.diametro_maceta_cm == blank -%}
                          <li>Altura aproximada: 35 cm</li>
                          <li>Diámetro: 12 cm</li>
                        {%- endif -%}
                      </ul>
                  {%- endcase -%}

                  {%- comment -%} Optional embedded YouTube / Vimeo video {%- endcomment -%}
                  {%- if block.settings.video_url != blank -%}
                    {%- assign vu = block.settings.video_url -%}
                    {%- assign yt_id = '' -%}
                    {%- if vu contains 'youtu.be/' -%}
                      {%- assign yt_id = vu | split: 'youtu.be/' | last | split: '?' | first | split: '&' | first -%}
                    {%- elsif vu contains 'youtube.com/watch' -%}
                      {%- assign yt_id = vu | split: 'v=' | last | split: '&' | first -%}
                    {%- elsif vu contains 'youtube.com/embed/' -%}
                      {%- assign yt_id = vu | split: 'youtube.com/embed/' | last | split: '?' | first -%}
                    {%- endif -%}
                    {%- if yt_id != '' -%}
                      <div class="pp-pdp__accordion-video">
                        <iframe src="https://www.youtube.com/embed/{{ yt_id }}" title="{{ block.settings.heading | escape }}" frameborder="0" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen loading="lazy"></iframe>
                      </div>
                    {%- elsif vu contains 'vimeo.com/' -%}
                      {%- assign vm_id = vu | split: 'vimeo.com/' | last | split: '?' | first | split: '/' | first -%}
                      <div class="pp-pdp__accordion-video">
                        <iframe src="https://player.vimeo.com/video/{{ vm_id }}" title="{{ block.settings.heading | escape }}" frameborder="0" allow="autoplay; fullscreen; picture-in-picture" allowfullscreen loading="lazy"></iframe>
                      </div>
                    {%- endif -%}
                  {%- endif -%}
                </div>
              </details>
            {%- endif -%}
        {%- endcase -%}
      {%- endfor -%}
      {%- if care_icons_open -%}
        </div>
      {%- endif -%}

      {%- comment -%} Left column image (uploadable from customizer) {%- endcomment -%}
      {%- for block in section.blocks -%}
        {%- if block.type == 'left_image' and block.settings.image != blank -%}
          <div class="pp-pdp__left-image" {{ block.shopify_attributes }}>
            <img src="{{ block.settings.image | image_url: width: 400 }}" alt="{{ block.settings.image.alt | default: product.title | escape }}" width="200" loading="lazy">
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>

    {%- comment -%} ═══ CENTER: Image Gallery ═══ {%- endcomment -%}
    <div class="pp-pdp__gallery">
      {%- if product.media.size > 1 -%}
        <div class="pp-pdp__thumbnails" data-pp-thumbs>
          {%- for media in product.media -%}
            <button
              type="button"
              class="pp-pdp__thumb{% if media.id == featured_image.id %} is-active{% endif %}"
              data-pp-thumb
              data-media-id="{{ media.id }}"
              data-index="{{ forloop.index0 }}"
              aria-label="{{ 'general.go_to_slide' | t: index: forloop.index | default: 'Go to image' }}"
            >
              <img
                src="{{ media | image_url: width: 100 }}"
                alt="{{ media.alt | escape }}"
                width="60"
                height="75"
                loading="lazy"
              >
            </button>
          {%- endfor -%}
        </div>
      {%- endif -%}

      <div class="pp-pdp__main-images" data-pp-main-images>
        {%- for media in product.media -%}
          <div
            class="pp-pdp__main-image"
            data-pp-image
            data-media-id="{{ media.id }}"
            data-index="{{ forloop.index0 }}"
          >
            {%- if media.media_type == 'image' -%}
              <img
                src="{{ media | image_url: width: 1200 }}"
                srcset="{{ media | image_url: width: 600 }} 600w, {{ media | image_url: width: 900 }} 900w, {{ media | image_url: width: 1200 }} 1200w"
                alt="{{ media.alt | escape }}"
                width="{{ media.width }}"
                height="{{ media.height }}"
                loading="{% if forloop.first %}eager{% else %}lazy{% endif %}"
                sizes="(min-width: 750px) 60vw, 100vw"
              >
            {%- elsif media.media_type == 'video' or media.media_type == 'external_video' -%}
              {{ media | media_tag: autoplay: true, loop: true, muted: true, controls: true }}
            {%- elsif media.media_type == 'model' -%}
              {{ media | media_tag }}
            {%- endif -%}
          </div>
        {%- endfor -%}
      </div>

      {%- comment -%} Mobile dots {%- endcomment -%}
      <div class="pp-pdp__dots mobile-only" data-pp-dots>
        {%- for media in product.media -%}
          <span class="pp-pdp__dot{% if forloop.first %} is-active{% endif %}" data-index="{{ forloop.index0 }}"></span>
        {%- endfor -%}
      </div>
    </div>

    {%- comment -%} ═══ RIGHT: Purchase info (sticky) ═══ {%- endcomment -%}
    <div class="pp-pdp__info-right" data-pp-info>

      {%- comment -%} Breadcrumb (right) {%- endcomment -%}
      <nav class="pp-pdp__breadcrumb pp-pdp__breadcrumb--right">
        <a href="{{ routes.root_url }}">Pur Plant</a>
        <span>/</span>
        {%- liquid
          comment
            Priority 1: product metafield custom.coleccion_principal
            Priority 2: first product.collection that has a coleccion_padre set
            Priority 3: any non-generic product.collection
          endcomment
          assign best_coll = product.metafields.custom.coleccion_principal.value

          if best_coll == blank and product.collections.size > 0
            assign fallback_coll = nil
            for c in product.collections
              assign coll_handle_lower = c.handle | downcase
              if coll_handle_lower contains 'iva' or coll_handle_lower contains 'plantas-nuevas' or coll_handle_lower contains 'plantas-bano' or coll_handle_lower contains 'plantas-cocina' or coll_handle_lower contains 'plantas-dormitorio' or coll_handle_lower contains 'plantas-oficina' or coll_handle_lower contains 'plantas-salon'
                continue
              endif
              if fallback_coll == nil
                assign fallback_coll = c
              endif
              if c.metafields.custom.coleccion_padre.value != blank
                assign best_coll = c
                break
              endif
            endfor
            if best_coll == blank
              assign best_coll = fallback_coll
            endif
          endif
        -%}
        {%- comment -%}
          Anchor: custom.coleccion_breadcrumb overrides coleccion_principal.
          Full chain rendered: Home / root / ... / anchor / Product.
          Anchor IS rendered as leaf-parent crumb.
        {%- endcomment -%}
        {%- assign breadcrumb_override = product.metafields.custom.coleccion_breadcrumb.value -%}
        {%- if breadcrumb_override != blank -%}
          {%- assign anchor_coll = breadcrumb_override -%}
        {%- else -%}
          {%- assign anchor_coll = best_coll -%}
        {%- endif -%}
        {%- if anchor_coll != blank -%}
          {%- assign walk_coll = anchor_coll -%}
          {%- assign chain_titles = anchor_coll.title -%}
          {%- assign chain_urls = anchor_coll.url -%}
          {%- for i in (1..8) -%}
            {%- assign parent_ref = walk_coll.metafields.custom.coleccion_padre.value -%}
            {%- if parent_ref != blank -%}
              {%- assign chain_titles = parent_ref.title | append: '|||' | append: chain_titles -%}
              {%- assign chain_urls = parent_ref.url | append: '|||' | append: chain_urls -%}
              {%- assign walk_coll = parent_ref -%}
            {%- else -%}
              {%- break -%}
            {%- endif -%}
          {%- endfor -%}
          {%- assign crumb_titles = chain_titles | split: '|||' -%}
          {%- assign crumb_urls = chain_urls | split: '|||' -%}
          {%- for t in crumb_titles -%}
            <a href="{{ crumb_urls[forloop.index0] }}">{{ t }}</a>
            <span>/</span>
          {%- endfor -%}
        {%- elsif product.type != blank -%}
          <span>{{ product.type }}</span>
          <span>/</span>
        {%- endif -%}
        <span>{{ product.title }}</span>
      </nav>

      {%- comment -%} Stars (reviews) {%- endcomment -%}
      {%- if product.metafields.reviews.rating != blank -%}
        <div class="pp-pdp__stars">
          {%- assign rating_val = product.metafields.reviews.rating.value.rating | round: 1 -%}
          {%- for i in (1..5) -%}
            {%- if i <= rating_val -%}
              <svg width="20" height="20" viewBox="0 0 24 24" fill="#e4ffd3" stroke="#23372c" stroke-width="1.5"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
            {%- else -%}
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#23372c" stroke-width="1.5"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
            {%- endif -%}
          {%- endfor -%}
          {%- if product.metafields.reviews.rating_count != blank -%}
            <span class="pp-pdp__review-count">({{ product.metafields.reviews.rating_count }})</span>
          {%- endif -%}
        </div>
      {%- endif -%}

      {%- comment -%} Title {%- endcomment -%}
      <h1 class="pp-pdp__title pp-pdp__title--right">{{ product.title }}</h1>

      {%- comment -%} Nombre científico {%- endcomment -%}
      {%- if product.metafields.custom.nombre_cientifico != blank -%}
        <p class="pp-pdp__scientific-name">{{ product.metafields.custom.nombre_cientifico }}</p>
      {%- endif -%}

      {%- comment -%} Price {%- endcomment -%}
      <div class="pp-pdp__price pp-pdp__price--right" data-pp-price>
        {%- if current_variant.compare_at_price > current_variant.price -%}
          <span class="pp-pdp__price-current pp-pdp__price-current--sale" data-pp-current-price>{{ current_variant.price | money }}</span>
          <s class="pp-pdp__price-compare" data-pp-compare-price>{{ current_variant.compare_at_price | money }}</s>
          {%- assign save_pct = current_variant.compare_at_price | minus: current_variant.price | times: 100 | divided_by: current_variant.compare_at_price -%}
          <span class="pp-pdp__save-badge" data-pp-save-badge>-{{ save_pct }}%</span>
        {%- else -%}
          <span class="pp-pdp__price-current" data-pp-current-price>{{ current_variant.price | money }}</span>
        {%- endif -%}
      </div>

      {%- comment -%}
        Size pills from tamano metafield + tamanos_relacionados.
        Only render if product has 2+ available sizes (current + 1 related min).
        XS is intentionally excluded.
      {%- endcomment -%}
      {%- liquid
        assign sizes = 'S,M,L,XL,XXL' | split: ','
        assign current_size = product.metafields.custom.tamano
        assign related = product.metafields.custom.tamanos_relacionados.value
        assign available_count = 0
        if current_size != blank and current_size != 'XS'
          assign available_count = available_count | plus: 1
        endif
        if related != blank
          for rel in related
            assign rel_size = rel.metafields.custom.tamano
            if rel_size != blank and rel_size != 'XS' and rel_size != current_size
              assign available_count = available_count | plus: 1
            endif
          endfor
        endif
      -%}
      {%- if available_count >= 2 -%}
        <div class="pp-pdp__variants-wrap">
          <div class="pp-pdp__variant-group">
            <div class="pp-pdp__variant-pills">
              {%- for size in sizes -%}
                {%- liquid
                  assign is_current = false
                  assign related_url = ''
                  assign is_available = false
                  if current_size == size
                    assign is_current = true
                    assign is_available = true
                  endif
                  if related != blank
                    for rel in related
                      if rel.metafields.custom.tamano == size
                        assign related_url = rel.url
                        assign is_available = true
                      endif
                    endfor
                  endif
                -%}
                {%- if is_available -%}
                  {%- if is_current -%}
                    <span class="pp-pdp__variant-pill is-active">{{ size }}</span>
                  {%- else -%}
                    <a href="{{ related_url }}" class="pp-pdp__variant-pill">{{ size }}</a>
                  {%- endif -%}
                {%- endif -%}
              {%- endfor -%}
            </div>
          </div>
        </div>
      {%- endif -%}

      {%- comment -%} Variant picker (hide if single variant) {%- endcomment -%}
      {%- for block in section.blocks -%}
        {%- if block.type == 'variant_picker' -%}
          {%- if product.variants.size > 1 -%}
            <div class="pp-pdp__variants-wrap" {{ block.shopify_attributes }}>
              {%- for option in product.options_with_values -%}
                {%- if option.values.size > 1 -%}
                  <div class="pp-pdp__variant-group" data-option-index="{{ forloop.index0 }}">
                    <label class="pp-pdp__variant-label">{{ option.name }}</label>
                    <div class="pp-pdp__variant-pills">
                      {%- for value in option.values -%}
                        {%- liquid
                          assign selected = false
                          if current_variant.options contains value
                            assign selected = true
                          endif
                        -%}
                        <button
                          type="button"
                          class="pp-pdp__variant-btn{% if selected %} is-active{% endif %}"
                          data-option-index="{{ forloop.parentloop.index0 }}"
                          data-value="{{ value | escape }}"
                        >
                          {{ value }}
                        </button>
                      {%- endfor -%}
                    </div>
                  </div>
                {%- endif -%}
              {%- endfor -%}
            </div>
          {%- endif -%}
        {%- endif -%}
      {%- endfor -%}

      {%- comment -%} Care icons — mobile duplicate (shown only on mobile via CSS) {%- endcomment -%}
      {%- assign mobile_care_open = false -%}
      {%- for block in section.blocks -%}
        {%- if block.type == 'care_icon' and mobile_care_open == false -%}
          {%- assign mobile_care_open = true -%}
          <div class="pp-pdp__care-icons pp-pdp__care-icons--mobile">
        {%- endif -%}
        {%- if block.type != 'care_icon' and mobile_care_open -%}
          {%- assign mobile_care_open = false -%}
          </div>
        {%- endif -%}
        {%- if block.type == 'care_icon' -%}
          {%- liquid
            assign mf_source = block.settings.metafield_source
            assign mf_value = blank
            assign should_show = false
            assign is_pet_true = false

            case mf_source
              when 'pet_friendly'
                if product.metafields.custom.pet_friendly != blank
                  assign should_show = true
                  if product.metafields.custom.pet_friendly == true
                    assign mf_value = 'Sí'
                    assign is_pet_true = true
                  else
                    assign mf_value = 'No'
                  endif
                endif
              when 'purificadora'
                if product.metafields.custom.purificadora != blank
                  assign should_show = true
                  if product.metafields.custom.purificadora == true
                    assign mf_value = 'Sí'
                  else
                    assign mf_value = 'No'
                  endif
                endif
              when 'luz'
                if product.metafields.custom.luz.value != blank
                  assign should_show = true
                  assign mf_value = product.metafields.custom.luz.value | join: ', '
                endif
              when 'riego'
                if product.metafields.custom.riego.value != blank
                  assign should_show = true
                  assign mf_value = product.metafields.custom.riego.value | join: ', '
                endif
              when 'dificultad'
                if product.metafields.custom.dificultad != blank
                  assign should_show = true
                  assign mf_value = product.metafields.custom.dificultad
                endif
              when 'ubicacion'
                if product.metafields.custom.ubicacion != blank
                  assign should_show = true
                  assign mf_value = product.metafields.custom.ubicacion
                endif
              when 'temperatura'
                if product.metafields.custom.temperatura != blank
                  assign should_show = true
                  assign mf_value = product.metafields.custom.temperatura
                endif
              when 'humedad'
                if product.metafields.custom.humedad != blank
                  assign should_show = true
                  assign mf_value = product.metafields.custom.humedad
                endif
              when 'crecimiento'
                if product.metafields.custom.crecimiento != blank
                  assign should_show = true
                  assign mf_value = product.metafields.custom.crecimiento
                endif
            endcase
          -%}
          {%- if should_show -%}
            <div class="pp-pdp__care-icon">
              {%- if mf_source == 'pet_friendly' -%}
                {%- if is_pet_true and block.settings.icon != blank -%}
                  <img src="{{ block.settings.icon | image_url: width: 80 }}" alt="{{ block.settings.label }}" width="32" height="32" loading="lazy">
                {%- elsif is_pet_true == false and block.settings.icon_false != blank -%}
                  <img src="{{ block.settings.icon_false | image_url: width: 80 }}" alt="{{ block.settings.label }}" width="32" height="32" loading="lazy">
                {%- elsif block.settings.icon != blank -%}
                  <img src="{{ block.settings.icon | image_url: width: 80 }}" alt="{{ block.settings.label }}" width="32" height="32" loading="lazy">
                {%- endif -%}
              {%- elsif block.settings.icon != blank -%}
                <img src="{{ block.settings.icon | image_url: width: 80 }}" alt="{{ block.settings.label }}" width="32" height="32" loading="lazy">
              {%- endif -%}
              {%- if block.settings.label != blank -%}
                <span class="pp-pdp__care-label">{{ block.settings.label }}</span>
              {%- endif -%}
              <span class="pp-pdp__care-value">{{ mf_value }}</span>
            </div>
          {%- endif -%}
        {%- endif -%}
      {%- endfor -%}
      {%- if mobile_care_open -%}</div>{%- endif -%}

      {%- comment -%} Recommended products (macetas que combinan) {%- endcomment -%}
      {%- if product.metafields.custom.encuentra_una_maceta_que_combine != blank -%}
        <div class="pp-pdp__recommended">
          <p class="pp-pdp__recommended-label">Incluir maceta</p>
          <div class="pp-pdp__recommended-items">
            {%- for rec_product in product.metafields.custom.encuentra_una_maceta_que_combine.value -%}
              <a href="{{ rec_product.url }}" class="pp-pdp__recommended-item" title="{{ rec_product.title }}">
                <img src="{{ rec_product.featured_image | image_url: width: 120 }}" alt="{{ rec_product.title }}" width="50" height="50" loading="lazy">
              </a>
            {%- endfor -%}
          </div>
        </div>
      {%- endif -%}

      {%- comment -%} INICIA TU RUTINA — Recommended products {%- endcomment -%}
      {%- liquid
        assign has_recs = false
        assign rec_products = null

        if product.metafields.custom.productos_recomendados != blank
          assign rec_products = product.metafields.custom.productos_recomendados.value
          assign has_recs = true
        elsif product.metafields.custom.explora_la_coleccion != blank
          assign rec_collection = product.metafields.custom.explora_la_coleccion.value
          if rec_collection.products.size > 0
            assign rec_products = rec_collection.products
            assign has_recs = true
          endif
        elsif product.collections.size > 0
          assign rec_products = product.collections.first.products
          assign has_recs = true
        endif
      -%}
      {%- if has_recs and rec_products != blank -%}
        <div class="pp-pdp__routine">
          <p class="pp-pdp__routine-title">{{ section.settings.recommended_title | default: 'INICIA TU RUTINA' }}</p>
          <div class="pp-pdp__routine-slider" data-pp-routine-slider>
            {%- for rec in rec_products limit: 8 -%}
              {%- if rec.id == product.id -%}{%- continue -%}{%- endif -%}
              {%- unless rec.available -%}{%- continue -%}{%- endunless -%}
              {%- liquid
                assign rec_variant = rec.selected_or_first_available_variant
                assign rec_can_direct_add = false
                if rec.has_only_default_variant and rec_variant.available
                  assign rec_can_direct_add = true
                endif

                assign has_badge = false
                assign badge_text = ''
                if rec.compare_at_price > rec.price
                  assign has_badge = true
                  assign badge_text = 'Oferta'
                elsif rec.tags contains 'New In' or rec.tags contains 'new in' or rec.tags contains 'Novedades'
                  assign has_badge = true
                  assign badge_text = 'New In'
                elsif rec.tags contains 'Best Sellers' or rec.tags contains 'Top Ventas'
                  assign has_badge = true
                  assign badge_text = 'Top'
                endif
              -%}
              <div class="pp-pdp__routine-item">
                <a href="{{ rec.url }}" class="pp-pdp__routine-link" aria-label="{{ rec.title }}">
                  <div class="pp-pdp__routine-img">
                    {%- if rec.featured_image != blank -%}
                      <img src="{{ rec.featured_image | image_url: width: 200 }}" alt="{{ rec.title }}" width="80" height="100" loading="lazy">
                    {%- endif -%}
                    {%- if has_badge -%}
                      <span class="pp-pdp__routine-badge">{{ badge_text }}</span>
                    {%- endif -%}
                  </div>
                </a>
                <div class="pp-pdp__routine-footer">
                  <span class="pp-pdp__routine-price">{{ rec.price | money }}</span>
                  {%- if rec_can_direct_add -%}
                    <button
                      type="button"
                      class="pp-pdp__routine-add"
                      data-pp-add-to-cart
                      data-variant-id="{{ rec_variant.id }}"
                      aria-label="Añadir {{ rec.title | escape }}">+</button>
                  {%- else -%}
                    <a href="{{ rec.url }}" class="pp-pdp__routine-add" aria-label="Ver {{ rec.title | escape }}">→</a>
                  {%- endif -%}
                </div>
              </div>
            {%- endfor -%}
          </div>
        </div>
      {%- endif -%}

      {%- comment -%} Shipping countdown — single instance, not inside the blocks loop {%- endcomment -%}
      {%- liquid
        assign shipping_block = nil
        for b in section.blocks
          if b.type == 'shipping_info'
            assign shipping_block = b
            break
          endif
        endfor
      -%}
      {%- if shipping_block -%}
        <div class="pp-pdp__shipping-info" style="padding-top: {{ shipping_block.settings.padding_top | default: 10 }}px; padding-bottom: {{ shipping_block.settings.padding_bottom | default: 10 }}px;" {{ shipping_block.shopify_attributes }}>
          {%- if shipping_block.settings.icon != blank -%}
            <img src="{{ shipping_block.settings.icon | image_url: width: 40 }}" width="20" height="20" alt="">
          {%- endif -%}
          <span class="pp-pdp__shipping-dot"></span>
          <span id="pp-shipping-countdown"></span>
        </div>
      {%- endif -%}

      {%- comment -%} Total {%- endcomment -%}
      <div class="pp-pdp__total" data-pp-total>
        <span class="pp-pdp__total-label">TOTAL</span>
        <span class="pp-pdp__total-label" data-pp-total-price>{{ current_variant.price | money }}</span>
      </div>

      {%- comment -%} Quantity + Add to cart {%- endcomment -%}
      {%- assign pp_lock_qty_to_1 = false -%}
      {%- if settings.pp_limit_under_1_enabled and current_variant.price < 100 -%}
        {%- assign pp_lock_qty_to_1 = true -%}
      {%- endif -%}
      {%- for block in section.blocks -%}
        {%- if block.type == 'buy_button' -%}
          <div class="pp-pdp__buy-wrap" {{ block.shopify_attributes }} {% if pp_lock_qty_to_1 %}data-pp-max-qty="1"{% endif %}>
            <div class="pp-pdp__qty"{% unless current_variant.available %} hidden{% endunless %}{% if pp_lock_qty_to_1 %} hidden{% endif %} data-pp-qty-wrap>
              <button type="button" class="pp-pdp__qty-minus" data-pp-qty-minus aria-label="Decrease quantity">−</button>
              <input type="number" class="pp-pdp__qty-input" data-pp-qty-input value="1" min="1" max="{% if pp_lock_qty_to_1 %}1{% else %}99{% endif %}" aria-label="Quantity">
              <button type="button" class="pp-pdp__qty-plus" data-pp-qty-plus aria-label="Increase quantity"{% if pp_lock_qty_to_1 %} disabled{% endif %}>+</button>
            </div>

            <button
              type="button"
              class="pp-pdp__add-to-cart-btn"
              data-pp-add-to-cart
              data-variant-id="{{ current_variant.id }}"
              {% unless current_variant.available %}disabled{% endunless %}
            >
              {%- if current_variant.available -%}
                {{ block.settings.button_text | default: 'Añadir' }}
              {%- else -%}
                {{ 'products.product.sold_out' | t | default: 'Agotado' }}
              {%- endif -%}
            </button>

            {%- if block.settings.show_dynamic_checkout -%}
              {%- form 'product', product, id: 'pp-product-form' -%}
                <input type="hidden" name="id" value="{{ current_variant.id }}" data-pp-form-variant-id>
                {{ form | payment_button }}
              {%- endform -%}
            {%- endif -%}
          </div>
        {%- endif -%}
      {%- endfor -%}

      {%- comment -%} App blocks (Planet Discounts, Judge.me, etc.) {%- endcomment -%}
      {%- for block in section.blocks -%}
        {%- if block.type == '@app' -%}
          <div class="pp-pdp__app-block" {{ block.shopify_attributes }}>
            {% render block %}
          </div>
        {%- endif -%}
      {%- endfor -%}

      {%- comment -%} Volume Discount cards (debajo del add to cart). Oculto si precio <= 1€ {%- endcomment -%}
      {%- for block in section.blocks -%}
        {%- if block.type == 'volume_discount' and current_variant.price > 100 -%}
          {%- liquid
            assign base = current_variant.price
            assign t1_pct = block.settings.tier1_pct | plus: 0
            assign t2_pct = block.settings.tier2_pct | plus: 0
            assign t3_pct = block.settings.tier3_pct | plus: 0
            assign t1_disc = base | times: t1_pct | divided_by: 100
            assign t1_unit = base | minus: t1_disc
            assign t2_disc = base | times: t2_pct | divided_by: 100
            assign t2_unit = base | minus: t2_disc
            assign t3_disc = base | times: t3_pct | divided_by: 100
            assign t3_unit = base | minus: t3_disc
          -%}
          <div class="pp-vol" {{ block.shopify_attributes }}>
            <p class="pp-pdp__routine-title">PACK AHORRO</p>
            <div class="pp-vol__grid">
              <div class="pp-vol__card">
                <span class="pp-vol__range">{{ block.settings.tier1_range }} Ud</span>
                <span class="pp-vol__unit-price">{{ t1_unit | money }}/unidad</span>
                <span class="pp-vol__badge">AHORRA {{ t1_pct }}%</span>
              </div>
              <div class="pp-vol__card">
                <span class="pp-vol__range">{{ block.settings.tier2_range }} Ud</span>
                <span class="pp-vol__unit-price">{{ t2_unit | money }}/unidad</span>
                <span class="pp-vol__badge">AHORRA {{ t2_pct }}%</span>
              </div>
              <div class="pp-vol__card">
                <span class="pp-vol__range">{{ block.settings.tier3_range }} Ud</span>
                <span class="pp-vol__unit-price">{{ t3_unit | money }}/unidad</span>
                <span class="pp-vol__badge">AHORRA {{ t3_pct }}%</span>
              </div>
            </div>
          </div>
        {%- endif -%}
      {%- endfor -%}

      {%- comment -%} Bottom shipping text {%- endcomment -%}
      <div class="pp-pdp__shipping-bottom">
        <div class="pp-pdp__shipping-bottom-row">
          {%- if section.settings.shipping_bottom_image1 != blank -%}
            <img src="{{ section.settings.shipping_bottom_image1 | image_url: width: 80 }}" width="28" height="28" alt="" class="pp-pdp__shipping-bottom-icon" loading="lazy">
          {%- endif -%}
          <p>{{ section.settings.shipping_bottom_line1 | default: 'RECÍBE TU PEDIDO EN 24/48H' }}</p>
        </div>
        <div class="pp-pdp__shipping-bottom-row">
          {%- if section.settings.shipping_bottom_image2 != blank -%}
            <img src="{{ section.settings.shipping_bottom_image2 | image_url: width: 80 }}" width="28" height="28" alt="" class="pp-pdp__shipping-bottom-icon" loading="lazy">
          {%- endif -%}
          <p>{{ section.settings.shipping_bottom_line2 | default: 'ENVÍO GRATIS PEDIDOS +49€ (Península y Baleares)' }}</p>
        </div>
      </div>
    </div>
  </div>

  {%- comment -%} Amazon title + SEO description below the fold {%- endcomment -%}
  {%- liquid
    assign type_needle = '|' | append: product.type | append: '|'
    assign plantas_types = '|Plantas|Plantas Interior|Plantas Exterior|Plantas Minis|Plantas Hidropónicas|Cactus|Alocasias|Calatheas|Begonias|Anthurium|Ficus|Hoya|Peperomias|Helecho|Monstera|Philodendron|Palmera|Adansonii|Croton|Marantas|Deliciosa|Fittonia|Caladium|Dracaena|Kalanchoe|Euphorbia|Cyclamen|Hypoestes|Ceropegia|Espatifilo|Areca|Dieffenbachia|Adenium|Cóleo|Aglaonema|Orquídeas|Chamaedorea|Bromelia|Crassula Ovata|Suculentas y Crasas|Bambú|Leuconeura|carnosa|Aloe Vera|Oxalis|Hoya Kerrii Variegada|Carnívora|Pet Friendly|Árboles|Árboles Frutales|Arce Japonés|Bonsái|Acebo|Jazmin|Hibiscus|Calluna|Crisantemo|Hortensia|Euonymus|Kokedamas|Kits Kokedamas|Lavanda|Guindilla|Aromáticas|Coníferas|'
    assign is_planta = false
    if plantas_types contains type_needle
      assign is_planta = true
    endif
  -%}
  {%- if is_planta -%}
    <p class="pp-pdp__plant-disclaimer"><em>*Estas imágenes corresponden a un ejemplar y son inspiracionales. Como todo ser vivo, las plantas están en continua transformación y cambio. Todas las plantas incluyen maceta de plástico original.</em></p>
  {%- endif -%}
  {%- if product.metafields.custom.titulo_amazon != blank -%}
    <h2 class="pp-pdp__amazon-title">{{ product.metafields.custom.titulo_amazon }}</h2>
  {%- endif -%}
  {%- comment -%} SEO text removed — description shown in accordion {%- endcomment -%}
</section>

{%- comment -%} Mobile floating add-to-cart bar {%- endcomment -%}
<div class="pp-pdp__floating-atc" data-pp-floating-atc aria-hidden="true">
  <div class="pp-pdp__floating-atc-info">
    {%- if featured_image -%}
      <img
        src="{{ featured_image | image_url: width: 120 }}"
        width="40"
        height="40"
        alt="{{ product.title | escape }}"
        class="pp-pdp__floating-atc-img"
        loading="lazy"
      >
    {%- endif -%}
    <span class="pp-pdp__floating-atc-price" data-pp-floating-price>
      {{ current_variant.price | money }}
    </span>
  </div>
  <button
    type="button"
    class="pp-pdp__floating-atc-btn"
    data-pp-floating-atc-btn
    {% unless current_variant.available %}disabled{% endunless %}
  >
    {%- if current_variant.available -%}
      Añadir
    {%- else -%}
      Agotado
    {%- endif -%}
  </button>
</div>

<script>
  window.ppProductVariants = {{ product.variants | json }};
  window.ppProductOptions = {{ product.options_with_values | json }};
  window.ppCurrentVariantId = {{ current_variant.id }};
  window.ppLimitUnder1 = {{ settings.pp_limit_under_1_enabled | json }};
</script>
<script src="{{ 'pp-product-main.js' | asset_url }}" type="module" defer></script>

<script>
  /* Hide Planet Volume Discount widget when current variant price <= 1€.
     The widget renders client-side after page load — observe DOM until it appears, then evaluate. */
  (function () {
    function getCurrentVariantPrice() {
      var btn = document.querySelector('.pp-pdp__add-to-cart-btn[data-variant-id]');
      var vid = btn ? parseInt(btn.dataset.variantId, 10) : window.ppCurrentVariantId;
      var v = (window.ppProductVariants || []).find(function (x) { return x.id === vid; });
      return v ? v.price : null;
    }
    function evaluateAndHide() {
      var price = getCurrentVariantPrice();
      if (price == null) return;
      var hide = price <= 100;
      document.querySelectorAll('volume-discount-product-selector').forEach(function (el) {
        var wrap = el.closest('.pp-pdp__app-block') || el.closest('.shopify-app-block') || el;
        wrap.style.display = hide ? 'none' : '';
      });
    }
    // Initial pass after load + observer for late-rendered widget
    evaluateAndHide();
    var mo = new MutationObserver(function () { evaluateAndHide(); });
    mo.observe(document.body, { childList: true, subtree: true });
    // Re-evaluate on variant change (price may change between variants)
    document.addEventListener('click', function (e) {
      if (e.target.closest('.pp-pdp__variant-btn')) setTimeout(evaluateAndHide, 50);
    });
  })();
</script>

<script>
  /* Mobile floating ATC — show when the main buy button leaves the viewport */
  (function () {
    const floating = document.querySelector('[data-pp-floating-atc]');
    // Specific selector — was grabbing FIRST [data-pp-add-to-cart] on page which
    // could be a routine/recommended product button (causing wrong product added).
    const mainBtn = document.querySelector('.pp-pdp__add-to-cart-btn[data-pp-add-to-cart]');
    const floatingBtn = document.querySelector('[data-pp-floating-atc-btn]');
    if (!floating || !mainBtn || !floatingBtn) return;

    const io = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          // Visible when the main button is OUT of view
          floating.classList.toggle('is-visible', !entry.isIntersecting);
          floating.setAttribute('aria-hidden', entry.isIntersecting ? 'true' : 'false');
        }
      },
      { rootMargin: '0px 0px -20% 0px', threshold: 0 }
    );
    io.observe(mainBtn);

    // Delegate the click — fires the same flow as the main ATC button
    floatingBtn.addEventListener('click', (e) => {
      e.preventDefault();
      mainBtn.click();
    });

    // Mirror the price + state of the main button.
    // Distinguish loading / success / truly-sold-out — otherwise ALL disabled
    // states (including during /cart/add.js request) read as "Agotado".
    function syncFromMain() {
      const priceSrc = document.querySelector('[data-pp-total-price]');
      const priceDst = document.querySelector('[data-pp-floating-price]');
      if (priceSrc && priceDst) priceDst.textContent = priceSrc.textContent;

      const isLoading = mainBtn.classList.contains('is-loading');
      const isSuccess = mainBtn.classList.contains('is-success');
      const isError = mainBtn.classList.contains('is-error');

      if (isLoading) {
        floatingBtn.disabled = true;
        floatingBtn.textContent = 'Añadiendo...';
      } else if (isSuccess) {
        floatingBtn.disabled = true;
        floatingBtn.textContent = '✓';
      } else if (isError) {
        floatingBtn.disabled = true;
        floatingBtn.textContent = 'Error';
      } else if (mainBtn.disabled) {
        floatingBtn.disabled = true;
        floatingBtn.textContent = 'Agotado';
      } else {
        floatingBtn.disabled = false;
        floatingBtn.textContent = 'Añadir';
      }
    }
    syncFromMain();
    new MutationObserver(syncFromMain).observe(mainBtn, {
      attributes: true,
      attributeFilter: ['disabled', 'class'],
    });
    const priceSrc = document.querySelector('[data-pp-total-price]');
    if (priceSrc) {
      new MutationObserver(syncFromMain).observe(priceSrc, {
        characterData: true,
        childList: true,
        subtree: true,
      });
    }
  })();
</script>

<script>
(function() {
  var thumbs = document.querySelectorAll('[data-pp-thumb]');
  var images = document.querySelectorAll('[data-pp-image]');
  var mainContainer = document.querySelector('[data-pp-main-images]');
  var dots = document.querySelectorAll('[data-pp-dots] .pp-pdp__dot');
  if (!thumbs.length && !dots.length) return;
  if (!images.length || !mainContainer) return;

  function activateThumb(index) {
    thumbs.forEach(function(t, i) {
      t.classList.toggle('is-active', i === index);
    });
    dots.forEach(function(d, i) {
      d.classList.toggle('is-active', i === index);
    });
  }

  /* Click thumbnail → scroll to image */
  thumbs.forEach(function(thumb) {
    thumb.addEventListener('click', function() {
      var idx = parseInt(thumb.dataset.index);
      var target = images[idx];
      if (target) {
        target.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
        activateThumb(idx);
      }
    });
  });

  /* Click dot → scroll to image */
  dots.forEach(function(dot) {
    dot.addEventListener('click', function() {
      var idx = parseInt(dot.dataset.index);
      var target = images[idx];
      if (target) {
        mainContainer.scrollTo({ left: target.offsetLeft, behavior: 'smooth' });
        activateThumb(idx);
      }
    });
  });

  /* Scroll observer — highlight active thumbnail */
  if ('IntersectionObserver' in window) {
    var observer = new IntersectionObserver(function(entries) {
      entries.forEach(function(entry) {
        if (entry.isIntersecting) {
          var idx = parseInt(entry.target.dataset.index);
          activateThumb(idx);
        }
      });
    }, {
      root: mainContainer,
      threshold: 0.5
    });

    images.forEach(function(img) {
      observer.observe(img);
    });
  }
})();
</script>

<script>
  // PLANET UPDATE QUANTITY
  document.addEventListener('planet:volume-discount-selector-widget-variants-change', function(e) {
    var variants = e.detail?.data?.variants;
    if (!variants || !variants.length) return;

    var qty = variants.length;

    var qtyInput = document.querySelector('[data-pp-qty-input]');
    if (!qtyInput) return;

    qtyInput.value = qty;
    qtyInput.dispatchEvent(new Event('input', { bubbles: true }));
    qtyInput.dispatchEvent(new Event('change', { bubbles: true }));
  });
</script>

