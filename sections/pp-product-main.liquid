{%- comment -%}
  PP Product Main — Custom 2-column PDP section
  Left: Image gallery with vertical thumbnails
  Right: Sticky product info with editable blocks
{%- endcomment -%}

{{ 'pp-product-main.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign product = product
  assign current_variant = product.selected_or_first_available_variant
  assign featured_image = current_variant.featured_image | default: product.featured_image
-%}

<script type="application/ld+json">{{ product | structured_data }}</script>

<section
  id="pp-pdp-{{ section.id }}"
  class="pp-pdp"
  data-section-id="{{ section.id }}"
  data-product-id="{{ product.id }}"
>
  <div class="pp-pdp__grid">
    {%- comment -%} ═══ LEFT: Product Info (top part) ═══ {%- endcomment -%}
    <div class="pp-pdp__info-left" data-pp-info-left>
      {%- for block in section.blocks -%}
        {%- case block.type -%}
          {%- when 'breadcrumb' -%}
            <nav class="pp-pdp__breadcrumb" {{ block.shopify_attributes }}>
              <a href="/">Home</a>
              <span>/</span>
              {%- if product.collections.size > 0 -%}
                {%- comment -%} Walk up the parent chain via custom.coleccion_padre {%- endcomment -%}
                {%- assign current_coll = product.collections.first -%}
                {%- assign breadcrumb_chain = '' -%}
                {%- assign breadcrumb_urls = '' -%}
                {%- assign depth = 0 -%}

                {%- comment -%} Build chain: walk up parents (max 5 levels) {%- endcomment -%}
                {%- assign walk_coll = current_coll -%}
                {%- for i in (1..5) -%}
                  {%- if breadcrumb_chain == '' -%}
                    {%- assign breadcrumb_chain = walk_coll.title -%}
                    {%- assign breadcrumb_urls = walk_coll.url -%}
                  {%- else -%}
                    {%- assign breadcrumb_chain = walk_coll.title | append: '|||' | append: breadcrumb_chain -%}
                    {%- assign breadcrumb_urls = walk_coll.url | append: '|||' | append: breadcrumb_urls -%}
                  {%- endif -%}
                  {%- assign parent_ref = walk_coll.metafields.custom.coleccion_padre -%}
                  {%- if parent_ref != blank and parent_ref.title != blank -%}
                    {%- assign walk_coll = parent_ref -%}
                  {%- else -%}
                    {%- break -%}
                  {%- endif -%}
                {%- endfor -%}

                {%- assign crumb_titles = breadcrumb_chain | split: '|||' -%}
                {%- assign crumb_urls = breadcrumb_urls | split: '|||' -%}
                {%- for crumb_title in crumb_titles -%}
                  <a href="{{ crumb_urls[forloop.index0] }}">{{ crumb_title }}</a>
                  <span>/</span>
                {%- endfor -%}
              {%- endif -%}
              <span>{{ product.title }}</span>
            </nav>
          {%- when 'title' -%}
            <div class="pp-pdp__title-row" {{ block.shopify_attributes }}>
              <h1 class="pp-pdp__title">{{ product.title }}</h1>
              {%- if block.settings.show_wishlist -%}
                <button type="button" class="pp-pdp__wishlist-btn" data-wishlist-add data-product-id="{{ product.id }}" data-product-handle="{{ product.handle }}" aria-label="{{ 'products.product.add_wishlist' | t | default: 'Add to wishlist' }}">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="22" height="22"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
                </button>
              {%- endif -%}
            </div>
          {%- when 'price' -%}
            <div class="pp-pdp__price" data-pp-price {{ block.shopify_attributes }}>
              {%- if current_variant.compare_at_price > current_variant.price -%}
                <s class="pp-pdp__price-compare" data-pp-compare-price>{{ current_variant.compare_at_price | money }}</s>
              {%- endif -%}
              <span class="pp-pdp__price-current" data-pp-current-price>{{ current_variant.price | money }}</span>
              {%- if current_variant.compare_at_price > current_variant.price and block.settings.show_save_badge -%}
                {%- assign save_pct = current_variant.compare_at_price | minus: current_variant.price | times: 100 | divided_by: current_variant.compare_at_price -%}
                <span class="pp-pdp__save-badge" data-pp-save-badge>-{{ save_pct }}%</span>
              {%- endif -%}
            </div>
          {%- when 'care_icons' -%}
            {%- liquid
              assign has_any_icon = false
              if product.metafields.custom.pet_friendly == true
                assign has_any_icon = true
              endif
              if product.metafields.custom.luz != blank
                assign has_any_icon = true
              endif
              if product.metafields.custom.riego != blank
                assign has_any_icon = true
              endif
              if product.metafields.custom.dificultad != blank
                assign has_any_icon = true
              endif
              if product.metafields.custom.ubicacion != blank
                assign has_any_icon = true
              endif
              if product.metafields.custom.purificadora == true
                assign has_any_icon = true
              endif
              if product.metafields.custom.temperatura != blank
                assign has_any_icon = true
              endif
              if product.metafields.custom.humedad != blank
                assign has_any_icon = true
              endif
            -%}
            {%- if has_any_icon -%}
              <div class="pp-pdp__care-icons" {{ block.shopify_attributes }}>
                {%- if product.metafields.custom.pet_friendly == true -%}
                  <div class="pp-pdp__care-icon" title="Pet Friendly">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 21c-1.5 0-3-1-4.5-3S5 14 5 12s1-3.5 2-4.5S9.5 6 12 6s3.5.5 5 1.5S19 10 19 12s-.5 4.5-2.5 6S13.5 21 12 21z"/></svg>
                    <span>Pet Friendly</span>
                  </div>
                {%- endif -%}
                {%- if product.metafields.custom.luz != blank -%}
                  <div class="pp-pdp__care-icon" title="Luz">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="5"/><path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/></svg>
                    <span>{{ product.metafields.custom.luz | join: ', ' }}</span>
                  </div>
                {%- endif -%}
                {%- if product.metafields.custom.riego != blank -%}
                  <div class="pp-pdp__care-icon" title="Riego">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 2.69l5.66 5.66a8 8 0 1 1-11.31 0z"/></svg>
                    <span>{{ product.metafields.custom.riego | join: ', ' }}</span>
                  </div>
                {%- endif -%}
                {%- if product.metafields.custom.dificultad != blank -%}
                  <div class="pp-pdp__care-icon" title="Dificultad">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                    <span>{{ product.metafields.custom.dificultad }}</span>
                  </div>
                {%- endif -%}
                {%- if product.metafields.custom.ubicacion != blank -%}
                  <div class="pp-pdp__care-icon" title="Ubicación">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
                    <span>{{ product.metafields.custom.ubicacion }}</span>
                  </div>
                {%- endif -%}
                {%- if product.metafields.custom.purificadora == true -%}
                  <div class="pp-pdp__care-icon" title="Purificadora de aire">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M9.59 4.59A2 2 0 1 1 11 8H2m10.59 11.41A2 2 0 1 0 14 16H2m15.73-8.27A2.5 2.5 0 1 1 19.5 12H2"/></svg>
                    <span>Purificadora</span>
                  </div>
                {%- endif -%}
                {%- if product.metafields.custom.temperatura != blank -%}
                  <div class="pp-pdp__care-icon" title="Temperatura">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M14 14.76V3.5a2.5 2.5 0 0 0-5 0v11.26a4.5 4.5 0 1 0 5 0z"/></svg>
                    <span>{{ product.metafields.custom.temperatura }}</span>
                  </div>
                {%- endif -%}
                {%- if product.metafields.custom.humedad != blank -%}
                  <div class="pp-pdp__care-icon" title="Humedad">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 2.69l5.66 5.66a8 8 0 1 1-11.31 0z"/><path d="M8 14a4 4 0 0 0 4 4"/></svg>
                    <span>{{ product.metafields.custom.humedad }}</span>
                  </div>
                {%- endif -%}
              </div>
            {%- endif -%}
          {%- when 'accordion' -%}
            {%- liquid
              assign accordion_content = ''
              case block.settings.content_source
                when 'description'
                  assign accordion_content = product.description
                when 'metafield'
                  assign mf_key = block.settings.metafield_key
                  assign accordion_content = product.metafields.custom[mf_key]
                when 'custom'
                  assign accordion_content = block.settings.custom_content
                when 'medidas'
                  if product.metafields.custom.altura_cm != blank or product.metafields.custom.diametro_maceta_cm != blank
                    assign accordion_content = 'has_medidas'
                  endif
              endcase
            -%}
            {%- if accordion_content != blank -%}
              <details class="pp-pdp__accordion"{% if block.settings.open_by_default %} open{% endif %} {{ block.shopify_attributes }}>
                <summary class="pp-pdp__accordion-header">
                  <span>{{ block.settings.heading }}</span>
                  <svg width="12" height="12" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M2 4.5L6 8.5L10 4.5"/></svg>
                </summary>
                <div class="pp-pdp__accordion-content">
                  {%- case block.settings.content_source -%}
                    {%- when 'description' -%}
                      {{ product.description }}
                    {%- when 'metafield' -%}
                      {{ product.metafields.custom[mf_key] | metafield_tag }}
                    {%- when 'custom' -%}
                      {{ block.settings.custom_content }}
                    {%- when 'medidas' -%}
                      <ul class="pp-pdp__medidas-list">
                        {%- if product.metafields.custom.altura_cm != blank -%}
                          <li>Altura aproximada: {{ product.metafields.custom.altura_cm }}cm</li>
                        {%- endif -%}
                        {%- if product.metafields.custom.diametro_maceta_cm != blank -%}
                          <li>Diámetro maceta: {{ product.metafields.custom.diametro_maceta_cm }}cm</li>
                        {%- endif -%}
                      </ul>
                  {%- endcase -%}
                </div>
              </details>
            {%- endif -%}
        {%- endcase -%}
      {%- endfor -%}
    </div>

    {%- comment -%} ═══ CENTER: Image Gallery ═══ {%- endcomment -%}
    <div class="pp-pdp__gallery">
      {%- if product.media.size > 1 -%}
        <div class="pp-pdp__thumbnails" data-pp-thumbs>
          {%- for media in product.media -%}
            <button
              type="button"
              class="pp-pdp__thumb{% if media.id == featured_image.id %} is-active{% endif %}"
              data-pp-thumb
              data-media-id="{{ media.id }}"
              data-index="{{ forloop.index0 }}"
              aria-label="{{ 'general.go_to_slide' | t: index: forloop.index | default: 'Go to image' }}"
            >
              <img
                src="{{ media | image_url: width: 100 }}"
                alt="{{ media.alt | escape }}"
                width="60"
                height="75"
                loading="lazy"
              >
            </button>
          {%- endfor -%}
        </div>
      {%- endif -%}

      <div class="pp-pdp__main-images" data-pp-main-images>
        {%- for media in product.media -%}
          <div
            class="pp-pdp__main-image"
            data-pp-image
            data-media-id="{{ media.id }}"
            data-index="{{ forloop.index0 }}"
          >
            {%- if media.media_type == 'image' -%}
              <img
                src="{{ media | image_url: width: 1200 }}"
                srcset="{{ media | image_url: width: 600 }} 600w, {{ media | image_url: width: 900 }} 900w, {{ media | image_url: width: 1200 }} 1200w"
                alt="{{ media.alt | escape }}"
                width="{{ media.width }}"
                height="{{ media.height }}"
                loading="{% if forloop.first %}eager{% else %}lazy{% endif %}"
                sizes="(min-width: 750px) 60vw, 100vw"
              >
            {%- elsif media.media_type == 'video' or media.media_type == 'external_video' -%}
              {{ media | media_tag: autoplay: true, loop: true, muted: true, controls: true }}
            {%- elsif media.media_type == 'model' -%}
              {{ media | media_tag }}
            {%- endif -%}
          </div>
        {%- endfor -%}
      </div>

      {%- comment -%} Mobile dots {%- endcomment -%}
      <div class="pp-pdp__dots mobile-only" data-pp-dots>
        {%- for media in product.media -%}
          <span class="pp-pdp__dot{% if forloop.first %} is-active{% endif %}" data-index="{{ forloop.index0 }}"></span>
        {%- endfor -%}
      </div>
    </div>

    {%- comment -%} ═══ RIGHT: Purchase info (sticky) ═══ {%- endcomment -%}
    <div class="pp-pdp__info-right" data-pp-info>
      {%- comment -%} Right column price (synced with left) {%- endcomment -%}
      <div class="pp-pdp__price pp-pdp__price--right" data-pp-price>
        {%- if current_variant.compare_at_price > current_variant.price -%}
          <s class="pp-pdp__price-compare" data-pp-compare-price>{{ current_variant.compare_at_price | money }}</s>
        {%- endif -%}
        <span class="pp-pdp__price-current" data-pp-current-price>{{ current_variant.price | money }}</span>
      </div>

      {%- for block in section.blocks -%}
        {%- case block.type -%}

          {%- comment -%} ── Variant Picker ── {%- endcomment -%}
          {%- when 'variant_picker' -%}
            {%- unless product.has_only_default_variant -%}
              <div class="pp-pdp__variants-wrap" {{ block.shopify_attributes }}>
                {%- for option in product.options_with_values -%}
                  <div class="pp-pdp__variant-group" data-option-index="{{ forloop.index0 }}">
                    <label class="pp-pdp__variant-label">{{ option.name }}</label>
                    <div class="pp-pdp__variant-pills">
                      {%- for value in option.values -%}
                        {%- liquid
                          assign selected = false
                          if current_variant.options contains value
                            assign selected = true
                          endif
                        -%}
                        <button
                          type="button"
                          class="pp-pdp__variant-btn{% if selected %} is-active{% endif %}"
                          data-option-index="{{ forloop.parentloop.index0 }}"
                          data-value="{{ value | escape }}"
                        >
                          {{ value }}
                        </button>
                      {%- endfor -%}
                    </div>
                  </div>
                {%- endfor -%}
              </div>
            {%- endunless -%}

          {%- comment -%} ── Shipping Info ── {%- endcomment -%}
          {%- when 'shipping_info' -%}
            <div class="pp-pdp__shipping-info" {{ block.shopify_attributes }}>
              {%- if block.settings.icon != blank -%}
                <img src="{{ block.settings.icon | image_url: width: 40 }}" width="20" height="20" alt="">
              {%- endif -%}
              <span>{{ block.settings.text }}</span>
            </div>

          {%- comment -%} ── Total Price ── {%- endcomment -%}
          {%- when 'total_price' -%}
            <div class="pp-pdp__total" data-pp-total {{ block.shopify_attributes }}>
              <span class="pp-pdp__total-label">TOTAL</span>
              <span class="pp-pdp__total-value" data-pp-total-price>{{ current_variant.price | money }}</span>
            </div>

          {%- comment -%} ── Buy Button ── {%- endcomment -%}
          {%- when 'buy_button' -%}
            <div class="pp-pdp__buy-wrap" {{ block.shopify_attributes }}>
              {%- if block.settings.show_quantity -%}
                <div class="pp-pdp__qty">
                  <button type="button" class="pp-pdp__qty-minus" data-pp-qty-minus aria-label="Decrease quantity">−</button>
                  <input type="number" class="pp-pdp__qty-input" data-pp-qty-input value="1" min="1" max="99" aria-label="Quantity">
                  <button type="button" class="pp-pdp__qty-plus" data-pp-qty-plus aria-label="Increase quantity">+</button>
                </div>
              {%- endif -%}

              <button
                type="button"
                class="pp-pdp__add-to-cart-btn"
                data-pp-add-to-cart
                data-variant-id="{{ current_variant.id }}"
                {% unless current_variant.available %}disabled{% endunless %}
              >
                {%- if current_variant.available -%}
                  {{ block.settings.button_text | default: 'Añadir' }}
                {%- else -%}
                  {{ 'products.product.sold_out' | t | default: 'Agotado' }}
                {%- endif -%}
              </button>

              {%- if block.settings.show_dynamic_checkout -%}
                {%- form 'product', product, id: 'pp-product-form' -%}
                  <input type="hidden" name="id" value="{{ current_variant.id }}" data-pp-form-variant-id>
                  {{ form | payment_button }}
                {%- endform -%}
              {%- endif -%}
            </div>

          {%- comment -%} ── Custom HTML / Richtext ── {%- endcomment -%}
          {%- when 'custom_html' -%}
            <div class="pp-pdp__custom-html" {{ block.shopify_attributes }}>
              {{ block.settings.content }}
            </div>

          {%- comment -%} ── Separator ── {%- endcomment -%}
          {%- when 'separator' -%}
            <hr class="pp-pdp__separator" {{ block.shopify_attributes }}>

        {%- endcase -%}
      {%- endfor -%}
    </div>
  </div>

  {%- comment -%} SEO product description below the fold {%- endcomment -%}
  {%- if section.settings.show_seo_text and product.description != blank -%}
    <div class="pp-pdp__seo-text">
      <p class="pp-pdp__seo-title">{{ product.title }} | {{ product.type }} | {{ product.vendor }}</p>
      {{ product.description }}
    </div>
  {%- endif -%}
</section>

<script>
  window.ppProductVariants = {{ product.variants | json }};
  window.ppProductOptions = {{ product.options_with_values | json }};
  window.ppCurrentVariantId = {{ current_variant.id }};
</script>
<script src="{{ 'pp-product-main.js' | asset_url }}" type="module" defer></script>

{% schema %}
{
  "name": "PP Product Main",
  "tag": "section",
  "class": "pp-product-main-section",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_seo_text",
      "label": "Show SEO description below",
      "default": true
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 20
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 40
    }
  ],
  "blocks": [
    {
      "type": "breadcrumb",
      "name": "Breadcrumb",
      "limit": 1,
      "settings": []
    },
    {
      "type": "title",
      "name": "Title",
      "limit": 1,
      "settings": [
        {
          "type": "checkbox",
          "id": "show_wishlist",
          "label": "Show wishlist button",
          "default": true
        }
      ]
    },
    {
      "type": "price",
      "name": "Price",
      "limit": 1,
      "settings": [
        {
          "type": "checkbox",
          "id": "show_save_badge",
          "label": "Show save percentage badge",
          "default": true
        }
      ]
    },
    {
      "type": "variant_picker",
      "name": "Variant picker",
      "limit": 1,
      "settings": [
        {
          "type": "select",
          "id": "style",
          "label": "Style",
          "options": [
            { "value": "pills", "label": "Pills" },
            { "value": "dropdown", "label": "Dropdown" }
          ],
          "default": "pills"
        }
      ]
    },
    {
      "type": "care_icons",
      "name": "Care Icons",
      "limit": 1,
      "settings": [
        {
          "type": "image_picker",
          "id": "icon_1",
          "label": "Icon 1"
        },
        {
          "type": "text",
          "id": "label_1",
          "label": "Label 1",
          "default": "Pet Friendly"
        },
        {
          "type": "image_picker",
          "id": "icon_2",
          "label": "Icon 2"
        },
        {
          "type": "text",
          "id": "label_2",
          "label": "Label 2",
          "default": "Poca Luz"
        },
        {
          "type": "image_picker",
          "id": "icon_3",
          "label": "Icon 3"
        },
        {
          "type": "text",
          "id": "label_3",
          "label": "Label 3",
          "default": "Riego bajo"
        },
        {
          "type": "image_picker",
          "id": "icon_4",
          "label": "Icon 4"
        },
        {
          "type": "text",
          "id": "label_4",
          "label": "Label 4"
        },
        {
          "type": "image_picker",
          "id": "icon_5",
          "label": "Icon 5"
        },
        {
          "type": "text",
          "id": "label_5",
          "label": "Label 5"
        },
        {
          "type": "image_picker",
          "id": "icon_6",
          "label": "Icon 6"
        },
        {
          "type": "text",
          "id": "label_6",
          "label": "Label 6"
        }
      ]
    },
    {
      "type": "accordion",
      "name": "Accordion",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Details"
        },
        {
          "type": "select",
          "id": "content_source",
          "label": "Content source",
          "options": [
            { "value": "custom", "label": "Custom text" },
            { "value": "description", "label": "Product description" },
            { "value": "metafield", "label": "Metafield" },
            { "value": "medidas", "label": "Medidas (auto from metafields)" }
          ],
          "default": "custom"
        },
        {
          "type": "richtext",
          "id": "custom_content",
          "label": "Custom content"
        },
        {
          "type": "text",
          "id": "metafield_key",
          "label": "Metafield key (namespace: custom)",
          "info": "Key of the product metafield under custom namespace"
        },
        {
          "type": "checkbox",
          "id": "open_by_default",
          "label": "Open by default",
          "default": false
        }
      ]
    },
