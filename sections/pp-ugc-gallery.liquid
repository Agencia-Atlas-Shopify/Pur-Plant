{{ 'pp-sections.css' | asset_url | stylesheet_tag }}

<div class="section-background color-{{ section.settings.color_scheme }}"></div>
<section
  class="section section--{{ section.settings.section_width }} color-{{ section.settings.color_scheme }} spacing-style"
  style="{% render 'spacing-style', settings: section.settings %}"
>
  {% if section.settings.heading != blank %}
    <h2 class="pp-ugc__heading">{{ section.settings.heading }}</h2>
  {% endif %}

  <div class="pp-ugc__grid">
    {% for block in section.blocks %}
      {% if block.type == 'image' %}
        <div class="pp-ugc__item" {{ block.shopify_attributes }}>
          {% if block.settings.link != blank %}
            <a href="{{ block.settings.link }}" class="pp-ugc__link">
          {% endif %}

          {% if block.settings.image != blank %}
            {{
              block.settings.image
              | image_url: width: 800
              | image_tag:
                loading: 'lazy',
                widths: '300, 400, 600, 800',
                sizes: '(min-width: 750px) 33vw, 100vw',
                class: 'pp-ugc__img'
            }}
          {% else %}
            {{ 'lifestyle-1' | placeholder_svg_tag: 'pp-ugc__placeholder' }}
          {% endif %}

          {% if block.settings.link != blank %}
            </a>
          {% endif %}
        </div>
      {% endif %}
    {% endfor %}
  </div>

  {% if section.settings.button_label != blank %}
    <div class="pp-ugc__actions">
      <a href="{{ section.settings.button_link | default: '#' }}" class="pp-ugc__btn">
        {{ section.settings.button_label }}
      </a>
    </div>
  {% endif %}
</section>

{% schema %}
{
  "name": "UGC Gallery",
  "class": "pp-ugc-section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": ""
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Opiniones"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "header",
      "content": "Section layout"
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "Width",
      "options": [
        { "value": "page-width", "label": "Page" },
        { "value": "full-width", "label": "Full" }
      ],
      "default": "page-width"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "pp-white"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "Top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "Bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 48
    }
  ],
  "blocks": [
    {
      "type": "image",
      "name": "Image",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "UGC Gallery",
      "category": "Pur Plant",
      "settings": {
        "button_label": "Opiniones",
        "color_scheme": "pp-white",
        "padding-block-start": 48,
        "padding-block-end": 48
      },
      "blocks": [
        { "type": "image" },
        { "type": "image" },
        { "type": "image" }
      ]
    }
  ]
}
{% endschema %}
