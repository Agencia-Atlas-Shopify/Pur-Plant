

<div class="section-background color-{{ section.settings.color_scheme }}"></div>
<div class="section color-{{ section.settings.color_scheme }}">
  <div
    class="
      spacing-style
      layout-panel-flex
      layout-panel-flex--column
      section-content-wrapper
      mobile-column
    "
    style="
      {% render 'layout-panel-style', settings: section.settings %}
      {% render 'spacing-style', settings: section.settings %}
    "
  >
    {%- if article.image -%}
      {%- content_for 'block', id: 'blog-post-image', type: '_blog-post-featured-image' %}
    {%- endif -%}

    <header>
      {%- content_for 'block', id: 'blog-post-title', type: 'text' %}
      {%- content_for 'block', id: 'blog-post-details', type: '_blog-post-info-text' %}
    </header>
    {%- content_for 'block', id: 'blog-post-content', type: '_blog-post-content' %}

    {% comment %} Dynamic area for @app blocks only, at the bottom {% endcomment %}
    {% content_for 'blocks' %}

    {% if blog.comments_enabled? %}
      <div class="blog-post-comments-container">
        <h2 class="h3">{{- 'blogs.article.comments_heading' | t: count: article.comments_count -}}</h2>

        <div class="blog-post-comments">
          {% paginate article.comments by 10 %}
            {% for comment in article.comments %}
              <div class="blog-post-comment">
                {{ comment.content }}
                <div class="blog-post-comment__author">
                  <span class="blog-post-comment__author-name">{{- comment.author -}}</span>
                  <span>{{- 'blogs.article.comment_author_separator' | t -}}</span>
                  <span class="blog-post-comment__date">
                    {{- comment.created_at | time_tag: format: 'date' -}}
                  </span>
                </div>
              </div>
            {% endfor %}

            <div class="blog-post-comments-pagination">
              {{- paginate | default_pagination -}}
            </div>
          {% endpaginate %}
        </div>

        {% render 'blog-comment-form', article: article, section_id: section.id %}
      </div>
    {% endif %}
    {%- comment -%} Auto TOC + Related articles {%- endcomment -%}
    {% render 'pp-blog-toc', article: article %}
    {% render 'pp-blog-related', article: article, blog: blog %}

    {%- comment -%} Author box {%- endcomment -%}
    {%- assign autor = article.metafields.custom.autor.value -%}
    {%- if autor -%}
      <div class="pp-author-box">
        {%- if autor.foto.value -%}
          <div class="pp-author-box__photo">
            {{ autor.foto.value | image_url: width: 120 | image_tag: loading: 'lazy', class: 'pp-author-box__img' }}
          </div>
        {%- endif -%}
        <div class="pp-author-box__info">
          <span class="pp-author-box__label">Escrito por</span>
          <span class="pp-author-box__name">{{ autor.nombre.value }}</span>
          {%- if autor.cargo.value != blank -%}
            <span class="pp-author-box__role">{{ autor.cargo.value }}</span>
          {%- endif -%}
          {%- if autor.bio.value != blank -%}
            <p class="pp-author-box__bio">{{ autor.bio.value }}</p>
          {%- endif -%}
          <div class="pp-author-box__social">
            {%- if autor.instagram.value != blank -%}
              <a href="{{ autor.instagram.value }}" target="_blank" rel="noopener" aria-label="Instagram">
                <svg width="18" height="18" viewBox="0 0 16 16" fill="none"><path d="M11.5 15.5h-7a4 4 0 0 1-4-4v-7a4 4 0 0 1 4-4h7a4 4 0 0 1 4 4v7a4 4 0 0 1-4 4z" stroke="currentColor"/><circle cx="8" cy="8" r="3.5" stroke="currentColor"/><circle cx="12.5" cy="3.5" r=".5" fill="currentColor"/></svg>
              </a>
            {%- endif -%}
            {%- if autor.twitter.value != blank -%}
              <a href="{{ autor.twitter.value }}" target="_blank" rel="noopener" aria-label="X / Twitter">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
              </a>
            {%- endif -%}
            {%- if autor.linkedin.value != blank -%}
              <a href="{{ autor.linkedin.value }}" target="_blank" rel="noopener" aria-label="LinkedIn">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452z"/></svg>
              </a>
            {%- endif -%}
            {%- if autor.web.value != blank -%}
              <a href="{{ autor.web.value }}" target="_blank" rel="noopener" aria-label="Web">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><path d="M2 12h20M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
              </a>
            {%- endif -%}
          </div>
        </div>
      </div>
    {%- endif -%}

  </div>
</div>

{%- comment -%} Structured data — enhanced with author {%- endcomment -%}
<script type="application/ld+json">
  {{ article | structured_data }}
</script>
{%- if autor -%}
  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Article",
      "headline": {{ article.title | json }},
      "datePublished": "{{ article.published_at | date: '%Y-%m-%dT%H:%M:%S%z' }}",
      "dateModified": "{{ article.updated_at | date: '%Y-%m-%dT%H:%M:%S%z' }}",
      "author": {
        "@type": "Person",
        "name": {{ autor.nombre.value | json }}
        {%- if autor.web.value != blank -%}
          ,"url": {{ autor.web.value | json }}
        {%- endif -%}
        {%- if autor.foto.value -%}
          ,"image": "{{ autor.foto.value | image_url: width: 400 }}"
        {%- endif -%}
      },
      "publisher": {
        "@type": "Organization",
        "name": "Pur Plant",
        "url": "{{ shop.url }}"
      }
      {%- if article.image -%}
        ,"image": "{{ article.image | image_url: width: 1200 }}"
      {%- endif -%}
    }
  </script>
{%- endif -%}

{% stylesheet %}
  /* Author box */
  .pp-author-box {
    display: flex;
    gap: 20px;
    align-items: flex-start;
    padding: 32px 0;
    margin-top: 40px;
    border-top: 1px solid rgba(35, 55, 44, 0.12);
    max-width: var(--page-content-width, 100%);
    width: 100%;
  }

  .pp-author-box__photo {
    flex-shrink: 0;
  }

  .pp-author-box__img {
    width: 72px;
    height: 72px;
    border-radius: 50%;
    object-fit: cover;
    display: block;
  }

  .pp-author-box__info {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .pp-author-box__label {
    font-family: 'Inter', sans-serif;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #23372c;
    opacity: 0.5;
  }

  .pp-author-box__name {
    font-family: 'Aileron', sans-serif;
    font-size: 20px;
    font-weight: 700;
    color: #23372c;
  }

  .pp-author-box__role {
    font-family: 'Inter', sans-serif;
    font-size: 13px;
    color: #23372c;
    opacity: 0.6;
  }

  .pp-author-box__bio {
    font-family: 'Inter', sans-serif;
    font-size: 14px;
    line-height: 1.6;
    color: #23372c;
    margin: 8px 0 0;
    opacity: 0.8;
  }

  .pp-author-box__social {
    display: flex;
    gap: 12px;
    margin-top: 10px;
  }

  .pp-author-box__social a {
    color: #23372c;
    opacity: 0.5;
    transition: opacity 0.15s;
  }

  .pp-author-box__social a:hover {
    opacity: 1;
  }

  @media screen and (max-width: 749px) {
    .pp-author-box {
      flex-direction: column;
      align-items: center;
      text-align: center;
    }

    .pp-author-box__social {
      justify-content: center;
    }
  }

  .blog-post-comments-container {
    width: 100%;
    max-width: var(--normal-content-width);
    margin: 0 auto;
  }

  .blog-post-comments {
    display: flex;
    flex-direction: column;
    gap: var(--gap-3xl);
  }

  .blog-post-comment__author {
    display: flex;
    align-items: center;
    gap: var(--gap-2xs);
    margin-top: var(--margin-md);
    font-size: var(--font-size--body-sm);
    color: rgb(var(--color-foreground-rgb) / var(--opacity-subdued-text));
  }

  .blog-post-comments-pagination {
    display: flex;
    justify-content: center;
    gap: var(--gap-2xs);
  }

  .blog-post-comments-pagination,
  .blog-post-comments-pagination a {
    color: var(--color-foreground);
  }

  .blog-post-comments-pagination .current {
    color: var(--color-foreground);
  }

  .blog-post-comments-pagination .current,
  .blog-post-comments-pagination a {
    display: block;
    padding: var(--padding-2xs) var(--padding-xs);
  }

  .blog-post-comments-pagination .current,
  .blog-post-comments-pagination a:hover {
    border-bottom: 1px solid var(--color-foreground);
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:names.blog_post",
  "blocks": [
    {
      "type": "@theme"
    },
    {
      "type": "@app"
    }
  ],
  "class": "section-wrapper",
  "settings": [
    {
      "type": "select",
      "id": "content_direction",
      "label": "t:settings.direction",
      "options": [
        {
          "value": "column",
          "label": "t:options.vertical"
        }
      ],
      "default": "column",
      "visible_if": "{{ section.settings.gap < 0 }}"
    },
    {
      "type": "range",
      "id": "gap",
      "label": "t:settings.gap",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 12
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:settings.color_scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "t:content.padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "t:settings.top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "t:settings.bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    }
  ],
  "presets": []
}
{% endschema %}
