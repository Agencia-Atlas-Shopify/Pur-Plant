{% liquid
  assign related_pages = collection.metafields.custom.paginas_relacionadas.value
  assign max_items = 0
  if related_pages != blank
    assign max_items = related_pages.size
  endif
%}

{%- if max_items == 0 -%}
  {%- comment -%} No pages — hide section {%- endcomment -%}
{%- else -%}

<div class="section-background color-{{ section.settings.color_scheme }}"></div>

<div
  class="
    section
    section--{{ section.settings.section_width }}
    color-{{ section.settings.color_scheme }}
    section-resource-list
    spacing-style
    gap-style
  "
  style="
    {% render 'spacing-style', settings: section.settings %}
    {% render 'gap-style', value: section.settings.gap %}
    --column-count: {{ section.settings.columns }};
    --column-count-laptop: {{ section.settings.columns_laptop | default: section.settings.columns }};
    --column-count-mobile: {{ section.settings.mobile_columns | default: 1 }};
  "
  data-testid="page-list"
>
  <div class="section-resource-list__content">
    {%- if section.settings.heading != blank -%}
      <rte-formatter class=" spacing-style text-block rte ">
        <h3><strong>{{ section.settings.heading }}</strong></h3>
      </rte-formatter>
    {%- endif -%}
  </div>

  {% capture list_items %}
    {%- for page in related_pages limit: max_items -%}
      {%- liquid
        assign page_img = page.metafields.custom.imagen_portada.value
        assign ratio = '4 / 5'
        case section.settings.image_ratio
          when 'portrait'
            assign ratio = '4 / 5'
          when 'square'
            assign ratio = '1 / 1'
          when 'landscape'
            assign ratio = '16 / 9'
          when 'portrait_tall'
            assign ratio = '3 / 4'
        endcase
      -%}
      <div class="resource-list__item">
        <div
          class="collection-card border-style"
          data-block-id="pp-page-card-{{ forloop.index }}"
          style="
            --border-width: 1px; --border-style: none; --border-color: rgb(var(--color-border-rgb) / 1.0); --border-radius: 0px;
            --horizontal-alignment: flex-start;
            --vertical-alignment: center;
            --gap: 8px;
          "
        >
          <a class="collection-card__link" href="{{ page.url }}">
            <span class="visually-hidden">{{ page.title }}</span>
          </a>
          <div class="collection-card__inner">
            <style>
              .collection-card[data-block-id="pp-page-card-{{ forloop.index }}"] { --ratio: {{ ratio }}; }
            </style>
            <div class="image-block resource-image collection-card__image spacing-style border-style" style="--border-radius: 0px;">
              {%- if page_img != blank -%}
                {{
                  page_img
                  | image_url: width: 1200
                  | image_tag:
                    widths: '180, 240, 360, 480, 600, 720, 960, 1200',
                    sizes: '(min-width: 750px) 20vw, 50vw',
                    loading: 'lazy',
                    class: 'image-block__image',
                    alt: page.title
                }}
              {%- else -%}
                <div class="pp-page-list__placeholder">
                  <svg viewBox="0 0 20 20" fill="currentColor" width="40" height="40" opacity="0.3">
                    <path d="M18 3H2a1 1 0 0 0-1 1v12a1 1 0 0 0 1 1h16a1 1 0 0 0 1-1V4a1 1 0 0 0-1-1zm-1 12H3V5h14v10z"/>
                    <path d="M6.5 10a1.5 1.5 0 1 0 0-3 1.5 1.5 0 0 0 0 3zM5 14l3-4 2 2 3-4 4 6H5z"/>
                  </svg>
                </div>
              {%- endif -%}
            </div>
            <div class="collection-card__content layout-panel-flex--column">
              <div class="spacing-style text-block h4">
                <p>{{ page.title }}</p>
              </div>
            </div>
          </div>
        </div>
      </div>
      {%- unless forloop.last -%}<!--@list/split-->{%- endunless -%}
    {%- endfor -%}
  {% endcapture %}

  {%- assign list_items_array = list_items | strip | split: '<!--@list/split-->' -%}

  {% render 'resource-list',
    list_items: list_items,
    list_items_array: list_items_array,
    settings: section.settings,
    carousel_ref: 'pageList',
    slide_count: max_items,
    content_type: 'collections',
    test_id: 'page-list-grid'
  %}
</div>

{%- endif -%}

{% schema %}
{
  "name": "PP Page List",
  "class": "ui-test-page-list",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Páginas relacionadas"
    },
    {
      "type": "select",
      "id": "layout_type",
      "label": "Layout",
      "options": [
        { "value": "grid", "label": "Grid" },
        { "value": "carousel", "label": "Carousel" }
      ],
      "default": "carousel"
    },
    {
      "type": "range",
      "id": "columns",
      "min": 2,
      "max": 6,
      "step": 1,
      "label": "Columns",
      "default": 5
    },
    {
      "type": "range",
      "id": "columns_laptop",
      "min": 2,
      "max": 6,
      "step": 1,
      "label": "Columns laptop",
      "default": 3
    },
    {
      "type": "range",
      "id": "mobile_columns",
      "min": 1,
      "max": 3,
      "step": 1,
      "label": "Columns mobile",
      "default": 2
    },
    {
      "type": "range",
      "id": "columns_gap",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "label": "Gap",
      "default": 16
    },
    {
      "type": "range",
      "id": "rows_gap",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "label": "Rows gap",
      "default": 16
    },
    {
      "type": "range",
      "id": "gap",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "label": "Section gap",
      "default": 0
    },
    {
      "type": "select",
      "id": "image_ratio",
      "label": "Image ratio",
      "options": [
        { "value": "portrait", "label": "Portrait 4/5" },
        { "value": "portrait_tall", "label": "Portrait 3/4" },
        { "value": "square", "label": "Square" },
        { "value": "landscape", "label": "Landscape" }
      ],
      "default": "portrait"
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "Section width",
      "options": [
        { "value": "page-width", "label": "Page width" },
        { "value": "full-width", "label": "Full width" }
      ],
      "default": "page-width"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 32
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 24
    }
  ],
  "enabled_on": { "templates": ["collection"] },
  "presets": [
    {
      "name": "PP Page List",
      "category": "Pur Plant"
    }
  ]
}
{% endschema %}
