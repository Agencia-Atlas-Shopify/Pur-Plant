{{ 'pp-sections.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign related_pages = collection.metafields.custom.paginas_relacionadas.value
  assign has_pages = false
  if related_pages != blank and related_pages.size > 0
    assign has_pages = true
  endif
-%}

{%- if has_pages -%}
  <section class="pp-page-list pp-collection-list" style="
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    ">
    <div class="pp-collection-list__inner">
      {%- if section.settings.heading != blank -%}
        <h2 class="pp-collection-list__heading">{{ section.settings.heading }}</h2>
      {%- endif -%}

      <div class="pp-collection-list__grid" style="--pp-coll-list-columns: {{ section.settings.columns_desktop }}; --pp-coll-list-columns-mobile: {{ section.settings.columns_mobile }};">
        {%- for page in related_pages limit: section.settings.max_items -%}
          {%- liquid
            assign page_image = page.metafields.custom.imagen.value
            if page_image == blank
              assign page_image = page.metafields.custom.image.value
            endif
            if page_image == blank
              assign page_image = page.metafields.custom.thumbnail.value
            endif
          -%}
          <a href="{{ page.url }}" class="pp-collection-list__item">
            <div class="pp-collection-list__image" style="--pp-coll-list-ratio: {{ section.settings.image_ratio }};">
              {%- if page_image != blank -%}
                <img
                  src="{{ page_image | image_url: width: 600 }}"
                  srcset="{{ page_image | image_url: width: 300 }} 300w, {{ page_image | image_url: width: 450 }} 450w, {{ page_image | image_url: width: 600 }} 600w"
                  alt="{{ page.title }}"
                  width="600"
                  height="{{ 600 | divided_by: 0.8 | round }}"
                  loading="lazy"
                  sizes="(min-width: 750px) {{ 100 | divided_by: section.settings.columns_desktop }}vw, {{ 100 | divided_by: section.settings.columns_mobile }}vw"
                >
              {%- else -%}
                <div class="pp-collection-list__placeholder">
                  <svg viewBox="0 0 20 20" fill="currentColor" width="40" height="40" opacity="0.3">
                    <path d="M18 3H2a1 1 0 0 0-1 1v12a1 1 0 0 0 1 1h16a1 1 0 0 0 1-1V4a1 1 0 0 0-1-1zm-1 12H3V5h14v10z"/>
                    <path d="M6.5 10a1.5 1.5 0 1 0 0-3 1.5 1.5 0 0 0 0 3zM5 14l3-4 2 2 3-4 4 6H5z"/>
                  </svg>
                </div>
              {%- endif -%}
            </div>
            <span class="pp-collection-list__title">{{ page.title }}</span>
          </a>
        {%- endfor -%}
      </div>
    </div>
  </section>
{%- endif -%}

{% schema %}
{
  "name": "PP Page List",
  "tag": "section",
  "class": "pp-page-list-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "EXPLORA"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "min": 2,
      "max": 6,
      "step": 1,
      "label": "Columns desktop",
      "default": 4
    },
    {
      "type": "range",
      "id": "columns_mobile",
      "min": 1,
      "max": 3,
      "step": 1,
      "label": "Columns mobile",
      "default": 2
    },
    {
      "type": "range",
      "id": "max_items",
      "min": 2,
      "max": 20,
      "step": 1,
      "label": "Max pages",
      "default": 8
    },
    {
      "type": "select",
      "id": "image_ratio",
      "label": "Image ratio",
      "options": [
        { "value": "1 / 1", "label": "Square" },
        { "value": "4 / 5", "label": "Portrait" },
        { "value": "3 / 4", "label": "Portrait tall" },
        { "value": "4 / 3", "label": "Landscape" }
      ],
      "default": "4 / 5"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 40
    }
  ],
  "templates": ["collection"],
  "presets": [
    {
      "name": "PP Page List",
      "category": "Pur Plant"
    }
  ]
}
{% endschema %}
