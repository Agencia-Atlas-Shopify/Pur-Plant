{%- comment -%}
  PP Page Landing — Renders generic/seasonal landing pages (Green Monday, Black Friday, etc.)
  Reads content from page.metafields.custom.page_content JSON array.
  Widget types: heading, text (raw HTML), image.
  First heading + first image = hero section (built via JS).
  Rest rendered sequentially in full-width flexible layout.
{%- endcomment -%}

{{ 'pp-page-guide.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign products_per_row = section.settings.products_per_row | default: 4
-%}

<style>
  /* --- PP Page Landing: type-specific styles --- */
  .pp-landing {
    padding-left: 0 !important;
    padding-right: 0 !important;
  }

  .pp-landing .pp-guide__breadcrumb {
    padding-left: var(--page-margin, 40px);
    padding-right: var(--page-margin, 40px);
  }

  /* --- Hero --- */
  .pp-landing__hero {
    position: relative;
    min-height: 400px;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 80px 40px;
    overflow: hidden;
    margin: 0 0 48px;
  }

  .pp-landing__hero-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .pp-landing__hero-bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .pp-landing__hero-overlay {
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
  }

  .pp-landing__hero-content {
    position: relative;
    z-index: 2;
    max-width: 700px;
  }

  .pp-landing__hero-title {
    font-family: var(--pp-font-heading);
    font-size: clamp(32px, 6vw, 56px);
    font-weight: 400;
    color: #fff;
    line-height: 1.1;
    margin: 0 0 20px;
    text-shadow: 0 2px 20px rgba(0, 0, 0, 0.3);
  }

  .pp-landing__hero-subtitle {
    font-family: var(--pp-font-body);
    font-size: clamp(16px, 2vw, 20px);
    font-weight: 400;
    color: rgba(255, 255, 255, 0.9);
    line-height: 1.6;
    margin: 0 0 28px;
    text-shadow: 0 1px 10px rgba(0, 0, 0, 0.2);
  }

  .pp-landing__hero-cta {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: #fff;
    color: var(--pp-dark-green);
    font-family: var(--pp-font-section);
    font-size: 14px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    padding: 14px 36px;
    border-radius: 100px;
    text-decoration: none;
    transition: transform var(--pp-transition), box-shadow var(--pp-transition);
  }

  .pp-landing__hero-cta:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.15);
  }

  /* --- Full-width content wrapper --- */
  .pp-landing__content {
    max-width: var(--page-content-width, 120rem);
    margin: 0 auto;
    padding: 0 var(--page-margin, 40px);
  }

  /* --- Content widget styles --- */
  .pp-landing .pp-content__heading {
    font-family: 'Aileron', sans-serif;
    font-size: clamp(24px, 3.5vw, 34px);
    font-weight: 800;
    color: #23372c;
    line-height: 1.2;
    margin: 40px 0 15px;
    text-transform: lowercase;
  }
  .pp-landing .pp-content__heading::first-letter {
    text-transform: uppercase;
  }

  .pp-landing .pp-content__heading:first-child {
    margin-top: 0;
  }

  .pp-landing .pp-content__text {
    font-family: var(--pp-font-body);
    font-size: 15px;
    font-weight: 400;
    color: var(--pp-text);
    line-height: 1.75;
    margin: 0 0 24px;
  }

  .pp-landing .pp-content__text p { margin: 0 0 16px; }
  .pp-landing .pp-content__text p:last-child { margin-bottom: 0; }
  .pp-landing .pp-content__text ul,
  .pp-landing .pp-content__text ol { margin: 0 0 16px; padding-left: 24px; }
  .pp-landing .pp-content__text li { margin-bottom: 6px; }
  .pp-landing .pp-content__text a { color: var(--pp-dark-green); text-decoration: underline; }
  .pp-landing .pp-content__text a:hover { opacity: 0.8; }
  .pp-landing .pp-content__text strong { font-weight: 600; }

  .pp-landing .pp-content__image {
    margin: 24px 0;
  }

  .pp-landing .pp-content__image img {
    width: 100%;
    height: auto;
    display: block;
    border-radius: var(--pp-radius, 8px);
    max-width: 100%;
  }

  /* --- Full-width images --- */
  .pp-landing__block-img--full {
    margin: 40px 0;
  }

  .pp-landing__block-img--full img {
    width: 100%;
    height: auto;
    display: block;
    border-radius: 0;
    max-width: 100%;
  }

  /* --- Product grid --- */
  .pp-landing__product-grid-wrapper {
    margin: 56px 0;
    padding: 40px 0;
    border-top: 1px solid rgba(35, 55, 44, 0.1);
    border-bottom: 1px solid rgba(35, 55, 44, 0.1);
  }

  .pp-landing__product-grid-title {
    font-family: var(--pp-font-heading);
    font-size: clamp(20px, 2.5vw, 28px);
    font-weight: 400;
    color: var(--pp-dark-green);
    margin: 0 0 24px;
    text-align: center;
  }

  .pp-landing__product-grid {
    display: grid;
    grid-template-columns: repeat(var(--pp-products-per-row, 4), 1fr);
    gap: 20px;
  }

  /* --- Banner CTA --- */
  .pp-landing__banner {
    background: var(--pp-dark-green);
    border-radius: var(--pp-radius);
    padding: 48px 40px;
    text-align: center;
    margin-top: 56px;
  }

  .pp-landing__banner-text {
    font-family: var(--pp-font-heading);
    font-size: clamp(22px, 3vw, 32px);
    font-weight: 400;
    color: #DAFFD3;
    line-height: 1.3;
    margin: 0 0 24px;
  }

  .pp-landing__banner-btn {
    display: inline-block;
    font-family: var(--pp-font-body);
    font-size: 14px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--pp-dark-green);
    background: #DAFFD3;
    border: none;
    border-radius: 100px;
    padding: 14px 36px;
    text-decoration: none;
    cursor: pointer;
    transition: background var(--pp-transition), transform var(--pp-transition);
  }

  .pp-landing__banner-btn:hover {
    background: #c4f5bb;
    transform: translateY(-1px);
  }

  @media screen and (max-width: 989px) {
    .pp-landing__product-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media screen and (max-width: 749px) {
    .pp-landing__hero {
      min-height: 300px;
      padding: 60px 20px;
    }

    .pp-landing .pp-guide__breadcrumb {
      padding-left: 20px;
      padding-right: 20px;
    }

    .pp-landing__content {
      padding: 0 20px;
    }

    .pp-landing__product-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 12px;
    }

    .pp-landing__product-grid-wrapper {
      margin: 36px 0;
      padding: 28px 0;
    }

    .pp-landing__banner {
      padding: 32px 20px;
      margin-top: 36px;
    }
  }
</style>

<section
  class="pp-guide pp-landing"
  style="
    background-color: {{ section.settings.bg_color }};
    --pp-guide-pad-top: {{ section.settings.padding_top }}px;
    --pp-guide-pad-bottom: {{ section.settings.padding_bottom }}px;
    --pp-products-per-row: {{ products_per_row }};
  "
>

  {%- comment -%} -- Breadcrumb -- {%- endcomment -%}
  {%- if section.settings.show_breadcrumb -%}
    <nav class="pp-guide__breadcrumb" aria-label="Breadcrumb">
      <a href="/">Pur Plant</a>
      <span class="pp-guide__breadcrumb-sep">/</span>
      <span>{{ page.title }}</span>
    </nav>
  {%- endif -%}

  {%- comment -%} -- Hero (built from first heading + first image in page_content, via JS) -- {%- endcomment -%}
  {%- if section.settings.show_hero -%}
    <div class="pp-landing__hero" data-pp-landing-hero style="display:none;">
      <div class="pp-landing__hero-bg" data-pp-landing-hero-bg></div>
      <div class="pp-landing__hero-overlay" style="background: {{ section.settings.hero_overlay_color }};"></div>
      <div class="pp-landing__hero-content">
        <h1 class="pp-landing__hero-title" data-pp-landing-hero-title></h1>
        <p class="pp-landing__hero-subtitle" data-pp-landing-hero-subtitle style="display:none;"></p>
        {%- if section.settings.cta_text != blank -%}
          <a href="{{ section.settings.cta_url }}" class="pp-landing__hero-cta">{{ section.settings.cta_text }}</a>
        {%- endif -%}
      </div>
    </div>
  {%- endif -%}

  {%- comment -%} -- Fallback title when hero is disabled -- {%- endcomment -%}
  {%- unless section.settings.show_hero -%}
    <div class="pp-landing__content">
      <h1 class="pp-guide__title">{{ page.title }}</h1>
    </div>
  {%- endunless -%}

  {%- comment -%} -- JSON data source for page_content -- {%- endcomment -%}
  <script type="application/json" data-page-content>
    {{ page.metafields.custom.page_content | default: '[]' }}
  </script>

  {%- comment -%} -- Content blocks (JS-rendered) -- {%- endcomment -%}
  <div class="pp-landing__content">
    <div data-content-container></div>
  </div>

  {%- comment -%} -- Product grids -- {%- endcomment -%}
  <div class="pp-landing__content">
    {%- assign coll_1 = page.metafields.custom.page_collection_1.value -%}
    {%- if coll_1 -%}
      <div class="pp-landing__product-grid-wrapper">
        {%- if coll_1.title != blank -%}
          <h3 class="pp-landing__product-grid-title">{{ coll_1.title }}</h3>
        {%- endif -%}
        <div class="pp-landing__product-grid">
          {%- for product in coll_1.products limit: 8 -%}
            {%- render 'pp-product-card-standalone', product: product, image_ratio: 'portrait' -%}
          {%- endfor -%}
        </div>
      </div>
    {%- endif -%}

    {%- assign coll_2 = page.metafields.custom.page_collection_2.value -%}
    {%- if coll_2 -%}
      <div class="pp-landing__product-grid-wrapper">
        {%- if coll_2.title != blank -%}
          <h3 class="pp-landing__product-grid-title">{{ coll_2.title }}</h3>
        {%- endif -%}
        <div class="pp-landing__product-grid">
          {%- for product in coll_2.products limit: 8 -%}
            {%- render 'pp-product-card-standalone', product: product, image_ratio: 'portrait' -%}
          {%- endfor -%}
        </div>
      </div>
    {%- endif -%}

    {%- assign coll_3 = page.metafields.custom.page_collection_3.value -%}
    {%- if coll_3 -%}
      <div class="pp-landing__product-grid-wrapper">
        {%- if coll_3.title != blank -%}
          <h3 class="pp-landing__product-grid-title">{{ coll_3.title }}</h3>
        {%- endif -%}
        <div class="pp-landing__product-grid">
          {%- for product in coll_3.products limit: 8 -%}
            {%- render 'pp-product-card-standalone', product: product, image_ratio: 'portrait' -%}
          {%- endfor -%}
        </div>
      </div>
    {%- endif -%}
  </div>

  {%- comment -%} -- Banner CTA -- {%- endcomment -%}
  {%- if section.settings.banner_text != blank -%}
    <div class="pp-landing__content">
      <div class="pp-landing__banner">
        <p class="pp-landing__banner-text">{{ section.settings.banner_text }}</p>
        {%- if section.settings.banner_cta_text != blank and section.settings.banner_cta_url != blank -%}
          <a href="{{ section.settings.banner_cta_url }}" class="pp-landing__banner-btn">
            {{ section.settings.banner_cta_text }}
          </a>
        {%- endif -%}
      </div>
    </div>
  {%- endif -%}

  {%- comment -%} -- Fallback -- {%- endcomment -%}
  <div class="pp-guide__empty" data-pp-empty style="display:none;">
    <p>Esta pagina aun no tiene contenido configurado.</p>
  </div>

</section>

<script>
(function() {
  var dataEl = document.querySelector('[data-page-content]');
  var container = document.querySelector('[data-content-container]');
  var emptyMsg = document.querySelector('[data-pp-empty]');
  var hero = document.querySelector('[data-pp-landing-hero]');
  var heroBg = document.querySelector('[data-pp-landing-hero-bg]');
  var heroTitle = document.querySelector('[data-pp-landing-hero-title]');
  var heroSubtitle = document.querySelector('[data-pp-landing-hero-subtitle]');
  if (!dataEl || !container) return;

  var widgets;
  try { widgets = JSON.parse(dataEl.textContent); } catch(e) { widgets = []; }
  dataEl.remove();

  if (!Array.isArray(widgets) || !widgets.length) {
    container.style.display = 'none';
    if (emptyMsg) emptyMsg.style.display = '';
    return;
  }

  /* --- Build hero from first heading + first image --- */
  var heroUsedIndexes = {};
  if (hero && heroTitle) {
    var foundTitle = false;
    var foundImage = false;
    var foundSubtitle = false;

    for (var i = 0; i < widgets.length; i++) {
      var b = widgets[i];
      if (!b) continue;

      if (!foundTitle && b.type === 'heading') {
        heroTitle.textContent = b.value || '';
        foundTitle = true;
        heroUsedIndexes[i] = true;
        continue;
      }

      if (foundTitle && !foundSubtitle && b.type === 'text') {
        if (heroSubtitle) {
          /* Strip HTML tags for subtitle display */
          var tmp = document.createElement('div');
          tmp.innerHTML = b.value || '';
          heroSubtitle.textContent = tmp.textContent || tmp.innerText || '';
          heroSubtitle.style.display = '';
          foundSubtitle = true;
          heroUsedIndexes[i] = true;
        }
        continue;
      }

      if (!foundImage && b.type === 'image' && b.src) {
        heroBg.innerHTML = '<img src="' + b.src + '" alt="" loading="eager">';
        foundImage = true;
        heroUsedIndexes[i] = true;
        continue;
      }

      if (foundTitle && foundImage) break;
    }

    if (foundTitle) {
      hero.style.display = '';
      if (!foundImage) {
        hero.style.background = 'var(--pp-dark-green)';
      }
    }
  }

  /* --- Render remaining widgets --- */
  var html = '';
  widgets.forEach(function(w, idx) {
    if (heroUsedIndexes[idx]) return;
    if (!w || !w.type) return;

    if (w.type === 'heading') {
      html += '<h2 class="pp-content__heading">' + w.value + '</h2>';
    } else if (w.type === 'text') {
      html += '<div class="pp-content__text">' + w.value + '</div>';
    } else if (w.type === 'image') {
      html += '<div class="pp-content__image"><img src="' + w.src + '" alt="' + (w.alt || '') + '" loading="lazy"></div>';
    }
  });

  container.innerHTML = html;
})();
</script>

{% schema %}
{
  "name": "PP Page Landing",
  "tag": "section",
  "class": "pp-guide-section pp-landing-section",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_breadcrumb",
      "label": "Show breadcrumb",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "show_hero",
      "label": "Show hero (from first heading + image in page_content)",
      "default": true
    },
    {
      "type": "color",
      "id": "hero_overlay_color",
      "label": "Hero overlay color",
      "default": "rgba(35, 55, 44, 0.45)"
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "Hero CTA text (leave blank to hide)",
      "default": "Ver ofertas"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "Hero CTA link",
      "default": "/collections/all"
    },
    {
      "type": "range",
      "id": "products_per_row",
      "min": 2,
      "max": 6,
      "step": 1,
      "label": "Products per row (desktop)",
      "default": 4
    },
    {
      "type": "header",
      "content": "Banner CTA"
    },
    {
      "type": "text",
      "id": "banner_text",
      "label": "Banner text"
    },
    {
      "type": "text",
      "id": "banner_cta_text",
      "label": "CTA button text"
    },
    {
      "type": "url",
      "id": "banner_cta_url",
      "label": "CTA button URL"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "#F5F0E8"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 60
    }
  ],
  "templates": ["page"],
  "presets": [
    {
      "name": "PP Page Landing",
      "category": "Pur Plant"
    }
  ]
}
{% endschema %}
