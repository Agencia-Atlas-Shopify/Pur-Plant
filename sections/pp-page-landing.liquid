{%- comment -%}
  PP Page Landing — Renders generic/seasonal landing pages (Green Monday, Black Friday, etc.)
  from JSON metafield data stored in page.metafields.custom.page_blocks
  Full-width flexible layout, hero with first H1 + first image as background
{%- endcomment -%}

{{ 'pp-page-guide.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign blocks_json = page.metafields.custom.page_blocks | default: '[]'
-%}

<style>
  /* --- PP Page Landing: type-specific styles --- */
  .pp-landing {
    padding-left: 0 !important;
    padding-right: 0 !important;
  }

  .pp-landing .pp-guide__breadcrumb {
    padding-left: var(--page-margin, 40px);
    padding-right: var(--page-margin, 40px);
  }

  /* --- Hero --- */
  .pp-landing__hero {
    position: relative;
    min-height: 400px;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 80px 40px;
    overflow: hidden;
    margin: 0 0 48px;
  }

  .pp-landing__hero-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .pp-landing__hero-bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .pp-landing__hero-overlay {
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
  }

  .pp-landing__hero-content {
    position: relative;
    z-index: 2;
    max-width: 700px;
  }

  .pp-landing__hero-title {
    font-family: var(--pp-font-heading);
    font-size: clamp(32px, 6vw, 56px);
    font-weight: 400;
    color: #fff;
    line-height: 1.1;
    margin: 0 0 20px;
    text-shadow: 0 2px 20px rgba(0, 0, 0, 0.3);
  }

  .pp-landing__hero-subtitle {
    font-family: var(--pp-font-body);
    font-size: clamp(16px, 2vw, 20px);
    font-weight: 400;
    color: rgba(255, 255, 255, 0.9);
    line-height: 1.6;
    margin: 0 0 28px;
    text-shadow: 0 1px 10px rgba(0, 0, 0, 0.2);
  }

  .pp-landing__hero-cta {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: #fff;
    color: var(--pp-dark-green);
    font-family: var(--pp-font-section);
    font-size: 14px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    padding: 14px 36px;
    border-radius: 100px;
    text-decoration: none;
    transition: transform var(--pp-transition), box-shadow var(--pp-transition);
  }

  .pp-landing__hero-cta:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.15);
  }

  /* --- Full-width content wrapper --- */
  .pp-landing__content {
    max-width: var(--page-content-width, 120rem);
    margin: 0 auto;
    padding: 0 var(--page-margin, 40px);
  }

  /* --- Full-width images --- */
  .pp-landing__block-img--full {
    margin: 40px 0;
    grid-column: 1 / -1;
  }

  .pp-landing__block-img--full img {
    width: 100%;
    height: auto;
    display: block;
    border-radius: 0;
    max-width: 100%;
  }

  /* --- Section divider --- */
  .pp-landing__divider {
    width: 60px;
    height: 2px;
    background: rgba(35, 55, 44, 0.15);
    margin: 48px auto;
    grid-column: 1 / -1;
  }

  @media screen and (max-width: 749px) {
    .pp-landing__hero {
      min-height: 300px;
      padding: 60px 20px;
    }

    .pp-landing .pp-guide__breadcrumb {
      padding-left: 20px;
      padding-right: 20px;
    }

    .pp-landing__content {
      padding: 0 20px;
    }
  }
</style>

<section
  class="pp-guide pp-landing"
  style="
    background-color: {{ section.settings.bg_color }};
    --pp-guide-pad-top: {{ section.settings.padding_top }}px;
    --pp-guide-pad-bottom: {{ section.settings.padding_bottom }}px;
  "
>

  {%- comment -%} -- Breadcrumb -- {%- endcomment -%}
  {%- if section.settings.show_breadcrumb -%}
    <nav class="pp-guide__breadcrumb" aria-label="Breadcrumb">
      <a href="/">Pur Plant</a>
      <span class="pp-guide__breadcrumb-sep">/</span>
      <span>{{ page.title }}</span>
    </nav>
  {%- endif -%}

  {%- comment -%} -- Hero (built from first H1 + first image in blocks, via JS) -- {%- endcomment -%}
  {%- if section.settings.show_hero -%}
    <div class="pp-landing__hero" data-pp-landing-hero style="display:none;">
      <div class="pp-landing__hero-bg" data-pp-landing-hero-bg></div>
      <div class="pp-landing__hero-overlay" style="background: {{ section.settings.hero_overlay_color }};"></div>
      <div class="pp-landing__hero-content">
        <h1 class="pp-landing__hero-title" data-pp-landing-hero-title></h1>
        <p class="pp-landing__hero-subtitle" data-pp-landing-hero-subtitle style="display:none;"></p>
        {%- if section.settings.cta_text != blank -%}
          <a href="{{ section.settings.cta_url }}" class="pp-landing__hero-cta">{{ section.settings.cta_text }}</a>
        {%- endif -%}
      </div>
    </div>
  {%- endif -%}

  {%- comment -%} -- Fallback title when hero is disabled -- {%- endcomment -%}
  {%- unless section.settings.show_hero -%}
    <div class="pp-landing__content">
      <h1 class="pp-guide__title">{{ page.title }}</h1>
    </div>
  {%- endunless -%}

  {%- comment -%} -- Content blocks from JSON metafield -- {%- endcomment -%}
  <div class="pp-landing__content">
    <div class="pp-guide__body pp-guide__body--columns" data-pp-landing-body>
      <script type="application/json" data-pp-landing-blocks>{{ blocks_json }}</script>
    </div>
  </div>

  <div class="pp-guide__empty" data-pp-landing-empty style="display:none;">
    <p>Esta pagina aun no tiene contenido configurado.</p>
  </div>

</section>

<script>
(function() {
  var container = document.querySelector('[data-pp-landing-body]');
  var emptyMsg = document.querySelector('[data-pp-landing-empty]');
  var dataEl = document.querySelector('[data-pp-landing-blocks]');
  var hero = document.querySelector('[data-pp-landing-hero]');
  var heroBg = document.querySelector('[data-pp-landing-hero-bg]');
  var heroTitle = document.querySelector('[data-pp-landing-hero-title]');
  var heroSubtitle = document.querySelector('[data-pp-landing-hero-subtitle]');
  if (!container || !dataEl) return;

  var blocks;
  try {
    blocks = JSON.parse(dataEl.textContent);
  } catch(e) {
    blocks = [];
  }

  dataEl.remove();

  if (!Array.isArray(blocks) || blocks.length === 0) {
    container.style.display = 'none';
    if (emptyMsg) emptyMsg.style.display = '';
    return;
  }

  function esc(str) {
    if (!str) return '';
    var div = document.createElement('div');
    div.appendChild(document.createTextNode(str));
    return div.innerHTML;
  }

  function renderParagraphText(text, links) {
    var html = esc(text);
    if (links && Array.isArray(links)) {
      links.forEach(function(link) {
        if (link.text && link.url) {
          var escaped = esc(link.text);
          html = html.replace(escaped, '<a href="' + esc(link.url) + '">' + escaped + '</a>');
        }
      });
    }
    return html;
  }

  /* --- Build hero from first H1/heading + first image --- */
  var heroUsedIndexes = {};
  if (hero && heroTitle) {
    var foundTitle = false;
    var foundImage = false;
    var foundSubtitle = false;

    for (var i = 0; i < blocks.length; i++) {
      var b = blocks[i];
      if (!b) continue;

      if (!foundTitle && b.type === 'heading' && (b.level === 1 || b.level === 2)) {
        heroTitle.textContent = b.text || '';
        foundTitle = true;
        heroUsedIndexes[i] = true;
        continue;
      }

      if (foundTitle && !foundSubtitle && b.type === 'paragraph') {
        if (heroSubtitle) {
          heroSubtitle.textContent = b.text || '';
          heroSubtitle.style.display = '';
          foundSubtitle = true;
          heroUsedIndexes[i] = true;
        }
        continue;
      }

      if (!foundImage && b.type === 'image' && b.url) {
        heroBg.innerHTML = '<img src="' + esc(b.url) + '" alt="" loading="eager">';
        foundImage = true;
        heroUsedIndexes[i] = true;
        continue;
      }

      if (foundTitle && foundImage) break;
    }

    if (foundTitle) {
      hero.style.display = '';
      if (!foundImage) {
        /* No image: dark green background */
        hero.style.background = 'var(--pp-dark-green)';
      }
    }
  }

  /* --- Render remaining blocks --- */
  var html = '';
  blocks.forEach(function(block, idx) {
    if (heroUsedIndexes[idx]) return;
    if (!block || !block.type) return;

    switch(block.type) {
      case 'heading':
        var level = block.level || 2;
        if (level < 1) level = 1;
        if (level > 6) level = 6;
        var cls = 'pp-guide__block-h' + level;
        var tag = 'h' + level;
        html += '<' + tag + ' class="' + cls + '">' + esc(block.text || '') + '</' + tag + '>';
        break;

      case 'paragraph':
        html += '<p class="pp-guide__block-p">' + renderParagraphText(block.text || '', block.links) + '</p>';
        break;

      case 'image':
        var alt = block.alt ? esc(block.alt) : '';
        var url = block.url || '';
        if (url) {
          html += '<div class="pp-guide__block-img pp-landing__block-img--full"><img src="' + esc(url) + '" alt="' + alt + '" loading="lazy"></div>';
        }
        break;

      case 'list':
        if (block.items && Array.isArray(block.items) && block.items.length > 0) {
          html += '<ul class="pp-guide__block-list">';
          block.items.forEach(function(item) {
            html += '<li>' + esc(item) + '</li>';
          });
          html += '</ul>';
        }
        break;
    }
  });

  container.innerHTML = html;
})();
</script>

{% schema %}
{
  "name": "PP Page Landing",
  "tag": "section",
  "class": "pp-guide-section pp-landing-section",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_breadcrumb",
      "label": "Show breadcrumb",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "show_hero",
      "label": "Show hero (from first H1 + image in blocks)",
      "default": true
    },
    {
      "type": "color",
      "id": "hero_overlay_color",
      "label": "Hero overlay color",
      "default": "rgba(35, 55, 44, 0.45)"
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "Hero CTA text (leave blank to hide)",
      "default": "Ver ofertas"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "Hero CTA link",
      "default": "/collections/all"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "#F5F0E8"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 60
    }
  ],
  "templates": ["page"],
  "presets": [
    {
      "name": "PP Page Landing",
      "category": "Pur Plant"
    }
  ]
}
{% endschema %}
