{%- comment -%}
  PP Page Tipos — Renders plant variety/types guide pages
  Reads content from page.metafields.custom.page_content JSON array.
  Widget types: heading, text (raw HTML), image.
  Layout: first text = intro, then heading+image+text groups = variety cards (2-col grid).
  Also uses: page_collection_1..3 for product grids.
{%- endcomment -%}

{{ 'pp-page-guide.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign products_per_row = section.settings.products_per_row | default: 4
  assign cards_per_row = section.settings.cards_per_row | default: 2
-%}

<style>
  /* ==========================================================================
     PP Page Tipos — Inline Styles
     ========================================================================== */

  /* --- Hero --- */
  .pp-tipos-hero {
    position: relative;
    width: 100%;
    min-height: 340px;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    border-radius: var(--pp-radius, 8px);
    margin-bottom: 48px;
  }

  .pp-tipos-hero__gradient {
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, #23372C 0%, #3a5a42 50%, #23372C 100%);
    z-index: 0;
  }

  .pp-tipos-hero__content {
    position: relative;
    z-index: 2;
    text-align: center;
    padding: 60px 24px;
    max-width: 800px;
  }

  .pp-tipos-hero__title {
    font-family: 'Aileron', sans-serif;
    font-size: clamp(36px, 6vw, 64px);
    font-weight: 700;
    color: #ffffff;
    line-height: 1.1;
    margin: 0;
    text-transform: none;
    letter-spacing: -0.02em;
  }

  /* --- Container --- */
  .pp-tipos {
    --pp-dark-green: #23372C;
    --pp-light-green: #DAFFD3;
    --pp-beige: #F5F0E8;
    --pp-text: #3a3838;
    --pp-font-body: 'Inter', sans-serif;
    --pp-font-heading: 'Tenor Sans', Georgia, serif;
    --pp-font-display: 'Aileron', sans-serif;
    --pp-radius: 8px;
    --pp-content-max: 800px;
    --pp-transition: 0.25s ease;
    max-width: var(--page-content-width, 120rem);
    margin: 0 auto;
    padding: var(--pp-tipos-pad-top, 40px) var(--page-margin, 40px) var(--pp-tipos-pad-bottom, 60px);
    font-family: var(--pp-font-body);
    color: var(--pp-text);
  }

  /* --- Intro text --- */
  .pp-tipos__intro {
    font-family: var(--pp-font-body);
    font-size: 16px;
    font-weight: 400;
    color: var(--pp-text);
    line-height: 1.8;
    margin: 0 auto 48px;
    max-width: var(--pp-content-max);
    text-align: center;
    opacity: 0.9;
  }

  .pp-tipos__intro p { margin: 0 0 16px; }
  .pp-tipos__intro p:last-child { margin-bottom: 0; }
  .pp-tipos__intro a { color: var(--pp-dark-green); text-decoration: underline; }
  .pp-tipos__intro strong { font-weight: 600; }

  /* --- Variety cards (horizontal: image left, content right) --- */
  .pp-tipos__cards-grid {
    display: flex;
    flex-direction: column;
    gap: 40px;
    margin: 0 0 56px;
  }

  .pp-tipos__card {
    display: grid;
    grid-template-columns: 35% 1fr;
    gap: 0;
    background: #ffffff;
    border-radius: var(--pp-radius);
    overflow: hidden;
    border: 1px solid rgba(35, 55, 44, 0.08);
    transition: box-shadow var(--pp-transition);
  }

  .pp-tipos__card:hover {
    box-shadow: 0 8px 32px rgba(35, 55, 44, 0.12);
  }

  .pp-tipos__card-image {
    width: 100%;
    min-height: 280px;
    overflow: hidden;
  }

  .pp-tipos__card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.4s ease;
  }

  .pp-tipos__card:hover .pp-tipos__card-image img {
    transform: scale(1.03);
  }

  /* Card without image: content spans full width */
  .pp-tipos__card--no-image {
    grid-template-columns: 1fr;
  }

  .pp-tipos__card-body {
    padding: 32px;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .pp-tipos__card-name {
    font-family: var(--pp-font-heading);
    font-size: clamp(20px, 2.5vw, 26px);
    font-weight: 700;
    color: #23372c;
    line-height: 1.25;
    margin: 0 0 16px;
    text-transform: lowercase;
  }
  .pp-tipos__card-name::first-letter {
    text-transform: uppercase;
  }

  .pp-tipos__card-desc {
    font-family: var(--pp-font-body);
    font-size: 15px;
    font-weight: 400;
    color: var(--pp-text);
    line-height: 1.75;
    margin: 0;
    opacity: 0.9;
  }

  .pp-tipos__card-desc p { margin: 0 0 12px; }
  .pp-tipos__card-desc p:last-child { margin-bottom: 0; }
  .pp-tipos__card-desc a { color: var(--pp-dark-green); text-decoration: underline; }
  .pp-tipos__card-desc strong { font-weight: 600; }
  .pp-tipos__card-desc ul,
  .pp-tipos__card-desc ol { margin: 0 0 12px; padding-left: 20px; }
  .pp-tipos__card-desc li { margin-bottom: 4px; }

  /* --- Product grid --- */
  .pp-tipos__product-grid-wrapper {
    margin: 56px 0;
    padding: 40px 0;
    border-top: 1px solid rgba(35, 55, 44, 0.1);
    border-bottom: 1px solid rgba(35, 55, 44, 0.1);
  }

  .pp-tipos__product-grid-title {
    font-family: var(--pp-font-heading);
    font-size: clamp(20px, 2.5vw, 28px);
    font-weight: 400;
    color: var(--pp-dark-green);
    margin: 0 0 24px;
    text-align: center;
  }

  .pp-tipos__product-grid {
    display: grid;
    grid-template-columns: repeat(var(--pp-products-per-row, 4), 1fr);
    gap: 20px;
  }

  /* --- Banner CTA --- */
  .pp-tipos__banner {
    background: var(--pp-dark-green);
    border-radius: var(--pp-radius);
    padding: 48px 40px;
    text-align: center;
    margin-top: 56px;
  }

  .pp-tipos__banner-text {
    font-family: var(--pp-font-heading);
    font-size: clamp(22px, 3vw, 32px);
    font-weight: 400;
    color: #DAFFD3;
    line-height: 1.3;
    margin: 0 0 24px;
  }

  .pp-tipos__banner-btn {
    display: inline-block;
    font-family: var(--pp-font-body);
    font-size: 14px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--pp-dark-green);
    background: #DAFFD3;
    border: none;
    border-radius: 100px;
    padding: 14px 36px;
    text-decoration: none;
    cursor: pointer;
    transition: background var(--pp-transition), transform var(--pp-transition);
  }

  .pp-tipos__banner-btn:hover {
    background: #c4f5bb;
    transform: translateY(-1px);
  }

  /* --- Breadcrumb --- */
  .pp-tipos .pp-guide__breadcrumb {
    margin-bottom: 24px;
  }

  /* ==========================================================================
     Responsive
     ========================================================================== */
  @media screen and (max-width: 989px) {
    .pp-tipos__product-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media screen and (max-width: 749px) {
    .pp-tipos-hero {
      min-height: 240px;
      border-radius: 0;
      margin-bottom: 32px;
    }

    .pp-tipos-hero__content {
      padding: 40px 20px;
    }

    .pp-tipos__card {
      grid-template-columns: 1fr;
    }

    .pp-tipos__card-image {
      min-height: 220px;
      max-height: 300px;
    }

    .pp-tipos__cards-grid {
      gap: 24px;
      margin-bottom: 36px;
    }

    .pp-tipos__card-body {
      padding: 20px 16px;
    }

    .pp-tipos__product-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 12px;
    }

    .pp-tipos__product-grid-wrapper {
      margin: 36px 0;
      padding: 28px 0;
    }

    .pp-tipos__banner {
      padding: 32px 20px;
      margin-top: 36px;
    }

    .pp-tipos__intro {
      font-size: 15px;
    }
  }
</style>

<section
  class="pp-tipos"
  style="
    --pp-tipos-pad-top: {{ section.settings.padding_top }}px;
    --pp-tipos-pad-bottom: {{ section.settings.padding_bottom }}px;
    --pp-products-per-row: {{ products_per_row }};
    /* cards are now horizontal layout, no per-row setting needed */
  "
>

  {%- comment -%} -- Breadcrumb -- {%- endcomment -%}
  {%- if section.settings.show_breadcrumb -%}
    <nav class="pp-guide__breadcrumb" aria-label="Breadcrumb">
      <a href="/">Pur Plant</a>
      <span class="pp-guide__breadcrumb-sep">/</span>
      <a href="/pages/tipos-de-plantas">Tipos de Plantas</a>
      <span class="pp-guide__breadcrumb-sep">/</span>
      <span>{{ page.title }}</span>
    </nav>
  {%- endif -%}

  {%- comment -%} -- 1. Hero Section -- {%- endcomment -%}
  {%- if section.settings.show_hero -%}
    <div class="pp-tipos-hero">
      <div class="pp-tipos-hero__gradient"></div>
      <div class="pp-tipos-hero__content">
        <h1 class="pp-tipos-hero__title">{{ page.title }}</h1>
      </div>
    </div>
  {%- endif -%}

  {%- comment -%} -- 2. JSON data source -- {%- endcomment -%}
  <script type="application/json" data-page-content>
    {{ page.metafields.custom.page_content | default: '[]' }}
  </script>

  {%- comment -%} -- 3. Intro container (JS fills with first text widget) -- {%- endcomment -%}
  <div data-tipos-intro></div>

  {%- comment -%} -- 4. Cards grid container (JS fills with heading+image+text cards) -- {%- endcomment -%}
  <div data-tipos-cards></div>

  {%- comment -%} -- 5. Product grids (server-rendered) -- {%- endcomment -%}
  {%- assign coll_1 = page.metafields.custom.page_collection_1.value -%}
  {%- if coll_1 -%}
    <div class="pp-tipos__product-grid-wrapper">
      {%- if coll_1.title != blank -%}
        <h3 class="pp-tipos__product-grid-title">{{ coll_1.title }}</h3>
      {%- endif -%}
      <div class="pp-tipos__product-grid">
        {%- for product in coll_1.products limit: 8 -%}
          {%- render 'pp-product-card-standalone', product: product, image_ratio: 'portrait' -%}
        {%- endfor -%}
      </div>
    </div>
  {%- endif -%}

  {%- assign coll_2 = page.metafields.custom.page_collection_2.value -%}
  {%- if coll_2 -%}
    <div class="pp-tipos__product-grid-wrapper">
      {%- if coll_2.title != blank -%}
        <h3 class="pp-tipos__product-grid-title">{{ coll_2.title }}</h3>
      {%- endif -%}
      <div class="pp-tipos__product-grid">
        {%- for product in coll_2.products limit: 8 -%}
          {%- render 'pp-product-card-standalone', product: product, image_ratio: 'portrait' -%}
        {%- endfor -%}
      </div>
    </div>
  {%- endif -%}

  {%- assign coll_3 = page.metafields.custom.page_collection_3.value -%}
  {%- if coll_3 -%}
    <div class="pp-tipos__product-grid-wrapper">
      {%- if coll_3.title != blank -%}
        <h3 class="pp-tipos__product-grid-title">{{ coll_3.title }}</h3>
      {%- endif -%}
      <div class="pp-tipos__product-grid">
        {%- for product in coll_3.products limit: 8 -%}
          {%- render 'pp-product-card-standalone', product: product, image_ratio: 'portrait' -%}
        {%- endfor -%}
      </div>
    </div>
  {%- endif -%}

  {%- comment -%} -- 6. Banner CTA -- {%- endcomment -%}
  {%- if section.settings.banner_text != blank -%}
    <div class="pp-tipos__banner" style="background-color: {{ section.settings.hero_bg_color }};">
      <p class="pp-tipos__banner-text">{{ section.settings.banner_text }}</p>
      {%- if section.settings.banner_cta_text != blank and section.settings.banner_cta_url != blank -%}
        <a href="{{ section.settings.banner_cta_url }}" class="pp-tipos__banner-btn">
          {{ section.settings.banner_cta_text }}
        </a>
      {%- endif -%}
    </div>
  {%- endif -%}

  {%- comment -%} -- Fallback -- {%- endcomment -%}
  <div class="pp-guide__empty" data-pp-empty style="display:none;">
    <p>Esta guia aun no tiene contenido configurado.</p>
  </div>

</section>

<script>
(function() {
  var dataEl = document.querySelector('[data-page-content]');
  var introContainer = document.querySelector('[data-tipos-intro]');
  var cardsContainer = document.querySelector('[data-tipos-cards]');
  var emptyMsg = document.querySelector('[data-pp-empty]');
  if (!dataEl || !introContainer || !cardsContainer) return;

  var widgets;
  try { widgets = JSON.parse(dataEl.textContent); } catch(e) { widgets = []; }
  dataEl.remove();

  if (!Array.isArray(widgets) || !widgets.length) {
    if (emptyMsg) emptyMsg.style.display = '';
    return;
  }

  /* First text widget = intro paragraph */
  var introHtml = '';
  var startIndex = 0;
  for (var i = 0; i < widgets.length; i++) {
    if (widgets[i] && widgets[i].type === 'text') {
      introHtml = '<div class="pp-tipos__intro">' + widgets[i].value + '</div>';
      startIndex = i + 1;
      break;
    }
  }
  introContainer.innerHTML = introHtml;

  /* Remaining widgets: group heading + next image + next text into variety cards.
     Any standalone text/image between card groups renders inline. */
  var cards = [];
  var idx = startIndex;

  while (idx < widgets.length) {
    var w = widgets[idx];
    if (!w || !w.type) { idx++; continue; }

    if (w.type === 'heading') {
      var card = { heading: w.value, image: null, imageAlt: '', text: '' };

      /* Look ahead for image and text */
      var next1 = widgets[idx + 1];
      var next2 = widgets[idx + 2];

      if (next1 && next1.type === 'image') {
        card.image = next1.src;
        card.imageAlt = next1.alt || '';
        idx++;
        next2 = widgets[idx + 1];
      }
      if (next2 && next2.type === 'text') {
        card.text = next2.value;
        idx++;
      } else if (next1 && next1.type === 'text' && !card.image) {
        card.text = next1.value;
        idx++;
      }

      cards.push(card);
    }
    idx++;
  }

  if (cards.length === 0 && !introHtml) {
    if (emptyMsg) emptyMsg.style.display = '';
    return;
  }

  /* Build cards grid HTML */
  if (cards.length > 0) {
    var html = '<div class="pp-tipos__cards-grid">';
    cards.forEach(function(card, ci) {
      var noImg = card.image ? '' : ' pp-tipos__card--no-image';
      html += '<div class="pp-tipos__card' + noImg + '" id="variety-' + (ci + 1) + '">';
      if (card.image) {
        html += '<div class="pp-tipos__card-image"><img src="' + card.image + '" alt="' + card.imageAlt + '" loading="lazy"></div>';
      }
      html += '<div class="pp-tipos__card-body">';
      html += '<h3 class="pp-tipos__card-name">' + card.heading + '</h3>';
      if (card.text) {
        html += '<div class="pp-tipos__card-desc">' + card.text + '</div>';
      }
      html += '</div></div>';
    });
    html += '</div>';
    cardsContainer.innerHTML = html;
  }
})();
</script>

{% schema %}
{
  "name": "PP Page Tipos",
  "tag": "section",
  "class": "pp-guide-section pp-tipos-section",
  "settings": [
    {
      "type": "header",
      "content": "Hero"
    },
    {
      "type": "checkbox",
      "id": "show_hero",
      "label": "Show hero section",
      "default": true
    },
    {
      "type": "color",
      "id": "hero_bg_color",
      "label": "Hero / Banner background color",
      "default": "#23372C"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "checkbox",
      "id": "show_breadcrumb",
      "label": "Show breadcrumb",
      "default": true
    },
    {
      "type": "range",
      "id": "cards_per_row",
      "min": 1,
      "max": 3,
      "step": 1,
      "label": "Variety cards per row (desktop)",
      "default": 2
    },
    {
      "type": "range",
      "id": "products_per_row",
      "min": 2,
      "max": 6,
      "step": 1,
      "label": "Products per row (desktop)",
      "default": 4
    },
    {
      "type": "header",
      "content": "Banner CTA"
    },
    {
      "type": "text",
      "id": "banner_text",
      "label": "Banner text",
      "default": "Descubre todas las variedades disponibles"
    },
    {
      "type": "text",
      "id": "banner_cta_text",
      "label": "CTA button text",
      "default": "Ver productos"
    },
    {
      "type": "url",
      "id": "banner_cta_url",
      "label": "CTA button URL"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 60
    }
  ],
  "templates": ["page"],
  "presets": [
    {
      "name": "PP Page Tipos",
      "category": "Pur Plant"
    }
  ]
}
{% endschema %}
