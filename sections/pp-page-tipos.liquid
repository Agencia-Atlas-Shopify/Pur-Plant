{%- comment -%}
  PP Page Tipos — Renders plant variety/types guide pages (SSR).
  Reads content from page.metafields.custom.page_content JSON array and renders
  100% server-side (no client hydration) so crawlers (ClaudeBot / GPTBot /
  PerplexityBot / Google) see the full HTML.
  Widget types: heading, text (raw HTML), image, cta.
  Layout: first text = intro; every heading opens a variety card and consumes
  the next non-heading widgets (up to 6) picking the first image/text/cta.
  Also emits BreadcrumbList + ItemList + FAQPage JSON-LD.
  Product grids come from page_collection_1..3 metafields (unchanged).
{%- endcomment -%}

{{ 'pp-page-guide.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign products_per_row = section.settings.products_per_row | default: 4
  assign cards_per_row = section.settings.cards_per_row | default: 2

  assign widgets = page.metafields.custom.page_content.value
  assign widgets_size = 0
  if widgets != blank
    assign widgets_size = widgets.size
  endif

  # Pre-pass 1: locate the first text widget (intro). Matches the JS behavior
  # (`startIndex = intro_idx + 1`) — headings before the intro are discarded.
  assign intro_idx = -1
  if widgets_size > 0
    for w in widgets
      if w.type == 'text' and intro_idx == -1
        assign intro_idx = forloop.index0
        break
      endif
    endfor
  endif
  assign start_idx = intro_idx | plus: 1

  # Pre-pass 2: count variety cards (headings after start_idx) so we know
  # whether to open the .pp-tipos__cards-grid wrapper and whether to emit
  # the ItemList JSON-LD. Excluye headings de FAQ y "Explora" (no son variedades).
  assign total_cards = 0
  if widgets_size > 0
    for w in widgets
      if forloop.index0 < start_idx
        continue
      endif
      if w.type == 'heading'
        assign heading_lc_pre2 = w.value | downcase
        assign is_special_heading = false
        if heading_lc_pre2 contains 'preguntas frecuentes' or heading_lc_pre2 contains 'faq'
          assign is_special_heading = true
        endif
        if heading_lc_pre2 contains 'explora'
          assign is_special_heading = true
        endif
        unless is_special_heading
          assign total_cards = total_cards | plus: 1
        endunless
      endif
    endfor
  endif

  # Pre-pass 3: detect an FAQ block embedded inside a text widget.
  # Trigger: a heading containing "preguntas frecuentes" or "faq" immediately
  # followed by a text widget that includes <details> markup.
  assign faq_html_source = ''
  assign faq_prev_was_heading = false
  if widgets_size > 0
    for w in widgets
      if w.type == 'heading'
        assign heading_lc = w.value | downcase
        if heading_lc contains 'preguntas frecuentes' or heading_lc contains 'faq'
          assign faq_prev_was_heading = true
        else
          assign faq_prev_was_heading = false
        endif
      elsif w.type == 'text' and faq_prev_was_heading and faq_html_source == ''
        if w.value contains '<details' or w.value contains 'pp-faq'
          assign faq_html_source = w.value
        endif
        assign faq_prev_was_heading = false
      endif
    endfor
  endif

  # Count valid Q/A pairs to decide whether to emit FAQPage schema.
  # Tolerante a <summary> con atributos (ej. <summary style="...">): usa split '<summary'
  # (sin '>') y descarta el resto de la etiqueta apertura hasta el primer '>'.
  # Antes de strip_html, inserta espacios en </p>, </li>, <br> para no pegar tokens al concatenar.
  assign faq_count = 0
  if faq_html_source != ''
    assign faq_blocks_pre = faq_html_source | split: '</details>'
    for block in faq_blocks_pre
      if block contains '<summary'
        assign after_open_pre = block | split: '<summary' | last
        assign after_summary_pre = after_open_pre | split: '>' | last
        assign _q_pre = after_summary_pre | split: '</summary>' | first | strip_html | strip | strip_newlines
        assign _a_html_pre = after_summary_pre | split: '</summary>' | last
        assign _a_spaced_pre = _a_html_pre | replace: '</p>', ' ' | replace: '</li>', ' ' | replace: '<br>', ' ' | replace: '<br/>', ' ' | replace: '<br />', ' '
        assign _a_pre = _a_spaced_pre | strip_html | strip | strip_newlines
        if _q_pre != '' and _a_pre != ''
          assign faq_count = faq_count | plus: 1
        endif
      endif
    endfor
  endif
-%}

<style>
  /* ==========================================================================
     PP Page Tipos — Inline Styles
     ========================================================================== */

  /* --- Hero (full-width, overlaps header) --- */
  .pp-tipos-hero {
    position: relative;
    left: 50%;
    right: 50%;
    width: 100vw;
    margin-left: -50vw;
    margin-right: -50vw;
    min-height: 450px;
    display: flex;
    align-items: flex-end;
    justify-content: flex-start;
    overflow: hidden;
    border-radius: 0;
    margin-bottom: 48px;
    margin-top: calc(-1 * (var(--pp-tipos-pad-top, 40px) + var(--pp-header-height, 120px)));
    padding-top: var(--pp-header-height, 120px);
  }

  .pp-tipos-hero__bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .pp-tipos-hero__bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .pp-tipos-hero__gradient {
    position: absolute;
    inset: 0;
    background: rgba(35, 55, 44, 0.3);
    z-index: 1;
  }

  .pp-tipos-hero__content {
    position: relative;
    z-index: 2;
    text-align: left;
    padding: 40px 32px;
    max-width: 800px;
  }

  .pp-tipos-hero__title {
    font-family: 'Aileron', sans-serif;
    font-size: clamp(36px, 6vw, 64px);
    font-weight: 700;
    color: #e4ffd3;
    line-height: 0.8;
    margin: 0;
    letter-spacing: -0.07em;
    text-transform: uppercase;
  }

  /* --- Container --- */
  .pp-tipos {
    --pp-dark-green: #23372C;
    --pp-light-green: #DAFFD3;
    --pp-beige: #F5F0E8;
    --pp-text: #3a3838;
    --pp-font-body: 'Inter', sans-serif;
    --pp-font-heading: 'Tenor Sans', Georgia, serif;
    --pp-font-display: 'Aileron', sans-serif;
    --pp-radius: 8px;
    --pp-content-max: 800px;
    --pp-transition: 0.25s ease;
    max-width: var(--page-content-width, 120rem);
    margin: 0 auto;
    padding: var(--pp-tipos-pad-top, 40px) var(--page-margin, 40px) var(--pp-tipos-pad-bottom, 60px);
    font-family: var(--pp-font-body);
    color: var(--pp-text);
  }

  /* --- Intro text --- */
  .pp-tipos__intro {
    font-family: var(--pp-font-body);
    font-size: 16px;
    font-weight: 400;
    color: var(--pp-text);
    line-height: 1.8;
    margin: 0 auto 48px;
    max-width: var(--pp-content-max);
    text-align: left;
    opacity: 0.9;
  }

  .pp-tipos__intro p { margin: 0 0 16px; }
  .pp-tipos__intro p:last-child { margin-bottom: 0; }
  .pp-tipos__intro a { color: var(--pp-dark-green); text-decoration: underline; }
  .pp-tipos__intro strong { font-weight: 600; }

  /* --- Variety cards (horizontal: image left, content right) --- */
  .pp-tipos__cards-grid {
    display: flex;
    flex-direction: column;
    gap: 40px;
    margin: 0 0 56px;
  }

  .pp-tipos__card {
    display: grid;
    grid-template-columns: 35% 1fr;
    gap: 0;
    background: transparent;
    border-radius: 0;
    overflow: hidden;
    border: none;
  }

  .pp-tipos__card-image {
    width: 100%;
    min-height: 280px;
    overflow: hidden;
  }

  .pp-tipos__card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.4s ease;
  }

  .pp-tipos__card:hover .pp-tipos__card-image img {
    transform: scale(1.03);
  }

  /* Card without image: content spans full width */
  .pp-tipos__card--no-image {
    grid-template-columns: 1fr;
  }

  .pp-tipos__card-body {
    padding: 32px;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .pp-tipos__card-name {
    font-family: 'Aileron', sans-serif;
    font-size: clamp(24px, 3.5vw, 34px);
    font-weight: 800;
    color: #23372c;
    line-height: 1.2;
    margin: 0 0 15px;
    text-transform: lowercase;
  }
  .pp-tipos__card-name::first-letter {
    text-transform: uppercase;
  }

  .pp-tipos__card-desc {
    font-family: var(--pp-font-body);
    font-size: 15px;
    font-weight: 400;
    color: var(--pp-text);
    line-height: 1.75;
    margin: 0;
    opacity: 0.9;
  }

  .pp-tipos__card-desc p { margin: 0 0 12px; }
  .pp-tipos__card-desc p:last-child { margin-bottom: 0; }
  .pp-tipos__card-desc a { color: var(--pp-dark-green); text-decoration: underline; }
  .pp-tipos__card-desc strong { font-weight: 600; }
  .pp-tipos__card-desc ul,
  .pp-tipos__card-desc ol { margin: 0 0 12px; padding-left: 20px; }
  .pp-tipos__card-desc li { margin-bottom: 4px; }

  .pp-tipos__card-cta {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    margin-top: 16px;
    padding: 10px 18px;
    border: 1px solid var(--pp-dark-green);
    border-radius: 999px;
    font-family: 'Inter', sans-serif;
    font-size: 13px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--pp-dark-green);
    text-decoration: none;
    transition: background .2s, color .2s;
    align-self: flex-start;
  }
  .pp-tipos__card-cta:hover {
    background: var(--pp-dark-green);
    color: #fff;
  }
  .pp-tipos__card-name a { color: inherit; text-decoration: none; }
  .pp-tipos__card-image a { display: block; }

  /* --- Page body fallback (page.content RTE) --- */
  .pp-tipos__page-body {
    max-width: var(--pp-content-max);
    margin: 0 auto 48px;
    font-family: var(--pp-font-body);
    font-size: 16px;
    line-height: 1.8;
    color: var(--pp-text);
  }
  .pp-tipos__page-body p { margin: 0 0 16px; }
  .pp-tipos__page-body p:last-child { margin-bottom: 0; }
  .pp-tipos__page-body a { color: var(--pp-dark-green); text-decoration: underline; }
  .pp-tipos__page-body h2,
  .pp-tipos__page-body h3 { font-family: 'Aileron', sans-serif; color: var(--pp-dark-green); }

  /* --- Product grid --- */
  .pp-tipos__product-grid-wrapper {
    margin: 56px 0;
    padding: 40px 0;
    border-top: 1px solid rgba(35, 55, 44, 0.1);
    border-bottom: 1px solid rgba(35, 55, 44, 0.1);
  }

  .pp-tipos__product-grid-title {
    font-family: var(--pp-font-heading);
    font-size: clamp(20px, 2.5vw, 28px);
    font-weight: 400;
    color: var(--pp-dark-green);
    margin: 0 0 24px;
    text-align: center;
  }

  .pp-tipos__product-grid {
    display: grid;
    grid-template-columns: repeat(var(--pp-products-per-row, 4), 1fr);
    gap: 20px;
  }

  /* --- Banner CTA --- */
  .pp-tipos__banner {
    background: var(--pp-dark-green);
    border-radius: var(--pp-radius);
    padding: 48px 40px;
    text-align: center;
    margin-top: 56px;
  }

  .pp-tipos__banner-text {
    font-family: var(--pp-font-heading);
    font-size: clamp(22px, 3vw, 32px);
    font-weight: 400;
    color: #DAFFD3;
    line-height: 1.3;
    margin: 0 0 24px;
  }

  .pp-tipos__banner-btn {
    display: inline-block;
    font-family: var(--pp-font-body);
    font-size: 14px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--pp-dark-green);
    background: #DAFFD3;
    border: none;
    border-radius: 100px;
    padding: 14px 36px;
    text-decoration: none;
    cursor: pointer;
    transition: background var(--pp-transition), transform var(--pp-transition);
  }

  .pp-tipos__banner-btn:hover {
    background: #c4f5bb;
    transform: translateY(-1px);
  }

  /* --- Hide banner --- */
  .pp-tipos__banner { display: none; }

  /* --- Breadcrumb --- */
  .pp-tipos .pp-guide__breadcrumb {
    margin-bottom: 24px;
  }

  /* ==========================================================================
     Responsive
     ========================================================================== */
  @media screen and (max-width: 989px) {
    .pp-tipos__product-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media screen and (max-width: 749px) {
    .pp-tipos-hero {
      min-height: 280px;
      margin-bottom: 24px;
    }

    .pp-tipos-hero__content {
      padding: 24px 20px;
    }

    .pp-tipos__card {
      grid-template-columns: 1fr;
    }

    .pp-tipos__card-image {
      min-height: 220px;
      max-height: 300px;
    }

    .pp-tipos__cards-grid {
      gap: 24px;
      margin-bottom: 36px;
    }

    .pp-tipos__card-body {
      padding: 20px 16px;
    }

    .pp-tipos__product-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 12px;
    }

    .pp-tipos__product-grid-wrapper {
      margin: 36px 0;
      padding: 28px 0;
    }

    .pp-tipos__banner {
      padding: 32px 20px;
      margin-top: 36px;
    }

    .pp-tipos__intro {
      font-size: 15px;
    }
  }

  .pp-content__video {
    position: relative;
    aspect-ratio: 16 / 9;
    margin: 0 0 24px;
    border-radius: 8px;
    overflow: hidden;
    background: #000;
    max-width: 800px;
  }
  .pp-content__video iframe,
  .pp-content__video video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: 0;
  }

  .pp-content__products-inline {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
    gap: 16px;
    margin: 24px 0;
  }
  .pp-inline-product {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: inherit;
    border-radius: 8px;
    overflow: hidden;
    background: #fff;
    transition: transform .2s;
  }
  .pp-inline-product:hover { transform: translateY(-2px); }
  .pp-inline-product__img {
    width: 100%;
    aspect-ratio: 1 / 1;
    object-fit: cover;
    display: block;
    background: #f5f5f5;
  }
  .pp-inline-product__title {
    padding: 10px 12px;
    font-size: 14px;
    line-height: 1.4;
    font-weight: 500;
  }
</style>

<section
  class="pp-tipos"
  style="
    --pp-tipos-pad-top: {{ section.settings.padding_top }}px;
    --pp-tipos-pad-bottom: {{ section.settings.padding_bottom }}px;
    --pp-products-per-row: {{ products_per_row }};
    /* cards are now horizontal layout, no per-row setting needed */
  "
>

  {%- comment -%} -- 1. Hero Section (full-width, under header) -- {%- endcomment -%}
  {%- if section.settings.show_hero -%}
    {%- assign hero_image = page.metafields.custom.imagen_portada.value -%}
    {%- assign hero_image_url = page.metafields.custom.imagen_portada_url.value -%}
    <div class="pp-tipos-hero">
      {%- if hero_image -%}
        <div class="pp-tipos-hero__bg">
          {{ hero_image | image_url: width: 1600 | image_tag: loading: 'eager', sizes: '100vw' }}
        </div>
      {%- elsif hero_image_url != blank -%}
        <div class="pp-tipos-hero__bg">
          <img src="{{ hero_image_url }}" alt="{{ page.title | escape }}" loading="eager">
        </div>
      {%- endif -%}
      <div class="pp-tipos-hero__gradient"></div>
      <div class="pp-tipos-hero__content">
        <h1 class="pp-tipos-hero__title">{{ page.title }}</h1>
      </div>
    </div>
  {%- endif -%}

  {%- comment -%} -- Breadcrumb (after hero) -- {%- endcomment -%}
  {%- if section.settings.show_breadcrumb -%}
    <nav class="pp-guide__breadcrumb" aria-label="Breadcrumb">
      <a href="/">Inicio</a>
      <span class="pp-guide__breadcrumb-sep">/</span>
      {%- if page.handle != 'guia-tipos-plantas' -%}
        <a href="/pages/guia-tipos-plantas">Guía Tipos Plantas</a>
        <span class="pp-guide__breadcrumb-sep">/</span>
        <span>{{ page.title }}</span>
      {%- else -%}
        <span>{{ page.title }}</span>
      {%- endif -%}
    </nav>
  {%- endif -%}

  {%- comment -%} -- 2. Page content (SSR) -- {%- endcomment -%}
  {%- if widgets_size > 0 -%}

    {%- comment -%} 2a. Intro paragraph (first text widget) {%- endcomment -%}
    {%- if intro_idx >= 0 -%}
      {%- assign intro_widget = widgets[intro_idx] -%}
      <div class="pp-tipos__intro" data-tipos-intro>{{ intro_widget.value }}</div>
    {%- endif -%}

    {%- comment -%} 2b. Variety cards grid (heading + look-ahead image/text/cta) {%- endcomment -%}
    {%- if total_cards > 0 -%}
      <div class="pp-tipos__cards-grid" data-tipos-cards>
        {%- assign card_count = 0 -%}
        {%- assign skip_until = -1 -%}
        {%- for w in widgets -%}
          {%- if forloop.index0 < start_idx -%}{%- continue -%}{%- endif -%}
          {%- if forloop.index0 <= skip_until -%}{%- continue -%}{%- endif -%}
          {%- if w.type != 'heading' -%}{%- continue -%}{%- endif -%}

          {%- assign card_count = card_count | plus: 1 -%}
          {%- assign i = forloop.index0 -%}
          {%- assign card_img = '' -%}
          {%- assign card_img_alt = '' -%}
          {%- assign card_img_link = '' -%}
          {%- assign card_text = '' -%}
          {%- assign card_cta_text = '' -%}
          {%- assign card_cta_url = '' -%}
          {%- assign last_consumed = i -%}

          {%- for j in (1..6) -%}
            {%- assign k = i | plus: j -%}
            {%- if k >= widgets_size -%}{%- break -%}{%- endif -%}
            {%- assign nw = widgets[k] -%}
            {%- if nw.type == 'heading' -%}{%- break -%}{%- endif -%}
            {%- assign last_consumed = k -%}
            {%- if nw.type == 'image' and card_img == '' -%}
              {%- assign card_img = nw.src -%}
              {%- assign card_img_alt = nw.alt | default: '' -%}
              {%- assign card_img_link = nw.link | default: '' -%}
            {%- elsif nw.type == 'text' and card_text == '' -%}
              {%- assign card_text = nw.value -%}
            {%- elsif nw.type == 'cta' and card_cta_url == '' -%}
              {%- assign card_cta_text = nw.text | default: '' -%}
              {%- assign card_cta_url = nw.url | default: '' -%}
            {%- endif -%}
          {%- endfor -%}
          {%- assign skip_until = last_consumed -%}

          {%- assign target_url = card_cta_url -%}
          {%- if target_url == blank -%}{%- assign target_url = card_img_link -%}{%- endif -%}
          {%- assign no_img_class = '' -%}
          {%- if card_img == '' -%}{%- assign no_img_class = ' pp-tipos__card--no-image' -%}{%- endif -%}

          <article class="pp-tipos__card pp-tipos__variety{{ no_img_class }}" id="variety-{{ card_count }}">
            {%- if card_img != '' -%}
              <div class="pp-tipos__card-image pp-content__image">
                {%- if target_url != blank -%}
                  <a href="{{ target_url }}"><img src="{{ card_img }}" alt="{{ card_img_alt | escape }}" loading="lazy"></a>
                {%- else -%}
                  <img src="{{ card_img }}" alt="{{ card_img_alt | escape }}" loading="lazy">
                {%- endif -%}
              </div>
            {%- endif -%}
            <div class="pp-tipos__card-body">
              <h2 class="pp-tipos__card-name pp-content__heading">
                {%- if target_url != blank -%}
                  <a href="{{ target_url }}">{{ w.value | escape }}</a>
                {%- else -%}
                  {{ w.value | escape }}
                {%- endif -%}
              </h2>
              {%- if card_text != '' -%}
                <div class="pp-tipos__card-desc pp-content__text">{{ card_text }}</div>
              {%- endif -%}
              {%- if target_url != blank -%}
                {%- assign cta_label = card_cta_text -%}
                {%- if cta_label == blank -%}
                  {%- assign cta_label = 'Comprar ' | append: w.value -%}
                {%- endif -%}
                <div class="pp-content__cta">
                  <a class="pp-tipos__card-cta pp-cta-btn" href="{{ target_url }}">{{ cta_label | escape }} <span aria-hidden="true">→</span></a>
                </div>
              {%- endif -%}
            </div>
          </article>
        {%- endfor -%}
      </div>
    {%- endif -%}

  {%- elsif page.content != blank -%}
    {%- comment -%} 2c. Fallback: legacy RTE body (ficus/monstera without metafield) {%- endcomment -%}
    <div class="pp-tipos__page-body rte">{{ page.content }}</div>
  {%- endif -%}

  {%- comment -%} -- 3. Product grids (server-rendered) -- {%- endcomment -%}
  {%- assign coll_1 = page.metafields.custom.page_collection_1.value -%}
  {%- if coll_1 -%}
    <div class="pp-tipos__product-grid-wrapper">
      {%- if coll_1.title != blank -%}
        <h3 class="pp-tipos__product-grid-title">{{ coll_1.title }}</h3>
      {%- endif -%}
      <div class="pp-tipos__product-grid">
        {%- for product in coll_1.products limit: 8 -%}
          {%- render 'pp-product-card-standalone', product: product, image_ratio: 'portrait' -%}
        {%- endfor -%}
      </div>
    </div>
  {%- endif -%}

  {%- assign coll_2 = page.metafields.custom.page_collection_2.value -%}
  {%- if coll_2 -%}
    <div class="pp-tipos__product-grid-wrapper">
      {%- if coll_2.title != blank -%}
        <h3 class="pp-tipos__product-grid-title">{{ coll_2.title }}</h3>
      {%- endif -%}
      <div class="pp-tipos__product-grid">
        {%- for product in coll_2.products limit: 8 -%}
          {%- render 'pp-product-card-standalone', product: product, image_ratio: 'portrait' -%}
        {%- endfor -%}
      </div>
    </div>
  {%- endif -%}

  {%- assign coll_3 = page.metafields.custom.page_collection_3.value -%}
  {%- if coll_3 -%}
    <div class="pp-tipos__product-grid-wrapper">
      {%- if coll_3.title != blank -%}
        <h3 class="pp-tipos__product-grid-title">{{ coll_3.title }}</h3>
      {%- endif -%}
      <div class="pp-tipos__product-grid">
        {%- for product in coll_3.products limit: 8 -%}
          {%- render 'pp-product-card-standalone', product: product, image_ratio: 'portrait' -%}
        {%- endfor -%}
      </div>
    </div>
  {%- endif -%}

  {%- comment -%} -- 4. Banner CTA (kept, hidden by CSS) -- {%- endcomment -%}
  {%- if section.settings.banner_text != blank -%}
    <div class="pp-tipos__banner" style="background-color: {{ section.settings.hero_bg_color }};">
      <p class="pp-tipos__banner-text">{{ section.settings.banner_text }}</p>
      {%- if section.settings.banner_cta_text != blank and section.settings.banner_cta_url != blank -%}
        <a href="{{ section.settings.banner_cta_url }}" class="pp-tipos__banner-btn">
          {{ section.settings.banner_cta_text }}
        </a>
      {%- endif -%}
    </div>
  {%- endif -%}

  {%- comment -%} -- Fallback for empty page (no metafield, no page.content) -- {%- endcomment -%}
  {%- if widgets_size == 0 and page.content == blank -%}
    <div class="pp-guide__empty">
      <p>Esta guía aún no tiene contenido configurado.</p>
    </div>
  {%- endif -%}

</section>

{%- comment -%} ==========================================================
     JSON-LD structured data (server-side, crawler-visible)
     ========================================================================== {%- endcomment -%}

{%- comment -%} -- BreadcrumbList -- {%- endcomment -%}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Inicio",
      "item": {{ shop.url | append: '/' | json }}
    }
    {%- if page.handle != 'guia-tipos-plantas' -%}
    ,{
      "@type": "ListItem",
      "position": 2,
      "name": "Guía Tipos Plantas",
      "item": {{ shop.url | append: '/pages/guia-tipos-plantas' | json }}
    },
    {
      "@type": "ListItem",
      "position": 3,
      "name": {{ page.title | json }},
      "item": {{ shop.url | append: page.url | json }}
    }
    {%- else -%}
    ,{
      "@type": "ListItem",
      "position": 2,
      "name": {{ page.title | json }},
      "item": {{ shop.url | append: page.url | json }}
    }
    {%- endif -%}
  ]
}
</script>

{%- comment -%} -- ItemList of variety cards (only if we detected >=1 heading) -- {%- endcomment -%}
{%- if total_cards > 0 -%}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": {{ page.title | json }},
  "numberOfItems": {{ total_cards }},
  "itemListElement": [
    {%- assign _pos = 0 -%}
    {%- assign _skip = -1 -%}
    {%- for w in widgets -%}
      {%- if forloop.index0 < start_idx -%}{%- continue -%}{%- endif -%}
      {%- if forloop.index0 <= _skip -%}{%- continue -%}{%- endif -%}
      {%- if w.type != 'heading' -%}{%- continue -%}{%- endif -%}

      {%- assign _pos = _pos | plus: 1 -%}
      {%- assign _i = forloop.index0 -%}
      {%- assign _img = '' -%}
      {%- assign _img_link = '' -%}
      {%- assign _cta_url = '' -%}
      {%- assign _last = _i -%}
      {%- for j in (1..6) -%}
        {%- assign _k = _i | plus: j -%}
        {%- if _k >= widgets_size -%}{%- break -%}{%- endif -%}
        {%- assign _nw = widgets[_k] -%}
        {%- if _nw.type == 'heading' -%}{%- break -%}{%- endif -%}
        {%- assign _last = _k -%}
        {%- if _nw.type == 'image' and _img == '' -%}
          {%- assign _img = _nw.src -%}
          {%- assign _img_link = _nw.link | default: '' -%}
        {%- elsif _nw.type == 'cta' and _cta_url == '' -%}
          {%- assign _cta_url = _nw.url | default: '' -%}
        {%- endif -%}
      {%- endfor -%}
      {%- assign _skip = _last -%}

      {%- assign _target = _cta_url -%}
      {%- if _target == blank -%}{%- assign _target = _img_link -%}{%- endif -%}

      {%- if _pos > 1 -%},{%- endif -%}
      {
        "@type": "ListItem",
        "position": {{ _pos }},
        "name": {{ w.value | json }}
        {%- if _target != blank -%},"url": {{ _target | json }}{%- endif -%}
        {%- if _img != '' -%},"image": {{ _img | json }}{%- endif -%}
      }
    {%- endfor -%}
  ]
}
</script>
{%- endif -%}

{%- comment -%} -- FAQPage (parsed from <details><summary>Q</summary>A</details>) -- {%- endcomment -%}
{%- if faq_count > 0 -%}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {%- assign faq_blocks = faq_html_source | split: '</details>' -%}
    {%- assign _fpos = 0 -%}
    {%- for block in faq_blocks -%}
      {%- if block contains '<summary' -%}
        {%- assign after_open_tag = block | split: '<summary' | last -%}
        {%- assign after_summary = after_open_tag | split: '>' | last -%}
        {%- assign _q = after_summary | split: '</summary>' | first | strip_html | strip | strip_newlines -%}
        {%- assign _a_html = after_summary | split: '</summary>' | last -%}
        {%- assign _a_spaced = _a_html | replace: '</p>', ' ' | replace: '</li>', ' ' | replace: '<br>', ' ' | replace: '<br/>', ' ' | replace: '<br />', ' ' -%}
        {%- assign _a = _a_spaced | strip_html | strip | strip_newlines -%}
        {%- if _q != '' and _a != '' -%}
          {%- assign _fpos = _fpos | plus: 1 -%}
          {%- if _fpos > 1 -%},{%- endif -%}
          {
            "@type": "Question",
            "name": {{ _q | json }},
            "acceptedAnswer": {
              "@type": "Answer",
              "text": {{ _a | json }}
            }
          }
        {%- endif -%}
      {%- endif -%}
    {%- endfor -%}
  ]
}
</script>
{%- endif -%}

