{%- comment -%}
  PP Page Tipos — Renders plant variety/types guide pages
  Based on WordPress reference: purplant.es/guia-tipos-plantas/
  Uses individual metafields: page_heading_1..50, page_text_1..30,
  page_image_1..35, page_collection_1..3

  Metafield mapping for variety cards:
    heading_1..2  = intro/general subtitles
    heading_3+    = variety names
    text_1        = intro paragraph
    text_2        = general varieties description
    text_3+       = variety descriptions (paired with heading_3+)
    image_1+      = variety photos (image_1 pairs with heading_3, image_2 with heading_4, etc.)
{%- endcomment -%}

{{ 'pp-page-guide.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign products_per_row = section.settings.products_per_row | default: 4
  assign cards_per_row = section.settings.cards_per_row | default: 2
-%}

<style>
  /* ==========================================================================
     PP Page Tipos — Inline Styles
     ========================================================================== */

  /* --- Hero --- */
  .pp-tipos-hero {
    position: relative;
    width: 100%;
    min-height: 340px;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    border-radius: var(--pp-radius, 8px);
    margin-bottom: 48px;
  }

  .pp-tipos-hero__bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 0;
  }

  .pp-tipos-hero__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(35,55,44,0.45) 0%, rgba(35,55,44,0.7) 100%);
    z-index: 1;
  }

  .pp-tipos-hero__gradient {
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, #23372C 0%, #3a5a42 50%, #23372C 100%);
    z-index: 0;
  }

  .pp-tipos-hero__content {
    position: relative;
    z-index: 2;
    text-align: center;
    padding: 60px 24px;
    max-width: 800px;
  }

  .pp-tipos-hero__title {
    font-family: 'Aileron', sans-serif;
    font-size: clamp(36px, 6vw, 64px);
    font-weight: 700;
    color: #ffffff;
    line-height: 1.1;
    margin: 0;
    text-transform: none;
    letter-spacing: -0.02em;
  }

  /* --- Container --- */
  .pp-tipos {
    --pp-dark-green: #23372C;
    --pp-light-green: #DAFFD3;
    --pp-beige: #F5F0E8;
    --pp-text: #3a3838;
    --pp-font-body: 'Inter', sans-serif;
    --pp-font-heading: 'Tenor Sans', Georgia, serif;
    --pp-font-display: 'Aileron', sans-serif;
    --pp-radius: 8px;
    --pp-content-max: 800px;
    --pp-transition: 0.25s ease;
    max-width: var(--page-content-width, 120rem);
    margin: 0 auto;
    padding: var(--pp-tipos-pad-top, 40px) var(--page-margin, 40px) var(--pp-tipos-pad-bottom, 60px);
    font-family: var(--pp-font-body);
    color: var(--pp-text);
  }

  /* --- Intro text --- */
  .pp-tipos__intro {
    font-family: var(--pp-font-body);
    font-size: 16px;
    font-weight: 400;
    color: var(--pp-text);
    line-height: 1.8;
    margin: 0 auto 48px;
    max-width: var(--pp-content-max);
    text-align: center;
    opacity: 0.9;
  }

  /* --- Subtitle section (heading_1 + text_2) --- */
  .pp-tipos__subtitle-section {
    text-align: center;
    max-width: var(--pp-content-max);
    margin: 0 auto 48px;
  }

  .pp-tipos__subtitle {
    font-family: var(--pp-font-heading);
    font-size: clamp(24px, 3.5vw, 36px);
    font-weight: 400;
    color: var(--pp-dark-green);
    line-height: 1.2;
    margin: 0 0 20px;
    text-transform: none;
  }

  .pp-tipos__subtitle-text {
    font-family: var(--pp-font-body);
    font-size: 15px;
    font-weight: 400;
    color: var(--pp-text);
    line-height: 1.8;
    margin: 0;
    opacity: 0.9;
  }

  /* --- Variety cards grid --- */
  .pp-tipos__cards-grid {
    display: grid;
    grid-template-columns: repeat(var(--pp-cards-per-row, 2), 1fr);
    gap: 32px;
    margin: 0 0 56px;
  }

  .pp-tipos__card {
    background: #ffffff;
    border-radius: var(--pp-radius);
    overflow: hidden;
    border: 1px solid rgba(35, 55, 44, 0.08);
    transition: box-shadow var(--pp-transition), transform var(--pp-transition);
  }

  .pp-tipos__card:hover {
    box-shadow: 0 8px 32px rgba(35, 55, 44, 0.12);
    transform: translateY(-2px);
  }

  .pp-tipos__card-image {
    width: 100%;
    aspect-ratio: 4 / 5;
    overflow: hidden;
    border-radius: var(--pp-radius) var(--pp-radius) 0 0;
  }

  .pp-tipos__card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.4s ease;
  }

  .pp-tipos__card:hover .pp-tipos__card-image img {
    transform: scale(1.03);
  }

  .pp-tipos__card-body {
    padding: 24px;
  }

  .pp-tipos__card-name {
    font-family: var(--pp-font-heading);
    font-size: clamp(20px, 2.5vw, 26px);
    font-weight: 700;
    color: var(--pp-dark-green);
    line-height: 1.25;
    margin: 0 0 12px;
  }

  .pp-tipos__card-desc {
    font-family: var(--pp-font-body);
    font-size: 15px;
    font-weight: 400;
    color: var(--pp-text);
    line-height: 1.75;
    margin: 0;
    opacity: 0.9;
  }

  /* --- Product grid --- */
  .pp-tipos__product-grid-wrapper {
    margin: 56px 0;
    padding: 40px 0;
    border-top: 1px solid rgba(35, 55, 44, 0.1);
    border-bottom: 1px solid rgba(35, 55, 44, 0.1);
  }

  .pp-tipos__product-grid-title {
    font-family: var(--pp-font-heading);
    font-size: clamp(20px, 2.5vw, 28px);
    font-weight: 400;
    color: var(--pp-dark-green);
    margin: 0 0 24px;
    text-align: center;
  }

  .pp-tipos__product-grid {
    display: grid;
    grid-template-columns: repeat(var(--pp-products-per-row, 4), 1fr);
    gap: 20px;
  }

  /* --- Closing text --- */
  .pp-tipos__closing {
    font-family: var(--pp-font-body);
    font-size: 16px;
    font-weight: 400;
    color: var(--pp-text);
    line-height: 1.8;
    margin: 48px auto 0;
    max-width: var(--pp-content-max);
    text-align: center;
    opacity: 0.9;
  }

  /* --- Banner CTA --- */
  .pp-tipos__banner {
    background: var(--pp-dark-green);
    border-radius: var(--pp-radius);
    padding: 48px 40px;
    text-align: center;
    margin-top: 56px;
  }

  .pp-tipos__banner-text {
    font-family: var(--pp-font-heading);
    font-size: clamp(22px, 3vw, 32px);
    font-weight: 400;
    color: #DAFFD3;
    line-height: 1.3;
    margin: 0 0 24px;
  }

  .pp-tipos__banner-btn {
    display: inline-block;
    font-family: var(--pp-font-body);
    font-size: 14px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--pp-dark-green);
    background: #DAFFD3;
    border: none;
    border-radius: 100px;
    padding: 14px 36px;
    text-decoration: none;
    cursor: pointer;
    transition: background var(--pp-transition), transform var(--pp-transition);
  }

  .pp-tipos__banner-btn:hover {
    background: #c4f5bb;
    transform: translateY(-1px);
  }

  /* --- Breadcrumb (inherits from pp-page-guide.css, local overrides) --- */
  .pp-tipos .pp-guide__breadcrumb {
    margin-bottom: 24px;
  }

  /* ==========================================================================
     Responsive
     ========================================================================== */
  @media screen and (max-width: 989px) {
    .pp-tipos__product-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media screen and (max-width: 749px) {
    .pp-tipos-hero {
      min-height: 240px;
      border-radius: 0;
      margin-bottom: 32px;
    }

    .pp-tipos-hero__content {
      padding: 40px 20px;
    }

    .pp-tipos__cards-grid {
      grid-template-columns: 1fr;
      gap: 24px;
      margin-bottom: 36px;
    }

    .pp-tipos__card-body {
      padding: 20px 16px;
    }

    .pp-tipos__product-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 12px;
    }

    .pp-tipos__product-grid-wrapper {
      margin: 36px 0;
      padding: 28px 0;
    }

    .pp-tipos__banner {
      padding: 32px 20px;
      margin-top: 36px;
    }

    .pp-tipos__intro,
    .pp-tipos__closing {
      font-size: 15px;
    }

    .pp-tipos__subtitle-section {
      margin-bottom: 32px;
    }
  }
</style>

<section
  class="pp-tipos"
  style="
    --pp-tipos-pad-top: {{ section.settings.padding_top }}px;
    --pp-tipos-pad-bottom: {{ section.settings.padding_bottom }}px;
    --pp-products-per-row: {{ products_per_row }};
    --pp-cards-per-row: {{ cards_per_row }};
  "
>

  {%- comment -%} ── Breadcrumb ── {%- endcomment -%}
  {%- if section.settings.show_breadcrumb -%}
    <nav class="pp-guide__breadcrumb" aria-label="Breadcrumb">
      <a href="/">Pur Plant</a>
      <span class="pp-guide__breadcrumb-sep">/</span>
      <a href="/pages/tipos-de-plantas">Tipos de Plantas</a>
      <span class="pp-guide__breadcrumb-sep">/</span>
      <span>{{ page.title }}</span>
    </nav>
  {%- endif -%}

  {%- comment -%} ── 1. Hero Section ── {%- endcomment -%}
  {%- if section.settings.show_hero -%}
    {%- assign hero_image = page.metafields.custom.page_image_1 | default: '' -%}
    <div class="pp-tipos-hero">
      {%- if hero_image != blank -%}
        <img
          class="pp-tipos-hero__bg"
          src="{{ hero_image }}"
          alt="{{ page.title | escape }}"
          loading="eager"
          width="1600"
          height="400"
        >
        <div class="pp-tipos-hero__overlay"></div>
      {%- else -%}
        <div class="pp-tipos-hero__gradient"></div>
      {%- endif -%}
      <div class="pp-tipos-hero__content">
        <h1 class="pp-tipos-hero__title">{{ page.title }}</h1>
      </div>
    </div>
  {%- endif -%}

  {%- comment -%} ── 2. Intro text (page_text_1) ── {%- endcomment -%}
  {%- assign intro_text = page.metafields.custom.page_text_1 | default: '' -%}
  {%- if intro_text != blank -%}
    <div class="pp-tipos__intro">{{ intro_text }}</div>
  {%- endif -%}

  {%- comment -%} ── 3. Subtitle section (page_heading_1 + page_text_2) ── {%- endcomment -%}
  {%- assign subtitle_heading = page.metafields.custom.page_heading_1 | default: '' -%}
  {%- assign subtitle_text = page.metafields.custom.page_text_2 | default: '' -%}
  {%- if subtitle_heading != blank or subtitle_text != blank -%}
    <div class="pp-tipos__subtitle-section">
      {%- if subtitle_heading != blank -%}
        <h2 class="pp-tipos__subtitle">{{ subtitle_heading }}</h2>
      {%- endif -%}
      {%- if subtitle_text != blank -%}
        <p class="pp-tipos__subtitle-text">{{ subtitle_text }}</p>
      {%- endif -%}
    </div>
  {%- endif -%}

  {%- comment -%} ── 4. Optional second subtitle (page_heading_2) ── {%- endcomment -%}
  {%- assign subtitle_2 = page.metafields.custom.page_heading_2 | default: '' -%}
  {%- if subtitle_2 != blank -%}
    <div class="pp-tipos__subtitle-section">
      <h2 class="pp-tipos__subtitle">{{ subtitle_2 }}</h2>
    </div>
  {%- endif -%}

  {%- comment -%} ── 5. Variety Cards Grid ──
    Variety cards pair: heading_3 + image_1 + text_3, heading_4 + image_2 + text_4, etc.
    Since headings 1-2 and texts 1-2 are used for intro/subtitles, variety data starts at index 3 for headings/texts
    and index 1 for images. We iterate through heading indices 3..50 and compute image index = heading_index - 2.
  {%- endcomment -%}

  {%- liquid
    assign card_count = 0
    assign grid_opened = false
  -%}

  {%- for i in (3..50) -%}
    {%- liquid
      comment
        Resolve current heading using case/when (Liquid can't build dynamic metafield keys)
      endcomment
      assign current_heading = ''
      case i
        when 3
          assign current_heading = page.metafields.custom.page_heading_3
        when 4
          assign current_heading = page.metafields.custom.page_heading_4
        when 5
          assign current_heading = page.metafields.custom.page_heading_5
        when 6
          assign current_heading = page.metafields.custom.page_heading_6
        when 7
          assign current_heading = page.metafields.custom.page_heading_7
        when 8
          assign current_heading = page.metafields.custom.page_heading_8
        when 9
          assign current_heading = page.metafields.custom.page_heading_9
        when 10
          assign current_heading = page.metafields.custom.page_heading_10
        when 11
          assign current_heading = page.metafields.custom.page_heading_11
        when 12
          assign current_heading = page.metafields.custom.page_heading_12
        when 13
          assign current_heading = page.metafields.custom.page_heading_13
        when 14
          assign current_heading = page.metafields.custom.page_heading_14
        when 15
          assign current_heading = page.metafields.custom.page_heading_15
        when 16
          assign current_heading = page.metafields.custom.page_heading_16
        when 17
          assign current_heading = page.metafields.custom.page_heading_17
        when 18
          assign current_heading = page.metafields.custom.page_heading_18
        when 19
          assign current_heading = page.metafields.custom.page_heading_19
        when 20
          assign current_heading = page.metafields.custom.page_heading_20
        when 21
          assign current_heading = page.metafields.custom.page_heading_21
        when 22
          assign current_heading = page.metafields.custom.page_heading_22
        when 23
          assign current_heading = page.metafields.custom.page_heading_23
        when 24
          assign current_heading = page.metafields.custom.page_heading_24
        when 25
          assign current_heading = page.metafields.custom.page_heading_25
        when 26
          assign current_heading = page.metafields.custom.page_heading_26
        when 27
          assign current_heading = page.metafields.custom.page_heading_27
        when 28
          assign current_heading = page.metafields.custom.page_heading_28
        when 29
          assign current_heading = page.metafields.custom.page_heading_29
        when 30
          assign current_heading = page.metafields.custom.page_heading_30
        when 31
          assign current_heading = page.metafields.custom.page_heading_31
        when 32
          assign current_heading = page.metafields.custom.page_heading_32
        when 33
          assign current_heading = page.metafields.custom.page_heading_33
        when 34
          assign current_heading = page.metafields.custom.page_heading_34
        when 35
          assign current_heading = page.metafields.custom.page_heading_35
        when 36
          assign current_heading = page.metafields.custom.page_heading_36
        when 37
          assign current_heading = page.metafields.custom.page_heading_37
        when 38
          assign current_heading = page.metafields.custom.page_heading_38
        when 39
          assign current_heading = page.metafields.custom.page_heading_39
        when 40
          assign current_heading = page.metafields.custom.page_heading_40
        when 41
          assign current_heading = page.metafields.custom.page_heading_41
        when 42
          assign current_heading = page.metafields.custom.page_heading_42
        when 43
          assign current_heading = page.metafields.custom.page_heading_43
        when 44
          assign current_heading = page.metafields.custom.page_heading_44
        when 45
          assign current_heading = page.metafields.custom.page_heading_45
        when 46
          assign current_heading = page.metafields.custom.page_heading_46
        when 47
          assign current_heading = page.metafields.custom.page_heading_47
        when 48
          assign current_heading = page.metafields.custom.page_heading_48
        when 49
          assign current_heading = page.metafields.custom.page_heading_49
        when 50
          assign current_heading = page.metafields.custom.page_heading_50
      endcase

      assign heading_val = current_heading | default: ''
    -%}

    {%- if heading_val == blank -%}
      {%- continue -%}
    {%- endif -%}

    {%- liquid
      comment
        Resolve current text (same index as heading)
      endcomment
      assign current_text = ''
      case i
        when 3
          assign current_text = page.metafields.custom.page_text_3
        when 4
          assign current_text = page.metafields.custom.page_text_4
        when 5
          assign current_text = page.metafields.custom.page_text_5
        when 6
          assign current_text = page.metafields.custom.page_text_6
        when 7
          assign current_text = page.metafields.custom.page_text_7
        when 8
          assign current_text = page.metafields.custom.page_text_8
        when 9
          assign current_text = page.metafields.custom.page_text_9
        when 10
          assign current_text = page.metafields.custom.page_text_10
        when 11
          assign current_text = page.metafields.custom.page_text_11
        when 12
          assign current_text = page.metafields.custom.page_text_12
        when 13
          assign current_text = page.metafields.custom.page_text_13
        when 14
          assign current_text = page.metafields.custom.page_text_14
        when 15
          assign current_text = page.metafields.custom.page_text_15
        when 16
          assign current_text = page.metafields.custom.page_text_16
        when 17
          assign current_text = page.metafields.custom.page_text_17
        when 18
          assign current_text = page.metafields.custom.page_text_18
        when 19
          assign current_text = page.metafields.custom.page_text_19
        when 20
          assign current_text = page.metafields.custom.page_text_20
        when 21
          assign current_text = page.metafields.custom.page_text_21
        when 22
          assign current_text = page.metafields.custom.page_text_22
        when 23
          assign current_text = page.metafields.custom.page_text_23
        when 24
          assign current_text = page.metafields.custom.page_text_24
        when 25
          assign current_text = page.metafields.custom.page_text_25
        when 26
          assign current_text = page.metafields.custom.page_text_26
        when 27
          assign current_text = page.metafields.custom.page_text_27
        when 28
          assign current_text = page.metafields.custom.page_text_28
        when 29
          assign current_text = page.metafields.custom.page_text_29
        when 30
          assign current_text = page.metafields.custom.page_text_30
      endcase

      assign text_val = current_text | default: ''

      comment
        Resolve image: image index = heading index - 2
        heading_3 -> image_1, heading_4 -> image_2, etc.
      endcomment
      assign img_index = i | minus: 2
      assign current_image = ''
      case img_index
        when 1
          assign current_image = page.metafields.custom.page_image_1
        when 2
          assign current_image = page.metafields.custom.page_image_2
        when 3
          assign current_image = page.metafields.custom.page_image_3
        when 4
          assign current_image = page.metafields.custom.page_image_4
        when 5
          assign current_image = page.metafields.custom.page_image_5
        when 6
          assign current_image = page.metafields.custom.page_image_6
        when 7
          assign current_image = page.metafields.custom.page_image_7
        when 8
          assign current_image = page.metafields.custom.page_image_8
        when 9
          assign current_image = page.metafields.custom.page_image_9
        when 10
          assign current_image = page.metafields.custom.page_image_10
        when 11
          assign current_image = page.metafields.custom.page_image_11
        when 12
          assign current_image = page.metafields.custom.page_image_12
        when 13
          assign current_image = page.metafields.custom.page_image_13
        when 14
          assign current_image = page.metafields.custom.page_image_14
        when 15
          assign current_image = page.metafields.custom.page_image_15
        when 16
          assign current_image = page.metafields.custom.page_image_16
        when 17
          assign current_image = page.metafields.custom.page_image_17
        when 18
          assign current_image = page.metafields.custom.page_image_18
        when 19
          assign current_image = page.metafields.custom.page_image_19
        when 20
          assign current_image = page.metafields.custom.page_image_20
        when 21
          assign current_image = page.metafields.custom.page_image_21
        when 22
          assign current_image = page.metafields.custom.page_image_22
        when 23
          assign current_image = page.metafields.custom.page_image_23
        when 24
          assign current_image = page.metafields.custom.page_image_24
        when 25
          assign current_image = page.metafields.custom.page_image_25
        when 26
          assign current_image = page.metafields.custom.page_image_26
        when 27
          assign current_image = page.metafields.custom.page_image_27
        when 28
          assign current_image = page.metafields.custom.page_image_28
        when 29
          assign current_image = page.metafields.custom.page_image_29
        when 30
          assign current_image = page.metafields.custom.page_image_30
        when 31
          assign current_image = page.metafields.custom.page_image_31
        when 32
          assign current_image = page.metafields.custom.page_image_32
        when 33
          assign current_image = page.metafields.custom.page_image_33
        when 34
          assign current_image = page.metafields.custom.page_image_34
        when 35
          assign current_image = page.metafields.custom.page_image_35
      endcase

      assign image_val = current_image | default: ''
    -%}

    {%- comment -%} Open the grid wrapper on the first card {%- endcomment -%}
    {%- if grid_opened == false -%}
      {%- assign grid_opened = true -%}
      <div class="pp-tipos__cards-grid">
    {%- endif -%}

    {%- assign card_count = card_count | plus: 1 -%}

    <div class="pp-tipos__card" id="variety-{{ i }}">
      {%- if image_val != blank -%}
        <div class="pp-tipos__card-image">
          <img
            src="{{ image_val }}"
            alt="{{ heading_val | escape }}"
            loading="lazy"
            width="600"
            height="750"
          >
        </div>
      {%- endif -%}
      <div class="pp-tipos__card-body">
        <h3 class="pp-tipos__card-name">{{ heading_val }}</h3>
        {%- if text_val != blank -%}
          <p class="pp-tipos__card-desc">{{ text_val }}</p>
        {%- endif -%}
      </div>
    </div>

  {%- endfor -%}

  {%- comment -%} Close the grid wrapper if it was opened {%- endcomment -%}
  {%- if grid_opened -%}
    </div>
  {%- endif -%}

  {%- comment -%} ── 6. Product grids from page_collection_1..3 ── {%- endcomment -%}
  {%- assign coll_1 = page.metafields.custom.page_collection_1.value -%}
  {%- if coll_1 -%}
    <div class="pp-tipos__product-grid-wrapper">
      {%- if coll_1.title != blank -%}
        <h3 class="pp-tipos__product-grid-title">{{ coll_1.title }}</h3>
      {%- endif -%}
      <div class="pp-tipos__product-grid">
        {%- for product in coll_1.products limit: 8 -%}
          {%- render 'pp-product-card-standalone', product: product, image_ratio: 'portrait' -%}
        {%- endfor -%}
      </div>
    </div>
  {%- endif -%}

  {%- assign coll_2 = page.metafields.custom.page_collection_2.value -%}
  {%- if coll_2 -%}
    <div class="pp-tipos__product-grid-wrapper">
      {%- if coll_2.title != blank -%}
        <h3 class="pp-tipos__product-grid-title">{{ coll_2.title }}</h3>
      {%- endif -%}
      <div class="pp-tipos__product-grid">
        {%- for product in coll_2.products limit: 8 -%}
          {%- render 'pp-product-card-standalone', product: product, image_ratio: 'portrait' -%}
        {%- endfor -%}
      </div>
    </div>
  {%- endif -%}

  {%- assign coll_3 = page.metafields.custom.page_collection_3.value -%}
  {%- if coll_3 -%}
    <div class="pp-tipos__product-grid-wrapper">
      {%- if coll_3.title != blank -%}
        <h3 class="pp-tipos__product-grid-title">{{ coll_3.title }}</h3>
      {%- endif -%}
      <div class="pp-tipos__product-grid">
        {%- for product in coll_3.products limit: 8 -%}
          {%- render 'pp-product-card-standalone', product: product, image_ratio: 'portrait' -%}
        {%- endfor -%}
      </div>
    </div>
  {%- endif -%}

  {%- comment -%} ── 7. Closing text — last page_text_X that has content ── {%- endcomment -%}
  {%- liquid
    assign closing_text = ''
    assign t30 = page.metafields.custom.page_text_30 | default: ''
    assign t29 = page.metafields.custom.page_text_29 | default: ''
    assign t28 = page.metafields.custom.page_text_28 | default: ''
    assign t27 = page.metafields.custom.page_text_27 | default: ''
    assign t26 = page.metafields.custom.page_text_26 | default: ''
    assign t25 = page.metafields.custom.page_text_25 | default: ''
    assign t24 = page.metafields.custom.page_text_24 | default: ''
    assign t23 = page.metafields.custom.page_text_23 | default: ''
    assign t22 = page.metafields.custom.page_text_22 | default: ''
    assign t21 = page.metafields.custom.page_text_21 | default: ''
    assign t20 = page.metafields.custom.page_text_20 | default: ''
    assign t19 = page.metafields.custom.page_text_19 | default: ''
    assign t18 = page.metafields.custom.page_text_18 | default: ''
    assign t17 = page.metafields.custom.page_text_17 | default: ''
    assign t16 = page.metafields.custom.page_text_16 | default: ''
    assign t15 = page.metafields.custom.page_text_15 | default: ''

    if t30 != blank
      assign closing_text = t30
    elsif t29 != blank
      assign closing_text = t29
    elsif t28 != blank
      assign closing_text = t28
    elsif t27 != blank
      assign closing_text = t27
    elsif t26 != blank
      assign closing_text = t26
    elsif t25 != blank
      assign closing_text = t25
    elsif t24 != blank
      assign closing_text = t24
    elsif t23 != blank
      assign closing_text = t23
    elsif t22 != blank
      assign closing_text = t22
    elsif t21 != blank
      assign closing_text = t21
    elsif t20 != blank
      assign closing_text = t20
    elsif t19 != blank
      assign closing_text = t19
    elsif t18 != blank
      assign closing_text = t18
    elsif t17 != blank
      assign closing_text = t17
    elsif t16 != blank
      assign closing_text = t16
    elsif t15 != blank
      assign closing_text = t15
    endif
  -%}

  {%- comment -%} Only show closing text if it is different from intro text {%- endcomment -%}
  {%- if closing_text != blank and closing_text != intro_text -%}
    <div class="pp-tipos__closing">{{ closing_text }}</div>
  {%- endif -%}

  {%- comment -%} ── 8. Banner CTA ── {%- endcomment -%}
  {%- if section.settings.banner_text != blank -%}
    <div class="pp-tipos__banner" style="background-color: {{ section.settings.hero_bg_color }};">
      <p class="pp-tipos__banner-text">{{ section.settings.banner_text }}</p>
      {%- if section.settings.banner_cta_text != blank and section.settings.banner_cta_url != blank -%}
        <a href="{{ section.settings.banner_cta_url }}" class="pp-tipos__banner-btn">
          {{ section.settings.banner_cta_text }}
        </a>
      {%- endif -%}
    </div>
  {%- endif -%}

  {%- comment -%} ── Fallback: render page.content if no variety cards found ── {%- endcomment -%}
  {%- if card_count == 0 and page.content != blank -%}
    <div class="pp-guide__body pp-guide__body--columns">
      {{ page.content }}
    </div>
  {%- endif -%}

  {%- if card_count == 0 and page.content == blank -%}
    <div class="pp-guide__empty">
      <p>Esta guia aun no tiene contenido configurado.</p>
    </div>
  {%- endif -%}

</section>

{% schema %}
{
  "name": "PP Page Tipos",
  "tag": "section",
  "class": "pp-guide-section pp-tipos-section",
  "settings": [
    {
      "type": "header",
      "content": "Hero"
    },
    {
      "type": "checkbox",
      "id": "show_hero",
      "label": "Show hero section",
      "default": true
    },
    {
      "type": "color",
      "id": "hero_bg_color",
      "label": "Hero / Banner background color",
      "default": "#23372C"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "checkbox",
      "id": "show_breadcrumb",
      "label": "Show breadcrumb",
      "default": true
    },
    {
      "type": "range",
      "id": "cards_per_row",
      "min": 1,
      "max": 3,
      "step": 1,
      "label": "Variety cards per row (desktop)",
      "default": 2
    },
    {
      "type": "range",
      "id": "products_per_row",
      "min": 2,
      "max": 6,
      "step": 1,
      "label": "Products per row (desktop)",
      "default": 4
    },
    {
      "type": "header",
      "content": "Banner CTA"
    },
    {
      "type": "text",
      "id": "banner_text",
      "label": "Banner text",
      "default": "Descubre todas las variedades disponibles"
    },
    {
      "type": "text",
      "id": "banner_cta_text",
      "label": "CTA button text",
      "default": "Ver productos"
    },
    {
      "type": "url",
      "id": "banner_cta_url",
      "label": "CTA button URL"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 60
    }
  ],
  "templates": ["page"],
  "presets": [
    {
      "name": "PP Page Tipos",
      "category": "Pur Plant"
    }
  ]
}
{% endschema %}
