{%- comment -%}
  PP Header - Main header section with logo, navigation, search, and cart
  Based on GNG.la header design
{%- endcomment -%}

{{ 'pp-header.css' | asset_url | stylesheet_tag }}
<script src="{{ 'pp-header.js' | asset_url }}" type="module" defer></script>

{%- liquid
  assign logo_width = section.settings.logo_width
  assign logo_mobile_width = section.settings.logo_mobile_width
  assign sticky_header = section.settings.sticky_header
  assign transparent_header = section.settings.transparent_header
-%}

<style>
  #pp-header-{{ section.id }} {
    --pp-header-logo-width: {{ logo_width }}px;
    --pp-header-logo-mobile-width: {{ logo_mobile_width }}px;
    --pp-header-padding-block: 1rem;
    --pp-header-is-sticky: {{ sticky_header | default: true }};
    {%- if transparent_header -%}
    --pp-header-transparent-text: {{ section.settings.transparent_text_color.red }} {{ section.settings.transparent_text_color.green }} {{ section.settings.transparent_text_color.blue }};
    --pp-header-hover-bg: {{ section.settings.transparent_bg_hover.red }} {{ section.settings.transparent_bg_hover.green }} {{ section.settings.transparent_bg_hover.blue }};
    --pp-header-hover-text: {{ section.settings.transparent_text_hover.red }} {{ section.settings.transparent_text_hover.green }} {{ section.settings.transparent_text_hover.blue }};
    {%- endif -%}
  }

  @media screen and (min-width: 1000px) {
    #pp-header-{{ section.id }} {
      --pp-header-padding-block: 1.25rem;
    }
  }
</style>

<pp-header-height-observer variable="header">
  <header
    id="pp-header-{{ section.id }}"
    class="pp-header{% if sticky_header %} pp-header--sticky{% endif %}{% if transparent_header %} pp-header--transparent{% endif %}"
    data-section-id="{{ section.id }}"
  >
    {%- if section.settings.show_announcement and section.settings.announcement_text != blank -%}
      <div class="pp-header__announcement" style="background-color: {{ section.settings.announcement_bg_color }}; color: {{ section.settings.announcement_text_color }};">
        <div class="pp-header__announcement-marquee" data-announcement-marquee>
          <span class="pp-header__announcement-text">{{ section.settings.announcement_text }}</span>
          <span class="pp-header__announcement-text" aria-hidden="true">{{ section.settings.announcement_text }}</span>
        </div>
      </div>
    {%- endif -%}
    <div class="pp-header__inner">
      {%- comment -%} Primary Nav - Mobile: Menu Button / Desktop: Horizontal Menu {%- endcomment -%}
      <nav class="pp-header__primary-nav" aria-label="Navegación principal">
        {%- comment -%} Mobile Menu Toggle — hamburger icon (EME Studios style) {%- endcomment -%}
        <button
          type="button"
          class="pp-header__menu-toggle desktop:hidden"
          aria-controls="pp-mobile-menu"
          aria-expanded="false"
        >
          <span class="pp-header__menu-icon">
            <svg width="16" height="5" viewBox="0 0 12 5" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
              <path d="M12 5H0V4.25H12V5ZM12 0.75H0V0H12V0.75Z" fill="currentColor"/>
            </svg>
          </span>
          <span class="pp-header__close-icon">
            <svg width="16" height="16" viewBox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
              <path d="M1 1L13 13M13 1L1 13" stroke="currentColor" stroke-width="1.5"/>
            </svg>
          </span>
        </button>

        {%- comment -%} Desktop Horizontal Menu - Uses linklist from settings {%- endcomment -%}
        {%- assign main_menu = linklists[section.settings.menu] -%}
        <ul class="pp-header__desktop-menu mobile:hidden">
          {%- for link in main_menu.links -%}
            {%- assign link_handle = link.title | handle -%}
            <li class="pp-header__desktop-menu-item" data-megamenu-trigger="{{ link_handle }}">
              {%- if link.links != blank -%}
                {%- comment -%} Has submenu - render megamenu {%- endcomment -%}
                <details class="pp-header__megamenu" data-megamenu>
                  <summary class="pp-header__desktop-link">
                    <span class="pp-header__desktop-link-text">{{ link.title }}</span>
                  </summary>
                  <div class="pp-header__megamenu-content">
                    <div class="pp-header__megamenu-inner">
                      {%- comment -%} EME Studios style - Link columns {%- endcomment -%}
                      {%- for child_link in link.links -%}
                        <div class="pp-header__megamenu-column">
                          <a href="{{ child_link.url }}" class="pp-header__megamenu-title">{{ child_link.title }}</a>
                          {%- if child_link.links != blank -%}
                            <ul class="pp-header__megamenu-links">
                              {%- for grandchild_link in child_link.links -%}
                                <li class="pp-header__megamenu-link-item">
                                  <a href="{{ grandchild_link.url }}" class="pp-header__megamenu-link">{{ grandchild_link.title }}</a>
                                </li>
                              {%- endfor -%}
                            </ul>
                          {%- endif -%}
                        </div>
                      {%- endfor -%}

                      {%- comment -%} Placeholder columns for testing - EME Studios reference {%- endcomment -%}
                      {%- if link.links.size == 0 -%}
                        <div class="pp-header__megamenu-column">
                          <a href="#" class="pp-header__megamenu-title">BEST SELLERS</a>
                          <ul class="pp-header__megamenu-links">
                            <li class="pp-header__megamenu-link-item"><a href="#" class="pp-header__megamenu-link" style="color:#152be6">REBAJAS</a></li>
                            <li class="pp-header__megamenu-link-item"><a href="#" class="pp-header__megamenu-link">NOVEDADES</a></li>
                            <li class="pp-header__megamenu-link-item"><a href="#" class="pp-header__megamenu-link">BACK IN STOCK</a></li>
                            <li class="pp-header__megamenu-link-item"><a href="#" class="pp-header__megamenu-link">BASICS</a></li>
                            <li class="pp-header__megamenu-link-item"><a href="#" class="pp-header__megamenu-link">FOOTWEAR STUDIO</a></li>
                            <li class="pp-header__megamenu-link-item"><a href="#" class="pp-header__megamenu-link">GIFT CARD</a></li>
                          </ul>
                        </div>
                        <div class="pp-header__megamenu-column">
                          <a href="#" class="pp-header__megamenu-title">ROPA</a>
                          <ul class="pp-header__megamenu-links">
                            <li class="pp-header__megamenu-link-item"><a href="#" class="pp-header__megamenu-link">VER TODO</a></li>
                            <li class="pp-header__megamenu-link-item"><a href="#" class="pp-header__megamenu-link">JERSÉIS</a></li>
                            <li class="pp-header__megamenu-link-item"><a href="#" class="pp-header__megamenu-link">SUDADERAS</a></li>
                            <li class="pp-header__megamenu-link-item"><a href="#" class="pp-header__megamenu-link">CAMISETAS</a></li>
                            <li class="pp-header__megamenu-link-item"><a href="#" class="pp-header__megamenu-link">PANTALONES</a></li>
                            <li class="pp-header__megamenu-link-item"><a href="#" class="pp-header__megamenu-link">CHAQUETAS | ABRIGOS</a></li>
                            <li class="pp-header__megamenu-link-item"><a href="#" class="pp-header__megamenu-link">SUDADERAS SIN CAPUCHA</a></li>
                            <li class="pp-header__megamenu-link-item"><a href="#" class="pp-header__megamenu-link">CAMISAS</a></li>
                            <li class="pp-header__megamenu-link-item"><a href="#" class="pp-header__megamenu-link">CALZADO</a></li>
                            <li class="pp-header__megamenu-link-item"><a href="#" class="pp-header__megamenu-link">SHORTS</a></li>
                            <li class="pp-header__megamenu-link-item"><a href="#" class="pp-header__megamenu-link">POLOS</a></li>
                            <li class="pp-header__megamenu-link-item"><a href="#" class="pp-header__megamenu-link">BAÑADORES</a></li>
                          </ul>
                        </div>
                        <div class="pp-header__megamenu-column">
                          <a href="#" class="pp-header__megamenu-title">ACCESORIOS</a>
                          <ul class="pp-header__megamenu-links">
                            <li class="pp-header__megamenu-link-item"><a href="#" class="pp-header__megamenu-link">VER TODO</a></li>
                            <li class="pp-header__megamenu-link-item"><a href="#" class="pp-header__megamenu-link">GORRAS</a></li>
                            <li class="pp-header__megamenu-link-item"><a href="#" class="pp-header__megamenu-link">ROPA INTERIOR</a></li>
                            <li class="pp-header__megamenu-link-item"><a href="#" class="pp-header__megamenu-link">CALCETINES</a></li>
                            <li class="pp-header__megamenu-link-item"><a href="#" class="pp-header__megamenu-link">LLAVEROS</a></li>
                          </ul>
                        </div>
                        <div class="pp-header__megamenu-column">
                          <a href="#" class="pp-header__megamenu-title" style="color:#152be6">REBAJAS</a>
                          <ul class="pp-header__megamenu-links">
                            <li class="pp-header__megamenu-link-item"><a href="#" class="pp-header__megamenu-link" style="color:#152be6">JERSÉIS</a></li>
                            <li class="pp-header__megamenu-link-item"><a href="#" class="pp-header__megamenu-link" style="color:#152be6">SUDADERAS</a></li>
                            <li class="pp-header__megamenu-link-item"><a href="#" class="pp-header__megamenu-link" style="color:#152be6">PANTALONES</a></li>
                            <li class="pp-header__megamenu-link-item"><a href="#" class="pp-header__megamenu-link" style="color:#152be6">CAMISETAS</a></li>
                            <li class="pp-header__megamenu-link-item"><a href="#" class="pp-header__megamenu-link" style="color:#152be6">CHAQUETAS</a></li>
                            <li class="pp-header__megamenu-link-item"><a href="#" class="pp-header__megamenu-link" style="color:#152be6">ACCESORIOS</a></li>
                          </ul>
                        </div>
                      {%- endif -%}

                      {%- comment -%} Promo images - EME Studios style {%- endcomment -%}
                      {%- assign promo_count = 0 -%}
                      {%- for block in section.blocks -%}
                        {%- if block.type == 'megamenu_promo' -%}
                          {%- assign block_handle = block.settings.menu_handle | handle -%}
                          {%- if block_handle == link_handle -%}
                            {%- assign promo_count = promo_count | plus: 1 -%}
                          {%- endif -%}
                        {%- endif -%}
                      {%- endfor -%}

                      <div class="pp-header__megamenu-promos">
                        {%- if promo_count > 0 -%}
                          {%- for block in section.blocks -%}
                            {%- if block.type == 'megamenu_promo' -%}
                              {%- assign block_handle = block.settings.menu_handle | handle -%}
                              {%- if block_handle == link_handle -%}
                                <a href="{{ block.settings.promo_link | default: '#' }}" class="pp-header__megamenu-promo" {{ block.shopify_attributes }}>
                                  <div class="pp-header__megamenu-promo-image">
                                    {%- if block.settings.promo_image != blank -%}
                                      {{ block.settings.promo_image | image_url: width: 570 | image_tag:
                                        loading: 'lazy',
                                        widths: '285, 400, 570'
                                      }}
                                    {%- else -%}
                                      {%- comment -%} Use EME reference image as fallback {%- endcomment -%}
                                      <img src="https://emestudios.com/cdn/shop/files/header_570x230@2x.webp?v=1765376987" alt="{{ block.settings.promo_title | default: 'Promo' }}" width="570" height="230" loading="lazy">
                                    {%- endif -%}
                                  </div>
                                  {%- if block.settings.promo_title != blank -%}
                                    <span class="pp-header__megamenu-promo-title">{{ block.settings.promo_title }}</span>
                                  {%- endif -%}
                                </a>
                              {%- endif -%}
                            {%- endif -%}
                          {%- endfor -%}
                        {%- else -%}
                          {%- comment -%} Default promos - EME Studios reference images {%- endcomment -%}
                          <a href="#" class="pp-header__megamenu-promo">
                            <div class="pp-header__megamenu-promo-image">
                              <img src="https://emestudios.com/cdn/shop/files/header_570x230@2x.webp?v=1765376987" alt="Best Sellers" width="570" height="230" loading="lazy">
                            </div>
                            <span class="pp-header__megamenu-promo-title">BEST SELLERS</span>
                          </a>
                          <a href="#" class="pp-header__megamenu-promo">
                            <div class="pp-header__megamenu-promo-image">
                              <img src="https://emestudios.com/cdn/shop/files/Sin_titulo-1_3_fe649b73-4179-4b10-bbfa-94b8e9c8d2a8_370x230@2x.webp?v=1765365939" alt="Accessories" width="370" height="230" loading="lazy">
                            </div>
                            <span class="pp-header__megamenu-promo-title">ACCESSORIES</span>
                          </a>
                        {%- endif -%}
                      </div>
                    </div>
                  </div>
                </details>
              {%- elsif link_handle == 'new-in' -%}
                {%- comment -%} Force EME Studios megamenu for "New in" as reference {%- endcomment -%}
                <details class="pp-header__megamenu" data-megamenu>
                  <summary class="pp-header__desktop-link">
                    <span class="pp-header__desktop-link-text">{{ link.title }}</span>
                  </summary>
                  <div class="pp-header__megamenu-content">
                    <div class="pp-header__megamenu-inner">
                      <div class="pp-header__megamenu-column">
                        <a href="#" class="pp-header__megamenu-title">BEST SELLERS</a>
                        <ul class="pp-header__megamenu-links">
                          <li class="pp-header__megamenu-link-item"><a href="#" class="pp-header__megamenu-link" style="color:#152be6">REBAJAS</a></li>
                          <li class="pp-header__megamenu-link-item"><a href="#" class="pp-header__megamenu-link">NOVEDADES</a></li>
                          <li class="pp-header__megamenu-link-item"><a href="#" class="pp-header__megamenu-link">BACK IN STOCK</a></li>
                          <li class="pp-header__megamenu-link-item"><a href="#" class="pp-header__megamenu-link">BASICS</a></li>
                          <li class="pp-header__megamenu-link-item"><a href="#" class="pp-header__megamenu-link">FOOTWEAR STUDIO</a></li>
                          <li class="pp-header__megamenu-link-item"><a href="#" class="pp-header__megamenu-link">GIFT CARD</a></li>
                        </ul>
                      </div>
                      <div class="pp-header__megamenu-column">
                        <a href="#" class="pp-header__megamenu-title">ROPA</a>
                        <ul class="pp-header__megamenu-links">
                          <li class="pp-header__megamenu-link-item"><a href="#" class="pp-header__megamenu-link">VER TODO</a></li>
                          <li class="pp-header__megamenu-link-item"><a href="#" class="pp-header__megamenu-link">JERSÉIS</a></li>
                          <li class="pp-header__megamenu-link-item"><a href="#" class="pp-header__megamenu-link">SUDADERAS</a></li>
                          <li class="pp-header__megamenu-link-item"><a href="#" class="pp-header__megamenu-link">CAMISETAS</a></li>
                          <li class="pp-header__megamenu-link-item"><a href="#" class="pp-header__megamenu-link">PANTALONES</a></li>
                          <li class="pp-header__megamenu-link-item"><a href="#" class="pp-header__megamenu-link">CHAQUETAS | ABRIGOS</a></li>
                          <li class="pp-header__megamenu-link-item"><a href="#" class="pp-header__megamenu-link">SUDADERAS SIN CAPUCHA</a></li>
                          <li class="pp-header__megamenu-link-item"><a href="#" class="pp-header__megamenu-link">CAMISAS</a></li>
                          <li class="pp-header__megamenu-link-item"><a href="#" class="pp-header__megamenu-link">CALZADO</a></li>
                          <li class="pp-header__megamenu-link-item"><a href="#" class="pp-header__megamenu-link">SHORTS</a></li>
                          <li class="pp-header__megamenu-link-item"><a href="#" class="pp-header__megamenu-link">POLOS</a></li>
                          <li class="pp-header__megamenu-link-item"><a href="#" class="pp-header__megamenu-link">BAÑADORES</a></li>
                        </ul>
                      </div>
                      <div class="pp-header__megamenu-column">
                        <a href="#" class="pp-header__megamenu-title">ACCESORIOS</a>
                        <ul class="pp-header__megamenu-links">
                          <li class="pp-header__megamenu-link-item"><a href="#" class="pp-header__megamenu-link">VER TODO</a></li>
                          <li class="pp-header__megamenu-link-item"><a href="#" class="pp-header__megamenu-link">GORRAS</a></li>
                          <li class="pp-header__megamenu-link-item"><a href="#" class="pp-header__megamenu-link">ROPA INTERIOR</a></li>
                          <li class="pp-header__megamenu-link-item"><a href="#" class="pp-header__megamenu-link">CALCETINES</a></li>
                          <li class="pp-header__megamenu-link-item"><a href="#" class="pp-header__megamenu-link">LLAVEROS</a></li>
                        </ul>
                      </div>
                      <div class="pp-header__megamenu-column">
                        <a href="#" class="pp-header__megamenu-title" style="color:#152be6">REBAJAS</a>
                        <ul class="pp-header__megamenu-links">
                          <li class="pp-header__megamenu-link-item"><a href="#" class="pp-header__megamenu-link" style="color:#152be6">JERSÉIS</a></li>
                          <li class="pp-header__megamenu-link-item"><a href="#" class="pp-header__megamenu-link" style="color:#152be6">SUDADERAS</a></li>
                          <li class="pp-header__megamenu-link-item"><a href="#" class="pp-header__megamenu-link" style="color:#152be6">PANTALONES</a></li>
                          <li class="pp-header__megamenu-link-item"><a href="#" class="pp-header__megamenu-link" style="color:#152be6">CAMISETAS</a></li>
                          <li class="pp-header__megamenu-link-item"><a href="#" class="pp-header__megamenu-link" style="color:#152be6">CHAQUETAS</a></li>
                          <li class="pp-header__megamenu-link-item"><a href="#" class="pp-header__megamenu-link" style="color:#152be6">ACCESORIOS</a></li>
                        </ul>
                      </div>
                      <div class="pp-header__megamenu-promos">
                        <a href="#" class="pp-header__megamenu-promo">
                          <div class="pp-header__megamenu-promo-image">
                            <img src="https://emestudios.com/cdn/shop/files/header_570x230@2x.webp?v=1765376987" alt="Best Sellers" width="570" height="230" loading="lazy">
                          </div>
                          <span class="pp-header__megamenu-promo-title">BEST SELLERS</span>
                        </a>
                        <a href="#" class="pp-header__megamenu-promo">
                          <div class="pp-header__megamenu-promo-image">
                            <img src="https://emestudios.com/cdn/shop/files/Sin_titulo-1_3_fe649b73-4179-4b10-bbfa-94b8e9c8d2a8_370x230@2x.webp?v=1765365939" alt="Accessories" width="370" height="230" loading="lazy">
                          </div>
                          <span class="pp-header__megamenu-promo-title">ACCESSORIES</span>
                        </a>
                      </div>
                    </div>
                  </div>
                </details>
              {%- else -%}
                {%- comment -%} No submenu - simple link {%- endcomment -%}
                <a href="{{ link.url }}" class="pp-header__desktop-link">
                  <span class="pp-header__desktop-link-text">{{ link.title }}</span>
                </a>
              {%- endif -%}
            </li>
          {%- endfor -%}
        </ul>
      </nav>

      {%- comment -%} Logo (Center) {%- endcomment -%}
      <h1 class="pp-header__logo">
        <a href="{{ routes.root_url }}">
          <span class="sr-only">{{ shop.name }}</span>
          {%- if section.settings.logo != blank -%}
            {%- assign logo_alt = section.settings.logo.alt | default: shop.name -%}
            {{ section.settings.logo | image_url: width: 400 | image_tag:
              class: 'pp-header__logo-image pp-header__logo-image--default',
              alt: logo_alt,
              loading: 'eager',
              fetchpriority: 'high',
              widths: '100, 150, 200, 250, 300, 400'
            }}
            {%- if transparent_header and section.settings.logo_transparent != blank -%}
              {%- assign logo_transparent_alt = section.settings.logo_transparent.alt | default: shop.name -%}
              {{ section.settings.logo_transparent | image_url: width: 400 | image_tag:
                class: 'pp-header__logo-image pp-header__logo-image--transparent',
                alt: logo_transparent_alt,
                loading: 'eager',
                fetchpriority: 'high',
                widths: '100, 150, 200, 250, 300, 400'
              }}
            {%- endif -%}
          {%- else -%}
            <span class="pp-header__logo-text">{{ shop.name }}</span>
          {%- endif -%}
        </a>
      </h1>

      {%- comment -%} Secondary Nav — Icons for wishlist & cart, text labels on desktop {%- endcomment -%}
      <nav class="pp-header__secondary-nav" aria-label="Navegación secundaria">
        <ul class="pp-header__secondary-nav-list">
          {%- comment -%} Search Link (desktop only) {%- endcomment -%}
          <li class="pp-header__nav-item pp-header__search-link">
            <a href="{{ routes.search_url }}" class="pp-header__nav-link" aria-controls="pp-header-search">
              <span class="sr-only">Buscar</span>
              <span class="pp-header__nav-label" aria-hidden="true">Buscar</span>
            </a>
          </li>

          {%- comment -%} Wishlist — icon on mobile, label on desktop {%- endcomment -%}
          <li class="pp-header__nav-item pp-header__wishlist-link">
            <a href="/pages/wishlist" class="pp-header__nav-link" data-wishlist-link>
              <span class="sr-only">Wishlist</span>
              {%- comment -%} Bookmark icon (EME Studios style) {%- endcomment -%}
              <span class="pp-header__nav-icon" aria-hidden="true">
                <svg width="16" height="16" viewBox="0 0 12 14" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path d="M10.625 2C10.625 1.65482 10.3452 1.375 10 1.375H2C1.65482 1.375 1.375 1.65482 1.375 2V12.3369L6 9.5625L10.625 12.3369V2ZM11.375 13.6621L6 10.4365L0.625 13.6621V2C0.625 1.24061 1.24061 0.625 2 0.625H10C10.7594 0.625 11.375 1.24061 11.375 2V13.6621Z" fill="currentColor"/>
                </svg>
              </span>
              <span class="pp-header__nav-label" aria-hidden="true">WISHLIST</span>
              <span class="pp-header__wishlist-bracket" data-wishlist-bracket>[<span class="pp-header__wishlist-count" data-wishlist-count></span>]</span>
            </a>
          </li>

          {%- comment -%} Account Link (desktop only) {%- endcomment -%}
          {%- if shop.customer_accounts_enabled -%}
            <li class="pp-header__nav-item pp-header__account-link">
              <a href="{{ routes.account_url }}" class="pp-header__nav-link">
                <span class="sr-only">Cuenta</span>
                <span class="pp-header__nav-label" aria-hidden="true">Cuenta</span>
              </a>
            </li>
          {%- endif -%}

          {%- comment -%} Cart — icon on mobile, label on desktop {%- endcomment -%}
          <li class="pp-header__nav-item pp-header__cart-link">
            {%- if settings.cart_type == 'drawer' and template.name != 'cart' -%}
              <button
                type="button"
                class="pp-header__nav-link pp-header__cart-btn"
                data-cart-drawer-trigger
              >
                <span class="sr-only">Carrito</span>
                {%- comment -%} Bag icon (EME Studios style) {%- endcomment -%}
                <span class="pp-header__nav-icon" aria-hidden="true">
                  <svg width="16" height="16" viewBox="0 0 13 13" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M8.74254 3.05169C8.68329 2.48758 8.42888 1.96638 8.02889 1.58784C7.6289 1.2093 7.11094 1 6.57412 1C6.0373 1 5.51933 1.2093 5.11934 1.58784C4.71935 1.96638 4.46543 2.48758 4.40618 3.05169M8.74254 3.05169H4.40618M8.74254 3.05169H10.4456H11.516C11.8654 3.05169 12.1487 3.33501 12.1487 3.68445C12.1487 6.16212 12.1487 8.59406 12.1487 11.1315C12.1487 11.4809 11.8654 11.7643 11.516 11.7643H1.63271C1.28327 11.7643 1 11.481 1 11.1316C1 8.65952 1 6.16676 1 3.6844C1 3.33496 1.28327 3.05169 1.63271 3.05169H4.40618" stroke="currentColor" stroke-width="0.664233"/>
                  </svg>
                </span>
                <span class="pp-header__cart-label">
                  Carrito [<span class="pp-header__cart-count" data-cart-count>{{ cart.item_count }}</span>]
                </span>
              </button>
            {%- else -%}
              <a href="{{ routes.cart_url }}" class="pp-header__nav-link">
                <span class="sr-only">Carrito</span>
                <span class="pp-header__nav-icon" aria-hidden="true">
                  <svg width="16" height="16" viewBox="0 0 13 13" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M8.74254 3.05169C8.68329 2.48758 8.42888 1.96638 8.02889 1.58784C7.6289 1.2093 7.11094 1 6.57412 1C6.0373 1 5.51933 1.2093 5.11934 1.58784C4.71935 1.96638 4.46543 2.48758 4.40618 3.05169M8.74254 3.05169H4.40618M8.74254 3.05169H10.4456H11.516C11.8654 3.05169 12.1487 3.33501 12.1487 3.68445C12.1487 6.16212 12.1487 8.59406 12.1487 11.1315C12.1487 11.4809 11.8654 11.7643 11.516 11.7643H1.63271C1.28327 11.7643 1 11.481 1 11.1316C1 8.65952 1 6.16676 1 3.6844C1 3.33496 1.28327 3.05169 1.63271 3.05169H4.40618" stroke="currentColor" stroke-width="0.664233"/>
                  </svg>
                </span>
                <span class="pp-header__cart-label">
                  Carrito [<span class="pp-header__cart-count" data-cart-count>{{ cart.item_count }}</span>]
                </span>
              </a>
            {%- endif -%}
          </li>
        </ul>
      </nav>
    </div>

    {%- comment -%} Search Overlay {%- endcomment -%}
    <pp-header-search id="pp-header-search-{{ section.id }}" class="pp-header-search" role="dialog" aria-modal="true" hidden>
      <div class="pp-header-search__container">
        <form action="{{ routes.search_url }}" method="GET" class="pp-header-search__form" role="search">
          <div class="pp-header-search__form-control">
            <input
              type="search"
              name="q"
              class="pp-header-search__input"
              placeholder="Buscar productos..."
              aria-label="Buscar"
              autocomplete="off"
              spellcheck="false"
            >
            <input type="hidden" name="type" value="product">
            <button type="button" class="pp-header-search__close">
              <span>Cerrar</span>
            </button>
          </div>
        </form>
        <div class="pp-header-search__results" id="pp-header-search-results-{{ section.id }}">
          {%- comment -%} Predictive search results will be rendered here via JavaScript {%- endcomment -%}
        </div>
      </div>
    </pp-header-search>
  </header>
</pp-header-height-observer>

{%- comment -%} Load wishlist JS globally so counter works on every page {%- endcomment -%}
<div style="display:none;" aria-hidden="true">{% render 'pp-wishlist', type: 'icon' %}</div>

{%- comment -%} Mobile Menu Drawer - EME Studios Style {%- endcomment -%}
<pp-mobile-menu id="pp-mobile-menu" class="pp-mobile-menu" hidden>
  <div class="pp-mobile-menu__backdrop"></div>
  <div class="pp-mobile-menu__panel">
    {%- comment -%} Header: Close Button (Scuffers-style: X + "Close") {%- endcomment -%}
    <div class="pp-mobile-menu__header">
      <button type="button" class="pp-mobile-menu__close" data-mobile-menu-close aria-label="Cerrar">
        <svg xmlns="http://www.w3.org/2000/svg" width="19" height="19" viewBox="0 0 19 19" fill="none">
          <path d="M1.04259 18.5781L0 17.5355L8.24647 9.28906L0 1.04259L1.04259 0L9.28906 8.24647L17.5355 0L18.5781 1.04259L10.3317 9.28906L18.5781 17.5355L17.5355 18.5781L9.28906 10.3317L1.04259 18.5781Z" fill="currentColor"/>
        </svg>
        Close
      </button>
    </div>

    {%- comment -%} Scrollable content area {%- endcomment -%}
    <div class="pp-mobile-menu__scroller">
      {%- assign mobile_menu = linklists[section.settings.menu] -%}

      {%- comment -%}
        Quick Links — top-level items without children
        (e.g. Best Sellers, New Arrivals, Back in Stock, Shop All)
      {%- endcomment -%}
      <nav class="pp-mobile-menu__nav pp-mobile-menu__nav--primary">
        {%- for link in mobile_menu.links -%}
          {%- if link.links == blank -%}
            <div class="pp-mobile-menu__collapsible">
              <a href="{{ link.url }}" class="pp-mobile-menu__collapsible-btn pp-mobile-menu__collapsible-btn--link">
                <span>{{ link.title }}</span>
              </a>
            </div>
          {%- endif -%}
        {%- endfor -%}
      </nav>

      {%- comment -%}
        Accordion Categories — top-level items WITH children
        (e.g. Shop, Accessories) — sub-links displayed as pill tags
      {%- endcomment -%}
      <nav class="pp-mobile-menu__nav pp-mobile-menu__nav--secondary">
        {%- for link in mobile_menu.links -%}
          {%- if link.links != blank -%}
            <div class="pp-mobile-menu__collapsible">
              <button type="button" class="pp-mobile-menu__collapsible-btn" data-collapsible-toggle aria-expanded="false">
                <span>{{ link.title }}</span>
                <span class="pp-mobile-menu__plus">
                  <svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 10 10" fill="none">
                    <path d="M4.26935 5.41371H0V4.26935H4.26935V0H5.41371V4.26935H9.68305V5.41371H5.41371V9.68305H4.26935V5.41371Z" fill="currentColor"/>
                  </svg>
                </span>
              </button>
              <div class="pp-mobile-menu__collapsible-content">
                {%- for child_link in link.links -%}
                  <a href="{{ child_link.url }}" class="pp-mobile-menu__collapsible-link">{{ child_link.title }}</a>
                {%- endfor -%}
              </div>
            </div>
          {%- endif -%}
        {%- endfor -%}
      </nav>

      {%- comment -%} Mobile Menu Promo Images {%- endcomment -%}
      {%- assign mobile_promo_count = 0 -%}
      {%- for block in section.blocks -%}
        {%- if block.type == 'mobile_promo' -%}
          {%- assign mobile_promo_count = mobile_promo_count | plus: 1 -%}
        {%- endif -%}
      {%- endfor -%}

      {%- if mobile_promo_count > 0 -%}
        <div class="pp-mobile-menu__promos">
          {%- for block in section.blocks -%}
            {%- if block.type == 'mobile_promo' -%}
              <a href="{{ block.settings.promo_link | default: '#' }}" class="pp-mobile-menu__promo" {{ block.shopify_attributes }}>
                <div class="pp-mobile-menu__promo-media">
                  {%- if block.settings.promo_image != blank -%}
                    {{ block.settings.promo_image | image_url: width: 570 | image_tag:
                      class: 'pp-mobile-menu__promo-image',
                      loading: 'lazy',
                      widths: '285, 400, 570'
                    }}
                  {%- else -%}
                    <div class="pp-mobile-menu__promo-placeholder">
                      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1">
                        <rect x="3" y="3" width="18" height="18" rx="2" ry="2"/>
                        <circle cx="8.5" cy="8.5" r="1.5"/>
                        <polyline points="21,15 16,10 5,21"/>
                      </svg>
                    </div>
                  {%- endif -%}
                </div>
                {%- if block.settings.promo_title != blank -%}
                  <span class="pp-mobile-menu__promo-title">{{ block.settings.promo_title }}</span>
                {%- endif -%}
              </a>
            {%- endif -%}
          {%- endfor -%}
        </div>
      {%- endif -%}
    </div>

    {%- comment -%} Footer with Account, Language, Social {%- endcomment -%}
    <footer class="pp-mobile-menu__footer">
      <div>
        {%- comment -%} Account Link {%- endcomment -%}
        {%- if shop.customer_accounts_enabled -%}
          <a href="{{ routes.account_url }}" class="pp-mobile-menu__account-link">
            {%- if customer -%}
              Cuenta
            {%- else -%}
              Iniciar sesión
            {%- endif -%}
          </a>
        {%- endif -%}

        {%- comment -%} Language Selector {%- endcomment -%}
        {%- if localization.available_languages.size > 1 -%}
          <div class="pp-mobile-menu__languages">
            {%- form 'localization', id: 'mobile-menu-localization-form', class: 'pp-mobile-menu__language-form' -%}
              {%- for language in localization.available_languages -%}
                <button
                  type="submit"
                  name="locale_code"
                  value="{{ language.iso_code }}"
                  class="pp-mobile-menu__language-btn{% if language.iso_code == localization.language.iso_code %} is-active{% endif %}"
                >
                  {{ language.iso_code | upcase }}
                </button>
              {%- endfor -%}
            {%- endform -%}
          </div>
        {%- endif -%}
      </div>

      {%- comment -%} Social Links {%- endcomment -%}
      {%- assign has_social = false -%}
      {%- if settings.social_instagram_link != blank or settings.social_whatsapp_link != blank or settings.social_youtube_link != blank or settings.social_tiktok_link != blank or settings.social_facebook_link != blank -%}
        {%- assign has_social = true -%}
      {%- endif -%}

      <div class="pp-mobile-menu__social">
        {%- if settings.social_instagram_link != blank -%}
          <a href="{{ settings.social_instagram_link }}" class="pp-mobile-menu__social-link" target="_blank" rel="noopener" aria-label="Instagram">
            <svg width="20" height="20" viewBox="0 0 16 16" fill="none">
              <path d="M11.5 15.5h-7a4 4 0 0 1-4-4v-7a4 4 0 0 1 4-4h7a4 4 0 0 1 4 4v7a4 4 0 0 1-4 4z" stroke="currentColor" fill="none"/>
              <circle cx="8" cy="8" r="3.5" stroke="currentColor" fill="none"/>
              <circle cx="12.5" cy="3.5" r=".5" fill="currentColor"/>
            </svg>
          </a>
        {%- elsif has_social == false -%}
          <a href="#" class="pp-mobile-menu__social-link" aria-label="Instagram">
            <svg width="20" height="20" viewBox="0 0 16 16" fill="none">
              <path d="M11.5 15.5h-7a4 4 0 0 1-4-4v-7a4 4 0 0 1 4-4h7a4 4 0 0 1 4 4v7a4 4 0 0 1-4 4z" stroke="currentColor" fill="none"/>
              <circle cx="8" cy="8" r="3.5" stroke="currentColor" fill="none"/>
              <circle cx="12.5" cy="3.5" r=".5" fill="currentColor"/>
            </svg>
          </a>
        {%- endif -%}
        {%- if settings.social_whatsapp_link != blank -%}
          <a href="{{ settings.social_whatsapp_link }}" class="pp-mobile-menu__social-link" target="_blank" rel="noopener" aria-label="WhatsApp">
            <svg width="20" height="20" viewBox="0 0 21 23" fill="currentColor">
              <path fill-rule="evenodd" clip-rule="evenodd" d="M1.86343 10.4968C1.86343 5.72867 5.72879 1.8633 10.497 1.8633C15.2651 1.8633 19.1305 5.72867 19.1305 10.4968C19.1305 15.265 15.2651 19.1304 10.497 19.1304C9.08231 19.1304 7.74948 18.7908 6.57317 18.1895L6.19011 17.9937L5.8031 18.1816L4.48897 18.8196L4.81195 17.6299L4.94741 17.1309L4.57143 16.7759C2.90293 15.2007 1.86343 12.9709 1.86343 10.4968ZM10.497 0.136597C4.77516 0.136597 0.136719 4.77504 0.136719 10.4968C0.136719 13.2768 1.23264 15.8021 3.01401 17.6621L2.78667 18.4995L2.74181 18.6648L2.73621 18.6854L2.73602 18.6861L2.73556 18.6878L2.73551 18.688L2.73547 18.6881L2.73544 18.6882L2.73543 18.6883L2.7354 18.6884L2.73531 18.6887L2.7346 18.6913L2.729 18.712L2.68414 18.8772L2.32526 20.1992L1.82795 22.0312L3.53556 21.2021L6.18073 19.9177C7.49561 20.521 8.95808 20.8571 10.497 20.8571C16.2188 20.8571 20.8572 16.2187 20.8572 10.4968C20.8572 4.77504 16.2188 0.136597 10.497 0.136597ZM7.0436 6.18013L9.77756 8.8366L8.33863 10.0652L10.9287 12.6553L12.2237 11.3603L14.8138 13.9503V14.8137H10.497L6.18025 10.829V6.18013H7.0436Z"/>
            </svg>
          </a>
        {%- elsif has_social == false -%}
          <a href="#" class="pp-mobile-menu__social-link" aria-label="WhatsApp">
            <svg width="20" height="20" viewBox="0 0 21 23" fill="currentColor">
              <path fill-rule="evenodd" clip-rule="evenodd" d="M1.86343 10.4968C1.86343 5.72867 5.72879 1.8633 10.497 1.8633C15.2651 1.8633 19.1305 5.72867 19.1305 10.4968C19.1305 15.265 15.2651 19.1304 10.497 19.1304C9.08231 19.1304 7.74948 18.7908 6.57317 18.1895L6.19011 17.9937L5.8031 18.1816L4.48897 18.8196L4.81195 17.6299L4.94741 17.1309L4.57143 16.7759C2.90293 15.2007 1.86343 12.9709 1.86343 10.4968ZM10.497 0.136597C4.77516 0.136597 0.136719 4.77504 0.136719 10.4968C0.136719 13.2768 1.23264 15.8021 3.01401 17.6621L2.78667 18.4995L2.74181 18.6648L2.73621 18.6854L2.73602 18.6861L2.73556 18.6878L2.73551 18.688L2.73547 18.6881L2.73544 18.6882L2.73543 18.6883L2.7354 18.6884L2.73531 18.6887L2.7346 18.6913L2.729 18.712L2.68414 18.8772L2.32526 20.1992L1.82795 22.0312L3.53556 21.2021L6.18073 19.9177C7.49561 20.521 8.95808 20.8571 10.497 20.8571C16.2188 20.8571 20.8572 16.2187 20.8572 10.4968C20.8572 4.77504 16.2188 0.136597 10.497 0.136597ZM7.0436 6.18013L9.77756 8.8366L8.33863 10.0652L10.9287 12.6553L12.2237 11.3603L14.8138 13.9503V14.8137H10.497L6.18025 10.829V6.18013H7.0436Z"/>
            </svg>
          </a>
        {%- endif -%}
        {%- if settings.social_youtube_link != blank -%}
          <a href="{{ settings.social_youtube_link }}" class="pp-mobile-menu__social-link" target="_blank" rel="noopener" aria-label="YouTube">
            <svg width="20" height="20" viewBox="0 0 24 18" fill="currentColor">
              <path fill-rule="evenodd" clip-rule="evenodd" d="M1.727 1.727H21.584V15.54H1.727V1.727ZM0 17.267V0h23.31v17.267H0zM15.54 8.202L8.634 5.18v6.044l6.907-3.022z"/>
            </svg>
          </a>
        {%- elsif has_social == false -%}
          <a href="#" class="pp-mobile-menu__social-link" aria-label="YouTube">
            <svg width="20" height="20" viewBox="0 0 24 18" fill="currentColor">
              <path fill-rule="evenodd" clip-rule="evenodd" d="M1.727 1.727H21.584V15.54H1.727V1.727ZM0 17.267V0h23.31v17.267H0zM15.54 8.202L8.634 5.18v6.044l6.907-3.022z"/>
            </svg>
          </a>
        {%- endif -%}
        {%- if settings.social_tiktok_link != blank -%}
          <a href="{{ settings.social_tiktok_link }}" class="pp-mobile-menu__social-link" target="_blank" rel="noopener" aria-label="TikTok">
            <svg width="20" height="20" viewBox="0 0 13 16" fill="currentColor">
              <path d="M12.998 6.146A4.055 4.055 0 019.23 4.331v6.245a4.616 4.616 0 11-4.615-4.615c.096 0 .19.008.285.014V8.25c-.095-.012-.188-.029-.285-.029a2.356 2.356 0 000 4.711c1.3 0 2.45-1.025 2.45-2.326L7.089 0h2.176A4.053 4.053 0 0013 3.618v2.528"/>
            </svg>
          </a>
        {%- elsif has_social == false -%}
          <a href="#" class="pp-mobile-menu__social-link" aria-label="TikTok">
            <svg width="20" height="20" viewBox="0 0 13 16" fill="currentColor">
              <path d="M12.998 6.146A4.055 4.055 0 019.23 4.331v6.245a4.616 4.616 0 11-4.615-4.615c.096 0 .19.008.285.014V8.25c-.095-.012-.188-.029-.285-.029a2.356 2.356 0 000 4.711c1.3 0 2.45-1.025 2.45-2.326L7.089 0h2.176A4.053 4.053 0 0013 3.618v2.528"/>
            </svg>
          </a>
        {%- endif -%}
      </div>
    </footer>
  </div>
</pp-mobile-menu>

{%- comment -%} Cart Drawer - GNG Style {%- endcomment -%}
{%- if settings.cart_type == 'drawer' and template.name != 'cart' -%}
  {% render 'pp-cart-drawer' %}
{%- endif -%}

{% schema %}
{
  "name": "PP Header",
  "class": "pp-header-section",
  "settings": [
    {
      "type": "header",
      "content": "Logo"
    },
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo image"
    },
    {
      "type": "range",
      "id": "logo_width",
      "min": 50,
      "max": 300,
      "step": 10,
      "default": 120,
      "unit": "px",
      "label": "Logo width (desktop)"
    },
    {
      "type": "range",
      "id": "logo_mobile_width",
      "min": 50,
      "max": 200,
      "step": 10,
      "default": 90,
      "unit": "px",
      "label": "Logo width (mobile)"
    },
    {
      "type": "image_picker",
      "id": "logo_transparent",
      "label": "Logo for transparent header",
      "info": "Optional: Use a different logo (e.g., white) when header is transparent"
    },
    {
      "type": "header",
      "content": "Announcement bar"
    },
    {
      "type": "checkbox",
      "id": "show_announcement",
      "label": "Show announcement bar",
      "default": false
    },
    {
      "type": "text",
      "id": "announcement_text",
      "label": "Announcement text",
      "default": "FREE SHIPPING ON ORDERS OVER 100€ — FREE SHIPPING ON ORDERS OVER 100€ — FREE SHIPPING ON ORDERS OVER 100€ —"
    },
    {
      "type": "color",
      "id": "announcement_bg_color",
      "label": "Announcement background color",
      "default": "#f1ede7"
    },
    {
      "type": "color",
      "id": "announcement_text_color",
      "label": "Announcement text color",
      "default": "#000000"
    },
    {
      "type": "header",
      "content": "Desktop Navigation"
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "Desktop menu",
      "default": "main-menu",
      "info": "Select a navigation menu. Use 2-3 levels of links for best results with megamenu."
    },
    {
      "type": "header",
      "content": "Mobile Menu"
    },
    {
      "type": "link_list",
      "id": "secondary_menu",
      "label": "Secondary mobile menu",
      "info": "Optional secondary links shown below the main menu (e.g., Help, Contact, FAQ)"
    },
    {
      "type": "header",
      "content": "Header behavior"
    },
    {
      "type": "checkbox",
      "id": "sticky_header",
      "label": "Enable sticky header",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "transparent_header",
      "label": "Enable transparent header",
      "info": "Header will be transparent and content will flow underneath",
      "default": false
    },
    {
      "type": "color",
      "id": "transparent_text_color",
      "label": "Transparent header text color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "transparent_bg_hover",
      "label": "Background color on hover",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "transparent_text_hover",
      "label": "Text color on hover",
      "default": "#000000"
    }
  ],
  "blocks": [
    {
      "type": "menu_item",
      "name": "Menu item",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Menu item"
        },
        {
          "type": "url",
          "id": "url",
          "label": "Link"
        },
        {
          "type": "text",
          "id": "superscript",
          "label": "Superscript text",
          "info": "Optional text shown as superscript (e.g., NEW, SALE)"
        },
        {
          "type": "checkbox",
          "id": "highlight",
          "label": "Highlight this item",
          "default": false
        },
        {
          "type": "link_list",
          "id": "submenu",
          "label": "Submenu",
          "info": "Optional submenu (creates accordion on mobile)"
        }
      ]
    },
    {
      "type": "divider",
      "name": "Divider",
      "settings": []
    },
    {
      "type": "megamenu_promo",
      "name": "Megamenu promo",
      "limit": 10,
      "settings": [
        {
          "type": "header",
          "content": "Menu Assignment"
        },
        {
          "type": "text",
          "id": "menu_handle",
          "label": "Menu item handle",
          "info": "Enter the handle of the menu item (e.g., 'hombre', 'mujer', 'accesorios'). The handle is the URL-friendly version of the menu title."
        },
        {
          "type": "header",
          "content": "Promo Card"
        },
        {
          "type": "image_picker",
          "id": "promo_image",
          "label": "Promo image",
          "info": "Recommended: 400x500px (4:5 aspect ratio)"
        },
        {
          "type": "text",
          "id": "promo_title",
          "label": "Title",
          "default": "Ver colección"
        },
        {
          "type": "text",
          "id": "promo_subtitle",
          "label": "Subtitle",
          "info": "Optional secondary text"
        },
        {
          "type": "url",
          "id": "promo_link",
          "label": "Link"
