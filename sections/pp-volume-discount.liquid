{%- comment -%}
  PP Volume Discount — Shows tiered quantity discounts as horizontal cards.
  Configurable from the theme editor: up to 3 tiers with unit range,
  discount %, and optional highlight (selected look).
  Calculates the per-unit price automatically from the current variant price.
{%- endcomment -%}

{%- liquid
  assign current_variant = product.selected_or_first_available_variant
  assign base_price = current_variant.price
-%}

<section
  class="pp-vol"
  id="pp-vol-{{ section.id }}"
  data-base-price="{{ base_price }}"
>
  {%- if section.settings.heading != blank -%}
    <p class="pp-vol__heading">{{ section.settings.heading }}</p>
  {%- endif -%}

  <div class="pp-vol__grid">
    {%- for block in section.blocks -%}
      {%- liquid
        assign pct = block.settings.discount_percent | plus: 0
        assign unit_price_cents = base_price | times: 100 | minus: base_price | times: pct | divided_by: 100
        assign discounted = base_price | times: pct | divided_by: 100
        assign unit_price = base_price | minus: discounted
      -%}
      <div
        class="pp-vol__card{% if block.settings.highlighted %} pp-vol__card--highlighted{% endif %}"
        {{ block.shopify_attributes }}
      >
        <span class="pp-vol__range">
          {{ block.settings.min_qty }}-{{ block.settings.max_qty }} Ud
        </span>
        <span class="pp-vol__unit-price" data-pp-vol-unit data-discount="{{ pct }}">
          {{ unit_price | money }}/unidad
        </span>
        <span class="pp-vol__badge">AHORRA {{ pct }}%</span>
      </div>
    {%- endfor -%}
  </div>
</section>

<script>
  /* Update unit prices when variant changes */
  (function () {
    if (window.__ppVolInit) return;
    window.__ppVolInit = true;
    document.addEventListener('variant:changed', function () {
      var section = document.querySelector('.pp-vol');
      if (!section) return;
      var base = parseInt(section.dataset.basePrice, 10);
      if (!base) return;
      section.querySelectorAll('[data-pp-vol-unit]').forEach(function (el) {
        var pct = parseInt(el.dataset.discount, 10) || 0;
        var unit = base - Math.round(base * pct / 100);
        el.textContent = (unit / 100).toFixed(2).replace('.', ',') + ' €/unidad';
      });
    });
  })();
</script>

{% stylesheet %}
  .pp-vol {
    width: 100%;
    margin: 16px 0 8px;
  }

  .pp-vol__heading {
    font-family: 'Inter', sans-serif;
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: #23372c;
    margin: 0 0 10px;
  }

  .pp-vol__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 10px;
  }

  .pp-vol__card {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 4px;
    padding: 16px 10px;
    border: 2px solid #23372c;
    border-radius: 16px;
    background: #fff;
    text-align: center;
    cursor: pointer;
    transition: background 0.2s, border-color 0.2s;
  }

  .pp-vol__card--highlighted {
    background: #e9fde0;
    border-color: #b0d8a0;
  }

  .pp-vol__range {
    font-family: 'Inter', sans-serif;
    font-size: 16px;
    font-weight: 400;
    color: #23372c;
    line-height: 1.3;
  }

  .pp-vol__unit-price {
    font-family: 'Inter', sans-serif;
    font-size: 14px;
    font-weight: 400;
    color: #23372c;
    line-height: 1.3;
  }

  .pp-vol__badge {
    display: inline-block;
    margin-top: 4px;
    padding: 4px 14px;
    background: #e4ffd3;
    border-radius: 20px;
    font-family: 'Inter', sans-serif;
    font-size: 13px;
    font-weight: 700;
    color: #23372c;
    line-height: 1.2;
  }

  @media screen and (max-width: 480px) {
    .pp-vol__grid {
      gap: 8px;
    }

    .pp-vol__card {
      padding: 12px 8px;
    }

    .pp-vol__range {
      font-size: 14px;
    }

    .pp-vol__unit-price {
      font-size: 12px;
    }

    .pp-vol__badge {
      font-size: 11px;
      padding: 3px 10px;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "PP Volume Discount",
  "tag": "section",
  "class": "pp-vol-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": ""
    }
  ],
  "blocks": [
    {
      "type": "tier",
      "name": "Tier",
      "settings": [
        {
          "type": "number",
          "id": "min_qty",
          "label": "Min quantity",
          "default": 3
        },
        {
          "type": "number",
          "id": "max_qty",
          "label": "Max quantity",
          "default": 4
        },
        {
          "type": "number",
          "id": "discount_percent",
          "label": "Discount %",
          "default": 10
        },
        {
          "type": "checkbox",
          "id": "highlighted",
          "label": "Highlighted (green background)",
          "default": false
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "PP Volume Discount",
      "category": "Pur Plant",
      "blocks": [
        { "type": "tier", "settings": { "min_qty": 3, "max_qty": 4, "discount_percent": 10, "highlighted": false } },
        { "type": "tier", "settings": { "min_qty": 5, "max_qty": 9, "discount_percent": 15, "highlighted": true } },
        { "type": "tier", "settings": { "min_qty": 10, "max_qty": 100, "discount_percent": 20, "highlighted": false } }
      ]
    }
  ]
}
{% endschema %}
