{%- comment -%}
  PP Collection Header - Minimal sticky toolbar with filter+sort button and view icons
{%- endcomment -%}

{%- liquid
  assign sort_by = collection.sort_by | default: collection.default_sort_by
  assign active_filters_count = 0
  for filter in collection.filters
    assign active_filters_count = active_filters_count | plus: filter.active_values.size
  endfor
-%}

<style>
  pp-collection-header {
    display: block;
  }

  .pp-ch {
    position: sticky;
    top: var(--pp-header-height, 60px);
    z-index: 50;
    display: flex;
    align-items: center;
    justify-content: space-between;
    background: #fff;
    padding: 12px var(--page-margin, 40px);
    min-height: 52px;
  }

  /* Filter + Sort button */
  .pp-ch__filter-btn {
    display: flex;
    align-items: center;
    gap: 6px;
    background: none;
    border: none;
    cursor: pointer;
    font-family: 'Inter', sans-serif;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #23372c;
    padding: 8px 0;
    transition: opacity 0.2s;
  }

  .pp-ch__filter-btn:hover {
    opacity: 0.6;
  }

  .pp-ch__filter-badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 18px;
    height: 18px;
    padding: 0 5px;
    background: #23372c;
    color: #e4ffd3;
    border-radius: 50%;
    font-size: 10px;
    font-weight: 700;
  }

  /* View icons */
  .pp-ch__views {
    display: flex;
    align-items: center;
    gap: 0;
  }

  .pp-ch__view-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 34px;
    height: 34px;
    background: none;
    border: none;
    cursor: pointer;
    color: #b0b0b0;
    transition: color 0.15s;
    position: relative;
  }

  .pp-ch__view-btn::after {
    content: '';
    position: absolute;
    bottom: 4px;
    left: 50%;
    transform: translateX(-50%);
    width: 20px;
    height: 1px;
    background: #23372c;
    opacity: 0;
    transition: opacity 0.15s;
  }

  .pp-ch__view-btn:hover {
    color: #23372c;
  }

  .pp-ch__view-btn:hover::after {
    opacity: 0.3;
  }

  .pp-ch__view-btn.is-active {
    color: #23372c;
  }

  .pp-ch__view-btn.is-active::after {
    opacity: 1;
  }

  .pp-ch__view-btn svg {
    width: 20px;
    height: 20px;
  }

  /* Desktop views hidden on mobile, mobile views hidden on desktop */
  .pp-ch__views--desktop { display: none; }
  .pp-ch__views--mobile { display: flex; }

  @media screen and (min-width: 750px) {
    .pp-ch__views--desktop { display: flex; }
    .pp-ch__views--mobile { display: none; }
  }

  @media screen and (min-width: 1000px) {
    .pp-ch__view-btn {
      width: 28px;
      height: 28px;
    }
    .pp-ch {
      gap: 12px;
    }
  }

  /* ═══ Filter/Sort Side Panel ═══ */
  .pp-ch__panel {
    position: fixed;
    top: 0;
    left: 0;
    bottom: 0;
    width: 100%;
    max-width: 400px;
    background: #fff;
    z-index: 10001;
    transform: translateX(-100%);
    transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    display: flex;
    flex-direction: column;
    overflow-y: auto;
  }

  .pp-ch__panel.is-open {
    transform: translateX(0);
  }

  .pp-ch__panel-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 20px 24px;
    border-bottom: 1px solid rgba(0,0,0,0.08);
    flex-shrink: 0;
  }

  .pp-ch__panel-title {
    font-family: 'Inter', sans-serif;
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #23372c;
  }

  .pp-ch__panel-close {
    background: none;
    border: none;
    cursor: pointer;
    color: #23372c;
    padding: 4px;
  }

  .pp-ch__panel-content {
    flex: 1;
    overflow-y: auto;
    padding: 0;
  }

  /* Sort section */
  .pp-ch__sort-section {
    padding: 16px 24px;
    border-bottom: 1px solid rgba(0,0,0,0.06);
  }

  .pp-ch__sort-label {
    font-family: 'Inter', sans-serif;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #23372c;
    opacity: 0.5;
    margin-bottom: 12px;
    display: block;
  }

  .pp-ch__sort-options {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }

  .pp-ch__sort-option {
    font-family: 'Inter', sans-serif;
    font-size: 12px;
    color: #23372c;
    text-decoration: none;
    padding: 6px 12px;
    border: 1px solid rgba(35,55,44,0.15);
    border-radius: 100px;
    transition: all 0.15s;
  }

  .pp-ch__sort-option:hover {
    border-color: #23372c;
  }

  .pp-ch__sort-option.is-active {
    background: #23372c;
    color: #e4ffd3;
    border-color: #23372c;
  }

  /* Filter groups */
  .pp-ch__filter-group {
    border-bottom: none;
  }

  .pp-ch__filter-group summary {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 16px 24px;
    cursor: pointer;
    font-family: 'Inter', sans-serif;
    font-size: 13px;
    font-weight: 500;
    color: #23372c;
    list-style: none;
  }

  .pp-ch__filter-group summary::-webkit-details-marker { display: none; }

  .pp-ch__filter-group summary svg {
    transition: transform 0.2s;
  }

  .pp-ch__filter-group[open] summary svg {
    transform: rotate(180deg);
  }

  .pp-ch__filter-group-content {
    padding: 0 24px 16px;
  }

  .pp-ch__filter-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .pp-ch__filter-option {
    display: flex;
    align-items: center;
    gap: 10px;
    text-decoration: none;
    color: #23372c;
    font-family: 'Inter', sans-serif;
    font-size: 13px;
    padding: 6px 0;
    transition: opacity 0.15s;
  }

  .pp-ch__filter-option:hover { opacity: 0.6; }

  .pp-ch__filter-checkbox {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 16px;
    height: 16px;
    border: 1px solid rgba(35,55,44,0.3);
    border-radius: 3px;
    flex-shrink: 0;
  }

  .pp-ch__filter-option.is-active .pp-ch__filter-checkbox {
    background: #23372c;
    border-color: #23372c;
    color: #e4ffd3;
  }

  .pp-ch__filter-count {
    opacity: 0.4;
    font-size: 11px;
    margin-left: auto;
  }

  /* Price range */
  .pp-ch__price-inputs {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .pp-ch__price-input {
    display: flex;
    align-items: center;
    gap: 4px;
    border: 1px solid rgba(35,55,44,0.2);
    border-radius: 6px;
    padding: 6px 10px;
    font-size: 13px;
    flex: 1;
  }

  .pp-ch__price-input input {
    border: none;
    outline: none;
    width: 100%;
    font-size: 13px;
    font-family: 'Inter', sans-serif;
  }

  .pp-ch__price-apply {
    margin-top: 10px;
    background: #23372c;
    color: #e4ffd3;
    border: none;
    border-radius: 100px;
    padding: 8px 20px;
    font-family: 'Inter', sans-serif;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    cursor: pointer;
  }

  /* Footer */
  .pp-ch__panel-footer {
    padding: 16px 24px;
    border-top: 1px solid rgba(0,0,0,0.08);
    flex-shrink: 0;
  }

  .pp-ch__filter-clear {
    font-family: 'Inter', sans-serif;
    font-size: 12px;
    color: #23372c;
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  /* Backdrop */
  .pp-ch__backdrop {
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.4);
    z-index: 10000;
    opacity: 0;
    transition: opacity 0.3s;
    pointer-events: none;
  }

  .pp-ch__backdrop.is-open {
    opacity: 1;
    pointer-events: auto;
  }
</style>

<pp-collection-header class="pp-ch" data-section-id="{{ section.id }}">
  {%- comment -%} Filter + Sort button {%- endcomment -%}
  <button type="button" class="pp-ch__filter-btn" data-panel-open>
    <span>Filtrar y ordenar</span>
    {%- if active_filters_count > 0 -%}
      <span class="pp-ch__filter-badge">{{ active_filters_count }}</span>
    {%- endif -%}
  </button>

  {%- comment -%} View icons {%- endcomment -%}
  <div class="pp-ch__views pp-ch__views--desktop">
    <button type="button" class="pp-ch__view-btn" data-view-desktop="2" aria-label="Mostrar pocos artículos">
      <svg xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 16 16"><path fill-rule="evenodd" d="M14 14H2V2h12zM3 13h10V3H3z" clip-rule="evenodd"/></svg>
    </button>
    <button type="button" class="pp-ch__view-btn" data-view-desktop="3" aria-label="Mostrar más artículos">
      <svg xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 16 16"><path fill-rule="evenodd" d="M14 14H2V2h12zm-5.5-1H13V3H8.5zM3 13h4.5V3H3z" clip-rule="evenodd"/></svg>
    </button>
    <button type="button" class="pp-ch__view-btn" data-view-desktop="4" aria-label="Mostrar el máximo de artículos">
      <svg xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 16 16"><path fill-rule="evenodd" d="M14 14H2V2h12zM3 8.5V13h4.5V8.5zm5.5 0V13H13V8.5zM3 7.5h4.5V3H3zm5.5 0H13V3H8.5z" clip-rule="evenodd"/></svg>
    </button>
  </div>
  <div class="pp-ch__views pp-ch__views--mobile">
    <button type="button" class="pp-ch__view-btn" data-view-mobile="1" aria-label="1 columna">
      <svg xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 16 16"><path fill-rule="evenodd" d="M14 14H2V2h12zM3 13h10V3H3z" clip-rule="evenodd"/></svg>
    </button>
    <button type="button" class="pp-ch__view-btn" data-view-mobile="2" aria-label="2 columnas">
      <svg xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 16 16"><path fill-rule="evenodd" d="M14 14H2V2h12zm-5.5-1H13V3H8.5zM3 13h4.5V3H3z" clip-rule="evenodd"/></svg>
    </button>
    <button type="button" class="pp-ch__view-btn" data-view-mobile="3" aria-label="3 columnas">
      <svg xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 16 16"><path fill-rule="evenodd" d="M14 14H2V2h12zM3 8.5V13h4.5V8.5zm5.5 0V13H13V8.5zM3 7.5h4.5V3H3zm5.5 0H13V3H8.5z" clip-rule="evenodd"/></svg>
    </button>
  </div>
</pp-collection-header>

{%- comment -%} Side Panel {%- endcomment -%}
<div class="pp-ch__panel" data-panel hidden>
  <div class="pp-ch__panel-header">
    <span class="pp-ch__panel-title">Filtrar y ordenar</span>
    <button type="button" class="pp-ch__panel-close" data-panel-close>
      <svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M1 1L13 13M1 13L13 1"/></svg>
    </button>
  </div>
  <div class="pp-ch__panel-content">
    {%- comment -%} Sort {%- endcomment -%}
    <div class="pp-ch__sort-section">
      <span class="pp-ch__sort-label">Ordenar por</span>
      <div class="pp-ch__sort-options">
        {%- for option in collection.sort_options -%}
          <a href="{{ collection.url }}?sort_by={{ option.value }}" class="pp-ch__sort-option{% if option.value == sort_by %} is-active{% endif %}">
            {{ option.name }}
          </a>
        {%- endfor -%}
      </div>
    </div>

    {%- comment -%} Filters {%- endcomment -%}
    {%- for filter in collection.filters -%}
      {%- if filter.type == 'list' and filter.values.size > 0 -%}
        <details class="pp-ch__filter-group" {% if filter.active_values.size > 0 %}open{% endif %}>
          <summary>
            <span>{{ filter.label }}{% if filter.active_values.size > 0 %} ({{ filter.active_values.size }}){% endif %}</span>
            <svg width="10" height="10" viewBox="0 0 10 10" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M2 4l3 3 3-3"/></svg>
          </summary>
          <div class="pp-ch__filter-group-content">
            <ul class="pp-ch__filter-list">
              {%- for value in filter.values -%}
                {%- if value.count > 0 or value.active -%}
                  <li>
                    <a href="{{ value.url }}" class="pp-ch__filter-option{% if value.active %} is-active{% endif %}">
                      <span class="pp-ch__filter-checkbox">
                        {%- if value.active -%}
                          <svg width="10" height="8" viewBox="0 0 10 8" fill="none"><path d="M1 4L3.5 6.5L9 1" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                        {%- endif -%}
                      </span>
                      <span>{{ value.label }}</span>
                      <span class="pp-ch__filter-count">({{ value.count }})</span>
                    </a>
                  </li>
                {%- endif -%}
              {%- endfor -%}
            </ul>
          </div>
        </details>
      {%- elsif filter.type == 'price_range' -%}
        <details class="pp-ch__filter-group">
          <summary>
            <span>{{ filter.label }}</span>
            <svg width="10" height="10" viewBox="0 0 10 10" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M2 4l3 3 3-3"/></svg>
          </summary>
          <div class="pp-ch__filter-group-content">
            <form class="pp-ch__price-form" data-price-form>
              <div class="pp-ch__price-inputs">
                <div class="pp-ch__price-input">
                  <span>{{ cart.currency.symbol }}</span>
                  <input type="number" name="{{ filter.min_value.param_name }}" min="0" max="{{ filter.range_max | money_without_currency | replace: ',', '' }}" value="{{ filter.min_value.value | money_without_currency | replace: ',', '' }}" placeholder="{{ filter.range_min | money_without_currency }}">
                </div>
                <span>–</span>
                <div class="pp-ch__price-input">
                  <span>{{ cart.currency.symbol }}</span>
                  <input type="number" name="{{ filter.max_value.param_name }}" min="0" max="{{ filter.range_max | money_without_currency | replace: ',', '' }}" value="{{ filter.max_value.value | money_without_currency | replace: ',', '' }}" placeholder="{{ filter.range_max | money_without_currency }}">
                </div>
              </div>
              <button type="submit" class="pp-ch__price-apply">Aplicar</button>
            </form>
          </div>
        </details>
      {%- endif -%}
    {%- endfor -%}
  </div>
  {%- if active_filters_count > 0 -%}
    <div class="pp-ch__panel-footer">
      <a href="{{ collection.url }}" class="pp-ch__filter-clear">Limpiar todo</a>
    </div>
  {%- endif -%}
</div>
<div class="pp-ch__backdrop" data-backdrop></div>

<script>
if (!customElements.get('pp-collection-header')) {
  class PPCollectionHeader extends HTMLElement {
    constructor() { super(); }

    connectedCallback() {
      this.STORAGE_DESKTOP = 'pp_grid_cols_desktop';
      this.STORAGE_MOBILE = 'pp_grid_cols_mobile';

      this.initPanel();
      this.initViews();
      this.initPriceForms();
    }

    initPanel() {
      const openBtn = this.querySelector('[data-panel-open]');
      const panel = document.querySelector('.pp-ch__panel');
      const closeBtn = document.querySelector('.pp-ch__panel-close');
      const backdrop = document.querySelector('.pp-ch__backdrop');
      if (!openBtn || !panel) return;

      const open = () => {
        panel.hidden = false;
        backdrop.hidden = false;
        document.body.style.overflow = 'hidden';
        requestAnimationFrame(() => {
          panel.classList.add('is-open');
          backdrop.classList.add('is-open');
        });
      };

      const close = () => {
        panel.classList.remove('is-open');
        backdrop.classList.remove('is-open');
        document.body.style.overflow = '';
        setTimeout(() => { panel.hidden = true; backdrop.hidden = true; }, 300);
      };

      openBtn.addEventListener('click', open);
      closeBtn?.addEventListener('click', close);
      backdrop?.addEventListener('click', close);
      document.addEventListener('keydown', (e) => { if (e.key === 'Escape') close(); });
    }

    initViews() {
      const savedDesktop = localStorage.getItem(this.STORAGE_DESKTOP) || '3';
      const savedMobile = localStorage.getItem(this.STORAGE_MOBILE) || '2';
      this.applyGrid(savedDesktop, savedMobile);

      this.querySelectorAll('[data-view-desktop]').forEach(btn => {
        if (btn.dataset.viewDesktop === savedDesktop) btn.classList.add('is-active');
        btn.addEventListener('click', () => {
          this.querySelectorAll('[data-view-desktop]').forEach(b => b.classList.remove('is-active'));
          btn.classList.add('is-active');
          localStorage.setItem(this.STORAGE_DESKTOP, btn.dataset.viewDesktop);
          this.applyGrid(btn.dataset.viewDesktop, localStorage.getItem(this.STORAGE_MOBILE) || '2');
        });
      });

      this.querySelectorAll('[data-view-mobile]').forEach(btn => {
        if (btn.dataset.viewMobile === savedMobile) btn.classList.add('is-active');
        btn.addEventListener('click', () => {
          this.querySelectorAll('[data-view-mobile]').forEach(b => b.classList.remove('is-active'));
          btn.classList.add('is-active');
          localStorage.setItem(this.STORAGE_MOBILE, btn.dataset.viewMobile);
          this.applyGrid(localStorage.getItem(this.STORAGE_DESKTOP) || '3', btn.dataset.viewMobile);
        });
      });
    }

    applyGrid(desktop, mobile) {
      const grid = document.querySelector('.pp-collection__grid') ||
                   document.querySelector('.product-grid') ||
                   document.querySelector('[class*="collection"] ul[role="list"]');
      if (!grid) return;
      grid.style.setProperty('--pp-cols-desktop', desktop);
      grid.style.setProperty('--pp-cols-mobile', mobile);
      grid.style.setProperty('--pp-items-per-row', desktop);
      const tablet = Math.max(2, Math.min(parseInt(desktop) - 1, parseInt(mobile) + 1));
      grid.style.setProperty('--pp-cols-tablet', tablet);
    }

    initPriceForms() {
      document.querySelectorAll('[data-price-form]').forEach(form => {
        form.addEventListener('submit', (e) => {
          e.preventDefault();
          const url = new URL(window.location.href);
          new FormData(form).forEach((v, k) => { v ? url.searchParams.set(k, v) : url.searchParams.delete(k); });
          window.location.href = url.toString();
        });
      });
    }
  }

  customElements.define('pp-collection-header', PPCollectionHeader);
}
</script>

{% schema %}
{
  "name": "PP Collection Header",
  "class": "pp-collection-header-section",
  "enabled_on": {
    "templates": ["collection"]
  },
  "settings": [],
  "presets": [
    {
      "name": "PP Collection Header"
    }
  ]
}
{% endschema %}
