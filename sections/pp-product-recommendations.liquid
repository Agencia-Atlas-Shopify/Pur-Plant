{{ 'pp-sections.css' | asset_url | stylesheet_tag }}

<section class="pp-recommendations" style="
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  ">
  <div class="pp-recommendations__inner">
    {%- if section.settings.heading != blank -%}
      <h2 class="pp-recommendations__heading">{{ section.settings.heading }}</h2>
    {%- endif -%}

    <div class="pp-recommendations__grid" id="pp-recs-grid-{{ section.id }}" data-product-id="{{ product.id }}" data-section-id="{{ section.id }}" data-limit="{{ section.settings.max_products }}" data-intent="{{ section.settings.intent | default: 'related' }}">
      {%- if recommendations.performed and recommendations.products.size > 0 -%}
        {%- for rec_product in recommendations.products limit: section.settings.max_products -%}
          <div class="pp-recommendations__item">
            {%- render 'pp-product-card-standalone', product: rec_product, image_ratio: section.settings.image_ratio -%}
          </div>
        {%- endfor -%}
      {%- endif -%}
    </div>

    <script>
      (function() {
        var grid = document.getElementById('pp-recs-grid-{{ section.id }}');
        if (!grid || grid.children.length > 0) return;
        var productId = grid.dataset.productId;
        var sectionId = grid.dataset.sectionId;
        var limit = grid.dataset.limit || 4;
        var intent = grid.dataset.intent || 'related';
        if (!productId) return;

        var url = '/recommendations/products?product_id=' + productId + '&limit=' + limit + '&section_id=' + sectionId + '&intent=' + intent;
        fetch(url)
          .then(function(r) { return r.text(); })
          .then(function(html) {
            var div = document.createElement('div');
            div.innerHTML = html;
            var newGrid = div.querySelector('#pp-recs-grid-' + sectionId);
            if (newGrid && newGrid.children.length > 0) {
              grid.innerHTML = newGrid.innerHTML;
            }
          })
          .catch(function() {});
      })();
    </script>
  </div>
</section>

{% schema %}
{
  "name": "PP Recommendations",
  "tag": "section",
  "class": "pp-recommendations-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "EXPLORA LA COLECCIÓN"
    },
    {
      "type": "range",
      "id": "max_products",
      "min": 2,
      "max": 12,
      "step": 1,
      "label": "Max products",
      "default": 4
    },
    {
      "type": "select",
      "id": "image_ratio",
      "label": "Image ratio",
      "options": [
        { "value": "portrait-tall", "label": "Portrait tall (4:5)" },
        { "value": "portrait", "label": "Portrait (3:4)" },
        { "value": "square", "label": "Square (1:1)" }
      ],
      "default": "portrait-tall"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 40
    }
  ],
  "templates": ["product"],
  "presets": [
    {
      "name": "PP Recommendations",
      "category": "Pur Plant"
    }
  ]
}
{% endschema %}
