{%- comment -%}
  PP Page Problemas — Renders plant problems/troubleshooting guide pages
  Reads content from page.metafields.custom.page_content JSON array.
  Widget types: heading, text (raw HTML), image.
  Also uses: page_collection_1..3 for product grids.
{%- endcomment -%}

{{ 'pp-page-guide.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign grid_after = section.settings.collection_grid_after_section | default: 3
  assign products_per_row = section.settings.products_per_row | default: 4
-%}

<style>
  /* ==========================================================================
     PP Page Problemas — Inline Styles
     ========================================================================== */

  /* --- Hero (full-width, overlaps header) --- */
  .pp-problemas-hero {
    position: relative;
    left: 50%;
    right: 50%;
    width: 100vw;
    margin-left: -50vw;
    margin-right: -50vw;
    min-height: 450px;
    display: flex;
    align-items: flex-end;
    justify-content: flex-start;
    overflow: hidden;
    border-radius: 0;
    margin-bottom: 48px;
    margin-top: calc(-1 * (var(--pp-problemas-pad-top, 40px) + var(--pp-header-height, 120px)));
    padding-top: var(--pp-header-height, 120px);
  }

  .pp-problemas-hero__bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .pp-problemas-hero__bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .pp-problemas-hero__gradient {
    position: absolute;
    inset: 0;
    background: rgba(35, 55, 44, 0.3);
    z-index: 1;
  }

  .pp-problemas-hero__content {
    position: relative;
    z-index: 2;
    text-align: left;
    padding: 40px 32px;
    max-width: 800px;
  }

  .pp-problemas-hero__title {
    font-family: 'Aileron', sans-serif;
    font-size: clamp(36px, 6vw, 64px);
    font-weight: 700;
    color: #e4ffd3;
    line-height: 0.8;
    margin: 0;
    letter-spacing: -0.07em;
    text-transform: uppercase;
  }

  /* --- Container --- */
  .pp-problemas {
    --pp-dark-green: #23372C;
    --pp-light-green: #DAFFD3;
    --pp-beige: #F5F0E8;
    --pp-text: #3a3838;
    --pp-font-body: 'Inter', sans-serif;
    --pp-font-heading: 'Tenor Sans', Georgia, serif;
    --pp-font-display: 'Aileron', sans-serif;
    --pp-radius: 8px;
    --pp-content-max: 800px;
    --pp-transition: 0.25s ease;
    max-width: var(--page-content-width, 120rem);
    margin: 0 auto;
    padding: var(--pp-problemas-pad-top, 40px) var(--page-margin, 40px) var(--pp-problemas-pad-bottom, 60px);
    font-family: var(--pp-font-body);
    color: var(--pp-text);
  }

  /* --- Content widgets --- */
  .pp-content__heading {
    font-family: 'Aileron', sans-serif;
    font-size: clamp(24px, 3.5vw, 34px);
    font-weight: 800;
    color: #23372c;
    line-height: 1.2;
    margin: 0 0 15px;
    text-transform: lowercase;
  }
  .pp-content__heading::first-letter {
    text-transform: uppercase;
  }

  .pp-content__text {
    font-family: var(--pp-font-body);
    font-size: 15px;
    font-weight: 400;
    color: var(--pp-text);
    line-height: 1.75;
    margin: 0 0 24px;
  }

  .pp-content__text p { margin: 0 0 16px; }
  .pp-content__text p:last-child { margin-bottom: 0; }
  .pp-content__text p.pp-empty { margin: 0; line-height: 0; font-size: 0; }
  .pp-content__text ul,
  .pp-content__text ol { margin: 0 0 16px; padding-left: 24px; }
  .pp-content__text li { margin-bottom: 6px; }
  .pp-content__text a { color: var(--pp-dark-green); text-decoration: underline; }
  .pp-content__text a:hover { opacity: 0.8; }
  .pp-content__text strong { font-weight: 600; }

  .pp-content__image {
    margin: 0 0 24px;
  }

  .pp-content__image img {
    max-width: 100%;
    height: auto;
    border-radius: var(--pp-radius);
    display: block;
  }

  .pp-content__video {
    position: relative;
    aspect-ratio: 16 / 9;
    margin: 0 0 24px;
    border-radius: var(--pp-radius);
    overflow: hidden;
    background: #000;
    max-width: 800px;
  }

  .pp-content__video iframe,
  .pp-content__video video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: 0;
  }

  .pp-content__cta {
    margin: 8px 0 24px;
  }
  .pp-cta-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 12px 22px;
    border: 1px solid var(--pp-dark-green);
    border-radius: 999px;
    font-family: 'Inter', sans-serif;
    font-size: 13px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--pp-dark-green);
    text-decoration: none;
    transition: background .2s, color .2s;
  }
  .pp-cta-btn:hover { background: var(--pp-dark-green); color: #fff; }

  .pp-content__products-inline {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
    gap: 16px;
    margin: 24px 0;
  }
  .pp-inline-product {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: inherit;
    border-radius: 8px;
    overflow: hidden;
    background: #fff;
    transition: transform .2s;
  }
  .pp-inline-product:hover { transform: translateY(-2px); }
  .pp-inline-product__img {
    width: 100%;
    aspect-ratio: 1 / 1;
    object-fit: cover;
    display: block;
    background: #f5f5f5;
  }
  .pp-inline-product__title {
    padding: 10px 12px;
    font-size: 14px;
    line-height: 1.4;
    font-weight: 500;
  }

  /* --- Section with image+text side by side --- */
  .pp-problemas__section {
    margin-bottom: 15px;
  }

  .pp-problemas__section-body {
    display: flex;
    gap: 32px;
    align-items: center;
  }

  .pp-problemas__section-body--with-image {
    flex-direction: row;
  }

  .pp-problemas__section-image {
    flex: 0 0 auto;
    max-width: 300px;
  }

  .pp-problemas__section-image img {
    width: 100%;
    max-width: 300px;
    height: auto;
    border-radius: var(--pp-radius);
    display: block;
    object-fit: cover;
  }

  .pp-problemas__section-text {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    justify-content: center;
  }

  .pp-problemas__section-text-title {
    font-family: 'Tenor Sans', Georgia, serif;
    font-size: 22.3px;
    font-weight: 400;
    color: #23372c;
    text-transform: uppercase;
    margin: 0 0 20px;
    line-height: 1.3;
  }

  .pp-problemas__section-text-btn {
    display: inline-block;
    font-family: 'Inter', sans-serif;
    font-size: 19.9px;
    font-weight: 400;
    color: #23372c;
    background: #daffd3;
    border: 1px solid #23372c;
    border-radius: 100px;
    padding: 12px 32px;
    text-decoration: none;
    cursor: pointer;
    transition: background 0.25s ease, transform 0.25s ease;
  }

  .pp-problemas__section-text-btn:hover {
    background: #c4f5bb;
    transform: translateY(-1px);
  }

  .pp-problemas__section-text p { margin: 0 0 16px; font-family: 'Tenor Sans', Georgia, serif; font-size: 16pt; color: var(--pp-text); line-height: 1.75; font-weight: 100; text-transform: uppercase; max-width: 80%; }
  .pp-problemas__section-text p:last-child { margin-bottom: 0; }
  .pp-problemas__section-text ul,
  .pp-problemas__section-text ol { margin: 0 0 16px; padding-left: 24px; }
  .pp-problemas__section-text li { margin-bottom: 6px; }
  .pp-problemas__section-text a { color: var(--pp-dark-green); text-decoration: none; }
  .pp-problemas__section-text strong { font-weight: 600; }

  .pp-problemas__section-text--full {
    max-width: var(--pp-content-max);
  }

  /* --- Product grid --- */
  .pp-problemas__product-grid-wrapper {
    margin: 56px 0;
    padding: 40px 0;
    border-top: 1px solid rgba(35, 55, 44, 0.1);
    border-bottom: 1px solid rgba(35, 55, 44, 0.1);
  }

  .pp-problemas__product-grid-title {
    font-family: var(--pp-font-heading);
    font-size: clamp(20px, 2.5vw, 28px);
    font-weight: 400;
    color: var(--pp-dark-green);
    margin: 0 0 24px;
    text-align: center;
  }

  .pp-problemas__product-grid {
    display: grid;
    grid-template-columns: repeat(var(--pp-products-per-row, 4), 1fr);
    gap: 20px;
  }

  /* --- Banner CTA --- */
  .pp-problemas__banner {
    background: var(--pp-dark-green);
    border-radius: var(--pp-radius);
    padding: 48px 40px;
    text-align: center;
    margin-top: 56px;
  }

  .pp-problemas__banner-text {
    font-family: var(--pp-font-heading);
    font-size: clamp(22px, 3vw, 32px);
    font-weight: 400;
    color: #DAFFD3;
    line-height: 1.3;
    margin: 0 0 24px;
  }

  .pp-problemas__banner-btn {
    display: inline-block;
    font-family: var(--pp-font-body);
    font-size: 14px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--pp-dark-green);
    background: #DAFFD3;
    border: none;
    border-radius: 100px;
    padding: 14px 36px;
    text-decoration: none;
    cursor: pointer;
    transition: background var(--pp-transition), transform var(--pp-transition);
  }

  .pp-problemas__banner-btn:hover {
    background: #c4f5bb;
    transform: translateY(-1px);
  }

  /* --- Hide banner --- */
  .pp-problemas__banner { display: none; }

  /* --- Breadcrumb (inherits from pp-page-guide.css, local overrides) --- */
  .pp-problemas .pp-guide__breadcrumb {
    margin-bottom: 24px;
  }

  /* ==========================================================================
     Responsive
     ========================================================================== */
  @media screen and (max-width: 989px) {
    .pp-problemas__product-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media screen and (max-width: 749px) {
    .pp-problemas-hero {
      min-height: 280px;
      margin-bottom: 24px;
    }

    .pp-problemas-hero__content {
      padding: 24px 20px;
    }

    .pp-problemas__section-body {
      flex-direction: column;
    }

    .pp-problemas__section-image {
      flex: 0 0 100%;
      max-width: 180px;
    }

    .pp-problemas__product-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 12px;
    }

    .pp-problemas__section {
      margin-bottom: 32px;
    }

    .pp-problemas__product-grid-wrapper {
      margin: 36px 0;
      padding: 28px 0;
    }

    .pp-problemas__banner {
      padding: 32px 20px;
      margin-top: 36px;
    }
  }
</style>

<section
  class="pp-problemas"
  style="
    --pp-problemas-pad-top: {{ section.settings.padding_top }}px;
    --pp-problemas-pad-bottom: {{ section.settings.padding_bottom }}px;
    --pp-products-per-row: {{ products_per_row }};
  "
>

  {%- comment -%} -- 1. Hero Section (full-width, under header) -- {%- endcomment -%}
  {%- if section.settings.show_hero -%}
    {%- assign hero_image = page.metafields.custom.imagen_portada.value -%}
    {%- assign hero_image_url = page.metafields.custom.imagen_portada_url.value -%}
    <div class="pp-problemas-hero">
      {%- if hero_image -%}
        <div class="pp-problemas-hero__bg">
          {{ hero_image | image_url: width: 1600 | image_tag: loading: 'eager', sizes: '100vw' }}
        </div>
      {%- elsif hero_image_url != blank -%}
        <div class="pp-problemas-hero__bg">
          <img src="{{ hero_image_url }}" alt="{{ page.title | escape }}" loading="eager">
        </div>
      {%- endif -%}
      <div class="pp-problemas-hero__gradient"></div>
      <div class="pp-problemas-hero__content">
        <h1 class="pp-problemas-hero__title">{{ page.title }}</h1>
      </div>
    </div>
  {%- endif -%}

  {%- comment -%} -- Breadcrumb (after hero) -- {%- endcomment -%}
  {%- if section.settings.show_breadcrumb -%}
    <nav class="pp-guide__breadcrumb" aria-label="Breadcrumb">
      <a href="/">Inicio</a>
      <span class="pp-guide__breadcrumb-sep">/</span>
      {%- if page.handle != 'guia-problemas-plantas' -%}
        <a href="/pages/guia-problemas-plantas">Guía Problemas Plantas</a>
        <span class="pp-guide__breadcrumb-sep">/</span>
        <span>{{ page.title }}</span>
      {%- else -%}
        <span>{{ page.title }}</span>
      {%- endif -%}
    </nav>
  {%- endif -%}

  {%- comment -%} -- 2. Detectar si hay widgets numerados (page_heading_N) -- {%- endcomment -%}
  {%- assign has_numbered = false -%}
  {%- for i in (1..50) -%}
    {%- assign hk = 'page_heading_' | append: i -%}
    {%- if page.metafields.custom[hk].value != blank -%}
      {%- assign has_numbered = true -%}
      {%- break -%}
    {%- endif -%}
  {%- endfor -%}
  {%- assign page_content_val = page.metafields.custom.page_content.value -%}

  {%- comment -%} -- 3a. Fallback page.content RTE si no hay ni widgets numerados ni page_content -- {%- endcomment -%}
  {%- if has_numbered == false and page_content_val == blank and page.content != blank -%}
    <div class="pp-problemas__page-body rte">
      {{ page.content }}
    </div>
  {%- endif -%}

  {%- comment -%} -- 3b. Contenido SSR desde metafields numerados o legacy page_content -- {%- endcomment -%}
  {%- if has_numbered or page_content_val != blank -%}
    {%- assign grid_1_val = page.metafields.custom.page_collection_1.value -%}
    {%- assign grid_2_val = page.metafields.custom.page_collection_2.value -%}
    {%- assign grid_3_val = page.metafields.custom.page_collection_3.value -%}

    {%- capture grid_1_html -%}
      {%- if grid_1_val -%}
        <div class="pp-problemas__product-grid-wrapper" data-product-grid="1">
          {%- if grid_1_val.title != blank -%}<h3 class="pp-problemas__product-grid-title">{{ grid_1_val.title }}</h3>{%- endif -%}
          <div class="pp-problemas__product-grid">
            {%- for product in grid_1_val.products limit: 8 -%}{%- render 'pp-product-card-standalone', product: product, image_ratio: 'portrait' -%}{%- endfor -%}
          </div>
        </div>
      {%- endif -%}
    {%- endcapture -%}
    {%- capture grid_2_html -%}
      {%- if grid_2_val -%}
        <div class="pp-problemas__product-grid-wrapper" data-product-grid="2">
          {%- if grid_2_val.title != blank -%}<h3 class="pp-problemas__product-grid-title">{{ grid_2_val.title }}</h3>{%- endif -%}
          <div class="pp-problemas__product-grid">
            {%- for product in grid_2_val.products limit: 8 -%}{%- render 'pp-product-card-standalone', product: product, image_ratio: 'portrait' -%}{%- endfor -%}
          </div>
        </div>
      {%- endif -%}
    {%- endcapture -%}
    {%- capture grid_3_html -%}
      {%- if grid_3_val -%}
        <div class="pp-problemas__product-grid-wrapper" data-product-grid="3">
          {%- if grid_3_val.title != blank -%}<h3 class="pp-problemas__product-grid-title">{{ grid_3_val.title }}</h3>{%- endif -%}
          <div class="pp-problemas__product-grid">
            {%- for product in grid_3_val.products limit: 8 -%}{%- render 'pp-product-card-standalone', product: product, image_ratio: 'portrait' -%}{%- endfor -%}
          </div>
        </div>
      {%- endif -%}
    {%- endcapture -%}

    <div class="pp-problemas__content">
      {%- assign heading_count = 0 -%}
      {%- assign coll_used = 0 -%}

      {%- if has_numbered -%}
        {%- for i in (1..50) -%}
          {%- assign hk = 'page_heading_' | append: i -%}
          {%- assign tk = 'page_text_' | append: i -%}
          {%- assign ik = 'page_image_' | append: i -%}
          {%- assign hv = page.metafields.custom[hk].value -%}
          {%- assign tv = page.metafields.custom[tk].value -%}
          {%- assign iv = page.metafields.custom[ik].value -%}
          {%- if hv != blank -%}
            {%- assign heading_count = heading_count | plus: 1 -%}
            {%- if heading_count > 1 and coll_used < 3 -%}
              {%- assign prev = heading_count | minus: 1 -%}
              {%- assign mod = prev | modulo: grid_after -%}
              {%- if mod == 0 -%}
                {%- assign coll_used = coll_used | plus: 1 -%}
                {%- if coll_used == 1 -%}{{ grid_1_html }}{%- endif -%}
                {%- if coll_used == 2 -%}{{ grid_2_html }}{%- endif -%}
                {%- if coll_used == 3 -%}{{ grid_3_html }}{%- endif -%}
              {%- endif -%}
            {%- endif -%}
            <div class="pp-problemas__section">
              <h2 class="pp-content__heading">{{ hv }}</h2>
              {%- if iv != blank and tv != blank -%}
                <div class="pp-problemas__section-body pp-problemas__section-body--with-image">
                  <div class="pp-problemas__section-image"><img src="{{ iv }}" alt="{{ hv | escape }}" loading="lazy"></div>
                  <div class="pp-problemas__section-text">{{ tv }}</div>
                </div>
              {%- else -%}
                {%- if iv != blank -%}<div class="pp-content__image"><img src="{{ iv }}" alt="{{ hv | escape }}" loading="lazy"></div>{%- endif -%}
                {%- if tv != blank -%}<div class="pp-content__text">{{ tv }}</div>{%- endif -%}
              {%- endif -%}
            </div>
          {%- else -%}
            {%- if iv != blank -%}<div class="pp-content__image"><img src="{{ iv }}" loading="lazy"></div>{%- endif -%}
            {%- if tv != blank -%}<div class="pp-content__text">{{ tv }}</div>{%- endif -%}
          {%- endif -%}
        {%- endfor -%}
      {%- elsif page_content_val != blank -%}
        {%- for w in page_content_val -%}
          {%- case w.type -%}
            {%- when 'heading' -%}
              {%- if w.value != blank -%}
                {%- assign heading_count = heading_count | plus: 1 -%}
                {%- if heading_count > 1 and coll_used < 3 -%}
                  {%- assign prev = heading_count | minus: 1 -%}
                  {%- assign mod = prev | modulo: grid_after -%}
                  {%- if mod == 0 -%}
                    {%- assign coll_used = coll_used | plus: 1 -%}
                    {%- if coll_used == 1 -%}{{ grid_1_html }}{%- endif -%}
                    {%- if coll_used == 2 -%}{{ grid_2_html }}{%- endif -%}
                    {%- if coll_used == 3 -%}{{ grid_3_html }}{%- endif -%}
                  {%- endif -%}
                {%- endif -%}
                <div class="pp-problemas__section"><h2 class="pp-content__heading">{{ w.value }}</h2></div>
              {%- endif -%}
            {%- when 'text' -%}
              {%- if w.value != blank -%}<div class="pp-content__text">{{ w.value }}</div>{%- endif -%}
            {%- when 'image' -%}
              {%- if w.src != blank -%}
                <div class="pp-content__image">
                  {%- if w.link != blank -%}<a href="{{ w.link }}"><img src="{{ w.src }}" alt="{{ w.alt | default: '' }}" loading="lazy"></a>
                  {%- else -%}<img src="{{ w.src }}" alt="{{ w.alt | default: '' }}" loading="lazy">{%- endif -%}
                </div>
              {%- endif -%}
            {%- when 'cta' -%}
              {%- if w.url != blank and w.text != blank -%}
                <div class="pp-content__cta"><a class="pp-cta-btn" href="{{ w.url }}">{{ w.text }} <span aria-hidden="true">&rarr;</span></a></div>
              {%- endif -%}
          {%- endcase -%}
        {%- endfor -%}
      {%- endif -%}

      {%- comment -%} Product grids sobrantes que no se intercalaron van al final {%- endcomment -%}
      {%- if coll_used < 1 and grid_1_val -%}{{ grid_1_html }}{%- endif -%}
      {%- if coll_used < 2 and grid_2_val -%}{{ grid_2_html }}{%- endif -%}
      {%- if coll_used < 3 and grid_3_val -%}{{ grid_3_html }}{%- endif -%}
    </div>
  {%- endif -%}

  {%- comment -%} -- 5. Banner CTA -- {%- endcomment -%}
  {%- if section.settings.banner_text != blank -%}
    <div class="pp-problemas__banner" style="background-color: {{ section.settings.hero_bg_color }};">
      <p class="pp-problemas__banner-text">{{ section.settings.banner_text }}</p>
      {%- if section.settings.banner_cta_text != blank and section.settings.banner_cta_url != blank -%}
        <a href="{{ section.settings.banner_cta_url }}" class="pp-problemas__banner-btn">
          {{ section.settings.banner_cta_text }}
        </a>
      {%- endif -%}
    </div>
  {%- endif -%}

  {%- comment -%} -- Fallback solo en editor del theme, NO en HTML público (Google lo indexa) -- {%- endcomment -%}
  {%- if request.design_mode -%}
    <div class="pp-guide__empty" data-pp-empty>
      <p>Esta guía aún no tiene contenido configurado.</p>
    </div>
  {%- endif -%}

</section>

<script>
/* IIFE JSON-legacy eliminado: contenido ahora es SSR (loop Liquid arriba).
   Widgets, product-grids intercalados y párrafos vacíos se emiten server-side. */
</script>

{% schema %}
{
  "name": "PP Page Problemas",
  "tag": "section",
  "class": "pp-guide-section pp-problemas-section",
  "settings": [
    {
      "type": "header",
      "content": "Hero"
    },
    {
      "type": "checkbox",
      "id": "show_hero",
      "label": "Show hero section",
      "default": true
    },
    {
      "type": "color",
      "id": "hero_bg_color",
      "label": "Hero / Banner background color",
      "default": "#23372C"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "checkbox",
      "id": "show_breadcrumb",
      "label": "Show breadcrumb",
      "default": true
    },
    {
      "type": "range",
      "id": "products_per_row",
      "min": 2,
      "max": 6,
      "step": 1,
      "label": "Products per row (desktop)",
      "default": 4
    },
    {
      "type": "range",
      "id": "collection_grid_after_section",
      "min": 1,
