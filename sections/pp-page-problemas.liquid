{%- comment -%}
  PP Page Problemas — Renders plant problems/troubleshooting guide pages
  Reads content from page.metafields.custom.page_content JSON array.
  Widget types: heading, text (raw HTML), image.
  Also uses: page_collection_1..3 for product grids.
{%- endcomment -%}

{{ 'pp-page-guide.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign grid_after = section.settings.collection_grid_after_section | default: 3
  assign products_per_row = section.settings.products_per_row | default: 4
-%}

<style>
  /* ==========================================================================
     PP Page Problemas — Inline Styles
     ========================================================================== */

  /* --- Hero (full-width, overlaps header) --- */
  .pp-problemas-hero {
    position: relative;
    width: 100vw;
    margin-left: calc(-1 * var(--page-margin, 40px));
    min-height: 450px;
    display: flex;
    align-items: flex-end;
    justify-content: flex-start;
    overflow: hidden;
    border-radius: 0;
    margin-bottom: 48px;
    margin-top: calc(-1 * (var(--pp-problemas-pad-top, 40px) + var(--pp-header-height, 120px)));
    padding-top: var(--pp-header-height, 120px);
  }

  .pp-problemas-hero__bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .pp-problemas-hero__bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .pp-problemas-hero__gradient {
    position: absolute;
    inset: 0;
    background: rgba(35, 55, 44, 0.3);
    z-index: 1;
  }

  .pp-problemas-hero__content {
    position: relative;
    z-index: 2;
    text-align: left;
    padding: 40px 32px;
    max-width: 800px;
  }

  .pp-problemas-hero__title {
    font-family: 'Aileron', sans-serif;
    font-size: clamp(36px, 6vw, 64px);
    font-weight: 700;
    color: #e4ffd3;
    line-height: 0.8;
    margin: 0;
    letter-spacing: -0.07em;
    text-transform: uppercase;
  }

  /* --- Container --- */
  .pp-problemas {
    --pp-dark-green: #23372C;
    --pp-light-green: #DAFFD3;
    --pp-beige: #F5F0E8;
    --pp-text: #3a3838;
    --pp-font-body: 'Inter', sans-serif;
    --pp-font-heading: 'Tenor Sans', Georgia, serif;
    --pp-font-display: 'Aileron', sans-serif;
    --pp-radius: 8px;
    --pp-content-max: 800px;
    --pp-transition: 0.25s ease;
    max-width: var(--page-content-width, 120rem);
    margin: 0 auto;
    padding: var(--pp-problemas-pad-top, 40px) var(--page-margin, 40px) var(--pp-problemas-pad-bottom, 60px);
    font-family: var(--pp-font-body);
    color: var(--pp-text);
  }

  /* --- Content widgets --- */
  .pp-content__heading {
    font-family: 'Aileron', sans-serif;
    font-size: clamp(24px, 3.5vw, 34px);
    font-weight: 800;
    color: #23372c;
    line-height: 1.2;
    margin: 0 0 15px;
    text-transform: lowercase;
  }
  .pp-content__heading::first-letter {
    text-transform: uppercase;
  }

  .pp-content__text {
    font-family: var(--pp-font-body);
    font-size: 15px;
    font-weight: 400;
    color: var(--pp-text);
    line-height: 1.75;
    margin: 0 0 24px;
  }

  .pp-content__text p { margin: 0 0 16px; }
  .pp-content__text p:last-child { margin-bottom: 0; }
  .pp-content__text p.pp-empty { margin: 0; line-height: 0; font-size: 0; }
  .pp-content__text ul,
  .pp-content__text ol { margin: 0 0 16px; padding-left: 24px; }
  .pp-content__text li { margin-bottom: 6px; }
  .pp-content__text a { color: var(--pp-dark-green); text-decoration: underline; }
  .pp-content__text a:hover { opacity: 0.8; }
  .pp-content__text strong { font-weight: 600; }

  .pp-content__image {
    margin: 0 0 24px;
  }

  .pp-content__image img {
    max-width: 100%;
    height: auto;
    border-radius: var(--pp-radius);
    display: block;
  }

  /* --- Section with image+text side by side --- */
  .pp-problemas__section {
    margin-bottom: 15px;
  }

  .pp-problemas__section-body {
    display: flex;
    gap: 32px;
    align-items: center;
  }

  .pp-problemas__section-body--with-image {
    flex-direction: row;
  }

  .pp-problemas__section-image {
    flex: 0 0 auto;
    max-width: 300px;
  }

  .pp-problemas__section-image img {
    width: 100%;
    max-width: 300px;
    height: auto;
    border-radius: var(--pp-radius);
    display: block;
    object-fit: cover;
  }

  .pp-problemas__section-text {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    justify-content: center;
  }

  .pp-problemas__section-text-title {
    font-family: 'Tenor Sans', Georgia, serif;
    font-size: 22.3px;
    font-weight: 400;
    color: #23372c;
    text-transform: uppercase;
    margin: 0 0 20px;
    line-height: 1.3;
  }

  .pp-problemas__section-text-btn {
    display: inline-block;
    font-family: 'Inter', sans-serif;
    font-size: 19.9px;
    font-weight: 400;
    color: #23372c;
    background: #daffd3;
    border: 1px solid #23372c;
    border-radius: 100px;
    padding: 12px 32px;
    text-decoration: none;
    cursor: pointer;
    transition: background 0.25s ease, transform 0.25s ease;
  }

  .pp-problemas__section-text-btn:hover {
    background: #c4f5bb;
    transform: translateY(-1px);
  }

  .pp-problemas__section-text p { margin: 0 0 16px; font-family: 'Tenor Sans', Georgia, serif; font-size: 22pt; color: var(--pp-text); line-height: 1.75; font-weight: 100; text-transform: uppercase; max-width: 80%; }
  .pp-problemas__section-text p:last-child { margin-bottom: 0; }
  .pp-problemas__section-text ul,
  .pp-problemas__section-text ol { margin: 0 0 16px; padding-left: 24px; }
  .pp-problemas__section-text li { margin-bottom: 6px; }
  .pp-problemas__section-text a { color: var(--pp-dark-green); text-decoration: underline; }
  .pp-problemas__section-text strong { font-weight: 600; }

  .pp-problemas__section-text--full {
    max-width: var(--pp-content-max);
  }

  /* --- Product grid --- */
  .pp-problemas__product-grid-wrapper {
    margin: 56px 0;
    padding: 40px 0;
    border-top: 1px solid rgba(35, 55, 44, 0.1);
    border-bottom: 1px solid rgba(35, 55, 44, 0.1);
  }

  .pp-problemas__product-grid-title {
    font-family: var(--pp-font-heading);
    font-size: clamp(20px, 2.5vw, 28px);
    font-weight: 400;
    color: var(--pp-dark-green);
    margin: 0 0 24px;
    text-align: center;
  }

  .pp-problemas__product-grid {
    display: grid;
    grid-template-columns: repeat(var(--pp-products-per-row, 4), 1fr);
    gap: 20px;
  }

  /* --- Banner CTA --- */
  .pp-problemas__banner {
    background: var(--pp-dark-green);
    border-radius: var(--pp-radius);
    padding: 48px 40px;
    text-align: center;
    margin-top: 56px;
  }

  .pp-problemas__banner-text {
    font-family: var(--pp-font-heading);
    font-size: clamp(22px, 3vw, 32px);
    font-weight: 400;
    color: #DAFFD3;
    line-height: 1.3;
    margin: 0 0 24px;
  }

  .pp-problemas__banner-btn {
    display: inline-block;
    font-family: var(--pp-font-body);
    font-size: 14px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--pp-dark-green);
    background: #DAFFD3;
    border: none;
    border-radius: 100px;
    padding: 14px 36px;
    text-decoration: none;
    cursor: pointer;
    transition: background var(--pp-transition), transform var(--pp-transition);
  }

  .pp-problemas__banner-btn:hover {
    background: #c4f5bb;
    transform: translateY(-1px);
  }

  /* --- Hide banner --- */
  .pp-problemas__banner { display: none; }

  /* --- Breadcrumb (inherits from pp-page-guide.css, local overrides) --- */
  .pp-problemas .pp-guide__breadcrumb {
    margin-bottom: 24px;
  }

  /* ==========================================================================
     Responsive
     ========================================================================== */
  @media screen and (max-width: 989px) {
    .pp-problemas__product-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media screen and (max-width: 749px) {
    .pp-problemas-hero {
      min-height: 280px;
      margin-bottom: 24px;
    }

    .pp-problemas-hero__content {
      padding: 24px 20px;
    }

    .pp-problemas__section-body {
      flex-direction: column;
    }

    .pp-problemas__section-image {
      flex: 0 0 100%;
      max-width: 180px;
    }

    .pp-problemas__product-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 12px;
    }

    .pp-problemas__section {
      margin-bottom: 32px;
    }

    .pp-problemas__product-grid-wrapper {
      margin: 36px 0;
      padding: 28px 0;
    }

    .pp-problemas__banner {
      padding: 32px 20px;
      margin-top: 36px;
    }
  }
</style>

<section
  class="pp-problemas"
  style="
    --pp-problemas-pad-top: {{ section.settings.padding_top }}px;
    --pp-problemas-pad-bottom: {{ section.settings.padding_bottom }}px;
    --pp-products-per-row: {{ products_per_row }};
  "
>

  {%- comment -%} -- 1. Hero Section (full-width, under header) -- {%- endcomment -%}
  {%- if section.settings.show_hero -%}
    {%- assign hero_image = page.metafields.custom.imagen_portada.value -%}
    <div class="pp-problemas-hero">
      {%- if hero_image -%}
        <div class="pp-problemas-hero__bg">
          {{ hero_image | image_url: width: 1600 | image_tag: loading: 'eager', sizes: '100vw' }}
        </div>
      {%- endif -%}
      <div class="pp-problemas-hero__gradient"></div>
      <div class="pp-problemas-hero__content">
        <h1 class="pp-problemas-hero__title">{{ page.title }}</h1>
      </div>
    </div>
  {%- endif -%}

  {%- comment -%} -- Breadcrumb (after hero) -- {%- endcomment -%}
  {%- if section.settings.show_breadcrumb -%}
    <nav class="pp-guide__breadcrumb" aria-label="Breadcrumb">
      <a href="/">Pur Plant</a>
      <span class="pp-guide__breadcrumb-sep">/</span>
      <a href="/pages/problemas-plantas">Guia de Problemas</a>
      <span class="pp-guide__breadcrumb-sep">/</span>
      <span>{{ page.title }}</span>
    </nav>
  {%- endif -%}

  {%- comment -%} -- 2. JSON data source for page_content -- {%- endcomment -%}
  <script type="application/json" data-page-content>
    {{ page.metafields.custom.page_content | default: '[]' }}
  </script>

  {%- comment -%} -- 3. Content container (JS-rendered) -- {%- endcomment -%}
  <div data-content-container></div>

  {%- comment -%} -- 4. Product grid placeholders (JS inserts content sections between them) -- {%- endcomment -%}
  {%- comment -%}
    Product grids are rendered server-side via Liquid since they need collection data.
    JS will move them into the right position after rendering content sections.
  {%- endcomment -%}

  {%- assign coll_1 = page.metafields.custom.page_collection_1.value -%}
  {%- if coll_1 -%}
    <div class="pp-problemas__product-grid-wrapper" data-product-grid="1" style="display:none;">
      {%- if coll_1.title != blank -%}
        <h3 class="pp-problemas__product-grid-title">{{ coll_1.title }}</h3>
      {%- endif -%}
      <div class="pp-problemas__product-grid">
        {%- for product in coll_1.products limit: 8 -%}
          {%- render 'pp-product-card-standalone', product: product, image_ratio: 'portrait' -%}
        {%- endfor -%}
      </div>
    </div>
  {%- endif -%}

  {%- assign coll_2 = page.metafields.custom.page_collection_2.value -%}
  {%- if coll_2 -%}
    <div class="pp-problemas__product-grid-wrapper" data-product-grid="2" style="display:none;">
      {%- if coll_2.title != blank -%}
        <h3 class="pp-problemas__product-grid-title">{{ coll_2.title }}</h3>
      {%- endif -%}
      <div class="pp-problemas__product-grid">
        {%- for product in coll_2.products limit: 8 -%}
          {%- render 'pp-product-card-standalone', product: product, image_ratio: 'portrait' -%}
        {%- endfor -%}
      </div>
    </div>
  {%- endif -%}

  {%- assign coll_3 = page.metafields.custom.page_collection_3.value -%}
  {%- if coll_3 -%}
    <div class="pp-problemas__product-grid-wrapper" data-product-grid="3" style="display:none;">
      {%- if coll_3.title != blank -%}
        <h3 class="pp-problemas__product-grid-title">{{ coll_3.title }}</h3>
      {%- endif -%}
      <div class="pp-problemas__product-grid">
        {%- for product in coll_3.products limit: 8 -%}
          {%- render 'pp-product-card-standalone', product: product, image_ratio: 'portrait' -%}
        {%- endfor -%}
      </div>
    </div>
  {%- endif -%}

  {%- comment -%} -- 5. Banner CTA -- {%- endcomment -%}
  {%- if section.settings.banner_text != blank -%}
    <div class="pp-problemas__banner" style="background-color: {{ section.settings.hero_bg_color }};">
      <p class="pp-problemas__banner-text">{{ section.settings.banner_text }}</p>
      {%- if section.settings.banner_cta_text != blank and section.settings.banner_cta_url != blank -%}
        <a href="{{ section.settings.banner_cta_url }}" class="pp-problemas__banner-btn">
          {{ section.settings.banner_cta_text }}
        </a>
      {%- endif -%}
    </div>
  {%- endif -%}

  {%- comment -%} -- Fallback -- {%- endcomment -%}
  <div class="pp-guide__empty" data-pp-empty style="display:none;">
    <p>Esta guia aun no tiene contenido configurado.</p>
  </div>

</section>

<script>
(function() {
  var dataEl = document.querySelector('[data-page-content]');
  var container = document.querySelector('[data-content-container]');
  var emptyMsg = document.querySelector('[data-pp-empty]');
  if (!dataEl || !container) return;

  var widgets;
  try { widgets = JSON.parse(dataEl.textContent); } catch(e) { widgets = []; }
  dataEl.remove();

  if (!Array.isArray(widgets) || !widgets.length) {
    if (emptyMsg) emptyMsg.style.display = '';
    return;
  }

  var GRID_AFTER = {{ grid_after }};
  var sectionCount = 0;
  var collectionIndex = 0;
  var html = '';

  /* Group widgets into "sections": a heading starts a new section.
     After every GRID_AFTER sections, insert the next product grid. */
  widgets.forEach(function(w, i) {
    if (!w || !w.type) return;

    if (w.type === 'heading') {
      /* A heading marks a new section boundary */
      sectionCount++;

      /* Check if we should insert a product grid BEFORE this heading */
      if (sectionCount > 1 && ((sectionCount - 1) % GRID_AFTER === 0) && collectionIndex < 3) {
        collectionIndex++;
        var gridEl = document.querySelector('[data-product-grid="' + collectionIndex + '"]');
        if (gridEl) {
          html += gridEl.outerHTML.replace('style="display:none;"', '');
        }
      }

      /* Look ahead: is the next widget an image followed by text (or vice versa)? */
      var nextW = widgets[i + 1];
      var nextNextW = widgets[i + 2];
      var hasImageTextPair = false;

      if (nextW && nextNextW && nextW.type === 'image' && nextNextW.type === 'text') {
        hasImageTextPair = true;
        html += '<div class="pp-problemas__section" id="variety-' + sectionCount + '">';
        html += '<div class="pp-problemas__section-body pp-problemas__section-body--with-image">';
        html += '<div class="pp-problemas__section-image"><img src="' + nextW.src + '" alt="' + (nextW.alt || '') + '" loading="lazy"></div>';
        html += '<div class="pp-problemas__section-text">';
        html += '<p class="pp-problemas__section-text-title">' + w.value + '</p>';
        html += '<a href="#" class="pp-problemas__section-text-btn">Descubrir</a>';
        html += '</div>';
        html += '</div>';
        html += '</div>';
        /* Mark these as consumed */
        widgets[i + 1] = { type: '_consumed' };
        widgets[i + 2] = { type: '_consumed' };
      }

      if (!hasImageTextPair) {
        html += '<div class="pp-problemas__section"><h2 class="pp-content__heading">' + w.value + '</h2>';
      }

      html += '</div>';

    } else if (w.type === 'image') {
      /* Check if this is an image followed by text (standalone, not inside a heading section) */
      var nextText = widgets[i + 1];
      if (nextText && nextText.type === 'text') {
        /* Render as image-left + text-right card */
        html += '<div class="pp-problemas__section">';
        html += '<div class="pp-problemas__section-body pp-problemas__section-body--with-image">';
        html += '<div class="pp-problemas__section-image"><img src="' + w.src + '" alt="' + (w.alt || '') + '" loading="lazy"></div>';
        html += '<div class="pp-problemas__section-text">' + nextText.value + '</div>';
        html += '</div>';
        html += '</div>';
        widgets[i + 1] = { type: '_consumed' };
      } else {
        html += '<div class="pp-content__image"><img src="' + w.src + '" alt="' + (w.alt || '') + '" loading="lazy"></div>';
      }
    } else if (w.type === 'text') {
      html += '<div class="pp-content__text">' + w.value + '</div>';
    }
  });

  /* Insert any remaining product grids that were not shown inline */
  for (var g = collectionIndex + 1; g <= 3; g++) {
    var gridEl = document.querySelector('[data-product-grid="' + g + '"]');
    if (gridEl) {
      html += gridEl.outerHTML.replace('style="display:none;"', '');
    }
  }

  container.innerHTML = html;

  /* Collapse empty &nbsp; paragraphs */
  container.querySelectorAll('.pp-content__text p').forEach(function(p) {
    if (p.innerHTML.replace(/&nbsp;/g, '').replace(/\u00a0/g, '').trim() === '') {
      p.classList.add('pp-empty');
    }
  });

  /* Remove the original hidden product grid elements (they are now duplicated inside container) */
  var origGrids = document.querySelectorAll('[data-product-grid]');
  origGrids.forEach(function(el) {
    if (!container.contains(el)) el.remove();
  });
})();
</script>

{% schema %}
{
  "name": "PP Page Problemas",
  "tag": "section",
  "class": "pp-guide-section pp-problemas-section",
  "settings": [
    {
      "type": "header",
      "content": "Hero"
    },
    {
      "type": "checkbox",
      "id": "show_hero",
      "label": "Show hero section",
      "default": true
    },
    {
      "type": "color",
      "id": "hero_bg_color",
      "label": "Hero / Banner background color",
      "default": "#23372C"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "checkbox",
      "id": "show_breadcrumb",
      "label": "Show breadcrumb",
      "default": true
    },
    {
      "type": "range",
      "id": "products_per_row",
      "min": 2,
      "max": 6,
      "step": 1,
      "label": "Products per row (desktop)",
      "default": 4
    },
    {
      "type": "range",
      "id": "collection_grid_after_section",
      "min": 1,
      "max": 10,
      "step": 1,
      "label": "Show product grid after every N sections",
      "default": 3
    },
    {
      "type": "header",
      "content": "Banner CTA"
    },
    {
      "type": "text",
      "id": "banner_text",
      "label": "Banner text",
      "default": "¿Necesitas ayuda con tus plantas?"
    },
    {
      "type": "text",
      "id": "banner_cta_text",
      "label": "CTA button text",
      "default": "Ver productos"
    },
    {
      "type": "url",
      "id": "banner_cta_url",
      "label": "CTA button URL"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 60
    }
  ],
  "templates": ["page"],
  "presets": [
    {
      "name": "PP Page Problemas",
      "category": "Pur Plant"
    }
  ]
}
{% endschema %}
