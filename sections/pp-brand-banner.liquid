{{ 'pp-sections.css' | asset_url | stylesheet_tag }}

<section
  class="pp-brand-wrap"
  style="
    --pp-brand-bg: {{ section.settings.bg_color }};
    --pp-brand-text: {{ section.settings.text_color }};
    --pp-brand-overflow: {{ section.settings.image_overflow }}px;
  "
>
  <div class="pp-brand__bg-strip"></div>
  <div class="pp-brand__inner {% if section.settings.image_position == 'left' %}pp-brand__inner--reverse{% endif %}">
    <div class="pp-brand__text">
      {% if section.settings.heading != blank %}
        <p class="pp-brand__copy">{{ section.settings.heading }}</p>
      {% endif %}

      {% if section.settings.subheading != blank %}
        <p class="pp-brand__sub">{{ section.settings.subheading }}</p>
      {% endif %}

      {% if section.settings.button_label != blank %}
        <a href="{{ section.settings.button_link | default: '#' }}" class="pp-brand__cta">
          {{ section.settings.button_label }}
        </a>
      {% endif %}
    </div>

    <div class="pp-brand__media">
      {% if section.settings.video != blank %}
        {{ section.settings.video | video_tag: autoplay: true, muted: true, loop: true, playsinline: true, loading: 'lazy', class: 'pp-brand__video' }}
      {% elsif section.settings.video_url != blank %}
        <video
          class="pp-brand__video"
          autoplay
          muted
          loop
          playsinline
          loading="lazy"
          {% if section.settings.image != blank %}
            poster="{{ section.settings.image | image_url: width: 900 }}"
          {% endif %}
        >
          <source src="{{ section.settings.video_url }}" type="video/mp4">
        </video>
      {% elsif section.settings.image != blank %}
        {{
          section.settings.image
          | image_url: width: 900
          | image_tag:
            loading: 'lazy',
            widths: '400, 600, 800, 900',
            sizes: '(min-width: 750px) 50vw, 100vw',
            class: 'pp-brand__img'
        }}
      {% else %}
        {{ 'lifestyle-2' | placeholder_svg_tag: 'pp-brand__placeholder' }}
      {% endif %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "PP Brand Banner",
  "class": "pp-brand-section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "textarea",
      "id": "heading",
      "label": "Heading",
      "default": "PUR PLANT ES LA MARCA QUE CREE EN EL PODER DE LAS PLANTAS"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Más sobre Nosotrxs"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "header",
      "content": "Media"
    },
    {
      "type": "video",
      "id": "video",
      "label": "Video (upload/drag)",
      "info": "Upload a video directly. Takes priority over URL and image."
    },
    {
      "type": "url",
      "id": "video_url",
      "label": "Video URL (MP4)",
      "info": "Alternative: paste an external MP4 URL"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image (fallback)",
      "info": "Used if no video is set"
    },
    {
      "type": "select",
      "id": "image_position",
      "label": "Image position",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "right", "label": "Right" }
      ],
      "default": "right"
    },
    {
      "type": "range",
      "id": "image_overflow",
      "label": "Image overflow (px)",
      "info": "How much the image extends beyond the background strip",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 48
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "#23372C"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#DAFFD3"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 40
    }
  ],
  "presets": [
    {
      "name": "PP Brand Banner",
      "category": "Pur Plant",
      "settings": {
        "heading": "PUR PLANT ES LA MARCA QUE CREE EN EL PODER DE LAS PLANTAS",
        "button_label": "Más sobre Nosotrxs",
        "image_position": "right",
        "image_overflow": 48,
        "bg_color": "#23372C",
        "text_color": "#DAFFD3"
      }
    }
  ]
}
{% endschema %}
