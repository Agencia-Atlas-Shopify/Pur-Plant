{{ 'pp-sections.css' | asset_url | stylesheet_tag }}

<section
  class="pp-brand-wrap"
  style="
    --pp-brand-bg: {{ section.settings.bg_color }};
    --pp-brand-text: {{ section.settings.text_color }};
    --pp-brand-overflow: {{ section.settings.image_overflow }}px;
    --pp-brand-pad-top: {{ section.settings.padding_top }}px;
    --pp-brand-pad-bottom: {{ section.settings.padding_bottom }}px;
    --pp-brand-video-max-h: {{ section.settings.video_max_height }}px;
  "
>
  <div class="pp-brand__inner {% if section.settings.image_position == 'left' %}pp-brand__inner--reverse{% endif %}">
    <div class="pp-brand__text">
      {% if section.settings.heading != blank %}
        <p class="pp-brand__copy">{{ section.settings.heading }}</p>
      {% endif %}

      {% if section.settings.subheading != blank %}
        <p class="pp-brand__sub">{{ section.settings.subheading }}</p>
      {% endif %}

      {% if section.settings.button_label != blank %}
        <a href="{{ section.settings.button_link | default: '#' }}" class="pp-brand__cta">
          {{ section.settings.button_label }}
        </a>
      {% endif %}
    </div>

    <div class="pp-brand__media" data-pp-brand-media>
      {% if section.settings.video != blank %}
        {{ section.settings.video | video_tag: autoplay: true, muted: true, loop: true, playsinline: true, loading: 'lazy', class: 'pp-brand__video', data-pp-brand-video: true }}
      {% elsif section.settings.video_url != blank %}
        <video
          class="pp-brand__video"
          autoplay
          muted
          loop
          playsinline
          loading="lazy"
          data-pp-brand-video
          {% if section.settings.image != blank %}
            poster="{{ section.settings.image | image_url: width: 900 }}"
          {% endif %}
        >
          <source src="{{ section.settings.video_url }}" type="video/mp4">
        </video>
      {% elsif section.settings.image != blank %}
        {{
          section.settings.image
          | image_url: width: 900
          | image_tag:
            loading: 'lazy',
            widths: '400, 600, 800, 900',
            sizes: '(min-width: 750px) 50vw, 100vw',
            class: 'pp-brand__img'
        }}
      {% endif %}

      {% if section.settings.video != blank or section.settings.video_url != blank %}
        <button type="button" class="pp-brand__sound-btn" data-pp-sound-toggle aria-label="Toggle sound">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" data-pp-sound-icon-off>
            <polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"></polygon>
            <line x1="23" y1="9" x2="17" y2="15"></line>
            <line x1="17" y1="9" x2="23" y2="15"></line>
          </svg>
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" data-pp-sound-icon-on style="display:none;">
            <polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"></polygon>
            <path d="M19.07 4.93a10 10 0 0 1 0 14.14M15.54 8.46a5 5 0 0 1 0 7.07"></path>
          </svg>
        </button>
      {% endif %}
    </div>
  </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    document.querySelectorAll('[data-pp-sound-toggle]').forEach(function(btn) {
      btn.addEventListener('click', function(e) {
        e.preventDefault();
        e.stopPropagation();
        var media = btn.closest('[data-pp-brand-media]');
        var video = media ? media.querySelector('video, [data-pp-brand-video]') : null;
        if (!video) return;
        video.muted = !video.muted;
        var iconOff = btn.querySelector('[data-pp-sound-icon-off]');
        var iconOn = btn.querySelector('[data-pp-sound-icon-on]');
        if (iconOff && iconOn) {
          iconOff.style.display = video.muted ? '' : 'none';
          iconOn.style.display = video.muted ? 'none' : '';
        }
      });
    });
  });
</script>

{% schema %}
{
  "name": "PP Brand Banner",
  "class": "pp-brand-section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "textarea",
      "id": "heading",
      "label": "Heading",
      "default": "PUR PLANT ES LA MARCA QUE CREE EN EL PODER DE LAS PLANTAS"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Más sobre Nosotrxs"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "header",
      "content": "Media"
    },
    {
      "type": "video",
      "id": "video",
      "label": "Video (upload/drag)",
      "info": "Upload a video directly. Takes priority over URL and image."
    },
    {
      "type": "url",
      "id": "video_url",
      "label": "Video URL (MP4)",
      "info": "Alternative: paste an external MP4 URL"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image (fallback)",
      "info": "Used if no video is set"
    },
    {
      "type": "select",
      "id": "image_position",
      "label": "Media position",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "right", "label": "Right" }
      ],
      "default": "right"
    },
    {
      "type": "range",
      "id": "image_overflow",
      "label": "Media overflow (px)",
      "info": "How much the media extends above/below the green strip",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 48
    },
    {
      "type": "range",
      "id": "video_max_height",
      "label": "Video max height (px)",
      "min": 200,
      "max": 800,
      "step": 20,
      "unit": "px",
      "default": 500
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "#23372C"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#DAFFD3"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Green strip padding top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Green strip padding bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 48
    }
  ],
  "presets": [
    {
      "name": "PP Brand Banner",
      "category": "Pur Plant",
      "settings": {
        "heading": "PUR PLANT ES LA MARCA QUE CREE EN EL PODER DE LAS PLANTAS",
        "button_label": "Más sobre Nosotrxs",
        "image_position": "right",
        "image_overflow": 48,
        "video_max_height": 500,
        "bg_color": "#23372C",
        "text_color": "#DAFFD3",
        "padding_top": 48,
        "padding_bottom": 48
      }
    }
  ]
}
{% endschema %}
