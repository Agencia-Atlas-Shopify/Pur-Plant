{{ 'pp-sections.css' | asset_url | stylesheet_tag }}

<div class="section-background color-{{ section.settings.color_scheme }}"></div>
<section
  class="section section--{{ section.settings.section_width }} color-{{ section.settings.color_scheme }} spacing-style"
  style="{% render 'spacing-style', settings: section.settings %}"
>
  <div class="pp-brand__inner">
    <div class="pp-brand__text">
      {% if section.settings.heading != blank %}
        <p class="pp-brand__copy">{{ section.settings.heading }}</p>
      {% endif %}

      {% if section.settings.subheading != blank %}
        <p class="pp-brand__sub">{{ section.settings.subheading }}</p>
      {% endif %}

      {% if section.settings.button_label != blank %}
        <a href="{{ section.settings.button_link | default: '#' }}" class="pp-brand__cta">
          {{ section.settings.button_label }}
        </a>
      {% endif %}
    </div>

    <div class="pp-brand__image">
      {% if section.settings.image != blank %}
        {{
          section.settings.image
          | image_url: width: 900
          | image_tag:
            loading: 'lazy',
            widths: '400, 600, 800, 900',
            sizes: '(min-width: 750px) 50vw, 100vw',
            class: 'pp-brand__img'
        }}
      {% else %}
        {{ 'lifestyle-2' | placeholder_svg_tag: 'pp-brand__placeholder' }}
      {% endif %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Brand banner",
  "class": "pp-brand-section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "textarea",
      "id": "heading",
      "label": "Heading",
      "default": "PUR PLANT ES LA MARCA QUE CREE EN EL PODER DE LAS PLANTAS"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Más sobre Nosotros"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "select",
      "id": "image_position",
      "label": "Image position",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "right", "label": "Right" }
      ],
      "default": "right"
    },
    {
      "type": "header",
      "content": "Section layout"
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "Width",
      "options": [
        { "value": "page-width", "label": "Page" },
        { "value": "full-width", "label": "Full" }
      ],
      "default": "page-width"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "pp-green-dark"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "Top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 64
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "Bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 64
    }
  ],
  "presets": [
    {
      "name": "Brand banner",
      "category": "Pur Plant",
      "settings": {
        "heading": "PUR PLANT ES LA MARCA QUE CREE EN EL PODER DE LAS PLANTAS",
        "button_label": "Más sobre Nosotros",
        "image_position": "right",
        "color_scheme": "pp-green-dark",
        "padding-block-start": 64,
        "padding-block-end": 64
      }
    }
  ]
}
{% endschema %}
