<section class="pp-about-split" style="
  background: {{ section.settings.bg_color }};
  padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px;
">
  <div class="pp-about-split__inner {% if section.settings.image_position == 'left' %}pp-about-split__inner--reverse{% endif %}">

    <div class="pp-about-split__text">
      {%- if section.settings.heading != blank -%}
        <p class="pp-about-split__heading">{{ section.settings.heading }}</p>
        <svg class="pp-about-split__underline" viewBox="0 0 480 18" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" preserveAspectRatio="none">
          <path d="M4 13 C60 4, 140 16, 240 9 S380 3, 476 11" stroke="{{ section.settings.accent_color }}" stroke-width="3.5" stroke-linecap="round" fill="none"/>
        </svg>
      {%- endif -%}

      {%- if section.settings.body != blank -%}
        <p class="pp-about-split__body">{{ section.settings.body }}</p>
      {%- endif -%}

      {%- if section.settings.button_label != blank -%}
        <a href="{{ section.settings.button_link | default: '#' }}" class="pp-about-split__cta">
          {{ section.settings.button_label }}
        </a>
      {%- endif -%}
    </div>

    <div class="pp-about-split__media">
      {%- if section.settings.image != blank -%}
        {{
          section.settings.image
          | image_url: width: 900
          | image_tag:
            loading: 'lazy',
            widths: '400, 600, 800, 900',
            sizes: '(min-width: 750px) 45vw, 100vw',
            class: 'pp-about-split__img'
        }}
      {%- else -%}
        <div class="pp-about-split__placeholder">{{ 'image' | placeholder_svg_tag: 'pp-about-split__placeholder-svg' }}</div>
      {%- endif -%}
    </div>

  </div>
</section>

<style>
.pp-about-split {
  overflow: hidden;
}

.pp-about-split__inner {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 0;
  max-width: 1400px;
  margin: 0 auto;
  align-items: center;
}

.pp-about-split__inner--reverse {
  direction: rtl;
}
.pp-about-split__inner--reverse > * {
  direction: ltr;
}

.pp-about-split__text {
  padding: 48px 56px 48px 48px;
}

.pp-about-split__heading {
  font-family: 'Aileron', var(--font-body--family), sans-serif;
  font-size: clamp(1.6rem, 3.2vw, 2.75rem);
  font-weight: 900;
  color: {{ section.settings.text_color }};
  line-height: 1.1;
  letter-spacing: 0.02em;
  text-transform: uppercase;
  margin: 0 0 16px;
}

.pp-about-split__underline {
  display: block;
  width: min(320px, 80%);
  height: 18px;
  margin-bottom: 28px;
  overflow: visible;
}

.pp-about-split__body {
  font-family: 'Aileron', var(--font-body--family), sans-serif;
  font-size: clamp(0.75rem, 1.1vw, 0.875rem);
  font-weight: 500;
  color: {{ section.settings.text_color }};
  line-height: 1.7;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  margin: 0 0 32px;
  max-width: 520px;
}

.pp-about-split__cta {
  display: inline-block;
  padding: 12px 28px;
  border: 1.5px solid {{ section.settings.text_color }};
  color: {{ section.settings.text_color }};
  font-family: 'Aileron', var(--font-body--family), sans-serif;
  font-size: 0.75rem;
  font-weight: 700;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  text-decoration: none;
  transition: background 0.2s, color 0.2s;
}
.pp-about-split__cta:hover {
  background: {{ section.settings.text_color }};
  color: {{ section.settings.bg_color }};
}

.pp-about-split__media {
  height: 100%;
  min-height: 400px;
}

.pp-about-split__img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}

.pp-about-split__placeholder {
  width: 100%;
  height: 100%;
  min-height: 400px;
  background: #e8ede8;
}
.pp-about-split__placeholder-svg {
  width: 100%;
  height: 100%;
}

@media screen and (max-width: 749px) {
  .pp-about-split__inner {
    grid-template-columns: 1fr;
  }
  .pp-about-split__inner--reverse {
    direction: ltr;
  }
  .pp-about-split__text {
    padding: 40px 24px 32px;
  }
  .pp-about-split__media {
    min-height: 300px;
  }
  .pp-about-split__body {
    max-width: 100%;
  }
}
</style>

{% schema %}
{
  "name": "PP About Split",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "textarea",
      "id": "heading",
      "label": "Heading",
      "default": "PUR PLANT ES LA MARCA QUE CREE EN EL PODER DE LAS PLANTAS."
    },
    {
      "type": "textarea",
      "id": "body",
      "label": "Body text",
      "default": "SOMOS LOS BOTÁNICOS DEL SXXI QUE OFRECEMOS BIENESTAR A TRAVÉS DE LA RE-CONEXIÓN CON LA NATURALEZA."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "header",
      "content": "Media"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "select",
      "id": "image_position",
      "label": "Image position",
      "options": [
        { "value": "right", "label": "Right" },
        { "value": "left", "label": "Left" }
      ],
      "default": "right"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#23372c"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Underline color",
      "default": "#23372c"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "PP About Split",
      "category": "Pur Plant",
      "settings": {
        "heading": "PUR PLANT ES LA MARCA QUE CREE EN EL PODER DE LAS PLANTAS.",
        "body": "SOMOS LOS BOTÁNICOS DEL SXXI QUE OFRECEMOS BIENESTAR A TRAVÉS DE LA RE-CONEXIÓN CON LA NATURALEZA.",
        "image_position": "right",
        "bg_color": "#ffffff",
        "text_color": "#23372c",
        "accent_color": "#23372c",
        "padding_top": 0,
        "padding_bottom": 0
      }
    }
  ]
}
{% endschema %}
