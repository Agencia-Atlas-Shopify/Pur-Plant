<div class="pp-trustindex" style="padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px; text-align: center;">
  {%- if section.settings.heading != blank -%}
    <p class="pp-trustindex__heading">{{ section.settings.heading }}</p>
  {%- endif -%}
  <script async src="https://cdn.trustindex.io/loader.js?{{ section.settings.widget_id }}"></script>
</div>

<style>
.ti-widget[data-layout-id='36'][data-set-id='ligth-border-3d-large'] .ti-reviews-container-wrapper {
  justify-content: center;
}

.pp-trustindex__heading {
  font-family: 'Tenor Sans', Georgia, serif;
  font-size: clamp(1.25rem, 2.5vw, 1.75rem);
  font-weight: 400;
  color: #23372c;
  margin: 0 auto {{ section.settings.heading_gap }}px;
  max-width: 680px;
  text-transform: none;
}
</style>

{% schema %}
{
  "name": "Trustindex Reviews",
  "settings": [
    {
      "type": "text",
      "id": "widget_id",
      "label": "Widget ID",
      "default": "6b1680714ea4723b58863bbcb6f"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Esto solo se consigue dando lo mejor"
    },
    {
      "type": "range",
      "id": "heading_gap",
      "label": "Heading bottom gap",
      "min": 0,
      "max": 80,
      "step": 4,
      "default": 32
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 40
    }
  ],
  "presets": [
    {
      "name": "Trustindex Reviews"
    }
  ]
}
{% endschema %}
